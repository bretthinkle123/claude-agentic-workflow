{"parentUuid":"c51d954e-a18c-40e3-8a87-5fbfe57818b7","isSidechain":true,"agentId":"a62a4b9fae3247ab0","message":{"model":"claude-opus-4-8","id":"msg_011CcpzMdxL96pdo5u3nrG47","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KEaKAewE6iUpoaWmaib3g9","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_perf_k6_load.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7440,"cache_read_input_tokens":61411,"output_tokens":452,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":7440},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":452,"cache_read_input_tokens":61411,"cache_creation_input_tokens":7440,"cache_creation":{"ephemeral_5m_input_tokens":7440,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcpzMcdhkzBEDsBeaucHC","attributionAgent":"planning","type":"assistant","uuid":"8031fafe-d54f-4bf7-963a-bd48da4d2af0","timestamp":"2026-07-08T17:32:16.581Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"8031fafe-d54f-4bf7-963a-bd48da4d2af0","isSidechain":true,"promptId":"baf21a5c-1a23-429e-9e74-122628363a90","agentId":"a62a4b9fae3247ab0","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KEaKAewE6iUpoaWmaib3g9","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF: a REAL sustained load run using k6 (via Docker), driving the\n2\tplan's declared scenario -- constant-arrival-rate at the target rate over a\n3\tsustained window, distributed key space -- against a real uvicorn process\n4\t(out-of-process, real network stack, multiple workers) backed by real\n5\tPostgres + Redis testcontainers.\n6\t\n7\tThis supersedes the best-effort in-process smoke in test_perf_smoke.py: k6\n8\truns in its own Docker container (grafana/k6) and reaches the host-run\n9\tuvicorn via `host.docker.internal`. True p95 is computed here by nearest-rank\n10\tover the raw per-request `http_req_duration` samples k6 writes to its JSON\n11\toutput (never trusting k6's own approximate percentile field blindly, per\n12\ttest-conventions) -- scoped to points tagged `scenario=ingest` so warm-up\n13\tcold-start latency is excluded from the measurement, the way a real load-test\n14\trig ramps up before recording.\n15\t\n16\tSkips (not fails) if Docker or the grafana/k6 image is unavailable -- this\n17\trecords an honest absence of measurement, never a fabricated one.\n18\t\"\"\"\n19\t\n20\timport asyncio\n21\timport datetime\n22\timport json\n23\timport os\n24\timport shutil\n25\timport socket\n26\timport subprocess\n27\timport sys\n28\timport tempfile\n29\timport time\n30\tfrom collections import Counter\n31\tfrom contextlib import closing\n32\tfrom pathlib import Path\n33\t\n34\timport httpx\n35\timport pytest\n36\t\n37\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n38\t_K6_SCRIPTS_DIR = Path(__file__).resolve().parent / \"k6\"\n39\t\n40\t\n41\tdef _free_port() -> int:\n42\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n43\t        sock.bind((\"0.0.0.0\", 0))\n44\t        return sock.getsockname()[1]\n45\t\n46\t\n47\tdef _docker_available() -> bool:\n48\t    if shutil.which(\"docker\") is None:\n49\t        return False\n50\t    result = subprocess.run([\"docker\", \"info\"], capture_output=True, timeout=10)\n51\t    return result.returncode == 0\n52\t\n53\t\n54\tdef _nearest_rank_from_raw_jsonl(path: Path, scenario: str) -> dict:\n55\t    \"\"\"Parse k6's raw JSON-lines output and compute the TRUE percentiles via\n56\t    nearest-rank over the `http_req_duration` samples tagged with `scenario`\n57\t    -- this is what test-conventions requires instead of trusting k6's own\n58\t    (t-digest-approximated) percentile fields.\"\"\"\n59\t    durations: list[float] = []\n60\t    timestamps: list[str] = []\n61\t    statuses: list[str] = []\n62\t\n63\t    with path.open(encoding=\"utf-8\") as f:\n64\t        for line in f:\n65\t            line = line.strip()\n66\t            if not line:\n67\t                continue\n68\t            record = json.loads(line)\n69\t            if record.get(\"type\") != \"Point\" or record.get(\"metric\") != \"http_req_duration\":\n70\t                continue\n71\t            tags = record[\"data\"].get(\"tags\", {})\n72\t            if tags.get(\"scenario\") != scenario:\n73\t                continue\n74\t            durations.append(record[\"data\"][\"value\"])\n75\t            timestamps.append(record[\"data\"][\"time\"])\n76\t            statuses.append(tags.get(\"status\"))\n77\t\n78\t    if not durations:\n79\t        return {\"sample_count\": 0}\n80\t\n81\t    durations.sort()\n82\t    n = len(durations)\n83\t\n84\t    def nearest_rank(percentile: float) -> float:\n85\t        rank = max(1, round(percentile / 100 * n))\n86\t        return durations[min(rank, n) - 1]\n87\t\n88\t    sorted_timestamps = sorted(timestamps)\n89\t    first = datetime.datetime.fromisoformat(sorted_timestamps[0].replace(\"Z\", \"+00:00\"))\n90\t    last = datetime.datetime.fromisoformat(sorted_timestamps[-1].replace(\"Z\", \"+00:00\"))\n91\t    elapsed_seconds = (last - first).total_seconds()\n92\t\n93\t    return {\n94\t        \"sample_count\": n,\n95\t        \"status_counts\": dict(Counter(statuses)),\n96\t        \"p50_ms\": round(nearest_rank(50), 2),\n97\t        \"p90_ms\": round(nearest_rank(90), 2),\n98\t        \"p95_ms\": round(nearest_rank(95), 2),\n99\t        \"p99_ms\": round(nearest_rank(99), 2),\n100\t        \"max_ms\": round(durations[-1], 2),\n101\t        \"elapsed_seconds\": round(elapsed_seconds, 2),\n102\t        \"throughput_rps\": round(n / elapsed_seconds, 2) if elapsed_seconds > 0 else 0.0,\n103\t    }\n104\t\n105\t\n106\t@pytest.fixture\n107\tasync def k6_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n108\t    \"\"\"Launch the real app under uvicorn (multi-worker, out-of-process)\n109\t    against the live containers, ready for a k6 container to hit it via\n110\t    `host.docker.internal`.\"\"\"\n111\t    if not _docker_available():\n112\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n113\t\n114\t    pull_result = subprocess.run(\n115\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n116\t    )\n117\t    if pull_result.returncode != 0:\n118\t        pull_result = subprocess.run(\n119\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n120\t        )\n121\t        if pull_result.returncode != 0:\n122\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n123\t\n124\t    port = _free_port()\n125\t    env = dict(os.environ)\n126\t    env[\"DATABASE_URL\"] = postgres_url\n127\t    env[\"METERLY_REDIS_URL\"] = redis_url\n128\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n129\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n130\t\n131\t    presented_key, _ = await make_api_key(label=\"k6-perf-key\", rate_limit_per_sec=1_000_000)\n132\t\n133\t    workers = int(os.environ.get(\"METERLY_PERF_UVICORN_WORKERS\", \"5\"))\n134\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_perf\"\n135\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n136\t\n137\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n138\t    process = subprocess.Popen(\n139\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n140\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n141\t    )\n142\t\n143\t    try:\n144\t        deadline = time.monotonic() + 30\n145\t        async with httpx.AsyncClient() as probe:\n146\t            ready = False\n147\t            while time.monotonic() < deadline:\n148\t                try:\n149\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n150\t                    if response.status_code == 200:\n151\t                        ready = True\n152\t                        break\n153\t                except httpx.TransportError:\n154\t                    pass\n155\t                await asyncio.sleep(0.3)\n156\t            if not ready:\n157\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n158\t\n159\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n160\t    finally:\n161\t        process.terminate()\n162\t        try:\n163\t            process.wait(timeout=10)\n164\t        except subprocess.TimeoutExpired:\n165\t            process.kill()\n166\t        uvicorn_log.close()\n167\t\n168\t\n169\tdef _run_k6(script_name: str, port: int, api_key: str, scratch_dir: Path, target_rps: int, duration: str, warmup: str, out_name: str) -> subprocess.CompletedProcess:\n170\t    raw_out = scratch_dir / out_name\n171\t    if raw_out.exists():\n172\t        raw_out.unlink()\n173\t    return subprocess.run(\n174\t        [\n175\t            \"docker\", \"run\", \"--rm\",\n176\t            \"--add-host=host.docker.internal:host-gateway\",\n177\t            \"-v\", f\"{scratch_dir}:/perf_out\",\n178\t            \"-v\", f\"{_K6_SCRIPTS_DIR}:/perf_scripts:ro\",\n179\t            \"-e\", f\"BASE_URL=http://host.docker.internal:{port}\",\n180\t            \"-e\", f\"API_KEY={api_key}\",\n181\t            \"-e\", f\"TARGET_RPS={target_rps}\",\n182\t            \"-e\", f\"DURATION={duration}\",\n183\t            \"-e\", f\"WARMUP_DURATION={warmup}\",\n184\t            \"grafana/k6\", \"run\",\n185\t            \"--out\", f\"json=/perf_out/{out_name}\",\n186\t            f\"/perf_scripts/{script_name}\",\n187\t        ],\n188\t        capture_output=True, text=True, timeout=180,\n189\t    )\n190\t\n191\t\n192\tdef test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n193\t    \"\"\"Drive POST /v1/events at a real, sustained constant-arrival-rate of\n194\t    500 req/s (the AC6 budget's declared rate) over a real k6 container\n195\t    against a real out-of-process uvicorn + Postgres + Redis, with a\n196\t    distributed key space (unique idempotency_key + customer_id spread across\n197\t    50 buckets per request, no replay contention). Records true nearest-rank\n198\t    p95 + achieved throughput -- an honest measurement, not a claim the\n199\t    budget is met.\"\"\"\n200\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n201\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n202\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n203\t\n204\t    result = _run_k6(\n205\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n206\t        target_rps, duration, warmup, \"k6_events_raw.jsonl\",\n207\t    )\n208\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n209\t\n210\t    if result.returncode != 0:\n211\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_stdout.log\")\n212\t\n213\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_events_raw.jsonl\", scenario=\"ingest\")\n214\t    (k6_load_env[\"scratch_dir\"] / \"events_metrics.json\").write_text(json.dumps(metrics, indent=2))\n215\t    print(\"POST /v1/events k6 load metrics:\", json.dumps(metrics, indent=2))\n216\t\n217\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n218\t\n219\t\n220\tdef test_usage_read_sustained_100rps_k6_load(k6_load_env):\n221\t    \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n222\t    against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n223\t    target_rps = int(os.environ.get(\"METERLY_PERF_USAGE_TARGET_RPS\", \"100\"))\n224\t    duration = os.environ.get(\"METERLY_PERF_USAGE_DURATION\", \"10s\")\n225\t    warmup = os.environ.get(\"METERLY_PERF_USAGE_WARMUP\", \"3s\")\n226\t\n227\t    result = _run_k6(\n228\t        \"load_usage.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n229\t        target_rps, duration, warmup, \"k6_usage_raw.jsonl\",\n230\t    )\n231\t    (k6_load_env[\"scratch_dir\"] / \"k6_usage_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n232\t\n233\t    if result.returncode != 0:\n234\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_usage_stdout.log\")\n235\t\n236\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_usage_raw.jsonl\", scenario=\"ingest\")\n237\t    (k6_load_env[\"scratch_dir\"] / \"usage_metrics.json\").write_text(json.dumps(metrics, indent=2))\n238\t    print(\"GET /v1/usage k6 load metrics:\", json.dumps(metrics, indent=2))\n239\t\n240\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n241\t"}]},"uuid":"ba31fc56-536d-44b9-9279-e764de0e51a6","timestamp":"2026-07-08T17:32:16.613Z","sourceToolAssistantUUID":"8031fafe-d54f-4bf7-963a-bd48da4d2af0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
