      poetry install --no-root\n+      - name: Mutation testing (advisory — score to the summary, never fails the gate)\n+        run: |\n+          set +e\n+          <MUTATION_CMD>   # e.g. mutmut run --paths-to-mutate <MUTATION_SCOPE>\n+          echo \"Mutation run complete (advisory; see output). This job never fails the merge gate.\" >> \"$GITHUB_STEP_SUMMARY\"\n+          exit 0\n+\n   sast:\n     runs-on: ubuntu-latest\n     timeout-minutes: 20","is_error":false}]},"uuid":"3e0c77cc-886c-4d6f-b024-57a2cc38fd6e","timestamp":"2026-07-09T03:48:03.366Z","sourceToolAssistantUUID":"96736bf7-00a5-4194-9828-e5dbdf736466","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
