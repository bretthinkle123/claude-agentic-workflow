[\n103\t       \"Read(**/.env)\",\n104\t       \"Read(**/*.tfstate)\",\n105\t       \"Read(**/*.tfvars)\",\n106\t+      \"Read(~/.ssh/**)\",\n107\t+      \"Read(~/.aws/**)\",\n108\t+      \"Read(~/.claude/.credentials.json)\",\n109\t       \"Write(**/.pipeline/diff-approved)\",\n110\t       \"Write(**/.pipeline/plan-approved)\",\n111\t       \"Write(**/.pipeline/design-approved)\",\n112\t@@ -48,5 +79,22 @@\n113\t       \"Edit(**/.pipeline/design-approved)\",\n114\t       \"Edit(**/.pipeline/waivers.json)\"\n115\t     ]\n116\t+  },\n117\t+  \"enableAllProjectMcpServers\": true,\n118\t+  \"autoMode\": {\n119\t+    \"environment\": [\n120\t+      \"$defaults\",\n121\t+      \"Autonomous multi-agent SDLC pipeline run. All file reads and writes must stay inside this repository (plus read-only pipeline assets under ~/.claude). Shell network access is limited to: localhost, the project's own GitHub remote (git/gh), and package-registry installs (npm/pip/go). Any other external network access must go through the WebFetch tool or a configured MCP server.\"\n122\t+    ],\n123\t+    \"soft_deny\": [\n124\t+      \"$defaults\",\n125\t+      \"Deleting, moving, or rewriting files that live outside this repository's working directory\"\n126\t+    ],\n127\t+    \"hard_deny\": [\n128\t+      \"$defaults\",\n129\t+      \"Creating, modifying, or deleting the .pipeline approval markers (plan-approved, diff-approved, design-approved) or waivers.json by ANY means, including shell redirection, scripts, or git operations — these files exist solely so a human can approve pipeline checkpoints\",\n130\t+      \"Shell commands that send data to external network destinations other than the project's git remote or package registries (use WebFetch or MCP tools instead)\",\n131\t+      \"Reading credential material (~/.ssh, ~/.aws, .env files, cloud or API tokens) or writing anywhere outside the repository working directory\"\n132\t+    ]\n133\t   }\n134\t }\n135\tdiff --git a/.github/workflows/pipeline-ci.yml b/.github/workflows/pipeline-ci.yml\n136\tindex d19a6b4..600d34e 100644\n137\t--- a/.github/workflows/pipeline-ci.yml\n138\t+++ b/.github/workflows/pipeline-ci.yml\n139\t@@ -68,6 +68,34 @@ jobs:\n140\t         # gate rides. Branch coverage: surface in the job summary, do NOT gate (mirrors\n141\t         # the local posture; see test-conventions).\n142\t \n143\t+  # mutation — U-22: run mutation testing HERE, on the Linux runner, not on the author's\n144\t+  # host. mutmut needs a POSIX environment (WSL on Windows), so the local pipeline honestly\n145\t+  # skips it and writes quality_ok:false (WS3-1) — the *measurement* just never happened on\n146\t+  # win32, two M3-series runs in a row. This job runs it where it works. ADVISORY: it reports\n147\t+  # the score in the job summary and NEVER fails the merge gate (mutation quality is\n148\t+  # settled-advisory; the local WS3-1 scope-honesty check stays the only deploy-side teeth).\n149\t+  # OPT-IN: fill <MUTATION_CMD> + <MUTATION_SCOPE> (the logic-dense changed modules, matching\n150\t+  # test-conventions) to enable; leave the placeholders and delete this job if not using it.\n151\t+  mutation:\n152\t+    if: false   # flip to `true` (or a repo/branch condition) once <MUTATION_CMD> is filled\n153\t+    runs-on: ubuntu-latest\n154\t+    timeout-minutes: 30\n155\t+    steps:\n156\t+      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n157\t+      - uses: actions/setup-python@v5\n158\t+        with:\n159\t+          python-version: \"3.12\"\n160\t+      - name: Install dependencies (from lockfile)\n161\t+        run: |\n162\t+          pip install poetry==2.4.1\n163\t+          poetry install --no-root\n164\t+      - name: Mutation testing (advisory — score to the summary, never fails the gate)\n165\t+        run: |\n166\t+          set +e\n167\t+          <MUTATION_CMD>   # e.g. mutmut run --paths-to-mutate <MUTATION_SCOPE>\n168\t+          echo \"Mutation run complete (advisory; see output). This job never fails the merge gate.\" >> \"$GITHUB_STEP_SUMMARY\"\n169\t+          exit 0\n170\t+\n171\t   sast:\n172\t     runs-on: ubuntu-latest\n173\t     timeout-minutes: 20\n174\tdiff --git a/CLAUDE.md b/CLAUDE.md\n175\tindex 0529630..d96624e 100644\n176\t--- a/CLAUDE.md\n177\t+++ b/CLAUDE.md\n178\t@@ -7,7 +7,9 @@\n179\t - Data stores: PostgreSQL\n180\t - Migration tool: Alembic\n181\t - Cloud / IaC: AWS + Terraform\n182\t-- Auth provider: API keys (Argon2id-hashed at rest), per-key rate limiting — no third-party IdP\n183\t+- Auth provider: API keys (Argon2id-hashed at rest), per-key rate limiting — no third-party IdP.\n184\t+  `api_keys.scope` (`'ingest'` default, `'admin'` elevated) gates `PUT /v1/quotas`; provision an\n185\t+  admin key with `scripts/seed_api_key.py --admin`.\n186\t - Observability: CloudWatch + X-Ray + Sentry (release-tagged)\n187\t - Packaging / runtime: container (Docker) — justified: deploys through the ECS canary path\n188\t \n189\tdiff --git a/PROJECT.md b/PROJECT.md\n190\tindex eb1d60f..ef22d91 100644\n191\t--- a/PROJECT.md\n192\t+++ b/PROJECT.md\n193\t@@ -1,43 +1,6 @@\n194\t-# Meterly\n195\t-\n196\t-## What this is\n197\t-A usage-metering API: ingest metered events, aggregate them into per-customer/metric counters,\n198\t-and query usage. A high-throughput ingestion primitive (think Stripe Metering / OpenMeter).\n199\t-\n200\t-## First feature (this build only — keep scope here)\n201\t-Two authenticated endpoints + their storage:\n202\t-- POST /v1/events {customer_id, metric, quantity, idempotency_key} — record an event, increment the\n203\t-  current-window counter; idempotent on idempotency_key (a duplicate key is a no-op, returns the\n204\t-  original result).\n205\t-- GET /v1/usage?customer_id=&metric=&window= — return aggregated usage for that customer/metric/window.\n206\t-Storage: an append-only `events` table and an `usage_rollup` hourly-aggregate table, the latter added\n207\t-by a SECOND migration that backfills from `events` (expand/contract).\n208\t-\n209\t-## Explicitly out of scope for this build (later features)\n210\t-Billing/invoice export, multi-tenant orgs & RBAC, a usage dashboard/UI, additional metric types,\n211\t-webhooks. Do not build these now.\n212\t-\n213\t-## Stack\n214\t-- Cloud: AWS (ECS Fargate + RDS PostgreSQL + ALB), Terraform under infra/.\n215\t-- Language/runtime: Python 3.12 (FastAPI), containerized (Docker).\n216\t-- Data store: PostgreSQL (Alembic migrations).\n217\t-- Auth: API keys (Argon2id-hashed at rest), per-key rate limiting.\n218\t-- Packaging: container (justified — it deploys through the ECS canary path).\n219\t-- Observability: CloudWatch + X-Ray + Sentry (release-tagged).\n220\t-\n221\t-## Frontend design source\n222\t-- Design source: none (API only).\n223\t-\n224\t-## Non-functional / acceptance signals\n225\t-- AC-PERF: POST /v1/events p95 < 50 ms measured UNDER 500 req/s sustained (not serial); throughput\n226\t-  sustains >= 475 req/s. GET /v1/usage p95 < 100 ms.\n227\t-- AC-CONCURRENCY: 50 concurrent POSTs with the SAME idempotency_key create exactly ONE event row.\n228\t-- AC-DATA-PROTECTION: the stored API-key value is an Argon2id hash, never plaintext.\n229\t-- AC-MIGRATION: the usage_rollup backfill migration round-trips (up→down→up) preserving seeded rows.\n230\t-- AC-SLO: define availability 99.9% and ingest p95 < 50 ms as SLOs.\n231\t-\n232\t-## What \"done\" means\n233\t-- Smoke check passes; both endpoints return correct output for a sample input.\n234\t-- Input validation in place; security report clean; ASVS L1/L2 met; data-protection gate satisfied.\n235\t-- Tests pass at >= 85% lines; the perf/concurrency/migration criteria above are covered.\n236\t-- Docs updated; PR description written.\n237\t+Feature: per-customer metric quotas.\n238\t+- PUT /v1/quotas (admin-scoped API key) sets {customer_id, metric, limit_per_window}.\n239\t+- POST /v1/events returns 429 with a quota error envelope when the current-window rollup for that customer/metric would exceed the quota. Customers without a quota are unlimited (no behavior change).\n240\t+- One expand-only migration: a quotas table.\n241\t+- Existing perf budget applies: p95 < 50 ms under load on POST /v1/events.\n242\t+Design source: none.\n243\tdiff --git a/docs/system_architecture.md b/docs/system_architecture.md\n244\tindex 613b2bd..281d5e0 100644\n245\t--- a/docs/system_architecture.md\n246\t+++ b/docs/system_architecture.md\n247\t@@ -1,10 +1,11 @@\n248\t-# Meterly — system architecture (first feature)\n249\t+# Meterly — system architecture\n250\t \n251\t ## Overview\n252\t \n253\t-Meterly ingests metered usage events and serves aggregated per-customer/metric\n254\t-counters. Two authenticated HTTP endpoints, one PostgreSQL database, one Redis\n255\t-rate-limit store, running as a Docker container on ECS Fargate behind an ALB.\n256\t+Meterly ingests metered usage events, serves aggregated per-customer/metric\n257\t+counters, and enforces admin-set per-customer, per-metric usage caps\n258\t+(\"quotas\"). Three authenticated HTTP endpoints, one PostgreSQL database, one\n259\t+Redis rate-limit store, running as a Docker container on ECS Fargate behind an ALB.\n260\t \n261\t ```\n262\t Client --HTTPS+API key--> ALB --> FastAPI (ECS Fargate, >=2 tasks)\n263\t@@ -26,11 +27,23 @@ Client --HTTPS+API key--> ALB --> FastAPI (ECS Fargate, >=2 tasks)\n264\t    allowlists, `extra='forbid'`.\n265\t 6. `events_service.create_event` — one transaction:\n266\t    `INSERT ... ON CONFLICT (api_key_id, idempotency_key) DO NOTHING`, and only\n267\t-   if a row was inserted, `INSERT ... ON CONFLICT ... DO UPDATE` the\n268\t-   `usage_rollup` counter (`src/services/events_service.py`,\n269\t-   `src/repositories/events_repo.py`).\n270\t+   if a row was inserted:\n271\t+   - the quota check: `read_tenant_quota_state_locked` locks the caller's\n272\t+     quota row for `(customer, metric)` (if one exists) and reads the\n273\t+     current-window rollup total fresh; if `R + Q > L` the service raises\n274\t+     `QuotaExceededError` (429 `quota_exceeded`, `Retry-After` to the next\n275\t+     hour boundary), which propagates out of the transaction and rolls back\n276\t+     the event insert — no partial write, no rollup increment\n277\t+     (`src/services/events_service.py`, `src/repositories/quotas_repo.py`).\n278\t+   - otherwise, `INSERT ... ON CONFLICT ... DO UPDATE` the `usage_rollup`\n279\t+     counter (`src/repositories/events_repo.py`).\n280\t+   A duplicate `idempotency_key` (replay) never reaches the quota check at\n281\t+   all — only the winning-insert branch does.\n282\t 7. Error-envelope boundary catches anything unhandled and returns the generic\n283\t-   `{error:{code,message,requestId}}` shape (`src/api/errors.py`).\n284\t+   `{error:{code,message,requestId}}` shape (`src/api/errors.py`); `AppError`\n285\t+   lets a handler attach an explicit `app_code` (e.g. `quota_exceeded`) that\n286\t+   overrides the default status->code map, so two different 429s\n287\t+   (`rate_limited` vs. `quota_exceeded`) stay distinguishable to the caller.\n288\t \n289\t ## Request flow — `GET /v1/usage`\n290\t \n291\t@@ -39,16 +52,67 @@ and reads a single `usage_rollup` row scoped by the caller's `api_key_id`\n292\t (`src/services/usage_service.py`, `src/repositories/usage_repo.py`). A missing\n293\t bucket returns zeros with 200, never 404.\n294\t \n295\t+## Request flow — `PUT /v1/quotas`\n296\t+\n297\t+Admin-scoped create-or-replace of a per-customer, per-metric usage cap.\n298\t+Auth -> Tier-2 per-`api_key_id` throttle -> an `admin`-scope assertion in the\n299\t+route's composed dependency (403 `forbidden` for a non-admin key) -> schema\n300\t+validation (`src/api/schemas/quotas.py`) -> `upsert_tenant_quota`, a single\n301\t+`INSERT ... ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE ...\n302\t+RETURNING (xmax = 0) AS inserted` that reports create-vs-replace in one\n303\t+round-trip (201 create / 200 replace), with a `quota.upsert` audit log\n304\t+(`src/api/routes/quotas.py`, `src/services/quota_service.py`,\n305\t+`src/repositories/quotas_repo.py`).\n306\t+\n307\t ## Data model\n308\t \n309\t-- `api_keys` — the tenant/credential table (migration 0001). `secret_hash` is\n310\t-  Argon2id; `key_id` is the public split-token lookup handle.\n311\t+- `api_keys` — the tenant/credential table (migration 0001), extended with a\n312\t+  `scope` column (migration 0003: `'ingest'` default, `'admin'` elevated).\n313\t+  `secret_hash` is Argon2id; `key_id` is the public split-token lookup\n314\t+  handle. `scope='admin'` is a superset scope — an admin key does everything\n315\t+  an ingest key does, plus call `PUT /v1/quotas`; a tenant that wants quotas\n316\t+  provisions one admin-scoped key and uses it for both.\n317\t - `events` — append-only ingest log (migration 0001). `UNIQUE (api_key_id,\n318\t   idempotency_key)` is the idempotency guarantee; RLS policy\n319\t   `events_tenant_isolation` is the application-scoping backstop.\n320\t - `usage_rollup` — derived hourly aggregate (migration 0002, expand +\n321\t   backfill from `events`). Composite PK `(api_key_id, customer_id, metric,\n322\t   window_start)`; RLS policy `usage_rollup_tenant_isolation`.\n323\t+- `quotas` — per-tenant, per-customer, per-metric usage caps (migration\n324\t+  0003). PK `(api_key_id, customer_id, metric)`; `CHECK (limit_per_window >=\n325\t+  1)`; RLS policy `quotas_tenant_isolation`. The `POST /v1/events` quota\n326\t+  check takes `FOR UPDATE` on this row to serialize concurrent writers for\n327\t+  the same `(customer, metric)` — see *Quota enforcement / atomicity* below.\n328\t+\n329\t+## Quota enforcement / atomicity\n330\t+\n331\t+Strict enforcement (\"usage can never exceed `L`\") is a check-then-act on a\n332\t+shared counter — the classic TOCTOU. `read_tenant_quota_state_locked`\n333\t+(`src/repositories/quotas_repo.py`) makes it race-free with a `SELECT\n334\t+limit_per_window ... FOR UPDATE` on the quota row, run **as a separate\n335\t+statement from the subsequent `usage_rollup` read**, both inside the same\n336\t+transaction as the event insert and rollup increment\n337\t+(`src/services/events_service.py`).\n338\t+\n339\t+This two-round-trip shape is deliberate, not incidental: PostgreSQL's `FOR\n340\t+UPDATE` only guarantees a fresh re-check of the *locked* row itself when a\n341\t+waiter unblocks after the lock holder commits — it does **not** force a\n342\t+fresh snapshot for another table read in the same statement (e.g. a `LEFT\n343\t+JOIN` to `usage_rollup`). A waiter queued before the holder committed would\n344\t+evaluate that join against its own pre-wait snapshot and read a stale total,\n345\t+silently letting concurrent writers jointly exceed the cap. Splitting the\n346\t+lock-acquire and the rollup-read into two statements gives the second query\n347\t+its own fresh READ COMMITTED snapshot (taken *after* the lock is held),\n348\t+which does reflect everything the previous holder just committed. This was\n349\t+verified empirically during implementation: a single combined\n350\t+`LEFT JOIN ... FOR UPDATE OF q` statement let every concurrent waiter read\n351\t+the same stale total and all get admitted; the two-statement version\n352\t+correctly serializes and caps admission at `L`\n353\t+(`tests/integration/test_quota_concurrency.py`).\n354\t+\n355\t+Unlimited customers (no quota row) take no lock at all — the first `SELECT\n356\t+... FOR UPDATE` simply matches zero rows, so the common, zero-contention\n357\t+path stays cheap (AC20 measures its added latency under load).\n358\t \n359\t ## Auth\n360\t \n361\t@@ -58,7 +122,8 @@ guarded by a constant-time digest comparison) avoids paying the Argon2id cost\n362\t on every request while the durable store stays Argon2id-only. See\n363\t `src/auth/__init__.py` for the full tradeoff writeup and\n364\t `scripts/seed_api_key.py` for the only key-provisioning path (no HTTP\n365\t-endpoint in this build's scope).\n366\t+endpoint in this build's scope; pass `--admin` to provision a `scope='admin'`\n367\t+key for `PUT /v1/quotas`, including the DAST-context admin test key, DAST-3).\n368\t \n369\t ## Rate limiting\n370\t \n371\tdiff --git a/scripts/ci/dast-review.sh b/scripts/ci/dast-review.sh\n372\tindex a1153ad..39b3ddd 100644\n373\t--- a/scripts/ci/dast-review.sh\n374\t+++ b/scripts/ci/dast-review.sh\n375\t@@ -32,7 +32,15 @@ budget_json='{\"high\":0,\"medium\":5,\"low\":20,\"informational\":100}'\n376\t # ZAP baseline JSON shape: {\"site\":[{\"@name\":URL,\"alerts\":[{\"name\",\"riskcode\":\"0|1|2|3\",\"count\":\"N\"}]}]}\n377\t # riskcode + count are STRINGS in ZAP's report — coerce with tonumber. Sum count per severity across\n378\t # every site; list the distinct alert names that pushed a severity over its cap.\n379\t-jq -n --slurpfile cap \"$CAP\" --argjson b \"$budget_json\" --arg t \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" '\n380\t+# U-14: fold in the target-reachability probe dast-capture writes. A false there means the\n381\t+# spider seeded on a non-page (bare root when the UI is at /dashboard), so a within-budget\n382\t+# verdict scanned nothing real — surfaced as a WARN below, still advisory (never a gate).\n383\t+# Read the sidecar into a variable (default {} when absent — backward compatible).\n384\t+probe_json='{}'\n385\t+if [ -f .pipeline/dast-target-probe.json ] && jq -e . .pipeline/dast-target-probe.json >/dev/null 2>&1; then\n386\t+  probe_json=\"$(jq -c '.' .pipeline/dast-target-probe.json)\"\n387\t+fi\n388\t+jq -n --slurpfile cap \"$CAP\" --argjson b \"$budget_json\" --argjson probe \"$probe_json\" --arg t \"$(date -u +%Y-%m-%dT%H:%M:%SZ)\" '\n389\t   ({\"3\":\"high\",\"2\":\"medium\",\"1\":\"low\",\"0\":\"informational\"}) as $sevmap\n390\t   | [ $cap[0].site // [] | .[] | .alerts // [] | .[]\n391\t       | {sev: ($sevmap[(.riskcode|tostring)] // \"informational\"),\n392\t@@ -46,19 +54,26 @@ jq -n --slurpfile cap \"$CAP\" --argjson b \"$budget_json\" --arg t \"$(date -u +%Y-%\n393\t       | select($n > $capn)\n394\t       | {severity: $s, count: $n, budget: $capn,\n395\t          alerts: ($alerts | map(select(.sev == $s) | .name) | unique)} ] as $over\n396\t+  | ({\"target_reached\": true} + ($probe // {})) as $p\n397\t   | {status: \"advisory\",\n398\t      ran_at: $t,\n399\t      target: $target,\n400\t+     target_reached: ($p.target_reached),\n401\t+     target_status: ($p.status // null),\n402\t      alerts_by_severity: $by_sev,\n403\t      over_budget: $over,\n404\t      within_budget: (($over | length) == 0)}\n405\t ' > \"$OUT\"\n406\t \n407\t OVER=$(jq '.over_budget | length' \"$OUT\" 2>/dev/null || echo 0)\n408\t+REACHED=$(jq -r '.target_reached' \"$OUT\" 2>/dev/null || echo true)\n409\t+if [ \"$REACHED\" = \"false\" ]; then\n410\t+  echo \"[dast-review] ADVISORY: DAST target was NOT reached (HTTP $(jq -r '.target_status // \"?\"' \"$OUT\")) — the passive scan did not traverse the real page; treat 'within budget' as uninformative. Set DAST_TARGET_URL to the served route. Surface in the PR (advisory). See $OUT.\" >&2\n411\t+fi\n412\t if [ \"${OVER:-0}\" -gt 0 ]; then\n413\t   HI=$(jq -r '[.over_budget[] | select(.severity==\"high\")] | length' \"$OUT\" 2>/dev/null || echo 0)\n414\t   echo \"[dast-review] ADVISORY: $OVER severity band(s) over budget (${HI} at HIGH) — surface in the PR (advisory, non-blocking). See $OUT.\" >&2\n415\t-else\n416\t+elif [ \"$REACHED\" != \"false\" ]; then\n417\t   echo \"[dast-review] within budget (target: $(jq -r '.target // \"n/a\"' \"$OUT\")).\"\n418\t fi\n419\t exit 0\n420\tdiff --git a/scripts/ci/guard-source-markers.sh b/scripts/ci/guard-source-markers.sh\n421\tindex ec6b942..cfc09f0 100644\n422\t--- a/scripts/ci/guard-source-markers.sh\n423\t+++ b/scripts/ci/guard-source-markers.sh\n424\t@@ -5,10 +5,10 @@\n425\t # The M5 hazard: a debugging agent replaced a money-path fix with the original buggy\n426\t # code tagged with an experimental scratch-revert marker (a TEMP-style prefix combined\n427\t # with a REVERT suffix — see the pattern list below) to demonstrate a repro, then capped\n428\t-# before restoring it — leaving the money path broken while the build stayed green (no signal).\n429\t-# It was caught only because a human re-grepped for SAVEPOINT. This hook makes that\n430\t-# signal deterministic: it greps the change set (tracked diff + untracked files vs HEAD,\n431\t-# the same set the rest of the pipeline scopes to) for danger markers and blocks.\n432\t+# before restoring it — leaving the money path broken while the build stayed green (no\n433\t+# signal). It was caught only because a human re-grepped for SAVEPOINT. This hook makes\n434\t+# that signal deterministic: it greps the change set (tracked diff + untracked files vs\n435\t+# HEAD, the same set the rest of the pipeline scopes to) for danger markers and blocks.\n436\t #\n437\t # Two roles (same logic):\n438\t #   1. deployment-gate.sh sources/invokes it → a HARD deploy block (the money guarantee).\n439\t@@ -16,13 +16,14 @@\n440\t #      can stop, that it left a marker in the tree (exit 2 feeds stderr back to the model).\n441\t #\n442\t # Markers matched (word-boundary, case-insensitive; see the MARKERS regex below for the\n443\t-# exact patterns — described here rather than spelled out literally, so this comment\n444\t-# doesn't trip the very check it documents): a TEMP-style scratch tag combined with a\n445\t-# REVERT suffix (optionally via an extra prefix word); a REVERT tag combined with an ME\n446\t-# suffix; an XXX tag combined with a REVERT suffix; a phrase meaning the change must not\n447\t-# be committed; and HACK/FIXME tags meaning remove-or-fix-before-shipping.\n448\t-# Plain TODO/FIXME/XXX are NOT matched — those are normal and blocking on them would just\n449\t-# train people to bypass the gate. Only experimental-revert or must-not-ship-class markers block.\n450\t+# exact shapes — U-05: this prose deliberately DESCRIBES them instead of spelling them,\n451\t+# so the scaffold copy of this file never trips the guard itself): a TEMP tag combined\n452\t+# with a REVERT suffix (optionally via an extra prefix word); a REVERT tag combined with\n453\t+# an ME suffix; an XXX tag combined with a REVERT suffix; a phrase meaning the change\n454\t+# must not be committed; a HACK tag with a REMOVE suffix; a FIXME tag scoped to\n455\t+# before-commit. Plain TODO/FIXME/XXX are NOT matched — those are normal and blocking on\n456\t+# them would just train people to bypass the gate. Only experimental-revert or\n457\t+# must-not-ship-class markers block.\n458\t #\n459\t # Exit: 0 = clean (or no change set / not a pipeline project) · 2 = marker found (BLOCK).\n460\t set -uo pipefail\n461\t@@ -45,14 +46,19 @@ else\n462\t   [ -f .pipeline/state.json ] || exit 0\n463\t fi\n464\t \n465\t-# Danger-marker pattern. Anchored to experimental-revert or must-not-ship intent, not ordinary TODOs.\n466\t+# Danger-marker pattern. Anchored to experimental-revert or must-not-ship intent, not\n467\t+# ordinary TODOs. (The regex itself does not self-match — verified in marker-guard.sh.)\n468\t MARKERS='TEMP[-_ ]?(PREFIX[-_ ]?)?REVERT|REVERT[-_ ]?ME|XXX[-_ ]?REVERT|DO[-_ ]?NOT[-_ ]?COMMIT|HACK[-_ ]?REMOVE|FIXME[-_ ]?BEFORE[-_ ]?COMMIT'\n469\t \n470\t # Change set = tracked diff (added lines only) + untracked files vs HEAD. We scan ADDED\n471\t # diff lines (leading '+') so a marker being REMOVED in the diff doesn't false-positive,\n472\t-# and untracked files in full. Exclude this hook itself and test fixtures/suites, which\n473\t-# legitimately contain marker strings as test data.\n474\t-EXCLUDE='(^|/)(tests/|.*\\.pipeline/|global-hooks/guard-source-markers\\.sh)'\n475\t+# and untracked files in full. Exclude this hook's own definition files by path — the\n476\t+# repo-of-record copy AND the per-project scaffold copy bootstrap writes to scripts/ci/\n477\t+# (U-05: the M3 run false-blocked on its own fresh scaffold because only the\n478\t+# global-hooks path was excluded) — plus test fixtures/suites, which legitimately\n479\t+# contain marker strings as test data. The exclusion is pinned to this one filename: a\n480\t+# real marker planted anywhere else in scripts/ci/ still blocks.\n481\t+EXCLUDE='(^|/)(tests/|.*\\.pipeline/|(global-hooks|scripts/ci)/guard-source-markers\\.sh)'\n482\t \n483\t hits=\"\"\n484\t \n485\t@@ -82,7 +88,7 @@ done < <(git ls-files -z --others --exclude-standard 2>/dev/null || true)\n486\t \n487\t if [ -n \"$hits\" ]; then\n488\t   echo \"Blocked: the change set contains an experimental / revert marker (audit E3) — a\" >&2\n489\t-  echo \"reverted or must-not-ship fix must never ship. Restore the real fix (prove repros in\" >&2\n490\t+  echo \"reverted or do-not-commit fix must never ship. Restore the real fix (prove repros in\" >&2\n491\t   echo \"a scratch copy, never in the tree), then re-run. Offending lines:\" >&2\n492\t   printf '%s\\n' \"$hits\" >&2\n493\t   exit 2\n494\tdiff --git a/scripts/seed_api_key.py b/scripts/seed_api_key.py\n495\tindex eecf1ed..0818bde 100644\n496\t--- a/scripts/seed_api_key.py\n497\t+++ b/scripts/seed_api_key.py\n498\t@@ -23,11 +23,17 @@ from src.db.session import dispose_engine, get_engine\n499\t from src.repositories.api_keys_repo import create_api_key\n500\t \n501\t \n502\t-async def _seed(label: str, rate_limit_per_sec: int) -> None:\n503\t+async def _seed(label: str, rate_limit_per_sec: int, *, admin: bool) -> None:\n504\t     \"\"\"Generate a new API key, persist its Argon2id hash, and print the\n505\t-    plaintext presented-key value to stdout exactly once.\"\"\"\n506\t+    plaintext presented-key value to stdout exactly once.\n507\t+\n508\t+    `admin=True` provisions the key with `scope='admin'` — the superset scope\n509\t+    required to call `PUT /v1/quotas` (a tenant that wants quotas provisions\n510\t+    one admin-scoped key and uses it for both ingest and administration).\n511\t+    \"\"\"\n512\t     key_id, secret, presented_key = generate_split_token()\n513\t     secret_hash = hash_new_secret(secret)\n514\t+    scope = \"admin\" if admin else \"ingest\"\n515\t \n516\t     async with get_engine().begin() as connection:\n517\t         api_key_row_id = await create_api_key(\n518\t@@ -36,6 +42,7 @@ async def _seed(label: str, rate_limit_per_sec: int) -> None:\n519\t             secret_hash=secret_hash,\n520\t             label=label,\n521\t             rate_limit_per_sec=rate_limit_per_sec,\n522\t+            scope=scope,\n523\t         )\n524\t \n525\t     await dispose_engine()\n526\t@@ -53,8 +60,12 @@ def main() -> None:\n527\t         \"--rate-limit\", type=int, default=100, dest=\"rate_limit_per_sec\",\n528\t         help=\"Tier-2 per-second token-bucket budget for this key (default: 100)\",\n529\t     )\n530\t+    parser.add_argument(\n531\t+        \"--admin\", action=\"store_true\",\n532\t+        help=\"Provision this key with scope='admin' (required to call PUT /v1/quotas); default is scope='ingest'\",\n533\t+    )\n534\t     args = parser.parse_args()\n535\t-    asyncio.run(_seed(args.label, args.rate_limit_per_sec))\n536\t+    asyncio.run(_seed(args.label, args.rate_limit_per_sec, admin=args.admin))\n537\t \n538\t \n539\t if __name__ == \"__main__\":\n540\tdiff --git a/src/api/README.md b/src/api/README.md\n541\tindex f65fb0a..11ca706 100644\n542\t--- a/src/api/README.md\n543\t+++ b/src/api/README.md\n544\t@@ -10,11 +10,13 @@ HTTP API layer: FastAPI route handlers, request/response schemas (Pydantic v2),\n545\t |---|---|\n546\t | `routes/events.py` | `POST /v1/events` handler; calls `events_service.create_event`. |\n547\t | `routes/usage.py` | `GET /v1/usage` handler; calls `usage_service.read_usage`. |\n548\t+| `routes/quotas.py` | `PUT /v1/quotas` handler; composes auth -> Tier-2 throttle -> an `admin`-scope gate (403 `forbidden` otherwise) -> `quota_service.upsert_tenant_quota`. |\n549\t | `routes/health.py` | `GET /health` (liveness, no dependencies) and `GET /health/ready` (readiness, DB + migration check). |\n550\t | `schemas/events.py` | Pydantic models for POST /v1/events request and response; `extra='forbid'` contract enforcement. |\n551\t | `schemas/usage.py` | Pydantic models for GET /v1/usage request (query parameters) and response. |\n552\t-| `middleware.py` | Request-ID / trace-ID assignment, security headers (HSTS, CSP, X-Frame-Options), CORS. |\n553\t-| `errors.py` | Error-envelope boundary: catches all unhandled exceptions and returns `{error:{code,message,requestId}}` with no stack/secret leakage. |\n554\t+| `schemas/quotas.py` | Pydantic models for PUT /v1/quotas request (`customer_id`, `metric`, `limit_per_window`, `extra='forbid'`) and response (echo shape). |\n555\t+| `middleware.py` | Request-ID / trace-ID assignment, security headers (HSTS, CSP, X-Frame-Options), CORS (allows GET/POST/PUT). |\n556\t+| `errors.py` | Error-envelope boundary: catches all unhandled exceptions and returns `{error:{code,message,requestId}}` with no stack/secret leakage. `AppError` lets a raised exception carry an explicit `app_code` (e.g. `quota_exceeded`) that overrides the default status->code map — needed because 429 is shared by two distinct codes (`rate_limited` vs `quota_exceeded`). |\n557\t \n558\t ## Relationships\n559\t \n560\t@@ -46,10 +48,13 @@ HTTP API layer: FastAPI route handlers, request/response schemas (Pydantic v2),\n561\t - All string fields are bounded length (e.g., `customer_id` ≤128, `metric` ≤64).\n562\t - `quantity` is a decimal > 0 (no zero or negative); `idempotency_key` is alphanumeric + underscore/dash.\n563\t - GET `/v1/usage` requires a timezone-aware ISO-8601 `window` parameter within 90 days past to 1 hour future (naive datetimes rejected).\n564\t+- PUT `/v1/quotas`: `limit_per_window` is an integer `>= 1` (`<= 1e15`, BIGINT-safe); `customer_id`/`metric` reuse the same anchored allowlists as events; unknown fields (including a client-supplied `api_key_id`/`scope`) are rejected outright.\n565\t \n566\t **Error handling:**\n567\t - Authentication failures (missing/invalid key) → 401/403 before handlers run.\n568\t-- Rate-limit exceeded (Tier-1 or Tier-2) → 429 + Retry-After header.\n569\t+- `PUT /v1/quotas` from a non-`admin`-scoped key → 403 `forbidden` (function-level authorization, checked in the route's composed dependency).\n570\t+- Rate-limit exceeded (Tier-1 or Tier-2) → 429 `rate_limited` + Retry-After header.\n571\t+- `POST /v1/events` over its quota → 429 `quota_exceeded` (distinct code, same status) + Retry-After to the next hour boundary; no event/rollup written (transaction rolled back).\n572\t - Schema validation failure → 422 with Pydantic error detail.\n573\t - Database errors (constraint violation, connection drop) → caught by error envelope → 500 (generic message, safe).\n574\t - Any unhandled exception → error envelope → 500, safe, no leak.\n575\tdiff --git a/src/api/errors.py b/src/api/errors.py\n576\tindex d1c0f75..675838c 100644\n577\t--- a/src/api/errors.py\n578\t+++ b/src/api/errors.py\n579\t@@ -39,6 +39,21 @@ def _envelope(code: str, message: str, request_id: str) -> dict:\n580\t     return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n581\t \n582\t \n583\t+class AppError(HTTPException):\n584\t+    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n585\t+    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n586\t+    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n587\t+    rejection needs its own, distinct `quota_exceeded` code on the same\n588\t+    status. `handle_http_exception` prefers `app_code` over the status map\n589\t+    when present, so this is the minimal single-boundary extension rather\n590\t+    than reshaping the map itself.\n591\t+    \"\"\"\n592\t+\n593\t+    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n594\t+        super().__init__(status_code=status_code, detail=detail, headers=headers)\n595\t+        self.app_code = app_code\n596\t+\n597\t+\n598\t def register_error_handlers(app: FastAPI) -> None:\n599\t     \"\"\"Register the centralized exception handlers on `app`.\n600\t \n601\t@@ -63,9 +78,14 @@ def register_error_handlers(app: FastAPI) -> None:\n602\t \n603\t     @app.exception_handler(StarletteHTTPException)\n604\t     async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n605\t-        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\"\"\"\n606\t+        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n607\t+\n608\t+        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n609\t+        map — this is what lets two different exceptions share one HTTP status\n610\t+        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n611\t+        \"\"\"\n612\t         request_id = _request_id(request)\n613\t-        code = _STATUS_TO_CODE.get(exc.status_code, \"error\")\n614\t+        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n615\t         message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n616\t         return JSONResponse(\n617\t             status_code=exc.status_code,\n618\t@@ -97,4 +117,4 @@ def register_error_handlers(app: FastAPI) -> None:\n619\t         )\n620\t \n621\t \n622\t-__all__ = [\"register_error_handlers\", \"HTTPException\"]\n623\t+__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n624\tdiff --git a/src/api/middleware.py b/src/api/middleware.py\n625\tindex d10bcb6..f21399c 100644\n626\t--- a/src/api/middleware.py\n627\t+++ b/src/api/middleware.py\n628\t@@ -160,6 +160,6 @@ def configure_cors(app: FastAPI, settings: Settings) -> None:\n629\t         CORSMiddleware,\n630\t         allow_origins=list(settings.cors_allowed_origins),\n631\t         allow_credentials=False,\n632\t-        allow_methods=[\"GET\", \"POST\"],\n633\t+        allow_methods=[\"GET\", \"POST\", \"PUT\"],\n634\t         allow_headers=[\"Authorization\", \"Content-Type\", \"Idempotency-Key\"],\n635\t     )\n636\tdiff --git a/src/auth/README.md b/src/auth/README.md\n637\tindex 13ed713..13ba15b 100644\n638\t--- a/src/auth/README.md\n639\t+++ b/src/auth/README.md\n640\t@@ -9,9 +9,14 @@ Authentication and authorization layer: API key verification (split-token parsin\n641\t | File / Module | Responsibility |\n642\t |---|---|\n643\t | `__init__.py` | `require_api_key` FastAPI dependency guard: parses the `Authorization: Bearer` header, checks the verification cache, falls back to DB lookup + Argon2id verify on cache miss, sets the authenticated `api_key_id` in request state. |\n644\t-| `api_key.py` | Split-token key parsing (`mtr_live_<key_id>_<secret>`), verification logic (Argon2id check), cache TTL management, revocation status check. |\n645\t+| `api_key.py` | Split-token key parsing (`mtr_live_<key_id>_<secret>`), verification logic (Argon2id check), cache TTL management, revocation status check. `AuthenticatedPrincipal.scope` (`\"ingest\"` default, `\"admin\"` elevated) rides the same cached principal. |\n646\t | `rate_limit.py` | Tier-1 (pre-auth, IP+route keyed) and Tier-2 (post-auth, api_key_id keyed) Redis token-bucket limiters; both fail open (log warning, allow request) on Redis connection error. |\n647\t \n648\t+**Authorization scope (function-level, on top of authentication):**\n649\t+- `AuthenticatedPrincipal.scope` is `\"ingest\"` by default; `\"admin\"` is a superset scope, not a separate key family — an admin-scoped key does everything an ingest key does, plus is permitted to call `PUT /v1/quotas`.\n650\t+- Only `src/api/routes/quotas.py`'s composed dependency checks `scope` (`principal.scope == \"admin\"`, else `HTTPException(403)`); every other route ignores it, so existing behavior is unchanged.\n651\t+- Provisioned via `scripts/seed_api_key.py --admin` (defaults to `\"ingest\"` without the flag); this is also the DAST-context admin test key (DAST-3).\n652\t+\n653\t ## Relationships\n654\t \n655\t **Public surface:**\n656\tdiff --git a/src/auth/api_key.py b/src/auth/api_key.py\n657\tindex 96ef6aa..a72654a 100644\n658\t--- a/src/auth/api_key.py\n659\t+++ b/src/auth/api_key.py\n660\t@@ -31,10 +31,19 @@ class ParsedApiKey:\n661\t \n662\t @dataclass(frozen=True)\n663\t class AuthenticatedPrincipal:\n664\t-    \"\"\"The authenticated caller: the internal `api_key_id` and its rate-limit budget.\"\"\"\n665\t+    \"\"\"The authenticated caller: the internal `api_key_id`, its rate-limit\n666\t+    budget, and its authorization `scope`.\n667\t+\n668\t+    `scope` defaults to `\"ingest\"` so any direct construction in existing unit\n669\t+    tests keeps working unchanged; `verify_api_key` always populates it\n670\t+    explicitly from the stored record. `\"admin\"` is a superset scope — an\n671\t+    admin-scoped key may do everything an ingest key does, plus call\n672\t+    `PUT /v1/quotas` (plan §\"The tenant model\").\n673\t+    \"\"\"\n674\t \n675\t     api_key_id: int\n676\t     rate_limit_per_sec: int\n677\t+    scope: str = \"ingest\"\n678\t \n679\t \n680\t def parse_split_token(presented_key: str) -> ParsedApiKey | None:\n681\t@@ -71,7 +80,7 @@ async def verify_api_key(\n682\t         return None\n683\t \n684\t     return AuthenticatedPrincipal(\n685\t-        api_key_id=record.id, rate_limit_per_sec=record.rate_limit_per_sec\n686\t+        api_key_id=record.id, rate_limit_per_sec=record.rate_limit_per_sec, scope=record.scope\n687\t     )\n688\t \n689\t \n690\tdiff --git a/src/main.py b/src/main.py\n691\tindex e691ed0..1215395 100644\n692\t--- a/src/main.py\n693\t+++ b/src/main.py\n694\t@@ -27,6 +27,7 @@ from src.api.middleware import (\n695\t )\n696\t from src.api.routes.events import router as events_router\n697\t from src.api.routes.health import router as health_router\n698\t+from src.api.routes.quotas import router as quotas_router\n699\t from src.api.routes.usage import router as usage_router\n700\t from src.config.settings import get_settings\n701\t from src.db.session import dispose_engine\n702\t@@ -84,6 +85,7 @@ def create_app() -> FastAPI:\n703\t     app.include_router(health_router)\n704\t     app.include_router(events_router)\n705\t     app.include_router(usage_router)\n706\t+    app.include_router(quotas_router)\n707\t \n708\t     # Must run after routes are mounted (FastAPIInstrumentor introspects them)\n709\t     # and before the app starts serving (it registers ASGI middleware, which\n710\tdiff --git a/src/repositories/README.md b/src/repositories/README.md\n711\tindex a839815..9400c70 100644\n712\t--- a/src/repositories/README.md\n713\t+++ b/src/repositories/README.md\n714\t@@ -10,13 +10,15 @@ Data access layer: SQL queries with parameterization, row-level scoping (by auth\n715\t |---|---|\n716\t | `events_repo.py` | `create_or_replay_event(api_key_id, customer_id, metric, quantity, idempotency_key, window_start)` — INSERT ... ON CONFLICT ... DO NOTHING (idempotency). Also `upsert_rollup()` (called only on insert success). |\n717\t | `usage_repo.py` | `read_usage(api_key_id, customer_id, metric, window_start)` — SELECT from `usage_rollup` scoped by `api_key_id`. Returns None if missing (caller handles zero conversion). |\n718\t-| `api_keys_repo.py` | `get_by_key_id(key_id)` — SELECT from `api_keys` by public `key_id` (used by auth cache miss). Returns the full row (id, key_id, secret_hash, rate_limit_per_sec, revoked_at). |\n719\t+| `api_keys_repo.py` | `find_active_key_by_key_id(key_id)` — SELECT from `api_keys` by public `key_id` (used by auth cache miss); returns the full row including `scope`. `create_api_key(..., scope=\"ingest\")` — the only key-provisioning path. |\n720\t+| `quotas_repo.py` | `upsert_quota(...)` — `INSERT ... ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE ... RETURNING (xmax = 0) AS inserted`, reporting create-vs-replace in one round-trip. `read_tenant_quota_state_locked(...)` — the atomic check-then-decide: locks the quota row (`FOR UPDATE`), then reads the current-window rollup total as a **separate, fresh** statement (see *Notes* below for why). Returns `None` when no quota exists (unlimited, no lock taken). |\n721\t \n722\t ## Relationships\n723\t \n724\t **Public surface:**\n725\t-- Imported by `src/services.{events_service, usage_service}` to execute queries.\n726\t+- Imported by `src/services.{events_service, usage_service, quota_service}` to execute queries.\n727\t - `api_keys_repo` is also imported by `src/auth.api_key` (credential lookup on cache miss).\n728\t+- `quotas_repo` is imported by both `quota_service` (the upsert) and `events_service` (the read-and-decide).\n729\t \n730\t **Dependencies:**\n731\t - All functions are async; they receive an `AsyncSession` from the service layer (obtained via `src/db.session_context`).\n732\t@@ -51,6 +53,12 @@ Data access layer: SQL queries with parameterization, row-level scoping (by auth\n733\t - This context variable is read by the PostgreSQL RLS policy on every table access.\n734\t - The `SET LOCAL` is per-transaction (automatically cleared at commit), so no context leakage across requests.\n735\t \n736\t+**Quota lock-then-read pattern (why it's two statements, not one):**\n737\t+- `read_tenant_quota_state_locked` deliberately issues the `FOR UPDATE` lock on `quotas` and the `usage_rollup` read as two separate statements, not a single `LEFT JOIN ... FOR UPDATE OF q` query.\n738\t+- PostgreSQL's `FOR UPDATE` only forces a fresh re-check (`EvalPlanQual`) of the *locked* row itself when a blocked waiter unblocks after the holder commits — it does **not** force a fresh snapshot for another table read in the same statement, including a joined one.\n739\t+- A single combined statement lets a waiter that queued before the holder committed read `usage_rollup` from its own stale pre-wait snapshot — verified empirically during implementation: every concurrent waiter read the same stale total and all got admitted, silently breaking the cap.\n740\t+- Issuing the `usage_rollup` read as its own statement *after* the lock is acquired gives it a fresh READ COMMITTED snapshot that does include everything the previous holder just committed — this is what makes `current_total` accurate for every waiter, not just the first uncontended caller (`tests/integration/test_quota_concurrency.py`).\n741\t+\n742\t **Async pattern:**\n743\t - All functions are async; they use `await session.execute(...)` for queries.\n744\t - They receive an `AsyncSession` that's already connected and in a transaction (setup by `src/db.session_context`).\n745\tdiff --git a/src/repositories/api_keys_repo.py b/src/repositories/api_keys_repo.py\n746\tindex bf7c5b4..204d515 100644\n747\t--- a/src/repositories/api_keys_repo.py\n748\t+++ b/src/repositories/api_keys_repo.py\n749\t@@ -22,6 +22,7 @@ class ApiKeyRecord:\n750\t     secret_hash: str\n751\t     rate_limit_per_sec: int\n752\t     revoked_at: object | None\n753\t+    scope: str\n754\t \n755\t \n756\t async def find_active_key_by_key_id(\n757\t@@ -36,7 +37,7 @@ async def find_active_key_by_key_id(\n758\t     result = await connection.execute(\n759\t         text(\n760\t             \"\"\"\n761\t-            SELECT id, key_id, secret_hash, rate_limit_per_sec, revoked_at\n762\t+            SELECT id, key_id, secret_hash, rate_limit_per_sec, revoked_at, scope\n763\t             FROM api_keys\n764\t             WHERE key_id = :key_id AND revoked_at IS NULL\n765\t             \"\"\"\n766\t@@ -52,6 +53,7 @@ async def find_active_key_by_key_id(\n767\t         secret_hash=row[\"secret_hash\"],\n768\t         rate_limit_per_sec=row[\"rate_limit_per_sec\"],\n769\t         revoked_at=row[\"revoked_at\"],\n770\t+        scope=row[\"scope\"],\n771\t     )\n772\t \n773\t \n774\t@@ -62,16 +64,21 @@ async def create_api_key(\n775\t     secret_hash: str,\n776\t     label: str,\n777\t     rate_limit_per_sec: int = 100,\n778\t+    scope: str = \"ingest\",\n779\t ) -> int:\n780\t     \"\"\"Insert a new API key row (secret already hashed by the caller) and\n781\t     return its internal surrogate id. Used only by `scripts/seed_api_key.py`\n782\t     — there is no key-creation HTTP endpoint in this build's scope.\n783\t+\n784\t+    `scope` defaults to `'ingest'` so every existing caller of this function\n785\t+    is unaffected; pass `scope='admin'` to provision a key that may also call\n786\t+    `PUT /v1/quotas` (admin is a superset scope, not a separate key family).\n787\t     \"\"\"\n788\t     result = await connection.execute(\n789\t         text(\n790\t             \"\"\"\n791\t-            INSERT INTO api_keys (key_id, secret_hash, label, rate_limit_per_sec)\n792\t-            VALUES (:key_id, :secret_hash, :label, :rate_limit_per_sec)\n793\t+            INSERT INTO api_keys (key_id, secret_hash, label, rate_limit_per_sec, scope)\n794\t+            VALUES (:key_id, :secret_hash, :label, :rate_limit_per_sec, :scope)\n795\t             RETURNING id\n796\t             \"\"\"\n797\t         ),\n798\t@@ -80,6 +87,7 @@ async def create_api_key(\n799\t             \"secret_hash\": secret_hash,\n800\t             \"label\": label,\n801\t             \"rate_limit_per_sec\": rate_limit_per_sec,\n802\t+            \"scope\": scope,\n803\t         },\n804\t     )\n805\t     return result.scalar_one()\n806\tdiff --git a/src/services/README.md b/src/services/README.md\n807\tindex 8f3610f..eb0f486 100644\n808\t--- a/src/services/README.md\n809\t+++ b/src/services/README.md\n810\t@@ -8,25 +8,29 @@ Business logic layer: event ingestion (with idempotency and counter atomicity),\n811\t \n812\t | File / Module | Responsibility |\n813\t |---|---|\n814\t-| `events_service.py` | `create_event(api_key_id, customer_id, metric, quantity, idempotency_key)` — inserts an event + increments the hourly counter in one transaction; idempotent on `idempotency_key`. Returns the created/replayed event. |\n815\t+| `events_service.py` | `create_event(principal, payload)` — inserts an event, checks the caller's quota (if any) on the winning-insert branch, and increments the hourly counter, all in one transaction; idempotent on `idempotency_key`. Raises `QuotaExceededError` (429 `quota_exceeded`) when `R + Q > L`, which rolls back the event insert. Returns the created/replayed event. |\n816\t | `usage_service.py` | `read_usage(api_key_id, customer_id, metric, window)` — reads the aggregated counter for a time bucket; returns zeros if the bucket is empty (never 404). |\n817\t-| `time_windows.py` | `window_start_utc(ts: datetime)` — floors a timezone-aware timestamp to the hour (UTC); used by both services. |\n818\t+| `quota_service.py` | `upsert_tenant_quota(principal, payload)` — create-or-replaces the caller's cap for `(customer_id, metric)` in one transaction; maps the repository's insert-vs-replace signal to 201/200 and logs the `quota.upsert` audit event. |\n819\t+| `time_windows.py` | `window_start_utc(ts: datetime)` — floors a timezone-aware timestamp to the hour (UTC); used by all three services. |\n820\t \n821\t ## Relationships\n822\t \n823\t **Public surface:**\n824\t-- Imported by `src/api.routes.{events, usage}` to execute the core business operations.\n825\t+- Imported by `src/api.routes.{events, usage, quotas}` to execute the core business operations.\n826\t \n827\t **Dependencies:**\n828\t-- `events_service` imports `src/repositories.{events_repo, usage_repo}` to insert the event and upsert the counter.\n829\t+- `events_service` imports `src/repositories.{events_repo, quotas_repo}` to insert the event, check the quota, and upsert the counter.\n830\t - `usage_service` imports `src/repositories.usage_repo` to read the rollup.\n831\t-- Both services receive an authenticated `api_key_id` from the route handler (set by `require_api_key` guard).\n832\t+- `quota_service` imports `src/repositories.quotas_repo` to upsert the cap.\n833\t+- All three services receive an authenticated `AuthenticatedPrincipal` from the route handler (set by `require_api_key` guard); `principal.scope` gates `PUT /v1/quotas` at the route layer before `quota_service` ever runs.\n834\t - `time_windows` is imported by `events_service` and `usage_service` to floor timestamps.\n835\t \n836\t **Transaction boundary:**\n837\t-- `create_event` wraps both the event insert and the rollup upsert in one PostgreSQL transaction (via `src/db/session_context`).\n838\t-- This atomicity ensures that if the insert wins (no existing `idempotency_key`), the counter increments exactly once.\n839\t-- If the insert loses (duplicate key), neither the counter nor any side effect happens — a no-op.\n840\t+- `create_event` wraps the event insert, the quota check, and the rollup upsert in one PostgreSQL transaction (via `src/db/session_context`).\n841\t+- This atomicity ensures that if the insert wins (no existing `idempotency_key`) and the quota check passes, the counter increments exactly once.\n842\t+- If the insert loses (duplicate key), the quota is never consulted and neither the counter nor any side effect happens — a no-op.\n843\t+- If the quota check rejects (`R + Q > L`), raising `QuotaExceededError` propagates out of the transaction context and rolls it back — the event insert is undone and the counter is never touched (no partial write).\n844\t+- `upsert_tenant_quota` wraps the quota upsert in its own transaction; a single `INSERT ... ON CONFLICT ... DO UPDATE ... RETURNING (xmax = 0)` reports create-vs-replace with no second round-trip.\n845\t \n846\t ## Notes\n847\t \n848\tdiff --git a/src/services/events_service.py b/src/services/events_service.py\n849\tindex 1f42491..82c6144 100644\n850\t--- a/src/services/events_service.py\n851\t+++ b/src/services/events_service.py\n852\t@@ -6,10 +6,12 @@ transaction the plan's idempotency mechanism depends on for atomicity — see\n853\t `src/repositories/events_repo.py` for the `ON CONFLICT` primitive itself.\n854\t \"\"\"\n855\t \n856\t+import math\n857\t from dataclasses import dataclass\n858\t-from datetime import datetime, timezone\n859\t+from datetime import datetime, timedelta, timezone\n860\t from decimal import Decimal\n861\t \n862\t+from src.api.errors import AppError\n863\t from src.api.schemas.events import EventCreateRequest, EventResponse\n864\t from src.auth.api_key import AuthenticatedPrincipal\n865\t from src.db.session import scoped_transaction\n866\t@@ -20,6 +22,7 @@ from src.repositories.events_repo import (\n867\t     increment_usage_rollup,\n868\t     insert_event_if_new,\n869\t )\n870\t+from src.repositories.quotas_repo import read_tenant_quota_state_locked\n871\t from src.services.time_windows import floor_to_hour_utc\n872\t \n873\t logger = get_logger(service=\"meterly\")\n874\t@@ -41,6 +44,33 @@ class IdempotencyRaceError(RuntimeError):\n875\t     the service fails loudly rather than returning an empty response.\"\"\"\n876\t \n877\t \n878\t+class QuotaExceededError(AppError):\n879\t+    \"\"\"429 with the distinct `quota_exceeded` app_code (never `rate_limited`,\n880\t+    which already owns 429 for the Tier-2 throttle), carrying `Retry-After`\n881\t+    seconds to the next hour boundary.\n882\t+\n883\t+    Raising this mid-transaction — after the event `INSERT`, before the\n884\t+    rollup increment — is what triggers the rollback that leaves no partial\n885\t+    write behind: propagating out of `scoped_transaction`'s `session.begin()`\n886\t+    context undoes the event row and skips `increment_usage_rollup` entirely.\n887\t+    \"\"\"\n888\t+\n889\t+    def __init__(self, retry_after_seconds: int) -> None:\n890\t+        super().__init__(\n891\t+            status_code=429,\n892\t+            app_code=\"quota_exceeded\",\n893\t+            detail=\"metric quota exceeded for the current window\",\n894\t+            headers={\"Retry-After\": str(retry_after_seconds)},\n895\t+        )\n896\t+\n897\t+\n898\t+def _seconds_until_next_hour_boundary(received_at: datetime, window_start: datetime) -> int:\n899\t+    \"\"\"Seconds from `received_at` to the end of `window_start`'s hour,\n900\t+    floored to at least 1 — the `Retry-After` value for a quota rejection.\"\"\"\n901\t+    next_window_start = window_start + timedelta(hours=1)\n902\t+    return max(1, math.ceil((next_window_start - received_at).total_seconds()))\n903\t+\n904\t+\n905\t async def create_event(\n906\t     principal: AuthenticatedPrincipal, payload: EventCreateRequest\n907\t ) -> EventCreationOutcome:\n908\t@@ -65,6 +95,28 @@ async def create_event(\n909\t         )\n910\t \n911\t         if inserted is not None:\n912\t+            quota_state = await read_tenant_quota_state_locked(\n913\t+                session,\n914\t+                api_key_id=principal.api_key_id,\n915\t+                customer_id=inserted.customer_id,\n916\t+                metric=inserted.metric,\n917\t+                window_start=inserted.window_start,\n918\t+            )\n919\t+            if quota_state is not None and quota_state.current_total + inserted.quantity > quota_state.limit_per_window:\n920\t+                # Deliberately omits current_total/limit from both the log and\n921\t+                # the (AppError-carried) client envelope — usage totals are\n922\t+                # billing-adjacent (plan §\"Info Disclosure\"); the enforcement\n923\t+                # event itself is what ops needs (ASVS 16.3.3).\n924\t+                logger.warning(\n925\t+                    \"quota.rejected\",\n926\t+                    userId=principal.api_key_id,\n927\t+                    action=\"deny\",\n928\t+                    customer_id=inserted.customer_id,\n929\t+                    metric=inserted.metric,\n930\t+                    reason=\"quota_exceeded\","}]},"uuid":"1d288f69-41de-4214-b774-e8fbbb2c3e87","timestamp":"2026-07-09T01:04:09.159Z","sourceToolAssistantUUID":"3990ace2-557f-4278-b45d-9cb3aa9994c8","userType":"external