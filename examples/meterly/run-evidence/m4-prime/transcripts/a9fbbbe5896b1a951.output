{"parentUuid":"c846334b-4b1a-4205-a394-6c6d7a4ad1a2","isSidechain":true,"agentId":"a9fbbbe5896b1a951","message":{"model":"claude-opus-4-8","id":"msg_011CcqawgbEZYEH881h4XQLc","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JfG18XNiWCNEG1i4LkdLXx","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\auth\\__init__.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":2291,"cache_read_input_tokens":68023,"output_tokens":1201,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":2291},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":1201,"cache_read_input_tokens":68023,"cache_creation_input_tokens":2291,"cache_creation":{"ephemeral_5m_input_tokens":2291,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcqawfV1pKnoASgNWSUg3","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"cc2b2a54-7f82-4991-974d-2dba47904261","timestamp":"2026-07-09T01:05:57.884Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"cc2b2a54-7f82-4991-974d-2dba47904261","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JfG18XNiWCNEG1i4LkdLXx","type":"tool_result","content":"1\t\"\"\"Auth facade — `require_api_key` is the only guard route handlers depend on.\n2\t\n3\tResolves the exact tension the plan calls out: Argon2id is intentionally slow\n4\t(tens of ms), so running it on every request at the target 500 req/s would\n5\tblow the ingest p95 budget. An in-process verification cache, keyed by the\n6\ttoken's public `key_id` and guarded by a constant-time digest comparison\n7\t(ASVS 11.2.4 — in-scope L3), lets a repeat caller on the same task skip the\n8\tArgon2id verify after the first request while the durable at-rest store stays\n9\tArgon2id-only. See the plan's \"Argon2id-vs-p95 tension\" section for the full\n10\ttradeoff writeup, including the accepted ~5 min revocation-latency risk (Q4).\n11\t\"\"\"\n12\t\n13\timport time\n14\tfrom dataclasses import dataclass\n15\t\n16\tfrom fastapi import Depends, HTTPException, Request, status\n17\t\n18\tfrom src.auth.api_key import AuthenticatedPrincipal, parse_split_token, verify_api_key\n19\tfrom src.config.settings import get_settings\n20\tfrom src.crypto import constant_time_equals, sha256_digest\n21\tfrom src.db.session import get_engine\n22\tfrom src.logging import get_logger\n23\t\n24\tlogger = get_logger(service=\"meterly\")\n25\t\n26\t_BEARER_PREFIX = \"Bearer \"\n27\t\n28\t\n29\t@dataclass\n30\tclass _CachedVerification:\n31\t    \"\"\"An in-process cache entry: the digest of the secret that was last\n32\t    verified for this `key_id`, and the resolved principal.\"\"\"\n33\t\n34\t    secret_digest: str\n35\t    principal: AuthenticatedPrincipal\n36\t    cached_at: float\n37\t\n38\t\n39\tclass ApiKeyVerificationCache:\n40\t    \"\"\"Per-process cache mapping a token's public `key_id` to its last-verified\n41\t    secret digest and resolved principal, with a TTL.\n42\t\n43\t    Keyed on the *public* `key_id` (not a secret) so the cache lookup itself\n44\t    leaks nothing; the constant-time digest comparison is what actually\n45\t    authorizes a cache hit.\n46\t    \"\"\"\n47\t\n48\t    def __init__(self, ttl_seconds: int) -> None:\n49\t        self._ttl_seconds = ttl_seconds\n50\t        self._entries: dict[str, _CachedVerification] = {}\n51\t\n52\t    def get(self, key_id: str, secret_digest: str) -> AuthenticatedPrincipal | None:\n53\t        \"\"\"Return the cached principal if `key_id` has a fresh, matching entry.\"\"\"\n54\t        entry = self._entries.get(key_id)\n55\t        if entry is None:\n56\t            return None\n57\t        if (time.monotonic() - entry.cached_at) > self._ttl_seconds:\n58\t            del self._entries[key_id]\n59\t            return None\n60\t        if not constant_time_equals(secret_digest, entry.secret_digest):\n61\t            return None\n62\t        return entry.principal\n63\t\n64\t    def put(self, key_id: str, secret_digest: str, principal: AuthenticatedPrincipal) -> None:\n65\t        \"\"\"Cache a freshly Argon2id-verified principal for `key_id`.\"\"\"\n66\t        self._entries[key_id] = _CachedVerification(\n67\t            secret_digest=secret_digest, principal=principal, cached_at=time.monotonic()\n68\t        )\n69\t\n70\t    def invalidate(self, key_id: str) -> None:\n71\t        \"\"\"Drop a cached entry (used by tests and any future revocation channel).\"\"\"\n72\t        self._entries.pop(key_id, None)\n73\t\n74\t\n75\t_verification_cache: ApiKeyVerificationCache | None = None\n76\t\n77\t\n78\tdef _get_verification_cache() -> ApiKeyVerificationCache:\n79\t    \"\"\"Return the process-wide verification cache, created on first use.\"\"\"\n80\t    global _verification_cache\n81\t    if _verification_cache is None:\n82\t        _verification_cache = ApiKeyVerificationCache(get_settings().api_key_cache_ttl_seconds)\n83\t    return _verification_cache\n84\t\n85\t\n86\tdef _extract_bearer_token(request: Request) -> str | None:\n87\t    \"\"\"Pull the raw bearer token out of the `Authorization` header, if present and well-formed.\"\"\"\n88\t    header_value = request.headers.get(\"authorization\")\n89\t    if not header_value or not header_value.startswith(_BEARER_PREFIX):\n90\t        return None\n91\t    return header_value[len(_BEARER_PREFIX) :]\n92\t\n93\t\n94\tasync def require_api_key(request: Request) -> AuthenticatedPrincipal:\n95\t    \"\"\"FastAPI dependency: authenticate the request's API key.\n96\t\n97\t    Cache hit path: constant-time digest compare only (no Argon2id). Cache\n98\t    miss: split-token parse + DB lookup + Argon2id verify, then populate the\n99\t    cache. Any failure raises 401 — malformed header, unknown/revoked key, and\n100\t    a wrong secret are all indistinguishable to the caller.\n101\t    \"\"\"\n102\t    presented_key = _extract_bearer_token(request)\n103\t    if presented_key is None:\n104\t        logger.warning(\"apikey.auth\", userId=None, action=\"deny\", reason=\"missing_or_malformed_header\")\n105\t        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail=\"authentication required\")\n106\t\n107\t    parsed = parse_split_token(presented_key)\n108\t    if parsed is None:\n109\t        logger.warning(\"apikey.auth\", userId=None, action=\"deny\", reason=\"malformed_token\")\n110\t        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail=\"invalid API key\")\n111\t\n112\t    secret_digest = sha256_digest(presented_key)\n113\t    cache = _get_verification_cache()\n114\t    cached_principal = cache.get(parsed.key_id, secret_digest)\n115\t    if cached_principal is not None:\n116\t        logger.info(\"apikey.auth\", userId=cached_principal.api_key_id, action=\"allow\", reason=\"cache_hit\")\n117\t        return cached_principal\n118\t\n119\t    async with get_engine().connect() as connection:\n120\t        principal = await verify_api_key(connection, presented_key)\n121\t\n122\t    if principal is None:\n123\t        logger.warning(\"apikey.auth\", userId=None, action=\"deny\", reason=\"verification_failed\")\n124\t        raise HTTPException(status_code=status.HTTP_401_UNAUTHORIZED, detail=\"invalid API key\")\n125\t\n126\t    cache.put(parsed.key_id, secret_digest, principal)\n127\t    logger.info(\"apikey.auth\", userId=principal.api_key_id, action=\"allow\", reason=\"verified\")\n128\t    return principal\n129\t\n130\t\n131\tApiKeyPrincipal = Depends(require_api_key)\n132\t"}]},"uuid":"c153b7b0-1b9b-44ec-b67a-878ebc85e785","timestamp":"2026-07-09T01:05:57.895Z","sourceToolAssistantUUID":"cc2b2a54-7f82-4991-974d-2dba47904261","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
