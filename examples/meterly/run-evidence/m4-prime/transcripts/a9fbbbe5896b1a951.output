{"parentUuid":"c7f9448f-7cda-497d-8c90-b537b67160af","isSidechain":true,"agentId":"a9fbbbe5896b1a951","message":{"model":"claude-opus-4-8","id":"msg_011CcqaqfSroXJBc2VpTBwkS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019uDU47UAGeLN3gJxWgmqLa","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\repositories\\quotas_repo.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6116,"cache_read_input_tokens":42716,"cache_creation":{"ephemeral_5m_input_tokens":6116,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqaqeMdKCXieQY46EyPe","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"bada61d3-23cc-4e08-a341-c1d0af153e42","timestamp":"2026-07-09T01:04:22.151Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"bada61d3-23cc-4e08-a341-c1d0af153e42","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019uDU47UAGeLN3gJxWgmqLa","type":"tool_result","content":"1\t\"\"\"Repository for `quotas` — the per-tenant, per-customer, per-metric usage\n2\tcap `upsert_quota` writes, and the atomic read-and-decide\n3\t`read_tenant_quota_state_locked` `POST /v1/events` consults.\n4\t\n5\tEvery query here is scoped by the authenticated `api_key_id` first (the\n6\trow-level-security invariant from `code-standards`); the PostgreSQL RLS\n7\tpolicy `quotas_tenant_isolation` is the backstop if this scoping were ever\n8\tmissing from a query.\n9\t\"\"\"\n10\t\n11\tfrom dataclasses import dataclass\n12\tfrom datetime import datetime\n13\tfrom decimal import Decimal\n14\t\n15\tfrom sqlalchemy import text\n16\tfrom sqlalchemy.ext.asyncio import AsyncSession\n17\t\n18\t\n19\t@dataclass(frozen=True)\n20\tclass QuotaRecord:\n21\t    \"\"\"The stored/echoed shape of a `quotas` row plus whether this call\n22\t    created it (`inserted`) or replaced an existing cap.\"\"\"\n23\t\n24\t    customer_id: str\n25\t    metric: str\n26\t    limit_per_window: int\n27\t    inserted: bool\n28\t\n29\t\n30\t@dataclass(frozen=True)\n31\tclass QuotaState:\n32\t    \"\"\"The result of the atomic read-and-decide: the configured cap and the\n33\t    current-window rollup total, read together under `FOR UPDATE OF q`.\"\"\"\n34\t\n35\t    limit_per_window: int\n36\t    current_total: Decimal\n37\t\n38\t\n39\tasync def upsert_quota(\n40\t    session: AsyncSession,\n41\t    *,\n42\t    api_key_id: int,\n43\t    customer_id: str,\n44\t    metric: str,\n45\t    limit_per_window: int,\n46\t) -> QuotaRecord:\n47\t    \"\"\"Create-or-replace the cap for `(api_key_id, customer_id, metric)` in\n48\t    one statement, reporting whether this call inserted a new row.\n49\t\n50\t    `RETURNING (xmax = 0) AS inserted` is the idiom that distinguishes a\n51\t    fresh `INSERT` from an `ON CONFLICT DO UPDATE` in a single round-trip: a\n52\t    freshly inserted row's `xmax` (the deleting-transaction marker) is still\n53\t    zero, while an updated row's `xmax` is set by the `UPDATE` — so the\n54\t    service can map `inserted -> 201` else `200` without a second read-before-\n55\t    write query or the TOCTOU race that would introduce.\n56\t    \"\"\"\n57\t    result = await session.execute(\n58\t        text(\n59\t            \"\"\"\n60\t            INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n61\t            VALUES (:api_key_id, :customer_id, :metric, :limit_per_window, now())\n62\t            ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n63\t                limit_per_window = EXCLUDED.limit_per_window,\n64\t                updated_at = now()\n65\t            RETURNING customer_id, metric, limit_per_window, (xmax = 0) AS inserted\n66\t            \"\"\"\n67\t        ),\n68\t        {\n69\t            \"api_key_id\": api_key_id,\n70\t            \"customer_id\": customer_id,\n71\t            \"metric\": metric,\n72\t            \"limit_per_window\": limit_per_window,\n73\t        },\n74\t    )\n75\t    row = result.mappings().one()\n76\t    return QuotaRecord(\n77\t        customer_id=row[\"customer_id\"],\n78\t        metric=row[\"metric\"],\n79\t        limit_per_window=row[\"limit_per_window\"],\n80\t        inserted=row[\"inserted\"],\n81\t    )\n82\t\n83\t\n84\tasync def read_tenant_quota_state_locked(\n85\t    session: AsyncSession,\n86\t    *,\n87\t    api_key_id: int,\n88\t    customer_id: str,\n89\t    metric: str,\n90\t    window_start: datetime,\n91\t) -> QuotaState | None:\n92\t    \"\"\"Lock the quota row, then read the current-window rollup total fresh —\n93\t    the atomic check-then-decide mechanism `POST /v1/events` uses to enforce\n94\t    `R + Q <= L` without a TOCTOU race (plan §\"The atomic read-and-decide\").\n95\t\n96\t    Returns None when no quota row matches `(api_key_id, customer_id,\n97\t    metric)` — the caller treats this as unlimited and takes no lock at all\n98\t    (the common, zero-contention path).\n99\t\n100\t    **Two round-trips, deliberately, not one combined `LEFT JOIN ... FOR\n101\t    UPDATE` statement.** `FOR UPDATE` only guarantees a fresh re-read of the\n102\t    *locked* row itself (via PostgreSQL's `EvalPlanQual` recheck) when a\n103\t    waiter unblocks after the lock holder commits — it does **not** force a\n104\t    fresh snapshot for other tables read in the same statement, including a\n105\t    `LEFT JOIN`. A waiter that queued for the lock before the holder\n106\t    committed would evaluate that join against its own original (pre-wait)\n107\t    snapshot and read a stale `total_quantity`, silently breaking strict\n108\t    enforcement under real concurrency (verified empirically: a single\n109\t    combined statement let every concurrent waiter read the same stale\n110\t    total and all get admitted). Issuing the `usage_rollup` read as its own\n111\t    statement *after* the lock is acquired gives it a fresh per-statement\n112\t    READ COMMITTED snapshot, which does include everything the previous lock\n113\t    holder just committed — this is what actually makes `current_total`\n114\t    accurate for every waiter, not just the first, uncontended caller.\n115\t    \"\"\"\n116\t    lock_result = await session.execute(\n117\t        text(\n118\t            \"\"\"\n119\t            SELECT limit_per_window\n120\t            FROM quotas\n121\t            WHERE api_key_id = :api_key_id AND customer_id = :customer_id AND metric = :metric\n122\t            FOR UPDATE\n123\t            \"\"\"\n124\t        ),\n125\t        {\"api_key_id\": api_key_id, \"customer_id\": customer_id, \"metric\": metric},\n126\t    )\n127\t    lock_row = lock_result.mappings().first()\n128\t    if lock_row is None:\n129\t        return None\n130\t\n131\t    rollup_result = await session.execute(\n132\t        text(\n133\t            \"\"\"\n134\t            SELECT total_quantity\n135\t            FROM usage_rollup\n136\t            WHERE api_key_id = :api_key_id AND customer_id = :customer_id\n137\t              AND metric = :metric AND window_start = :window_start\n138\t            \"\"\"\n139\t        ),\n140\t        {\n141\t            \"api_key_id\": api_key_id,\n142\t            \"customer_id\": customer_id,\n143\t            \"metric\": metric,\n144\t            \"window_start\": window_start,\n145\t        },\n146\t    )\n147\t    rollup_row = rollup_result.mappings().first()\n148\t    current_total = rollup_row[\"total_quantity\"] if rollup_row is not None else Decimal(0)\n149\t    return QuotaState(limit_per_window=lock_row[\"limit_per_window\"], current_total=Decimal(current_total))\n150\t"}]},"uuid":"f97a16f3-71dd-44d2-8751-9e3bdd1e3404","timestamp":"2026-07-09T01:04:22.159Z","sourceToolAssistantUUID":"bada61d3-23cc-4e08-a341-c1d0af153e42","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"f97a16f3-71dd-44d2-8751-9e3bdd1e3404","isSidechain":true,"agentId":"a9fbbbe5896b1a951","message":{"model":"claude-opus-4-8","id":"msg_011CcqaqfSroXJBc2VpTBwkS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011ps2GgnHAhsoAFssTF1Knp","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\services\\quota_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6116,"cache_read_input_tokens":42716,"cache_creation":{"ephemeral_5m_input_tokens":6116,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqaqeMdKCXieQY46EyPe","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"89f767f3-b0da-4b27-ba9a-d381fa86eed1","timestamp":"2026-07-09T01:04:22.658Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"89f767f3-b0da-4b27-ba9a-d381fa86eed1","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011ps2GgnHAhsoAFssTF1Knp","type":"tool_result","content":"1\t\"\"\"Service for `PUT /v1/quotas` — the admin-scoped upsert + 201/200 mapping.\n2\t\n3\tOrchestrates one transaction per request: the `xmax` upsert in\n4\t`src/repositories/quotas_repo.py` reports create-vs-replace in a single\n5\tround-trip, so this layer only maps that to the HTTP status and emits the\n6\taudit-trail log (`quota.upsert`, plan §\"Repudiation\").\n7\t\"\"\"\n8\t\n9\tfrom dataclasses import dataclass\n10\t\n11\tfrom src.api.schemas.quotas import QuotaPutRequest, QuotaResponse\n12\tfrom src.auth.api_key import AuthenticatedPrincipal\n13\tfrom src.db.session import scoped_transaction\n14\tfrom src.logging import get_logger\n15\tfrom src.repositories.quotas_repo import upsert_quota\n16\t\n17\tlogger = get_logger(service=\"meterly\")\n18\t\n19\t\n20\t@dataclass(frozen=True)\n21\tclass QuotaUpsertOutcome:\n22\t    \"\"\"The result of processing a `PUT /v1/quotas` request: the stored quota\n23\t    and the HTTP status the route should return (201 create, 200 replace).\"\"\"\n24\t\n25\t    customer_id: str\n26\t    metric: str\n27\t    limit_per_window: int\n28\t    http_status: int\n29\t\n30\t\n31\tasync def upsert_tenant_quota(\n32\t    principal: AuthenticatedPrincipal, payload: QuotaPutRequest\n33\t) -> QuotaUpsertOutcome:\n34\t    \"\"\"Create-or-replace the cap for `(customer_id, metric)` under the\n35\t    authenticated principal's own `api_key_id` — the server, never the\n36\t    client, sets `api_key_id`, which is the mass-assignment protection\n37\t    (ASVS 15.3.3) against writing another tenant's cap.\n38\t    \"\"\"\n39\t    async with scoped_transaction(principal.api_key_id) as session:\n40\t        record = await upsert_quota(\n41\t            session,\n42\t            api_key_id=principal.api_key_id,\n43\t            customer_id=payload.customer_id,\n44\t            metric=payload.metric,\n45\t            limit_per_window=payload.limit_per_window,\n46\t        )\n47\t\n48\t    action = \"create\" if record.inserted else \"replace\"\n49\t    logger.info(\n50\t        \"quota.upsert\",\n51\t        userId=principal.api_key_id,\n52\t        action=action,\n53\t        customer_id=record.customer_id,\n54\t        metric=record.metric,\n55\t        limit_per_window=record.limit_per_window,\n56\t    )\n57\t    return QuotaUpsertOutcome(\n58\t        customer_id=record.customer_id,\n59\t        metric=record.metric,\n60\t        limit_per_window=record.limit_per_window,\n61\t        http_status=201 if record.inserted else 200,\n62\t    )\n63\t\n64\t\n65\tdef to_response(outcome: QuotaUpsertOutcome) -> QuotaResponse:\n66\t    \"\"\"Map the service outcome to the minimal public response shape (ASVS 15.3.1).\"\"\"\n67\t    return QuotaResponse(\n68\t        customer_id=outcome.customer_id,\n69\t        metric=outcome.metric,\n70\t        limit_per_window=outcome.limit_per_window,\n71\t    )\n72\t"}]},"uuid":"412bea27-192d-4089-a1ba-44d5ee21c218","timestamp":"2026-07-09T01:04:22.665Z","sourceToolAssistantUUID":"89f767f3-b0da-4b27-ba9a-d381fa86eed1","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"412bea27-192d-4089-a1ba-44d5ee21c218","isSidechain":true,"agentId":"a9fbbbe5896b1a951","message":{"model":"claude-opus-4-8","id":"msg_011CcqaqfSroXJBc2VpTBwkS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0118CkssbXMCir9LuHdCBEZV","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\alembic\\versions\\0003_create_quotas_and_api_key_scope.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6116,"cache_read_input_tokens":42716,"cache_creation":{"ephemeral_5m_input_tokens":6116,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqaqeMdKCXieQY46EyPe","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"f44e88e3-d5b5-417d-b757-6a2aa7006045","timestamp":"2026-07-09T01:04:23.660Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"f44e88e3-d5b5-417d-b757-6a2aa7006045","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0118CkssbXMCir9LuHdCBEZV","type":"tool_result","content":"1\t\"\"\"create quotas table and api_keys.scope column\n2\t\n3\tOne expand-only revision covering two changes (plan: \"ONE expand-only\n4\tmigration\"):\n5\t\n6\t- `quotas`: a create-migration. `down` drops the table, so row survival\n7\t  across `down` is undefined by definition — reversibility kind is\n8\t  schema + constraints only. `up -> down -> up` must restore the schema and\n9\t  re-enforce every PK/FK/CHECK identically (AC16).\n10\t- `api_keys.scope`: an expand on a populated table (`DEFAULT 'ingest'`\n11\t  backfills existing rows for free, no data migration needed, safe on a live\n12\t  table). Pre-existing `api_keys` rows survive `up -> down -> up` unchanged\n13\t  except the `scope` column resets to its default on `down` — the defined\n14\t  expand/contract contract of an add-column, not data loss of a populated\n15\t  business column (AC16).\n16\t\n17\tRevision ID: 0003\n18\tRevises: 0002\n19\tCreate Date: 2026-07-08 00:00:00\n20\t\n21\t\"\"\"\n22\t\n23\tfrom typing import Sequence, Union\n24\t\n25\timport sqlalchemy as sa\n26\t\n27\tfrom alembic import op\n28\t\n29\trevision: str = \"0003\"\n30\tdown_revision: Union[str, None] = \"0002\"\n31\tbranch_labels: Union[str, Sequence[str], None] = None\n32\tdepends_on: Union[str, Sequence[str], None] = None\n33\t\n34\t\n35\tdef upgrade() -> None:\n36\t    \"\"\"Create `quotas` (per-tenant per-customer per-metric usage caps) and add\n37\t    `api_keys.scope` (authorization attribute: `'ingest'` default, `'admin'`\n38\t    elevated for `PUT /v1/quotas`).\"\"\"\n39\t    op.create_table(\n40\t        \"quotas\",\n41\t        sa.Column(\"api_key_id\", sa.BigInteger(), sa.ForeignKey(\"api_keys.id\"), nullable=False),\n42\t        sa.Column(\"customer_id\", sa.Text(), nullable=False),\n43\t        sa.Column(\"metric\", sa.Text(), nullable=False),\n44\t        sa.Column(\"limit_per_window\", sa.BigInteger(), nullable=False),\n45\t        sa.Column(\"created_at\", sa.DateTime(timezone=True), nullable=False, server_default=sa.text(\"now()\")),\n46\t        sa.Column(\"updated_at\", sa.DateTime(timezone=True), nullable=False, server_default=sa.text(\"now()\")),\n47\t        sa.PrimaryKeyConstraint(\"api_key_id\", \"customer_id\", \"metric\", name=\"pk_quotas\"),\n48\t        sa.CheckConstraint(\"limit_per_window >= 1\", name=\"ck_quotas_limit_per_window_positive\"),\n49\t    )\n50\t\n51\t    # Row-level security backstop (mirrors events/usage_rollup — plan\n52\t    # §\"Row-level security\"); the primary control is the explicit\n53\t    # `api_key_id = :api_key_id` filter every quotas query already applies.\n54\t    op.execute(\"ALTER TABLE quotas ENABLE ROW LEVEL SECURITY\")\n55\t    op.execute(\n56\t        \"\"\"\n57\t        CREATE POLICY quotas_tenant_isolation ON quotas\n58\t        USING (api_key_id = current_setting('app.current_api_key_id', true)::bigint)\n59\t        \"\"\"\n60\t    )\n61\t\n62\t    # `DEFAULT 'ingest'` backfills every existing row with no data migration\n63\t    # (Postgres 11+ does not rewrite the table for a non-volatile default),\n64\t    # so this is safe to run against a live, populated api_keys table.\n65\t    op.add_column(\n66\t        \"api_keys\",\n67\t        sa.Column(\"scope\", sa.Text(), nullable=False, server_default=\"ingest\"),\n68\t    )\n69\t    op.execute(\n70\t        \"ALTER TABLE api_keys ADD CONSTRAINT ck_api_keys_scope CHECK (scope IN ('ingest', 'admin'))\"\n71\t    )\n72\t\n73\t\n74\tdef downgrade() -> None:\n75\t    \"\"\"Drop `quotas` (schema-only rollback — row survival not asserted) and\n76\t    remove `api_keys.scope` (the pre-existing rows and their other columns\n77\t    survive; only the `scope` column itself disappears).\"\"\"\n78\t    op.drop_table(\"quotas\")\n79\t    op.drop_constraint(\"ck_api_keys_scope\", \"api_keys\", type_=\"check\")\n80\t    op.drop_column(\"api_keys\", \"scope\")\n81\t"}]},"uuid":"3e026b56-3ada-4c62-9853-8fd25783cc5a","timestamp":"2026-07-09T01:04:23.667Z","sourceToolAssistantUUID":"f44e88e3-d5b5-417d-b757-6a2aa7006045","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"3e026b56-3ada-4c62-9853-8fd25783cc5a","isSidechain":true,"agentId":"a9fbbbe5896b1a951","message":{"model":"claude-opus-4-8","id":"msg_011CcqaqfSroXJBc2VpTBwkS","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01DfG3xoEnfzN3VyqLuDRrvL","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\repositories\\events_repo.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6116,"cache_read_input_tokens":42716,"output_tokens":420,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":6116},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":420,"cache_read_input_tokens":42716,"cache_creation_input_tokens":6116,"cache_creation":{"ephemeral_5m_input_tokens":6116,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcqaqeMdKCXieQY46EyPe","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"4456b781-ecd2-4757-ab90-3625ebf82c26","timestamp":"2026-07-09T01:04:24.039Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"4456b781-ecd2-4757-ab90-3625ebf82c26","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DfG3xoEnfzN3VyqLuDRrvL","type":"tool_result","content":"1\t\"\"\"Repository for `events` + the `usage_rollup` increment — the idempotent\n2\tinsert-and-aggregate primitive at the core of `POST /v1/events`.\n3\t\n4\tEvery query here is scoped by the authenticated `api_key_id` (the row-level-\n5\tsecurity invariant from `code-standards`); the PostgreSQL RLS policy on both\n6\ttables is the backstop if this scoping were ever missing.\n7\t\"\"\"\n8\t\n9\tfrom dataclasses import dataclass\n10\tfrom datetime import datetime\n11\tfrom decimal import Decimal\n12\t\n13\tfrom sqlalchemy import text\n14\tfrom sqlalchemy.ext.asyncio import AsyncSession\n15\t\n16\t\n17\t@dataclass(frozen=True)\n18\tclass EventRecord:\n19\t    \"\"\"A row of `events`, the fields the service layer returns to the caller.\"\"\"\n20\t\n21\t    id: int\n22\t    api_key_id: int\n23\t    customer_id: str\n24\t    metric: str\n25\t    quantity: Decimal\n26\t    idempotency_key: str\n27\t    window_start: datetime\n28\t\n29\t\n30\tasync def insert_event_if_new(\n31\t    session: AsyncSession,\n32\t    *,\n33\t    api_key_id: int,\n34\t    customer_id: str,\n35\t    metric: str,\n36\t    quantity: Decimal,\n37\t    idempotency_key: str,\n38\t    window_start: datetime,\n39\t) -> EventRecord | None:\n40\t    \"\"\"Insert a new event row unless `(api_key_id, idempotency_key)` already\n41\t    exists; returns None when the row already existed (a duplicate replay).\n42\t\n43\t    The `UNIQUE (api_key_id, idempotency_key)` constraint + `ON CONFLICT DO\n44\t    NOTHING` is the sole source of truth for \"have I seen this key before?\" —\n45\t    evaluated atomically by PostgreSQL, so 50 concurrent identical requests\n46\t    produce exactly one winner (AC-CONCURRENCY) with no application-level lock.\n47\t    \"\"\"\n48\t    result = await session.execute(\n49\t        text(\n50\t            \"\"\"\n51\t            INSERT INTO events (\n52\t                api_key_id, customer_id, metric, quantity, idempotency_key, window_start\n53\t            )\n54\t            VALUES (\n55\t                :api_key_id, :customer_id, :metric, :quantity, :idempotency_key, :window_start\n56\t            )\n57\t            ON CONFLICT (api_key_id, idempotency_key) DO NOTHING\n58\t            RETURNING id, api_key_id, customer_id, metric, quantity, idempotency_key, window_start\n59\t            \"\"\"\n60\t        ),\n61\t        {\n62\t            \"api_key_id\": api_key_id,\n63\t            \"customer_id\": customer_id,\n64\t            \"metric\": metric,\n65\t            \"quantity\": quantity,\n66\t            \"idempotency_key\": idempotency_key,\n67\t            \"window_start\": window_start,\n68\t        },\n69\t    )\n70\t    row = result.mappings().first()\n71\t    if row is None:\n72\t        return None\n73\t    return EventRecord(**row)\n74\t\n75\t\n76\tasync def find_event_by_idempotency_key(\n77\t    session: AsyncSession, *, api_key_id: int, idempotency_key: str\n78\t) -> EventRecord | None:\n79\t    \"\"\"Fetch the original event for a duplicate `idempotency_key` replay.\n80\t\n81\t    Scoped by `api_key_id` first — an idempotency key is only ever unique\n82\t    within its owning tenant (plan's \"idempotency_key scope\" note), so this\n83\t    also doubles as the tenant-isolation guard for the replay read.\n84\t    \"\"\"\n85\t    result = await session.execute(\n86\t        text(\n87\t            \"\"\"\n88\t            SELECT id, api_key_id, customer_id, metric, quantity, idempotency_key, window_start\n89\t            FROM events\n90\t            WHERE api_key_id = :api_key_id AND idempotency_key = :idempotency_key\n91\t            \"\"\"\n92\t        ),\n93\t        {\"api_key_id\": api_key_id, \"idempotency_key\": idempotency_key},\n94\t    )\n95\t    row = result.mappings().first()\n96\t    if row is None:\n97\t        return None\n98\t    return EventRecord(**row)\n99\t\n100\t\n101\tasync def increment_usage_rollup(\n102\t    session: AsyncSession,\n103\t    *,\n104\t    api_key_id: int,\n105\t    customer_id: str,\n106\t    metric: str,\n107\t    window_start: datetime,\n108\t    quantity: Decimal,\n109\t) -> None:\n110\t    \"\"\"Upsert the hourly rollup counter for `(api_key_id, customer_id, metric,\n111\t    window_start)`, adding `quantity` and incrementing `event_count` by one.\n112\t\n113\t    Only called after `insert_event_if_new` returns a row (this request won\n114\t    the insert) — a duplicate replay must never reach here, which is exactly\n115\t    why duplicates never double-count (AC2).\n116\t    \"\"\"\n117\t    await session.execute(\n118\t        text(\n119\t            \"\"\"\n120\t            INSERT INTO usage_rollup (\n121\t                api_key_id, customer_id, metric, window_start, total_quantity, event_count, updated_at\n122\t            )\n123\t            VALUES (\n124\t                :api_key_id, :customer_id, :metric, :window_start, :quantity, 1, now()\n125\t            )\n126\t            ON CONFLICT (api_key_id, customer_id, metric, window_start) DO UPDATE SET\n127\t                total_quantity = usage_rollup.total_quantity + EXCLUDED.total_quantity,\n128\t                event_count = usage_rollup.event_count + 1,\n129\t                updated_at = now()\n130\t            \"\"\"\n131\t        ),\n132\t        {\n133\t            \"api_key_id\": api_key_id,\n134\t            \"customer_id\": customer_id,\n135\t            \"metric\": metric,\n136\t            \"window_start\": window_start,\n137\t            \"quantity\": quantity,\n138\t        },\n139\t    )\n140\t"}]},"uuid":"95635349-b78e-494c-b4ff-b17812610fb2","timestamp":"2026-07-09T01:04:24.050Z","sourceToolAssistantUUID":"4456b781-ecd2-4757-ab90-3625ebf82c26","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
