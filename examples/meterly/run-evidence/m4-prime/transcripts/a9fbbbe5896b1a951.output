{"parentUuid":"362929ea-5f0f-4510-941b-ede90f258e7a","isSidechain":true,"promptId":"bcf5258e-2708-4b49-a1f7-27fad0c3c471","agentId":"a9fbbbe5896b1a951","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018TrKxTNhh9pTcEAq5d7bkQ","type":"tool_result","content":"931\t+                )\n932\t+                raise QuotaExceededError(_seconds_until_next_hour_boundary(received_at, window_start))\n933\t+\n934\t             await increment_usage_rollup(\n935\t                 session,\n936\t                 api_key_id=principal.api_key_id,\n937\tdiff --git a/tests/integration/conftest.py b/tests/integration/conftest.py\n938\tindex 23e0806..61bbd41 100644\n939\t--- a/tests/integration/conftest.py\n940\t+++ b/tests/integration/conftest.py\n941\t@@ -28,8 +28,20 @@ def _asyncpg_url(sync_url: str) -> str:\n942\t \n943\t @pytest.fixture(scope=\"session\")\n944\t def postgres_url():\n945\t-    \"\"\"A session-scoped live Postgres, migrated to head once.\"\"\"\n946\t-    with PostgresContainer(\"postgres:16-alpine\") as postgres:\n947\t+    \"\"\"A session-scoped live Postgres, migrated to head once.\n948\t+\n949\t+    Raises `max_connections` above Postgres's default of 100: this container\n950\t+    is shared across the whole integration-test session, including three k6\n951\t+    perf fixtures that each launch a separate multi-worker uvicorn process\n952\t+    (its own DB connection pool) against it — the default ceiling is too low\n953\t+    for that cumulative demand when the full suite runs in one session and\n954\t+    was observed to exhaust mid-suite (`TooManyConnectionsError`) with only\n955\t+    the default. This is a test-container capacity knob, not a production\n956\t+    change (the real RDS instance sizes `max_connections` independently).\n957\t+    \"\"\"\n958\t+    with PostgresContainer(\"postgres:16-alpine\").with_command(\n959\t+        \"postgres -c max_connections=300\"\n960\t+    ) as postgres:\n961\t         url = _asyncpg_url(postgres.get_connection_url())\n962\t         env = dict(os.environ)\n963\t         env[\"DATABASE_URL\"] = url\n964\t@@ -104,7 +116,9 @@ async def truncate_tables(app_env, postgres_url, redis_url):\n965\t     async with engine.begin() as connection:\n966\t         from sqlalchemy import text\n967\t \n968\t-        await connection.execute(text(\"TRUNCATE TABLE events, usage_rollup, api_keys RESTART IDENTITY CASCADE\"))\n969\t+        await connection.execute(\n970\t+            text(\"TRUNCATE TABLE events, usage_rollup, quotas, api_keys RESTART IDENTITY CASCADE\")\n971\t+        )\n972\t     await engine.dispose()\n973\t \n974\t     redis_client = redis_async.from_url(redis_url, decode_responses=True)\n975\t@@ -134,7 +148,9 @@ async def make_api_key(truncate_tables):\n976\t \n977\t     created_ids = []\n978\t \n979\t-    async def _make(label: str = \"test-key\", rate_limit_per_sec: int = 100) -> tuple[str, int]:\n980\t+    async def _make(\n981\t+        label: str = \"test-key\", rate_limit_per_sec: int = 100, scope: str = \"ingest\"\n982\t+    ) -> tuple[str, int]:\n983\t         key_id, secret, presented_key = generate_split_token()\n984\t         secret_hash = hash_new_secret(secret)\n985\t         async with get_engine().begin() as connection:\n986\t@@ -144,6 +160,7 @@ async def make_api_key(truncate_tables):\n987\t                 secret_hash=secret_hash,\n988\t                 label=label,\n989\t                 rate_limit_per_sec=rate_limit_per_sec,\n990\t+                scope=scope,\n991\t             )\n992\t         created_ids.append(api_key_row_id)\n993\t         return presented_key, api_key_row_id\n994\tdiff --git a/tests/integration/test_perf_k6_load.py b/tests/integration/test_perf_k6_load.py\n995\tindex 642c18d..da45414 100644\n996\t--- a/tests/integration/test_perf_k6_load.py\n997\t+++ b/tests/integration/test_perf_k6_load.py\n998\t@@ -217,6 +217,137 @@ def test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n999\t     assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n1000\t \n1001\t \n1002\t+@pytest.fixture\n1003\t+async def k6_quota_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n1004\t+    \"\"\"Like `k6_load_env`, but the provisioned key is admin-scoped and each\n1005\t+    `cust_0..cust_49` bucket the k6 script drives (`load_events_quota.js`)\n1006\t+    carries a pre-seeded, deliberately high quota (AC20) -- so the ingest\n1007\t+    path exercises the quota-check read-and-decide on every request without\n1008\t+    ever actually rejecting one, isolating the added latency of the `FOR\n1009\t+    UPDATE` lookup itself from the (much larger, transaction-aborting) cost\n1010\t+    of a rejection.\n1011\t+    \"\"\"\n1012\t+    if not _docker_available():\n1013\t+        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n1014\t+\n1015\t+    pull_result = subprocess.run(\n1016\t+        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n1017\t+    )\n1018\t+    if pull_result.returncode != 0:\n1019\t+        pull_result = subprocess.run(\n1020\t+            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n1021\t+        )\n1022\t+        if pull_result.returncode != 0:\n1023\t+            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n1024\t+\n1025\t+    port = _free_port()\n1026\t+    env = dict(os.environ)\n1027\t+    env[\"DATABASE_URL\"] = postgres_url\n1028\t+    env[\"METERLY_REDIS_URL\"] = redis_url\n1029\t+    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n1030\t+    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n1031\t+\n1032\t+    presented_key, api_key_id = await make_api_key(\n1033\t+        label=\"k6-quota-perf-key\", rate_limit_per_sec=1_000_000, scope=\"admin\"\n1034\t+    )\n1035\t+\n1036\t+    from sqlalchemy import text\n1037\t+    from sqlalchemy.ext.asyncio import create_async_engine\n1038\t+\n1039\t+    # A high-but-finite cap per bucket (well above anything a 15s run at the\n1040\t+    # target rate could accumulate) -- active enough to exercise the FOR\n1041\t+    # UPDATE read-and-decide on every request, never high enough to matter\n1042\t+    # for whether a single run's requests are accepted.\n1043\t+    quota_engine = create_async_engine(postgres_url)\n1044\t+    async with quota_engine.begin() as connection:\n1045\t+        for customer_index in range(50):\n1046\t+            await connection.execute(\n1047\t+                text(\n1048\t+                    \"\"\"\n1049\t+                    INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n1050\t+                    VALUES (:api_key_id, :customer_id, 'api_calls', 100000000, now())\n1051\t+                    ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n1052\t+                        limit_per_window = EXCLUDED.limit_per_window\n1053\t+                    \"\"\"\n1054\t+                ),\n1055\t+                {\"api_key_id\": api_key_id, \"customer_id\": f\"cust_{customer_index}\"},\n1056\t+            )\n1057\t+    await quota_engine.dispose()\n1058\t+\n1059\t+    # A dedicated (lower) default worker count, not the shared\n1060\t+    # METERLY_PERF_UVICORN_WORKERS knob: this is the third heavy multi-worker\n1061\t+    # uvicorn+DB-pool fixture in this module, and all three share ONE\n1062\t+    # session-scoped Postgres container with a fixed max_connections budget\n1063\t+    # -- keeping this fixture's footprint smaller avoids exhausting that\n1064\t+    # budget when the whole suite (all three perf fixtures) runs in one\n1065\t+    # pytest session, without changing the existing two tests' tuning.\n1066\t+    workers = int(os.environ.get(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", \"2\"))\n1067\t+    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_quota_perf\"\n1068\t+    scratch_dir.mkdir(parents=True, exist_ok=True)\n1069\t+\n1070\t+    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n1071\t+    process = subprocess.Popen(\n1072\t+        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n1073\t+        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n1074\t+    )\n1075\t+\n1076\t+    try:\n1077\t+        deadline = time.monotonic() + 30\n1078\t+        async with httpx.AsyncClient() as probe:\n1079\t+            ready = False\n1080\t+            while time.monotonic() < deadline:\n1081\t+                try:\n1082\t+                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n1083\t+                    if response.status_code == 200:\n1084\t+                        ready = True\n1085\t+                        break\n1086\t+                except httpx.TransportError:\n1087\t+                    pass\n1088\t+                await asyncio.sleep(0.3)\n1089\t+            if not ready:\n1090\t+                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n1091\t+\n1092\t+        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n1093\t+    finally:\n1094\t+        process.terminate()\n1095\t+        try:\n1096\t+            process.wait(timeout=10)\n1097\t+        except subprocess.TimeoutExpired:\n1098\t+            process.kill()\n1099\t+        uvicorn_log.close()\n1100\t+        # Give Postgres a moment to reclaim the just-closed workers' backend\n1101\t+        # connection slots before the next test's fixtures open new ones\n1102\t+        # against the same shared container (mitigates TooManyConnectionsError\n1103\t+        # when this module's perf tests run back-to-back in one session).\n1104\t+        await asyncio.sleep(1.0)\n1105\t+\n1106\t+\n1107\t+def test_events_ingest_with_quotas_p95_under_50ms(k6_quota_load_env):\n1108\t+    \"\"\"AC20: drive POST /v1/events at the same sustained 500 req/s scenario\n1109\t+    with quotas active (high limits, no rejection) -- records the true\n1110\t+    nearest-rank p95 so the quota-check path's added latency is measured\n1111\t+    against the existing ingest budget, an honest measurement rather than a\n1112\t+    fabricated pass/fail claim (mirrors test_events_ingest_sustained_500rps_k6_load).\"\"\"\n1113\t+    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n1114\t+    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n1115\t+    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n1116\t+\n1117\t+    result = _run_k6(\n1118\t+        \"load_events_quota.js\", k6_quota_load_env[\"port\"], k6_quota_load_env[\"api_key\"], k6_quota_load_env[\"scratch_dir\"],\n1119\t+        target_rps, duration, warmup, \"k6_events_quota_raw.jsonl\",\n1120\t+    )\n1121\t+    (k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n1122\t+\n1123\t+    if result.returncode != 0:\n1124\t+        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_quota_stdout.log\")\n1125\t+\n1126\t+    metrics = _nearest_rank_from_raw_jsonl(k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_raw.jsonl\", scenario=\"ingest\")\n1127\t+    (k6_quota_load_env[\"scratch_dir\"] / \"events_quota_metrics.json\").write_text(json.dumps(metrics, indent=2))\n1128\t+    print(\"POST /v1/events (quotas active) k6 load metrics:\", json.dumps(metrics, indent=2))\n1129\t+\n1130\t+    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n1131\t+\n1132\t+\n1133\t def test_usage_read_sustained_100rps_k6_load(k6_load_env):\n1134\t     \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n1135\t     against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n1136\tdiff --git a/tests/integration/test_seed_api_key_script.py b/tests/integration/test_seed_api_key_script.py\n1137\tindex 9530407..f623bc3 100644\n1138\t--- a/tests/integration/test_seed_api_key_script.py\n1139\t+++ b/tests/integration/test_seed_api_key_script.py\n1140\t@@ -46,3 +46,45 @@ async def test_seed_api_key_script_persists_only_the_hash(postgres_url, truncate\n1141\t     assert row[\"secret_hash\"].startswith(\"$argon2id$\")\n1142\t     assert row[\"secret_hash\"] not in printed_key\n1143\t     assert row[\"rate_limit_per_sec\"] == 50\n1144\t+\n1145\t+\n1146\t+async def test_admin_flag_sets_scope(postgres_url, truncate_tables):\n1147\t+    \"\"\"AC17: `--admin` provisions a key with `scope='admin'`; omitting the\n1148\t+    flag defaults to `scope='ingest'` (no change to the printed key format).\"\"\"\n1149\t+    import os\n1150\t+\n1151\t+    env = dict(os.environ)\n1152\t+    env[\"DATABASE_URL\"] = postgres_url\n1153\t+\n1154\t+    admin_result = subprocess.run(\n1155\t+        [sys.executable, \"scripts/seed_api_key.py\", \"--label\", \"admin-key\", \"--admin\"],\n1156\t+        cwd=str(_REPO_ROOT),\n1157\t+        env=env,\n1158\t+        capture_output=True,\n1159\t+        text=True,\n1160\t+    )\n1161\t+    assert admin_result.returncode == 0, f\"seed script failed:\\n{admin_result.stdout}\\n{admin_result.stderr}\"\n1162\t+    admin_printed_key = admin_result.stdout.strip().splitlines()[-1]\n1163\t+    assert admin_printed_key.startswith(\"mtr_live_\")\n1164\t+\n1165\t+    ingest_result = subprocess.run(\n1166\t+        [sys.executable, \"scripts/seed_api_key.py\", \"--label\", \"ingest-key\"],\n1167\t+        cwd=str(_REPO_ROOT),\n1168\t+        env=env,\n1169\t+        capture_output=True,\n1170\t+        text=True,\n1171\t+    )\n1172\t+    assert ingest_result.returncode == 0, f\"seed script failed:\\n{ingest_result.stdout}\\n{ingest_result.stderr}\"\n1173\t+\n1174\t+    engine = create_async_engine(postgres_url)\n1175\t+    async with engine.connect() as connection:\n1176\t+        admin_row = (\n1177\t+            await connection.execute(text(\"SELECT scope FROM api_keys WHERE label = 'admin-key'\"))\n1178\t+        ).mappings().first()\n1179\t+        ingest_row = (\n1180\t+            await connection.execute(text(\"SELECT scope FROM api_keys WHERE label = 'ingest-key'\"))\n1181\t+        ).mappings().first()\n1182\t+    await engine.dispose()\n1183\t+\n1184\t+    assert admin_row[\"scope\"] == \"admin\"\n1185\t+    assert ingest_row[\"scope\"] == \"ingest\"\n1186\t"}]},"uuid":"2c2287bb-f5c9-4e02-804c-aaf5fcf1a1c8","timestamp":"2026-07-09T01:04:18.950Z","sourceToolAssistantUUID":"362929ea-5f0f-4510-941b-ede90f258e7a","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
