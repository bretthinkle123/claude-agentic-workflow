{"parentUuid":"68833dae-79b7-4eea-a770-8fb7fb9a0a42","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"aa3e97ca51fd7e87e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XsBAbVYZns88cyLkkG6xcA","type":"tool_result","content":"1\t\"\"\"Unit tests for `src/services/usage_export_service.py` — the pre-flight\n2\trow-cap check and the streaming generator, with the DB layer mocked out\n3\t(AC8, AC9, AC12, AC17, AC22).\n4\t\"\"\"\n5\t\n6\tfrom contextlib import asynccontextmanager\n7\tfrom datetime import datetime, timezone\n8\tfrom decimal import Decimal\n9\t\n10\timport pytest\n11\tfrom fastapi import HTTPException\n12\t\n13\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n14\tfrom src.auth.api_key import AuthenticatedPrincipal\n15\tfrom src.repositories.usage_repo import UsageRollupExportRecord\n16\tfrom src.services import usage_export_service\n17\t\n18\t\n19\tdef _principal(api_key_id: int = 42) -> AuthenticatedPrincipal:\n20\t    return AuthenticatedPrincipal(api_key_id=api_key_id, rate_limit_per_sec=100)\n21\t\n22\t\n23\tdef _no_filter_params() -> UsageExportQueryParams:\n24\t    return UsageExportQueryParams()\n25\t\n26\t\n27\tdef _fake_scoped_transaction_factory():\n28\t    \"\"\"A fake `scoped_transaction` async context manager yielding a sentinel\n29\t    'session' — the mocked repo functions never actually use it.\"\"\"\n30\t\n31\t    @asynccontextmanager\n32\t    async def _fake(api_key_id: int):\n33\t        yield \"fake-session\"\n34\t\n35\t    return _fake\n36\t\n37\t\n38\tasync def test_prepare_export_passes_when_under_cap(monkeypatch):\n39\t    \"\"\"AC8: a count under the cap raises nothing.\"\"\"\n40\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n41\t\n42\t    async def _fake_count(session, **kwargs):\n43\t        return 5\n44\t\n45\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _fake_count)\n46\t\n47\t    await usage_export_service.prepare_export(_principal(), _no_filter_params())\n48\t\n49\t\n50\tasync def test_prepare_export_passes_when_exactly_at_cap_boundary(monkeypatch):\n51\t    \"\"\"AC8 boundary: a count exactly equal to MAX_EXPORT_ROWS (100,000) is\n52\t    NOT rejected — the check is strictly `>`, not `>=`, so the cap itself is\n53\t    a valid, exportable size.\"\"\"\n54\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n55\t\n56\t    async def _fake_count(session, **kwargs):\n57\t        return usage_export_service.MAX_EXPORT_ROWS\n58\t\n59\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _fake_count)\n60\t\n61\t    await usage_export_service.prepare_export(_principal(), _no_filter_params())\n62\t\n63\t\n64\tasync def test_prepare_export_rejects_over_cap_with_422(monkeypatch, capsys):\n65\t    \"\"\"AC8: a count over MAX_EXPORT_ROWS raises a 422 with no stream started,\n66\t    and logs the rejection at warn (AC17).\"\"\"\n67\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n68\t\n69\t    async def _fake_count(session, **kwargs):\n70\t        return usage_export_service.MAX_EXPORT_ROWS + 1\n71\t\n72\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _fake_count)\n73\t\n74\t    with pytest.raises(HTTPException) as excinfo:\n75\t        await usage_export_service.prepare_export(_principal(), _no_filter_params())\n76\t\n77\t    assert excinfo.value.status_code == 422\n78\t    captured = capsys.readouterr()\n79\t    assert \"usage.export.rejected\" in captured.out\n80\t    assert \"row_cap_exceeded\" in captured.out\n81\t\n82\t\n83\tasync def test_prepare_export_propagates_non_cap_error_uncaught(monkeypatch):\n84\t    \"\"\"AC22: an unexpected error during the pre-flight COUNT (e.g. a DB\n85\t    connection drop) is NOT caught or swallowed here — it propagates to the\n86\t    error-envelope boundary, fail-closed, so no stream is ever started.\"\"\"\n87\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n88\t\n89\t    async def _raising_count(session, **kwargs):\n90\t        raise RuntimeError(\"connection reset by peer\")\n91\t\n92\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n93\t\n94\t    with pytest.raises(RuntimeError, match=\"connection reset by peer\"):\n95\t        await usage_export_service.prepare_export(_principal(), _no_filter_params())\n96\t\n97\t\n98\tasync def test_stream_export_csv_is_header_only_on_empty_result(monkeypatch):\n99\t    \"\"\"AC12: an empty result still yields the header row first — a\n100\t    header-only CSV, never an empty body / 404.\"\"\"\n101\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n102\t\n103\t    async def _empty_stream(session, **kwargs):\n104\t        return\n105\t        yield  # pragma: no cover - makes this an async generator function\n106\t\n107\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _empty_stream)\n108\t\n109\t    chunks = [chunk async for chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params())]\n110\t    body = b\"\".join(chunks).decode(\"utf-8\")\n111\t\n112\t    assert body == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n113\t\n114\t\n115\tasync def test_stream_export_csv_rows_are_escaped_and_formatted(monkeypatch):\n116\t    \"\"\"AC1/AC10/AC14: streamed rows are formula-escaped on text cells and\n117\t    formatted per the value-format contract.\"\"\"\n118\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n119\t\n120\t    record = UsageRollupExportRecord(\n121\t        customer_id=\"-1\",\n122\t        metric=\"api_calls\",\n123\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n124\t        total_quantity=Decimal(\"12.500000\"),\n125\t    )\n126\t\n127\t    async def _one_row_stream(session, **kwargs):\n128\t        yield record\n129\t\n130\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _one_row_stream)\n131\t\n132\t    chunks = [chunk async for chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params())]\n133\t    body = b\"\".join(chunks).decode(\"utf-8\")\n134\t    lines = body.split(\"\\r\\n\")\n135\t\n136\t    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n137\t    assert lines[1] == \"'-1,api_calls,2026-07-08T14:00:00+00:00,12.500000\"\n138\t\n139\t\n140\tasync def test_stream_export_csv_logs_completion_audit_event(monkeypatch, capsys):\n141\t    \"\"\"AC17: exactly one `usage.export` info event at completion, with\n142\t    rowCount/capped/completed and no raw customer_id.\"\"\"\n143\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n144\t\n145\t    record = UsageRollupExportRecord(\n146\t        customer_id=\"cust_super_secret\",\n147\t        metric=\"api_calls\",\n148\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n149\t        total_quantity=Decimal(\"1.000000\"),\n150\t    )\n151\t\n152\t    async def _one_row_stream(session, **kwargs):\n153\t        yield record\n154\t\n155\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _one_row_stream)\n156\t\n157\t    async for _chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params()):\n158\t        pass\n159\t\n160\t    captured = capsys.readouterr()\n161\t    assert \"usage.export\" in captured.out\n162\t    assert '\"rowCount\": 1' in captured.out\n163\t    assert '\"capped\": false' in captured.out\n164\t    assert '\"completed\": true' in captured.out\n165\t    assert \"cust_super_secret\" not in captured.out\n166\t\n167\t\n168\tasync def test_stream_export_csv_completion_is_false_on_mid_stream_failure(monkeypatch, capsys):\n169\t    \"\"\"A mid-stream DB error still triggers exactly one completion log (via\n170\t    `finally`), but `completed=False` — records what was sent even though the\n171\t    body is truncated (plan's accepted risk R3, distinct from AC22's\n172\t    pre-flight case).\"\"\"\n173\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n174\t\n175\t    record = UsageRollupExportRecord(\n176\t        customer_id=\"cust_1\",\n177\t        metric=\"api_calls\",\n178\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n179\t        total_quantity=Decimal(\"1.000000\"),\n180\t    )\n181\t\n182\t    async def _failing_stream(session, **kwargs):\n183\t        yield record\n184\t        raise RuntimeError(\"connection dropped mid-stream\")\n185\t\n186\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _failing_stream)\n187\t\n188\t    with pytest.raises(RuntimeError, match=\"connection dropped mid-stream\"):\n189\t        async for _chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params()):\n190\t            pass\n191\t\n192\t    captured = capsys.readouterr()\n193\t    assert '\"completed\": false' in captured.out\n194\t    assert '\"rowCount\": 1' in captured.out\n195\t"}]},"uuid":"896902e8-81c8-4a3b-9177-db9ef87d1d31","timestamp":"2026-07-09T19:42:36.076Z","sourceToolAssistantUUID":"68833dae-79b7-4eea-a770-8fb7fb9a0a42","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
