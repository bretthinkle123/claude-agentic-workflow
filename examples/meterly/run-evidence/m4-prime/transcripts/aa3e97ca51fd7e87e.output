{"parentUuid":"213f6daa-c58c-4cf1-932e-98603d49601a","isSidechain":true,"agentId":"aa3e97ca51fd7e87e","message":{"model":"claude-opus-4-8","id":"msg_011Ccs2zrLEpSy71yzgYVwfn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01JBuEyKBUwvAYKuYNrzcmEn","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\csv_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4095,"cache_read_input_tokens":18640,"cache_creation":{"ephemeral_5m_input_tokens":4095,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs2zqJESDHdupJ6xeZdc","attributionAgent":"debugging","type":"assistant","uuid":"d0830192-2bcb-4334-804c-1ee8ef5b9da5","timestamp":"2026-07-09T19:28:02.851Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"d0830192-2bcb-4334-804c-1ee8ef5b9da5","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"aa3e97ca51fd7e87e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JBuEyKBUwvAYKuYNrzcmEn","type":"tool_result","content":"1\t\"\"\"CSV encoding facade for `GET /v1/usage/export`.\n2\t\n3\tThe single boundary that owns the RFC 4180 column contract and the OWASP\n4\tCSV/formula-injection escape (`code-standards` facade rule) — centralizing it\n5\there, rather than inlining it in the streaming generator, keeps the control\n6\tgreppable, independently unit-testable, and the one place the security agent\n7\tverifies it lives.\n8\t\"\"\"\n9\t\n10\tfrom decimal import Decimal\n11\tfrom datetime import datetime\n12\t\n13\tEXPORT_HEADER = [\"customer_id\", \"metric\", \"window_start\", \"total_quantity\"]\n14\t\n15\t# A spreadsheet application (Excel/Sheets) treats a cell beginning with any of\n16\t# these characters as the start of a formula/command — the OWASP CSV/formula-\n17\t# injection trigger set.\n18\t_FORMULA_TRIGGER_CHARS = (\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\")\n19\t\n20\t# Control characters other than tab/CR/LF, which RFC 4180 quoting (handled by\n21\t# `csv.writer`'s QUOTE_MINIMAL at the generator that calls this facade) already\n22\t# renders safely — everything else is a raw control byte with no legitimate\n23\t# reason to appear in a customer/metric identifier and is stripped outright.\n24\t_SAFE_WHITESPACE = (\"\\t\", \"\\r\", \"\\n\")\n25\t\n26\t\n27\tdef escape_csv_text_cell(value: str) -> str:\n28\t    \"\"\"Neutralize a text cell against spreadsheet formula-injection.\n29\t\n30\t    Applied at the CSV encoding *sink*, independent of upstream ingest\n31\t    validation: today's ingest allowlist (`^[A-Za-z0-9_.:-]{1,128}$`) permits\n32\t    a leading `-`, which is a live formula trigger in Excel/Sheets, so this is\n33\t    not hypothetical defense-in-depth — it is a real, reachable case. Strips\n34\t    embedded raw control characters, then prefixes a single quote `'` when the\n35\t    (post-strip) first character is a formula trigger; a spreadsheet then\n36\t    renders the cell as literal text rather than evaluating it. RFC 4180\n37\t    quoting itself (comma/quote/CR/LF) is the caller's `csv.writer`'s job, not\n38\t    this function's.\n39\t    \"\"\"\n40\t    if not value:\n41\t        return value\n42\t    cleaned = \"\".join(char for char in value if _is_safe_character(char))\n43\t    if cleaned and cleaned[0] in _FORMULA_TRIGGER_CHARS:\n44\t        return \"'\" + cleaned\n45\t    return cleaned\n46\t\n47\t\n48\tdef _is_safe_character(char: str) -> bool:\n49\t    \"\"\"True unless `char` is a raw control byte with no legitimate reason to\n50\t    appear in a customer/metric identifier (tab/CR/LF pass through — RFC 4180\n51\t    quoting already renders them safely).\"\"\"\n52\t    if char in _SAFE_WHITESPACE:\n53\t        return True\n54\t    codepoint = ord(char)\n55\t    return not (codepoint < 0x20 or codepoint == 0x7F)\n56\t\n57\t\n58\tdef format_window_start(window_start: datetime) -> str:\n59\t    \"\"\"Render `window_start` identically to the JSON `GET /v1/usage`\n60\t    response's string form: UTC ISO-8601 with an explicit offset.\"\"\"\n61\t    return window_start.isoformat()\n62\t\n63\t\n64\tdef format_total_quantity(total_quantity: Decimal) -> str:\n65\t    \"\"\"Render `total_quantity` as a plain decimal string.\n66\t\n67\t    `Decimal.__str__` never emits scientific notation and preserves\n68\t    `Numeric(38,6)` scale-6 trailing zeros, which keeps the export\n69\t    deterministic and diff-clean (the brief's \"plain decimal\" requirement).\n70\t    Numeric cells are server-generated and never attacker-controlled, so they\n71\t    are deliberately not passed through `escape_csv_text_cell` — doing so\n72\t    would corrupt the value.\n73\t    \"\"\"\n74\t    return str(total_quantity)\n75\t"}]},"uuid":"2537f770-b09a-4316-b34e-bdf621bfe16c","timestamp":"2026-07-09T19:28:02.869Z","sourceToolAssistantUUID":"d0830192-2bcb-4334-804c-1ee8ef5b9da5","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"2537f770-b09a-4316-b34e-bdf621bfe16c","isSidechain":true,"agentId":"aa3e97ca51fd7e87e","message":{"model":"claude-opus-4-8","id":"msg_011Ccs2zrLEpSy71yzgYVwfn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Xe5PmjjHc1JZDn9NBvSLA5","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\services\\usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4095,"cache_read_input_tokens":18640,"cache_creation":{"ephemeral_5m_input_tokens":4095,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs2zqJESDHdupJ6xeZdc","attributionAgent":"debugging","type":"assistant","uuid":"6de16a16-f81e-4ab3-8607-fec90e06cab5","timestamp":"2026-07-09T19:28:03.857Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"6de16a16-f81e-4ab3-8607-fec90e06cab5","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"aa3e97ca51fd7e87e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Xe5PmjjHc1JZDn9NBvSLA5","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t\n35\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n36\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n37\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n38\t\n39\t    This must run and fully resolve *before* the route returns a\n40\t    `StreamingResponse` — once that response object exists the status line\n41\t    is already 200 and bytes may already be on the wire, so a 422 can no\n42\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n43\t    (a DB connection drop, a query error) is deliberately left to propagate\n44\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n45\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n46\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n47\t    \"\"\"\n48\t    async with scoped_transaction(principal.api_key_id) as session:\n49\t        row_count = await count_usage_rollups(\n50\t            session,\n51\t            api_key_id=principal.api_key_id,\n52\t            customer_id=params.customer_id,\n53\t            metric=params.metric,\n54\t            window_from=params.from_,\n55\t            window_to=params.to,\n56\t        )\n57\t\n58\t    if row_count > MAX_EXPORT_ROWS:\n59\t        logger.warning(\n60\t            \"usage.export.rejected\",\n61\t            userId=principal.api_key_id,\n62\t            action=\"deny\",\n63\t            reason=\"row_cap_exceeded\",\n64\t        )\n65\t        raise HTTPException(\n66\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n67\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n68\t        )\n69\t\n70\t\n71\tdef _drain(buffer: io.StringIO) -> bytes:\n72\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n73\t    place — this is what keeps the generator at constant memory: it never\n74\t    holds more than one row's encoded text at a time.\"\"\"\n75\t    data = buffer.getvalue().encode(\"utf-8\")\n76\t    buffer.seek(0)\n77\t    buffer.truncate(0)\n78\t    return data\n79\t\n80\t\n81\tasync def stream_export_csv(\n82\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n83\t) -> AsyncIterator[bytes]:\n84\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n85\t    CSV-encoded row per streamed `usage_rollup` record.\n86\t\n87\t    Yielding the header before touching the database means an empty result\n88\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n89\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n90\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n91\t    setting and the server-side cursor both stay valid for the whole stream.\n92\t    \"\"\"\n93\t    row_count = 0\n94\t    capped = False\n95\t    completed = False\n96\t\n97\t    buffer = io.StringIO()\n98\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n99\t\n100\t    try:\n101\t        writer.writerow(EXPORT_HEADER)\n102\t        yield _drain(buffer)\n103\t\n104\t        async with scoped_transaction(principal.api_key_id) as session:\n105\t            async for record in stream_usage_rollups(\n106\t                session,\n107\t                api_key_id=principal.api_key_id,\n108\t                customer_id=params.customer_id,\n109\t                metric=params.metric,\n110\t                window_from=params.from_,\n111\t                window_to=params.to,\n112\t                limit=MAX_EXPORT_ROWS,\n113\t            ):\n114\t                writer.writerow(\n115\t                    [\n116\t                        escape_csv_text_cell(record.customer_id),\n117\t                        escape_csv_text_cell(record.metric),\n118\t                        format_window_start(record.window_start),\n119\t                        format_total_quantity(record.total_quantity),\n120\t                    ]\n121\t                )\n122\t                yield _drain(buffer)\n123\t                row_count += 1\n124\t\n125\t        capped = row_count >= MAX_EXPORT_ROWS\n126\t        completed = True\n127\t    finally:\n128\t        # In `finally` so a client disconnect or a mid-stream DB error still\n129\t        # records what was actually sent (`completed=False` in that case) —\n130\t        # exactly one usage.export event per request either way (AC17).\n131\t        logger.info(\n132\t            \"usage.export\",\n133\t            userId=principal.api_key_id,\n134\t            action=\"read\",\n135\t            resource=\"usage_rollup\",\n136\t            rowCount=row_count,\n137\t            capped=capped,\n138\t            completed=completed,\n139\t            filtered_by_customer=params.customer_id is not None,\n140\t            filtered_by_metric=params.metric is not None,\n141\t            bounded_from=params.from_ is not None,\n142\t            bounded_to=params.to is not None,\n143\t        )\n144\t"}]},"uuid":"afca0f56-60b5-4099-b7c0-3eac0ca306da","timestamp":"2026-07-09T19:28:03.876Z","sourceToolAssistantUUID":"6de16a16-f81e-4ab3-8607-fec90e06cab5","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"afca0f56-60b5-4099-b7c0-3eac0ca306da","isSidechain":true,"agentId":"aa3e97ca51fd7e87e","message":{"model":"claude-opus-4-8","id":"msg_011Ccs2zrLEpSy71yzgYVwfn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ELP1QiwW4zTFNWb4VePE6k","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\routes\\usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4095,"cache_read_input_tokens":18640,"output_tokens":289,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":4095},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":289,"cache_read_input_tokens":18640,"cache_creation_input_tokens":4095,"cache_creation":{"ephemeral_5m_input_tokens":4095,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccs2zqJESDHdupJ6xeZdc","attributionAgent":"debugging","type":"assistant","uuid":"c4d90226-8b55-43d5-b24e-098ccf61048f","timestamp":"2026-07-09T19:28:04.259Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"c4d90226-8b55-43d5-b24e-098ccf61048f","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"aa3e97ca51fd7e87e","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ELP1QiwW4zTFNWb4VePE6k","type":"tool_result","content":"1\t\"\"\"`GET /v1/usage/export` — streams the authenticated caller's own\n2\t`usage_rollup` rows as an RFC 4180 CSV.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> schema validation -> a two-phase pre-flight-cap +\n7\tstream service call, mirroring `src/api/routes/usage.py`'s composition. Kept\n8\tin its own module (not added to `usage.py`) so `GET /v1/usage`'s code path is\n9\tliterally untouched by this change — the brief's no-behavior-change\n10\tconstraint is then trivially auditable in the diff.\n11\t\"\"\"\n12\t\n13\tfrom datetime import datetime, timezone\n14\tfrom typing import Annotated\n15\t\n16\tfrom fastapi import APIRouter, Depends, Query, Request\n17\tfrom fastapi.responses import StreamingResponse\n18\t\n19\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n20\tfrom src.auth import require_api_key\n21\tfrom src.auth.api_key import AuthenticatedPrincipal\n22\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n23\tfrom src.services.usage_export_service import prepare_export, stream_export_csv\n24\t\n25\trouter = APIRouter(tags=[\"usage\"])\n26\t\n27\t# Explicit OpenAPI response metadata: a StreamingResponse has no `response_model`\n28\t# for FastAPI to introspect, so the served schema would otherwise omit the real\n29\t# response shape — this is what a DAST scanner (and AC19) reads.\n30\t_EXPORT_RESPONSES: dict = {\n31\t    200: {\n32\t        \"description\": \"The caller's usage_rollup rows as RFC 4180 CSV (header row always first).\",\n33\t        \"content\": {\"text/csv\": {\"schema\": {\"type\": \"string\", \"format\": \"binary\"}}},\n34\t    },\n35\t    422: {\n36\t        \"description\": \"Validation failure, or the filtered result exceeds the 100,000-row export cap.\",\n37\t        \"content\": {\n38\t            \"application/json\": {\n39\t                \"example\": {\n40\t                    \"error\": {\n41\t                        \"code\": \"validation_failed\",\n42\t                        \"message\": \"result exceeds 100000 rows; narrow with customer_id, metric, from, and/or to\",\n43\t                        \"requestId\": \"…\",\n44\t                    }\n45\t                }\n46\t            }\n47\t        },\n48\t    },\n49\t}\n50\t\n51\t\n52\tasync def _require_authenticated_and_throttled(\n53\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n54\t) -> AuthenticatedPrincipal:\n55\t    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (kept as\n56\t    a sibling, not a shared import, per the existing per-route convention —\n57\t    each route's dependency chain stays independently readable).\"\"\"\n58\t    await enforce_tier2_rate_limit(request, principal)\n59\t    return principal\n60\t\n61\t\n62\tdef _export_filename(now: datetime) -> str:\n63\t    \"\"\"Build the `Content-Disposition` filename: a UTC timestamp only — no\n64\t    tenant identifier, so the filename itself never leaks `api_key_id` or any\n65\t    caller identity (ASVS 14.3.2).\"\"\"\n66\t    return f\"usage-export-{now:%Y%m%dT%H%M%SZ}.csv\"\n67\t\n68\t\n69\t@router.get(\"/v1/usage/export\", responses=_EXPORT_RESPONSES)\n70\tasync def get_usage_export(\n71\t    params: Annotated[UsageExportQueryParams, Query()],\n72\t    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n73\t) -> StreamingResponse:\n74\t    \"\"\"Stream the caller's own `usage_rollup` rows as CSV, optionally\n75\t    narrowed by `customer_id`/`metric`/`from`/`to`.\n76\t\n77\t    Two-phase: `prepare_export` runs the pre-flight row-cap check (a clean\n78\t    422 over 100,000 rows, or a fail-closed generic 500 on an unexpected\n79\t    error — AC22) before any response byte; only then is the\n80\t    `StreamingResponse` constructed. Starlette pulls `stream_export_csv`\n81\t    after this handler returns, so the generator opens its own DB\n82\t    transaction rather than reusing one already closed by the time it runs.\n83\t    \"\"\"\n84\t    await prepare_export(principal, params)\n85\t\n86\t    filename = _export_filename(datetime.now(timezone.utc))\n87\t    return StreamingResponse(\n88\t        stream_export_csv(principal, params),\n89\t        media_type=\"text/csv; charset=utf-8\",\n90\t        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},\n91\t    )\n92\t"}]},"uuid":"b54c1a95-b7d1-4676-b187-019efcc8cc96","timestamp":"2026-07-09T19:28:04.292Z","sourceToolAssistantUUID":"c4d90226-8b55-43d5-b24e-098ccf61048f","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
