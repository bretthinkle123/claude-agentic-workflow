tion=\"store_true\",\n+        help=\"Provision this key with scope='admin' (required to call PUT /v1/quotas); default is scope='ingest'\",\n+    )\n     args = parser.parse_args()\n-    asyncio.run(_seed(args.label, args.rate_limit_per_sec))\n+    asyncio.run(_seed(args.label, args.rate_limit_per_sec, admin=args.admin))\n \n \n if __name__ == \"__main__\":\n=== rate_limit Tier-2 key ===\n1:\"\"\"Redis-backed token-bucket rate limiting — Tier 1 (pre-auth, IP+route) and\n2:Tier 2 (post-auth, per-`api_key_id`).\n6:(`api-edge-conventions`). The bucket check-and-decrement is a single atomic\n7:Lua script so concurrent requests against the same bucket can't race past the\n19:# Atomic token-bucket refill + consume: KEYS[1] = bucket key.\n23:local key = KEYS[1]\n29:local bucket = redis.call('HMGET', key, 'tokens', 'updated_at')\n30:local tokens = tonumber(bucket[1])\n31:local updated_at = tonumber(bucket[2])\n51:redis.call('HMSET', key, 'tokens', tokens, 'updated_at', now_ms)\n52:redis.call('PEXPIRE', key, 60000)\n68:    \"\"\"A shared, atomic Redis token-bucket limiter used by both throttle tiers.\n70:    Each tier instantiates this with its own key prefix and capacity/refill\n81:        self, bucket_identity: str, *, capacity: int, refill_rate_per_second: float, cost: float = 1.0\n83:        \"\"\"Consume `cost` tokens from `bucket_identity`'s bucket; returns the decision.\"\"\"\n88:            keys=[f\"{self._key_prefix}:{bucket_identity}\"],\n119:    \"\"\"Return the Tier-2 (post-auth, `api_key_id`-keyed) limiter singleton.\"\"\"\n136:async def enforce_tier2_rate_limit(request: \"Request\", principal: \"AuthenticatedPrincipal\") -> None:\n137:    \"\"\"Tier-2 dependency: enforce the caller's per-`api_key_id` token bucket.\n139:    Registered on a dependency that runs strictly **after** `require_api_key`\n140:    (both endpoint routes depend on this ordering), so the bucket key is\n153:            str(principal.api_key_id),\n166:            userId=principal.api_key_id,\n169:            reason=\"tier2_bucket_exhausted\",","is_error":false}]},"uuid":"b56b0352-fcea-4858-8ff3-8b6f304994aa","timestamp":"2026-07-09T01:46:08.671Z","sourceToolAssistantUUID":"c0ac2b0d-8ea7-4f0c-a31c-f9e4fa59beff","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
