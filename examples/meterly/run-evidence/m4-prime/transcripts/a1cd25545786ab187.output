{"parentUuid":"96896730-001f-4a5f-834f-dbd52309b497","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs96h3kZPQAJgyAAjWG8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01961NfUoo9K8xj2UZuuA2ox","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\csv_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":915,"cache_read_input_tokens":35088,"cache_creation":{"ephemeral_5m_input_tokens":915,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs96fRXNQe5YaRmwj5CJ","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"f4f40706-b9eb-4efd-b8cf-58fa6c2d1f96","timestamp":"2026-07-09T20:48:09.791Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"f4f40706-b9eb-4efd-b8cf-58fa6c2d1f96","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a1cd25545786ab187","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01961NfUoo9K8xj2UZuuA2ox","type":"tool_result","content":"1\t\"\"\"CSV encoding facade for `GET /v1/usage/export`.\n2\t\n3\tThe single boundary that owns the RFC 4180 column contract and the OWASP\n4\tCSV/formula-injection escape (`code-standards` facade rule) — centralizing it\n5\there, rather than inlining it in the streaming generator, keeps the control\n6\tgreppable, independently unit-testable, and the one place the security agent\n7\tverifies it lives.\n8\t\"\"\"\n9\t\n10\tfrom decimal import Decimal\n11\tfrom datetime import datetime\n12\t\n13\tEXPORT_HEADER = [\"customer_id\", \"metric\", \"window_start\", \"total_quantity\"]\n14\t\n15\t# A spreadsheet application (Excel/Sheets) treats a cell beginning with any of\n16\t# these characters as the start of a formula/command — the OWASP CSV/formula-\n17\t# injection trigger set.\n18\t_FORMULA_TRIGGER_CHARS = (\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\")\n19\t\n20\t# Control characters other than tab/CR/LF, which RFC 4180 quoting (handled by\n21\t# `csv.writer`'s QUOTE_MINIMAL at the generator that calls this facade) already\n22\t# renders safely — everything else is a raw control byte with no legitimate\n23\t# reason to appear in a customer/metric identifier and is stripped outright.\n24\t_SAFE_WHITESPACE = (\"\\t\", \"\\r\", \"\\n\")\n25\t\n26\t# Precomputed `str.translate` deletion table for exactly the control bytes the\n27\t# strip step removes: every C0 control (0x00–0x1F) except tab/CR/LF, plus DEL\n28\t# (0x7F). Encoding runs this per text cell for every exported row (up to 200,000\n29\t# cell escapes at the 100,000-row cap), so the strip is done by the C-level\n30\t# `str.translate` in a single pass rather than a per-character Python generator +\n31\t# function call + `ord()` (the previous hot path). Semantics are identical to the\n32\t# prior `_is_safe_character` filter — same characters kept, same characters\n33\t# removed — verified by the unchanged AC10 escape unit tests.\n34\t_CONTROL_STRIP_TABLE = {\n35\t    codepoint: None for codepoint in range(0x20) if chr(codepoint) not in _SAFE_WHITESPACE\n36\t}\n37\t_CONTROL_STRIP_TABLE[0x7F] = None\n38\t\n39\t\n40\tdef escape_csv_text_cell(value: str) -> str:\n41\t    \"\"\"Neutralize a text cell against spreadsheet formula-injection.\n42\t\n43\t    Applied at the CSV encoding *sink*, independent of upstream ingest\n44\t    validation: today's ingest allowlist (`^[A-Za-z0-9_.:-]{1,128}$`) permits\n45\t    a leading `-`, which is a live formula trigger in Excel/Sheets, so this is\n46\t    not hypothetical defense-in-depth — it is a real, reachable case. Strips\n47\t    embedded raw control characters, then prefixes a single quote `'` when the\n48\t    (post-strip) first character is a formula trigger; a spreadsheet then\n49\t    renders the cell as literal text rather than evaluating it. RFC 4180\n50\t    quoting itself (comma/quote/CR/LF) is the caller's `csv.writer`'s job, not\n51\t    this function's.\n52\t    \"\"\"\n53\t    if not value:\n54\t        return value\n55\t    cleaned = value.translate(_CONTROL_STRIP_TABLE)\n56\t    if cleaned and cleaned[0] in _FORMULA_TRIGGER_CHARS:\n57\t        return \"'\" + cleaned\n58\t    return cleaned\n59\t\n60\t\n61\tdef format_window_start(window_start: datetime) -> str:\n62\t    \"\"\"Render `window_start` identically to the JSON `GET /v1/usage`\n63\t    response's string form: UTC ISO-8601 with an explicit offset.\"\"\"\n64\t    return window_start.isoformat()\n65\t\n66\t\n67\tdef format_total_quantity(total_quantity: Decimal) -> str:\n68\t    \"\"\"Render `total_quantity` as a plain decimal string.\n69\t\n70\t    `Decimal.__str__` never emits scientific notation and preserves\n71\t    `Numeric(38,6)` scale-6 trailing zeros, which keeps the export\n72\t    deterministic and diff-clean (the brief's \"plain decimal\" requirement).\n73\t    Numeric cells are server-generated and never attacker-controlled, so they\n74\t    are deliberately not passed through `escape_csv_text_cell` — doing so\n75\t    would corrupt the value.\n76\t    \"\"\"\n77\t    return str(total_quantity)\n78\t"}]},"uuid":"ae7dbd05-ce37-40a4-80f7-11c41efe4ba6","timestamp":"2026-07-09T20:48:09.812Z","sourceToolAssistantUUID":"f4f40706-b9eb-4efd-b8cf-58fa6c2d1f96","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"ae7dbd05-ce37-40a4-80f7-11c41efe4ba6","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs96h3kZPQAJgyAAjWG8","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01RJeVL31Q8cDg71S3VSs2GS","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\services\\usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":915,"cache_read_input_tokens":35088,"cache_creation":{"ephemeral_5m_input_tokens":915,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs96fRXNQe5YaRmwj5CJ","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"eafcd7af-bc07-415a-81bc-1a7a9b252cc4","timestamp":"2026-07-09T20:48:10.260Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"eafcd7af-bc07-415a-81bc-1a7a9b252cc4","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a1cd25545786ab187","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RJeVL31Q8cDg71S3VSs2GS","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t# How many encoded data rows to accumulate in the buffer before handing one\n35\t# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n36\t# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n37\t# every streamed chunk through its own anyio memory-object-stream — ran once\n38\t# per row (100,000× at the cap), which dominated the export's wall-clock time\n39\t# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n40\t# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n41\t# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n42\t_ROWS_PER_CHUNK = 1000\n43\t\n44\t\n45\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n46\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n47\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n48\t\n49\t    This must run and fully resolve *before* the route returns a\n50\t    `StreamingResponse` — once that response object exists the status line\n51\t    is already 200 and bytes may already be on the wire, so a 422 can no\n52\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n53\t    (a DB connection drop, a query error) is deliberately left to propagate\n54\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n55\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n56\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n57\t    \"\"\"\n58\t    async with scoped_transaction(principal.api_key_id) as session:\n59\t        row_count = await count_usage_rollups(\n60\t            session,\n61\t            api_key_id=principal.api_key_id,\n62\t            customer_id=params.customer_id,\n63\t            metric=params.metric,\n64\t            window_from=params.from_,\n65\t            window_to=params.to,\n66\t        )\n67\t\n68\t    if row_count > MAX_EXPORT_ROWS:\n69\t        logger.warning(\n70\t            \"usage.export.rejected\",\n71\t            userId=principal.api_key_id,\n72\t            action=\"deny\",\n73\t            reason=\"row_cap_exceeded\",\n74\t        )\n75\t        raise HTTPException(\n76\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n77\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n78\t        )\n79\t\n80\t\n81\tdef _drain(buffer: io.StringIO) -> bytes:\n82\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n83\t    place — this is what keeps the generator at constant memory: it never\n84\t    holds more than one row's encoded text at a time.\"\"\"\n85\t    data = buffer.getvalue().encode(\"utf-8\")\n86\t    buffer.seek(0)\n87\t    buffer.truncate(0)\n88\t    return data\n89\t\n90\t\n91\tasync def stream_export_csv(\n92\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n93\t) -> AsyncIterator[bytes]:\n94\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n95\t    CSV-encoded row per streamed `usage_rollup` record.\n96\t\n97\t    Yielding the header before touching the database means an empty result\n98\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n99\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n100\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n101\t    setting and the server-side cursor both stay valid for the whole stream.\n102\t    \"\"\"\n103\t    row_count = 0\n104\t    capped = False\n105\t    completed = False\n106\t\n107\t    buffer = io.StringIO()\n108\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n109\t\n110\t    try:\n111\t        # Header first, always, as its own chunk — so an empty result is a\n112\t        # 200 header-only CSV (AC12) and the first bytes are observable before\n113\t        # the data rows stream (AC9), independent of the data-row batching below.\n114\t        writer.writerow(EXPORT_HEADER)\n115\t        yield _drain(buffer)\n116\t\n117\t        async with scoped_transaction(principal.api_key_id) as session:\n118\t            async for record in stream_usage_rollups(\n119\t                session,\n120\t                api_key_id=principal.api_key_id,\n121\t                customer_id=params.customer_id,\n122\t                metric=params.metric,\n123\t                window_from=params.from_,\n124\t                window_to=params.to,\n125\t                limit=MAX_EXPORT_ROWS,\n126\t            ):\n127\t                writer.writerow(\n128\t                    [\n129\t                        escape_csv_text_cell(record.customer_id),\n130\t                        escape_csv_text_cell(record.metric),\n131\t                        format_window_start(record.window_start),\n132\t                        format_total_quantity(record.total_quantity),\n133\t                    ]\n134\t                )\n135\t                row_count += 1\n136\t                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n137\t                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n138\t                # cap this yields ~100 chunks, never one buffered blob.\n139\t                if row_count % _ROWS_PER_CHUNK == 0:\n140\t                    yield _drain(buffer)\n141\t\n142\t        # Flush the trailing partial batch. For an empty result nothing is\n143\t        # buffered here (the header already went out above), so no stray chunk.\n144\t        if buffer.tell():\n145\t            yield _drain(buffer)\n146\t\n147\t        capped = row_count >= MAX_EXPORT_ROWS\n148\t        completed = True\n149\t    finally:\n150\t        # In `finally` so a client disconnect or a mid-stream DB error still\n151\t        # records what was actually sent (`completed=False` in that case) —\n152\t        # exactly one usage.export event per request either way (AC17).\n153\t        logger.info(\n154\t            \"usage.export\",\n155\t            userId=principal.api_key_id,\n156\t            action=\"read\",\n157\t            resource=\"usage_rollup\",\n158\t            rowCount=row_count,\n159\t            capped=capped,\n160\t            completed=completed,\n161\t            filtered_by_customer=params.customer_id is not None,\n162\t            filtered_by_metric=params.metric is not None,\n163\t            bounded_from=params.from_ is not None,\n164\t            bounded_to=params.to is not None,\n165\t        )\n166\t"}]},"uuid":"f43817a9-7805-4810-afb1-ad96c6858580","timestamp":"2026-07-09T20:48:10.272Z","sourceToolAssistantUUID":"eafcd7af-bc07-415a-81bc-1a7a9b252cc4","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"f43817a9-7805-4810-afb1-ad96c6858580","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs97qWmapjPygHYvezRZ","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5296,"cache_read_input_tokens":36003,"cache_creation":{"ephemeral_5m_input_tokens":5296,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs97om6jPRSJ1CDCf3p2","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"42c433be-fc11-4ab0-a0bf-7071297b1de1","timestamp":"2026-07-09T20:48:34.692Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"42c433be-fc11-4ab0-a0bf-7071297b1de1","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs97qWmapjPygHYvezRZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016R3GKB58vYhu4fBVChxSd3","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_usage_export_perf.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5296,"cache_read_input_tokens":36003,"cache_creation":{"ephemeral_5m_input_tokens":5296,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs97om6jPRSJ1CDCf3p2","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"03350a09-c588-4228-81f2-dd03161d3b90","timestamp":"2026-07-09T20:48:35.693Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"03350a09-c588-4228-81f2-dd03161d3b90","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a1cd25545786ab187","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016R3GKB58vYhu4fBVChxSd3","type":"tool_result","content":"1\t\"\"\"AC16: p95 timing assertion for `GET /v1/usage/export` at the\n2\t100,000-row cap.\n3\t\n4\tThis is an integration timing check against the real ASGI app + a real\n5\tPostgres testcontainer (in-process transport, no separate uvicorn process) —\n6\tnot a k6/Locust load campaign. The plan's originally-proposed 500ms figure was\n7\tcarried as an *open, unconfirmed* number (plan \"Open questions\" #1). At the\n8\t2026-07-09 debugging escalation the HUMAN confirmed a revised, binding budget\n9\tof **p95 <= 3,000 ms at the 100,000-row cap** after a genuine, within-design\n10\toptimization pass (batched per-chunk streaming instead of per-row, a\n11\tprecompiled `str.translate` CSV escape, and a tuned `yield_per` on the\n12\tserver-side cursor) reduced p95 from ~10.7s (pre-fix) to a stable ~2.0s — see\n13\t`.pipeline/debug-notes.md` and the revised AC16 row in `.pipeline/acceptance.md`.\n14\tThe residual gap to the original 500ms aspiration is an irreducible cost of\n15\tthe approved constant-memory streaming design (server-side cursor + per-row\n16\tstdlib `csv` + the app's `BaseHTTPMiddleware` stack), not a further bug.\n17\t\n18\tThis test HARD-ASSERTS the confirmed 3,000ms bound (a stable-sample p95 over\n19\tmultiple full-cap requests), rather than merely recording the number for the\n20\trecord as the pre-remediation version did.\n21\t\"\"\"\n22\t\n23\timport json\n24\timport os\n25\timport tempfile\n26\timport time\n27\tfrom datetime import datetime, timezone\n28\tfrom pathlib import Path\n29\t\n30\tfrom httpx import ASGITransport, AsyncClient\n31\tfrom sqlalchemy import text\n32\t\n33\t_CONFIRMED_P95_BUDGET_MS = 3_000\n34\t_SAMPLE_REQUESTS = 10\n35\t_EXPECTED_ROW_COUNT = 100_000\n36\t\n37\t\n38\tdef _nearest_rank_percentile(sorted_samples: list, percentile: float) -> float:\n39\t    \"\"\"The budgeted percentile via nearest-rank, mirroring\n40\t    `test_perf_smoke.py`'s convention (never a load tool's named-bucket field).\"\"\"\n41\t    if not sorted_samples:\n42\t        return float(\"nan\")\n43\t    rank = max(1, int(round(percentile / 100 * len(sorted_samples))))\n44\t    return sorted_samples[min(rank, len(sorted_samples)) - 1]\n45\t\n46\t\n47\tasync def _bulk_insert_rollups(\n48\t    postgres_url, *, api_key_id: int, metric: str, window_start: datetime, count: int\n49\t) -> None:\n50\t    \"\"\"Seed `usage_rollup` directly via a single set-based INSERT — seeding\n51\t    100,000 rows one ingest POST at a time would dominate the test's own runtime.\"\"\"\n52\t    from sqlalchemy.ext.asyncio import create_async_engine\n53\t\n54\t    engine = create_async_engine(postgres_url)\n55\t    async with engine.begin() as connection:\n56\t        await connection.execute(\n57\t            text(\n58\t                \"\"\"\n59\t                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n60\t                SELECT :api_key_id, 'cust_' || lpad(gs::text, 8, '0'), :metric, :window_start, 1, 1\n61\t                FROM generate_series(1, :count) AS gs\n62\t                \"\"\"\n63\t            ),\n64\t            {\"api_key_id\": api_key_id, \"metric\": metric, \"window_start\": window_start, \"count\": count},\n65\t        )\n66\t    await engine.dispose()\n67\t\n68\t\n69\tasync def test_export_p95_timing_meets_the_confirmed_3000ms_budget_at_the_row_cap(\n70\t    make_api_key, truncate_tables, postgres_url\n71\t):\n72\t    \"\"\"AC16: measure p95 wall-clock latency for a full 100,000-row export\n73\t    over a stable multi-request sample, and hard-assert it against the\n74\t    human-confirmed 3,000ms budget (revised from the original 500ms\n75\t    aspiration — see module docstring). Also asserts the request completes\n76\t    correctly end to end at the cap on every sample (no truncation, no\n77\t    partial rows) — a hang, an error, or a wrong row count still fails it\n78\t    independent of the timing assertion.\n79\t    \"\"\"\n80\t    from src.main import app\n81\t\n82\t    presented_key, api_key_id = await make_api_key()\n83\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n84\t    await _bulk_insert_rollups(\n85\t        postgres_url,\n86\t        api_key_id=api_key_id,\n87\t        metric=\"api_calls\",\n88\t        window_start=window_start,\n89\t        count=_EXPECTED_ROW_COUNT,\n90\t    )\n91\t\n92\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n93\t    transport = ASGITransport(app=app)\n94\t    latencies_ms: list[float] = []\n95\t\n96\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as export_client:\n97\t        for _ in range(_SAMPLE_REQUESTS):\n98\t            started = time.perf_counter()\n99\t            async with export_client.stream(\"GET\", \"/v1/usage/export\", headers=headers) as response:\n100\t                assert response.status_code == 200\n101\t                body_text = \"\"\n102\t                async for chunk in response.aiter_bytes():\n103\t                    body_text += chunk.decode(\"utf-8\")\n104\t            latencies_ms.append((time.perf_counter() - started) * 1000)\n105\t            row_count = body_text.count(\"\\r\\n\") - 1  # exclude the header line\n106\t            assert row_count == _EXPECTED_ROW_COUNT, \"the full capped row set must be present, not truncated\"\n107\t\n108\t    latencies_ms.sort()\n109\t    p95_ms = _nearest_rank_percentile(latencies_ms, 95)\n110\t\n111\t    scratch_dir = os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())\n112\t    scratch_path = Path(scratch_dir) / \"meterly_usage_export_perf_measurement.json\"\n113\t    scratch_path.write_text(\n114\t        json.dumps(\n115\t            {\n116\t                \"p95_ms\": round(p95_ms, 2),\n117\t                \"min_ms\": round(latencies_ms[0], 2),\n118\t                \"median_ms\": round(latencies_ms[len(latencies_ms) // 2], 2),\n119\t                \"confirmed_budget_ms\": _CONFIRMED_P95_BUDGET_MS,\n120\t                \"sample_count\": len(latencies_ms),\n121\t                \"row_count\": _EXPECTED_ROW_COUNT,\n122\t                \"meets_confirmed_budget\": p95_ms <= _CONFIRMED_P95_BUDGET_MS,\n123\t            }\n124\t        )\n125\t    )\n126\t\n127\t    assert len(latencies_ms) == _SAMPLE_REQUESTS\n128\t    assert p95_ms <= _CONFIRMED_P95_BUDGET_MS, (\n129\t        f\"p95 {p95_ms:.2f}ms exceeds the human-confirmed {_CONFIRMED_P95_BUDGET_MS}ms \"\n130\t        f\"budget at the {_EXPECTED_ROW_COUNT}-row cap (samples: {latencies_ms})\"\n131\t    )\n132\t"}]},"uuid":"29467391-9195-435f-b14a-b9c96f6dadd8","timestamp":"2026-07-09T20:48:35.706Z","sourceToolAssistantUUID":"03350a09-c588-4228-81f2-dd03161d3b90","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"29467391-9195-435f-b14a-b9c96f6dadd8","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs97qWmapjPygHYvezRZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_014YyAo2Bpq4yvjHcx6BxD4K","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\routes\\usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5296,"cache_read_input_tokens":36003,"cache_creation":{"ephemeral_5m_input_tokens":5296,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs97om6jPRSJ1CDCf3p2","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"5d7b8fe4-c697-44c9-a34b-537c974a3ac0","timestamp":"2026-07-09T20:48:36.192Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"5d7b8fe4-c697-44c9-a34b-537c974a3ac0","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a1cd25545786ab187","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014YyAo2Bpq4yvjHcx6BxD4K","type":"tool_result","content":"1\t\"\"\"`GET /v1/usage/export` — streams the authenticated caller's own\n2\t`usage_rollup` rows as an RFC 4180 CSV.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> schema validation -> a two-phase pre-flight-cap +\n7\tstream service call, mirroring `src/api/routes/usage.py`'s composition. Kept\n8\tin its own module (not added to `usage.py`) so `GET /v1/usage`'s code path is\n9\tliterally untouched by this change — the brief's no-behavior-change\n10\tconstraint is then trivially auditable in the diff.\n11\t\"\"\"\n12\t\n13\tfrom datetime import datetime, timezone\n14\tfrom typing import Annotated\n15\t\n16\tfrom fastapi import APIRouter, Depends, Query, Request\n17\tfrom fastapi.responses import StreamingResponse\n18\t\n19\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n20\tfrom src.auth import require_api_key\n21\tfrom src.auth.api_key import AuthenticatedPrincipal\n22\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n23\tfrom src.services.usage_export_service import prepare_export, stream_export_csv\n24\t\n25\trouter = APIRouter(tags=[\"usage\"])\n26\t\n27\t# Explicit OpenAPI response metadata: a StreamingResponse has no `response_model`\n28\t# for FastAPI to introspect, so the served schema would otherwise omit the real\n29\t# response shape — this is what a DAST scanner (and AC19) reads.\n30\t_EXPORT_RESPONSES: dict = {\n31\t    200: {\n32\t        \"description\": \"The caller's usage_rollup rows as RFC 4180 CSV (header row always first).\",\n33\t        \"content\": {\"text/csv\": {\"schema\": {\"type\": \"string\", \"format\": \"binary\"}}},\n34\t    },\n35\t    422: {\n36\t        \"description\": \"Validation failure, or the filtered result exceeds the 100,000-row export cap.\",\n37\t        \"content\": {\n38\t            \"application/json\": {\n39\t                \"example\": {\n40\t                    \"error\": {\n41\t                        \"code\": \"validation_failed\",\n42\t                        \"message\": \"result exceeds 100000 rows; narrow with customer_id, metric, from, and/or to\",\n43\t                        \"requestId\": \"…\",\n44\t                    }\n45\t                }\n46\t            }\n47\t        },\n48\t    },\n49\t}\n50\t\n51\t\n52\tasync def _require_authenticated_and_throttled(\n53\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n54\t) -> AuthenticatedPrincipal:\n55\t    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (kept as\n56\t    a sibling, not a shared import, per the existing per-route convention —\n57\t    each route's dependency chain stays independently readable).\"\"\"\n58\t    await enforce_tier2_rate_limit(request, principal)\n59\t    return principal\n60\t\n61\t\n62\tdef _export_filename(now: datetime) -> str:\n63\t    \"\"\"Build the `Content-Disposition` filename: a UTC timestamp only — no\n64\t    tenant identifier, so the filename itself never leaks `api_key_id` or any\n65\t    caller identity (ASVS 14.3.2).\"\"\"\n66\t    return f\"usage-export-{now:%Y%m%dT%H%M%SZ}.csv\"\n67\t\n68\t\n69\t@router.get(\"/v1/usage/export\", responses=_EXPORT_RESPONSES)\n70\tasync def get_usage_export(\n71\t    params: Annotated[UsageExportQueryParams, Query()],\n72\t    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n73\t) -> StreamingResponse:\n74\t    \"\"\"Stream the caller's own `usage_rollup` rows as CSV, optionally\n75\t    narrowed by `customer_id`/`metric`/`from`/`to`.\n76\t\n77\t    Two-phase: `prepare_export` runs the pre-flight row-cap check (a clean\n78\t    422 over 100,000 rows, or a fail-closed generic 500 on an unexpected\n79\t    error — AC22) before any response byte; only then is the\n80\t    `StreamingResponse` constructed. Starlette pulls `stream_export_csv`\n81\t    after this handler returns, so the generator opens its own DB\n82\t    transaction rather than reusing one already closed by the time it runs.\n83\t    \"\"\"\n84\t    await prepare_export(principal, params)\n85\t\n86\t    filename = _export_filename(datetime.now(timezone.utc))\n87\t    return StreamingResponse(\n88\t        stream_export_csv(principal, params),\n89\t        media_type=\"text/csv; charset=utf-8\",\n90\t        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},\n91\t    )\n92\t"}]},"uuid":"41acd1cc-fb56-4de6-9d76-b251f77cd663","timestamp":"2026-07-09T20:48:36.204Z","sourceToolAssistantUUID":"5d7b8fe4-c697-44c9-a34b-537c974a3ac0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"41acd1cc-fb56-4de6-9d76-b251f77cd663","isSidechain":true,"agentId":"a1cd25545786ab187","message":{"model":"claude-opus-4-8","id":"msg_011Ccs97qWmapjPygHYvezRZ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01UbRQTsCjcX8TYHuQFWuufC","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\schemas\\usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5296,"cache_read_input_tokens":36003,"cache_creation":{"ephemeral_5m_input_tokens":5296,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs97om6jPRSJ1CDCf3p2","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"e1aa2fb9-2f85-4472-8035-290b4263b4ce","timestamp":"2026-07-09T20:48:36.799Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"e1aa2fb9-2f85-4472-8035-290b4263b4ce","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a1cd25545786ab187","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UbRQTsCjcX8TYHuQFWuufC","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage/export`.\n2\t\n3\tReuses the exact `customer_id`/`metric` anchored allowlists\n4\t`src/api/schemas/events.py` already enforces for the SQL sink these filters\n5\tshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\n6\tapplied here as an optional `[from, to]` range rather than a single\n7\tpoint-in-time window.\n8\t\"\"\"\n9\t\n10\tfrom datetime import datetime, timedelta, timezone\n11\t\n12\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n13\t\n14\tfrom src.api.schemas.events import CustomerId, Metric\n15\t\n16\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n17\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n18\t\n19\t\n20\tclass UsageExportQueryParams(BaseModel):\n21\t    \"\"\"Optional filters for `GET /v1/usage/export`.\n22\t\n23\t    Every field is optional; omitting all of them exports the caller's full\n24\t    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n25\t    unknown query parameter — the same mass-assignment posture the write\n26\t    schemas use, applied to a read (a client-supplied `api_key_id` is\n27\t    rejected rather than silently ignored).\n28\t    \"\"\"\n29\t\n30\t    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n31\t\n32\t    customer_id: CustomerId | None = None\n33\t    metric: Metric | None = None\n34\t    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n35\t    to: AwareDatetime | None = None\n36\t\n37\t    @model_validator(mode=\"after\")\n38\t    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n39\t        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n40\t        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n41\t        so a caller can't probe arbitrarily far into the past (unbounded\n42\t        query cost) or the future.\"\"\"\n43\t        now = datetime.now(timezone.utc)\n44\t        earliest = now - _MAX_WINDOW_LOOKBACK\n45\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n46\t\n47\t        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n48\t            if value is not None and not (earliest <= value <= latest):\n49\t                raise ValueError(\n50\t                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n51\t                )\n52\t\n53\t        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n54\t            raise ValueError(\"from must be <= to\")\n55\t\n56\t        return self\n57\t"}]},"uuid":"2fc1159e-d09a-4f71-a27d-481d57659698","timestamp":"2026-07-09T20:48:36.811Z","sourceToolAssistantUUID":"e1aa2fb9-2f85-4472-8035-290b4263b4ce","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
