{"parentUuid":"a928b857-dfda-47fa-bafd-23221a6866c0","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013GBUwejTn1uW6zXNVZARap","type":"tool_result","content":"3:Discriminating shape (per test-conventions): two principals sharing one\n4:client IP must get independent buckets, and a single principal across two\n18:async def test_two_principals_sharing_one_ip_get_independent_buckets(truncate_tables, make_api_key):","is_error":false}]},"uuid":"50bb5804-fdfa-4d2c-b9e1-ab3f0afb8985","timestamp":"2026-07-09T18:19:27.624Z","sourceToolAssistantUUID":"a928b857-dfda-47fa-bafd-23221a6866c0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"6d3509ca-4c61-4717-99c8-59be4852471f","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016UUCJUsazadBFQnUKLUrSB","type":"tool_result","content":"1\t\"\"\"AC14/AC16: Tier-2 per-owner (api_key_id-keyed) rate limiting.\n2\t\n3\tDiscriminating shape (per test-conventions): two principals sharing one\n4\tclient IP must get independent buckets, and a single principal across two\n5\tIPs must still share one bucket — proving the limiter is keyed on\n6\t`api_key_id`, never the client IP.\n7\t\"\"\"\n8\t\n9\tfrom httpx import ASGITransport, AsyncClient\n10\t\n11\t\n12\tdef _usage_query_params() -> dict:\n13\t    from datetime import datetime, timezone\n14\t\n15\t    return {\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": datetime.now(timezone.utc).isoformat()}\n16\t\n17\t\n18\tasync def test_two_principals_sharing_one_ip_get_independent_buckets(truncate_tables, make_api_key):\n19\t    \"\"\"Principal A exhausts its own (tiny) bucket -> 429; principal B, same\n20\t    client IP, still succeeds -> the bucket key is the api_key_id, not the IP.\"\"\"\n21\t    from src.main import app\n22\t\n23\t    key_a, _ = await make_api_key(label=\"a\", rate_limit_per_sec=1)\n24\t    key_b, _ = await make_api_key(label=\"b\", rate_limit_per_sec=100)\n25\t\n26\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.5\", 4000))\n27\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as client:\n28\t        # Exhaust A's 1-token bucket.\n29\t        first = await client.get(\"/v1/usage\", params=_usage_query_params(), headers={\"Authorization\": f\"Bearer {key_a}\"})\n30\t        second = await client.get(\"/v1/usage\", params=_usage_query_params(), headers={\"Authorization\": f\"Bearer {key_a}\"})\n31\t\n32\t        assert first.status_code == 200\n33\t        assert second.status_code == 429\n34\t        assert \"Retry-After\" in second.headers\n35\t\n36\t        # Principal B, same client IP, is unaffected.\n37\t        b_response = await client.get(\"/v1/usage\", params=_usage_query_params(), headers={\"Authorization\": f\"Bearer {key_b}\"})\n38\t        assert b_response.status_code == 200\n39\t\n40\t\n41\tasync def test_one_principal_across_two_ips_still_shares_one_bucket(truncate_tables, make_api_key):\n42\t    \"\"\"The same api_key_id from two different client IPs still shares a single\n43\t    bucket (Tier-2 is never IP-keyed, unlike Tier-1).\"\"\"\n44\t    from src.main import app\n45\t\n46\t    key_a, _ = await make_api_key(label=\"a\", rate_limit_per_sec=1)\n47\t\n48\t    transport_ip1 = ASGITransport(app=app, client=(\"10.0.0.1\", 1))\n49\t    transport_ip2 = ASGITransport(app=app, client=(\"10.0.0.2\", 2))\n50\t\n51\t    async with AsyncClient(transport=transport_ip1, base_url=\"http://test\") as client1, AsyncClient(\n52\t        transport=transport_ip2, base_url=\"http://test\"\n53\t    ) as client2:\n54\t        first = await client1.get(\"/v1/usage\", params=_usage_query_params(), headers={\"Authorization\": f\"Bearer {key_a}\"})\n55\t        second = await client2.get(\"/v1/usage\", params=_usage_query_params(), headers={\"Authorization\": f\"Bearer {key_a}\"})\n56\t\n57\t        assert first.status_code == 200\n58\t        assert second.status_code == 429, \"the same api_key_id from a different IP must still share the exhausted bucket\"\n59\t"}]},"uuid":"11181403-a5ce-423c-9e49-0919bfd7ad91","timestamp":"2026-07-09T18:19:27.634Z","sourceToolAssistantUUID":"6d3509ca-4c61-4717-99c8-59be4852471f","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
