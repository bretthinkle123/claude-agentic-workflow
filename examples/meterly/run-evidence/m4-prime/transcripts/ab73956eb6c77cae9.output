{"parentUuid":"d28cbecf-75d2-4c72-a7d8-06ca795b3043","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013erdh9X4XJHngmoyN3sjyF","type":"tool_result","content":"339\t    # sent — a genuinely streamed multi-row export arrives as more than one\n340\t    # discrete read on the wire.\n341\t    assert chunk_count > 1\n342\t\n343\t\n344\tasync def test_openapi_schema_exposes_the_export_route_and_responses(client):\n345\t    \"\"\"AC19 (DAST-1): the served /openapi.json includes GET /v1/usage/export\n346\t    with its 200 text/csv and 422 responses, matching the implemented route.\"\"\"\n347\t    response = await client.get(\"/openapi.json\")\n348\t\n349\t    assert response.status_code == 200\n350\t    schema = response.json()\n351\t    assert \"/v1/usage/export\" in schema[\"paths\"]\n352\t    export_operation = schema[\"paths\"][\"/v1/usage/export\"][\"get\"]\n353\t    assert \"200\" in export_operation[\"responses\"]\n354\t    assert \"422\" in export_operation[\"responses\"]\n355\t    assert \"text/csv\" in export_operation[\"responses\"][\"200\"][\"content\"]\n356\t\n357\t\n358\tasync def test_export_forced_pre_flight_count_error_returns_generic_500(client, make_api_key, monkeypatch):\n359\t    \"\"\"AC22: a forced error during the pre-flight COUNT phase (before any\n360\t    response byte) returns the generic 500 internal envelope — no\n361\t    stack/SQL/internal-path leak, and no partial CSV body.\"\"\"\n362\t    from src.services import usage_export_service\n363\t\n364\t    async def _raising_count(session, **kwargs):\n365\t        raise RuntimeError(\"simulated connection drop mid-count\")\n366\t\n367\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n368\t"}]},"uuid":"bab7b3da-78b9-4243-a4d7-92197c4c4f28","timestamp":"2026-07-09T18:27:59.593Z","sourceToolAssistantUUID":"d28cbecf-75d2-4c72-a7d8-06ca795b304