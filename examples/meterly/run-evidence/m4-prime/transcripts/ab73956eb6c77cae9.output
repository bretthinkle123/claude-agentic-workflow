{"parentUuid":"368ec9ac-8198-448d-aecc-230d74ece167","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9KSBDohcDkXdxJTYW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017EKVzA9m9zVuTJTPs6at8Y","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\middleware.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6665,"cache_read_input_tokens":58889,"cache_creation":{"ephemeral_5m_input_tokens":6665,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9GVZn2D42je7AVWC2","attributionAgent":"implementation","type":"assistant","uuid":"234587ab-2a1e-4b19-a30a-f8999c7a3dd5","timestamp":"2026-07-09T18:11:13.784Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"234587ab-2a1e-4b19-a30a-f8999c7a3dd5","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017EKVzA9m9zVuTJTPs6at8Y","type":"tool_result","content":"1\t\"\"\"Centralized edge middleware — security headers, CORS, the body-size guard,\n2\tand the Tier-1 (pre-auth, IP+route-keyed) throttle.\n3\t\n4\tRegistered once at app construction (`src/main.py`) in the order\n5\t`api-edge-conventions` specifies: request-id/trace, security headers, CORS,\n6\tbody-size guard, Tier-1 throttle, auth guard, Tier-2 throttle, handler. No\n7\troute re-declares any of this — a new endpoint inherits it by being mounted\n8\ton the app.\n9\t\"\"\"\n10\t\n11\tfrom collections.abc import Awaitable, Callable\n12\t\n13\tfrom fastapi import FastAPI, status\n14\tfrom fastapi.middleware.cors import CORSMiddleware\n15\tfrom starlette.middleware.base import BaseHTTPMiddleware\n16\tfrom starlette.requests import Request\n17\tfrom starlette.responses import JSONResponse, Response\n18\t\n19\tfrom src.auth.rate_limit import get_tier1_limiter\n20\tfrom src.config.settings import Settings\n21\tfrom src.logging import get_logger\n22\t\n23\tlogger = get_logger(service=\"meterly\")\n24\t\n25\t_SECURITY_HEADERS = {\n26\t    \"Strict-Transport-Security\": \"max-age=63072000; includeSubDomains\",\n27\t    \"X-Content-Type-Options\": \"nosniff\",\n28\t    \"Content-Security-Policy\": \"default-src 'none'\",\n29\t    \"X-Frame-Options\": \"DENY\",\n30\t    \"Referrer-Policy\": \"strict-origin-when-cross-origin\",\n31\t    \"Permissions-Policy\": \"geolocation=(), camera=(), microphone=()\",\n32\t}\n33\t\n34\t\n35\tclass SecurityHeadersMiddleware(BaseHTTPMiddleware):\n36\t    \"\"\"Sets a fixed set of security headers on every response, including error responses.\"\"\"\n37\t\n38\t    async def dispatch(\n39\t        self, request: Request, call_next: Callable[[Request], Awaitable[Response]]\n40\t    ) -> Response:\n41\t        \"\"\"Run the request, then stamp the security header set onto the response.\"\"\"\n42\t        response = await call_next(request)\n43\t        for header_name, header_value in _SECURITY_HEADERS.items():\n44\t            response.headers[header_name] = header_value\n45\t        if request.url.path.startswith(\"/v1/usage\"):\n46\t            # Usage totals are billing-adjacent personal-scoped data — never cache\n47\t            # them client-side or in an intermediary (ASVS 14.3.2).\n48\t            response.headers[\"Cache-Control\"] = \"no-store\"\n49\t        return response\n50\t\n51\t\n52\tclass BodySizeLimitMiddleware(BaseHTTPMiddleware):\n53\t    \"\"\"Rejects a request whose `Content-Length` exceeds the configured cap with 413.\n54\t\n55\t    These payloads are tiny by design (a handful of scalar fields); an\n56\t    unbounded body is a cheap denial-of-service vector worth rejecting before\n57\t    it reaches any parsing.\n58\t    \"\"\"\n59\t\n60\t    def __init__(self, app: FastAPI, *, max_body_size_bytes: int) -> None:\n61\t        super().__init__(app)\n62\t        self._max_body_size_bytes = max_body_size_bytes\n63\t\n64\t    async def dispatch(\n65\t        self, request: Request, call_next: Callable[[Request], Awaitable[Response]]\n66\t    ) -> Response:\n67\t        \"\"\"Check `Content-Length` before invoking the rest of the stack.\"\"\"\n68\t        content_length = request.headers.get(\"content-length\")\n69\t        if content_length is not None:\n70\t            try:\n71\t                if int(content_length) > self._max_body_size_bytes:\n72\t                    return JSONResponse(\n73\t                        status_code=status.HTTP_413_REQUEST_ENTITY_TOO_LARGE,\n74\t                        content={\n75\t                            \"error\": {\n76\t                                \"code\": \"payload_too_large\",\n77\t                                \"message\": \"request body exceeds the maximum allowed size\",\n78\t                                \"requestId\": getattr(request.state, \"request_id\", \"unknown\"),\n79\t                            }\n80\t                        },\n81\t                    )\n82\t            except ValueError:\n83\t                pass  # malformed Content-Length falls through to normal request handling/validation\n84\t        return await call_next(request)\n85\t\n86\t\n87\t# Paths exempt from the Tier-1 Redis throttle: the liveness probe must return\n88\t# 200 with *zero* dependencies (no DB, no Redis) — it is the smoke check's and\n89\t# the build-fallback's only signal, and gating it on Redis would make a cache\n90\t# outage look like a total application outage (plan §\"health split\").\n91\t_TIER1_EXEMPT_PATHS = frozenset({\"/health\"})\n92\t\n93\t\n94\tclass Tier1EdgeThrottleMiddleware(BaseHTTPMiddleware):\n95\t    \"\"\"Pre-auth, IP+route-keyed Redis token bucket — sheds an anonymous flood\n96\t    before the request can spend an Argon2id verification (mitigates D1/D3).\n97\t    \"\"\"\n98\t\n99\t    def __init__(self, app: FastAPI, *, capacity: int, refill_rate_per_second: float) -> None:\n100\t        super().__init__(app)\n101\t        self._capacity = capacity\n102\t        self._refill_rate_per_second = refill_rate_per_second\n103\t\n104\t    async def dispatch(\n105\t        self, request: Request, call_next: Callable[[Request], Awaitable[Response]]\n106\t    ) -> Response:\n107\t        \"\"\"Consume one token from the `client_ip:route` bucket before proceeding.\n108\t\n109\t        Fails **open** (allows the request, logs a warning) on a Redis\n110\t        connection error rather than 500ing every request — an unreachable\n111\t        cache degrading to \"temporarily unlimited\" is preferable to a full\n112\t        outage of the ingest path; Tier-2's per-key bucket and the underlying\n113\t        DB constraints remain the durable protections either way.\n114\t        \"\"\"\n115\t        if request.url.path in _TIER1_EXEMPT_PATHS:\n116\t            return await call_next(request)\n117\t\n118\t        client_ip = request.client.host if request.client else \"unknown\"\n119\t        bucket_identity = f\"{client_ip}:{request.url.path}\"\n120\t        try:\n121\t            decision = await get_tier1_limiter().check(\n122\t                bucket_identity,\n123\t                capacity=self._capacity,\n124\t                refill_rate_per_second=self._refill_rate_per_second,\n125\t            )\n126\t        except Exception:  # noqa: BLE001 - a Redis outage must not take down the whole API\n127\t            logger.warning(\"ratelimit.backend_unavailable\", endpoint=request.url.path, tier=\"tier1\")\n128\t            return await call_next(request)\n129\t\n130\t        if not decision.allowed:\n131\t            logger.warning(\n132\t                \"ratelimit.exceeded\",\n133\t                userId=None,\n134\t                action=\"deny\",\n135\t                endpoint=request.url.path,\n136\t                reason=\"tier1_bucket_exhausted\",\n137\t            )\n138\t            return JSONResponse(\n139\t                status_code=status.HTTP_429_TOO_MANY_REQUESTS,\n140\t                content={\n141\t                    \"error\": {\n142\t                        \"code\": \"rate_limited\",\n143\t                        \"message\": \"too many requests\",\n144\t                        \"requestId\": getattr(request.state, \"request_id\", \"unknown\"),\n145\t                    }\n146\t                },\n147\t                headers={\"Retry-After\": str(max(1, int(decision.retry_after_seconds) or 1))},\n148\t            )\n149\t        return await call_next(request)\n150\t\n151\t\n152\tdef configure_cors(app: FastAPI, settings: Settings) -> None:\n153\t    \"\"\"Register the CORS middleware with an explicit origin allowlist from config.\n154\t\n155\t    Defaults to an empty allowlist (this is a server-to-server API, not a\n156\t    browser client) rather than `*` — `api-edge-conventions` forbids\n157\t    reflecting an arbitrary origin.\n158\t    \"\"\"\n159\t    app.add_middleware(\n160\t        CORSMiddleware,\n161\t        allow_origins=list(settings.cors_allowed_origins),\n162\t        allow_credentials=False,\n163\t        allow_methods=[\"GET\", \"POST\", \"PUT\"],\n164\t        allow_headers=[\"Authorization\", \"Content-Type\", \"Idempotency-Key\"],\n165\t    )\n166\t"}]},"uuid":"2e17ffcf-b44d-4a23-9ab1-a4df25b1ed67","timestamp":"2026-07-09T18:11:13.825Z","sourceToolAssistantUUID":"234587ab-2a1e-4b19-a30a-f8999c7a3dd5","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"2e17ffcf-b44d-4a23-9ab1-a4df25b1ed67","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9KSBDohcDkXdxJTYW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XZxfajeMGquh11meWpsj2S","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\conftest.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6665,"cache_read_input_tokens":58889,"cache_creation":{"ephemeral_5m_input_tokens":6665,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9GVZn2D42je7AVWC2","attributionAgent":"implementation","type":"assistant","uuid":"6ff97daa-de71-436f-abef-8026882353c2","timestamp":"2026-07-09T18:11:14.153Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"6ff97daa-de71-436f-abef-8026882353c2","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XZxfajeMGquh11meWpsj2S","type":"tool_result","content":"1\t\"\"\"Shared pytest fixtures.\n2\t\n3\tUnit tests (schemas, crypto, auth parsing, time flooring) need no external\n4\tservices. Integration tests under `tests/integration/` spin up a real\n5\tPostgreSQL via `testcontainers` — the correctness guarantees the plan calls\n6\tout (ON CONFLICT concurrency, RLS, migration round-trips) are only real\n7\tagainst actual Postgres, not a mock.\n8\t\"\"\"\n9\t\n10\timport os\n11\t\n12\t# Ensure the app never tries to reach a real AWS account during tests: the\n13\t# secrets facade falls back to this env var when Secrets Manager is\n14\t# unreachable (see src/config/secrets.py).\n15\tos.environ.setdefault(\"DATABASE_URL\", \"postgresql+asyncpg://meterly:meterly@localhost:5432/meterly_test\")\n16\t"}]},"uuid":"6803ec4d-a31a-48cc-a505-417ff0b4c137","timestamp":"2026-07-09T18:11:14.194Z","sourceToolAssistantUUID":"6ff97daa-de71-436f-abef-8026882353c2","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"6803ec4d-a31a-48cc-a505-417ff0b4c137","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9KSBDohcDkXdxJTYW","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NkZ6waBHnY4myQJSicQspX","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\conftest.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6665,"cache_read_input_tokens":58889,"output_tokens":431,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":6665},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":431,"cache_read_input_tokens":58889,"cache_creation_input_tokens":6665,"cache_creation":{"ephemeral_5m_input_tokens":6665,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccrw9GVZn2D42je7AVWC2","attributionAgent":"implementation","type":"assistant","uuid":"7f5d836c-0312-448e-ba4b-0d1f5c2cfdd0","timestamp":"2026-07-09T18:11:14.555Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"7f5d836c-0312-448e-ba4b-0d1f5c2cfdd0","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NkZ6waBHnY4myQJSicQspX","type":"tool_result","content":"1\t\"\"\"Shared fixtures for integration tests: a real PostgreSQL + Redis, each in a\n2\ttestcontainer, migrated with the project's actual Alembic revisions and wired\n3\tinto the app's process-wide singletons so requests through the ASGI app hit\n4\treal dependencies — the correctness guarantees under test here (ON CONFLICT\n5\tconcurrency, RLS tenant isolation, migration round-trips) are only real\n6\tagainst actual Postgres, not a mock.\n7\t\"\"\"\n8\t\n9\timport asyncio\n10\timport os\n11\timport subprocess\n12\timport sys\n13\tfrom pathlib import Path\n14\t\n15\timport pytest\n16\tfrom httpx import ASGITransport, AsyncClient\n17\tfrom testcontainers.postgres import PostgresContainer\n18\tfrom testcontainers.redis import RedisContainer\n19\t\n20\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n21\t\n22\t\n23\tdef _asyncpg_url(sync_url: str) -> str:\n24\t    \"\"\"Convert testcontainers' default `postgresql+psycopg2://` URL to the\n25\t    `postgresql+asyncpg://` dialect the application (and Alembic's env.py) uses.\"\"\"\n26\t    return sync_url.replace(\"postgresql+psycopg2://\", \"postgresql+asyncpg://\")\n27\t\n28\t\n29\t@pytest.fixture(scope=\"session\")\n30\tdef postgres_url():\n31\t    \"\"\"A session-scoped live Postgres, migrated to head once.\n32\t\n33\t    Raises `max_connections` above Postgres's default of 100: this container\n34\t    is shared across the whole integration-test session, including three k6\n35\t    perf fixtures that each launch a separate multi-worker uvicorn process\n36\t    (its own DB connection pool) against it — the default ceiling is too low\n37\t    for that cumulative demand when the full suite runs in one session and\n38\t    was observed to exhaust mid-suite (`TooManyConnectionsError`) with only\n39\t    the default. This is a test-container capacity knob, not a production\n40\t    change (the real RDS instance sizes `max_connections` independently).\n41\t    \"\"\"\n42\t    with PostgresContainer(\"postgres:16-alpine\").with_command(\n43\t        \"postgres -c max_connections=300\"\n44\t    ) as postgres:\n45\t        url = _asyncpg_url(postgres.get_connection_url())\n46\t        env = dict(os.environ)\n47\t        env[\"DATABASE_URL\"] = url\n48\t        # Run the project's real Alembic migrations (0001 + 0002) against the\n49\t        # container out-of-process, so this is the same upgrade path `alembic\n50\t        # upgrade head` runs in CI/deploy, not a re-implemented schema.\n51\t        result = subprocess.run(\n52\t            [sys.executable, \"-m\", \"alembic\", \"upgrade\", \"head\"],\n53\t            cwd=str(_REPO_ROOT),\n54\t            env=env,\n55\t            capture_output=True,\n56\t            text=True,\n57\t        )\n58\t        assert result.returncode == 0, f\"alembic upgrade head failed:\\n{result.stdout}\\n{result.stderr}\"\n59\t        yield url\n60\t\n61\t\n62\t@pytest.fixture(scope=\"session\")\n63\tdef redis_url():\n64\t    \"\"\"A session-scoped live Redis for the Tier-1/Tier-2 token-bucket limiters.\"\"\"\n65\t    with RedisContainer(\"redis:7-alpine\") as redis_container:\n66\t        host = redis_container.get_container_host_ip()\n67\t        port = redis_container.get_exposed_port(redis_container.port)\n68\t        yield f\"redis://{host}:{port}/0\"\n69\t\n70\t\n71\t@pytest.fixture\n72\tasync def app_env(postgres_url, redis_url, monkeypatch):\n73\t    \"\"\"Point the app's process-wide DB/Redis singletons at the live\n74\t    containers, then reset them so each test starts with fresh pools/caches\n75\t    and no leaked verification-cache entries from a previous test.\n76\t    \"\"\"\n77\t    monkeypatch.setenv(\"DATABASE_URL\", postgres_url)\n78\t    monkeypatch.setenv(\"METERLY_REDIS_URL\", redis_url)\n79\t\n80\t    from src import auth as auth_module\n81\t    from src.auth import rate_limit as rate_limit_module\n82\t    from src.config import secrets as secrets_module\n83\t    from src.config.settings import get_settings\n84\t    from src.db import session as session_module\n85\t\n86\t    get_settings.cache_clear()\n87\t    secrets_module._facade._cache.clear()\n88\t\n89\t    await session_module.dispose_engine()\n90\t    await rate_limit_module.dispose_redis_client()\n91\t    auth_module._verification_cache = None\n92\t\n93\t    yield\n94\t\n95\t    await session_module.dispose_engine()\n96\t    await rate_limit_module.dispose_redis_client()\n97\t    auth_module._verification_cache = None\n98\t    get_settings.cache_clear()\n99\t\n100\t\n101\t@pytest.fixture\n102\tasync def truncate_tables(app_env, postgres_url, redis_url):\n103\t    \"\"\"Truncate the mutable tables between tests so each test starts from a\n104\t    clean, empty schema (api_keys are re-seeded per test via `make_api_key`).\n105\t\n106\t    The DB truncate uses RESTART IDENTITY, so `api_keys.id` (the Tier-2 bucket\n107\t    key) resets to 1 each test. Redis is session-scoped and would otherwise\n108\t    retain the previous test's token buckets under those reused ids, leaking an\n109\t    exhausted bucket into the next test -> flush it here too so bucket state is\n110\t    isolated per test, mirroring the DB truncate.\n111\t    \"\"\"\n112\t    import redis.asyncio as redis_async\n113\t    from sqlalchemy.ext.asyncio import create_async_engine\n114\t\n115\t    engine = create_async_engine(postgres_url)\n116\t    async with engine.begin() as connection:\n117\t        from sqlalchemy import text\n118\t\n119\t        await connection.execute(\n120\t            text(\"TRUNCATE TABLE events, usage_rollup, quotas, api_keys RESTART IDENTITY CASCADE\")\n121\t        )\n122\t    await engine.dispose()\n123\t\n124\t    redis_client = redis_async.from_url(redis_url, decode_responses=True)\n125\t    await redis_client.flushdb()\n126\t    await redis_client.aclose()\n127\t    yield\n128\t\n129\t\n130\t@pytest.fixture\n131\tasync def client(truncate_tables):\n132\t    \"\"\"An async test client bound to the real app via ASGI transport, with\n133\t    live DB/Redis singletons already pointed at the containers.\"\"\"\n134\t    from src.main import app\n135\t\n136\t    transport = ASGITransport(app=app)\n137\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as async_client:\n138\t        yield async_client\n139\t\n140\t\n141\t@pytest.fixture\n142\tasync def make_api_key(truncate_tables):\n143\t    \"\"\"Factory fixture: provision a real API key row (Argon2id-hashed) and\n144\t    return `(presented_key, api_key_id)`.\"\"\"\n145\t    from src.auth.api_key import generate_split_token, hash_new_secret\n146\t    from src.db.session import get_engine\n147\t    from src.repositories.api_keys_repo import create_api_key\n148\t\n149\t    created_ids = []\n150\t\n151\t    async def _make(\n152\t        label: str = \"test-key\", rate_limit_per_sec: int = 100, scope: str = \"ingest\"\n153\t    ) -> tuple[str, int]:\n154\t        key_id, secret, presented_key = generate_split_token()\n155\t        secret_hash = hash_new_secret(secret)\n156\t        async with get_engine().begin() as connection:\n157\t            api_key_row_id = await create_api_key(\n158\t                connection,\n159\t                key_id=key_id,\n160\t                secret_hash=secret_hash,\n161\t                label=label,\n162\t                rate_limit_per_sec=rate_limit_per_sec,\n163\t                scope=scope,\n164\t            )\n165\t        created_ids.append(api_key_row_id)\n166\t        return presented_key, api_key_row_id\n167\t\n168\t    yield _make\n169\t"}]},"uuid":"acab4ebf-506d-4dcc-b0c4-c2fae0b02941","timestamp":"2026-07-09T18:11:14.599Z","sourceToolAssistantUUID":"7f5d836c-0312-448e-ba4b-0d1f5c2cfdd0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
