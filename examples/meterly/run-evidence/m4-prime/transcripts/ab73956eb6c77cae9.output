{"parentUuid":"4837d78b-3ca6-4793-b1d6-a12cc2e896bb","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9gfsS4N6ckNGcDgSH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TA1p2zfqocw8HGXFS1bVFf","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_usage_endpoint.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6464,"cache_read_input_tokens":65554,"cache_creation":{"ephemeral_5m_input_tokens":6464,"ephemeral_1h_input_tokens":0},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9epzK1WMFDHezZ8sR","attributionAgent":"implementation","type":"assistant","uuid":"2421274a-59b8-4399-b177-fffe90d31f19","timestamp":"2026-07-09T18:11:19.101Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"2421274a-59b8-4399-b177-fffe90d31f19","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TA1p2zfqocw8HGXFS1bVFf","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/usage` against a real Postgres (AC4, AC5,\n2\tAC15-wire, AC17 tenant isolation).\"\"\"\n3\t\n4\tfrom datetime import datetime, timezone\n5\tfrom decimal import Decimal\n6\t\n7\t\n8\tdef _event_payload(**overrides) -> dict:\n9\t    payload = {\n10\t        \"customer_id\": \"cust_1\",\n11\t        \"metric\": \"api_calls\",\n12\t        \"quantity\": \"5\",\n13\t        \"idempotency_key\": \"idem-1\",\n14\t    }\n15\t    payload.update(overrides)\n16\t    return payload\n17\t\n18\t\n19\tasync def test_usage_returns_correct_aggregate_for_seeded_events(client, make_api_key):\n20\t    \"\"\"AC4: two events in the same hour bucket aggregate to the correct total/count.\"\"\"\n21\t    presented_key, _ = await make_api_key()\n22\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n23\t\n24\t    await client.post(\"/v1/events\", json=_event_payload(idempotency_key=\"a\"), headers=headers)\n25\t    await client.post(\"/v1/events\", json=_event_payload(idempotency_key=\"b\", quantity=\"3\"), headers=headers)\n26\t\n27\t    now = datetime.now(timezone.utc).isoformat()\n28\t    response = await client.get(\n29\t        \"/v1/usage\",\n30\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": now},\n31\t        headers=headers,\n32\t    )\n33\t\n34\t    assert response.status_code == 200\n35\t    body = response.json()\n36\t    assert Decimal(str(body[\"total_quantity\"])) == Decimal(\"8\")\n37\t    assert body[\"event_count\"] == 2\n38\t\n39\t\n40\tasync def test_usage_for_empty_bucket_returns_200_with_zeros(client, make_api_key):\n41\t    \"\"\"AC5: a window with no data returns 200 with zeros, never 404.\"\"\"\n42\t    presented_key, _ = await make_api_key()\n43\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n44\t\n45\t    now = datetime.now(timezone.utc).isoformat()\n46\t    response = await client.get(\n47\t        \"/v1/usage\",\n48\t        params={\"customer_id\": \"cust_no_data\", \"metric\": \"api_calls\", \"window\": now},\n49\t        headers=headers,\n50\t    )\n51\t\n52\t    assert response.status_code == 200\n53\t    body = response.json()\n54\t    assert Decimal(str(body[\"total_quantity\"])) == Decimal(\"0\")\n55\t    assert body[\"event_count\"] == 0\n56\t\n57\t\n58\tasync def test_naive_datetime_window_is_rejected(client, make_api_key):\n59\t    \"\"\"AC15-wire: a naive (no-offset) window is rejected with 422 through the live route.\"\"\"\n60\t    presented_key, _ = await make_api_key()\n61\t    response = await client.get(\n62\t        \"/v1/usage\",\n63\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": \"2026-01-01T00:00:00\"},\n64\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n65\t    )\n66\t    assert response.status_code == 422\n67\t\n68\t\n69\tasync def test_cross_owner_cannot_read_anothers_usage(client, make_api_key):\n70\t    \"\"\"AC17 (IDOR/BOLA): key B querying key A's customer_id gets B's own zero,\n71\t    never A's totals — proves the api_key_id scoping (+ RLS backstop) actually isolates.\"\"\"\n72\t    key_a, _ = await make_api_key(label=\"tenant-a\")\n73\t    key_b, _ = await make_api_key(label=\"tenant-b\")\n74\t\n75\t    await client.post(\n76\t        \"/v1/events\",\n77\t        json=_event_payload(idempotency_key=\"a-1\", quantity=\"1000\"),\n78\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n79\t    )\n80\t\n81\t    now = datetime.now(timezone.utc).isoformat()\n82\t    response = await client.get(\n83\t        \"/v1/usage\",\n84\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": now},\n85\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n86\t    )\n87\t\n88\t    assert response.status_code == 200\n89\t    body = response.json()\n90\t    assert Decimal(str(body[\"total_quantity\"])) == Decimal(\"0\")\n91\t    assert body[\"event_count\"] == 0\n92\t\n93\t\n94\tasync def test_cross_owner_idempotency_key_is_scoped_per_tenant(client, make_api_key):\n95\t    \"\"\"AC17 write-path: the same idempotency_key string used by two different\n96\t    keys creates two independent events, not a cross-tenant collision.\"\"\"\n97\t    key_a, api_key_id_a = await make_api_key(label=\"tenant-a\")\n98\t    key_b, api_key_id_b = await make_api_key(label=\"tenant-b\")\n99\t\n100\t    response_a = await client.post(\n101\t        \"/v1/events\",\n102\t        json=_event_payload(idempotency_key=\"shared-key\"),\n103\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n104\t    )\n105\t    response_b = await client.post(\n106\t        \"/v1/events\",\n107\t        json=_event_payload(idempotency_key=\"shared-key\"),\n108\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n109\t    )\n110\t\n111\t    assert response_a.status_code == 201\n112\t    assert response_b.status_code == 201\n113\t    assert response_a.json()[\"event_id\"] != response_b.json()[\"event_id\"]\n114\t"}]},"uuid":"fdabc9b9-0e30-49cf-bda9-150f1857ab96","timestamp":"2026-07-09T18:11:19.150Z","sourceToolAssistantUUID":"2421274a-59b8-4399-b177-fffe90d31f19","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"fdabc9b9-0e30-49cf-bda9-150f1857ab96","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9gfsS4N6ckNGcDgSH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_016Wai47amiCS2AUdcbCzTVy","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_schemas_usage.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6464,"cache_read_input_tokens":65554,"cache_creation":{"ephemeral_5m_input_tokens":6464,"ephemeral_1h_input_tokens":0},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9epzK1WMFDHezZ8sR","attributionAgent":"implementation","type":"assistant","uuid":"c0b1d5cb-7a32-4a8e-a4b8-543d099cc4e7","timestamp":"2026-07-09T18:11:19.907Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"c0b1d5cb-7a32-4a8e-a4b8-543d099cc4e7","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016Wai47amiCS2AUdcbCzTVy","type":"tool_result","content":"1\t\"\"\"Validation-contract tests for `UsageQueryParams` (AC15).\"\"\"\n2\t\n3\tfrom datetime import datetime, timedelta, timezone\n4\t\n5\timport pytest\n6\tfrom pydantic import ValidationError\n7\t\n8\tfrom src.api.schemas.usage import UsageQueryParams\n9\t\n10\t\n11\tdef _valid_query(**overrides) -> dict:\n12\t    payload = {\n13\t        \"customer_id\": \"cust_123\",\n14\t        \"metric\": \"api_calls\",\n15\t        \"window\": datetime.now(timezone.utc).isoformat(),\n16\t    }\n17\t    payload.update(overrides)\n18\t    return payload\n19\t\n20\t\n21\tdef test_accepts_a_well_formed_query():\n22\t    \"\"\"A valid, timezone-aware window within range parses successfully.\"\"\"\n23\t    query = UsageQueryParams(**_valid_query())\n24\t    assert query.customer_id == \"cust_123\"\n25\t\n26\t\n27\tdef test_rejects_naive_datetime():\n28\t    \"\"\"A naive (no-offset) datetime is rejected rather than silently assumed UTC.\"\"\"\n29\t    with pytest.raises(ValidationError):\n30\t        UsageQueryParams(**_valid_query(window=\"2026-01-01T00:00:00\"))\n31\t\n32\t\n33\tdef test_rejects_window_too_far_in_the_past():\n34\t    \"\"\"A window older than 90 days is rejected (unbounded query-cost guard).\"\"\"\n35\t    too_old = datetime.now(timezone.utc) - timedelta(days=91)\n36\t    with pytest.raises(ValidationError):\n37\t        UsageQueryParams(**_valid_query(window=too_old.isoformat()))\n38\t\n39\t\n40\tdef test_rejects_window_too_far_in_the_future():\n41\t    \"\"\"A window more than 1 hour ahead is rejected.\"\"\"\n42\t    too_future = datetime.now(timezone.utc) + timedelta(hours=2)\n43\t    with pytest.raises(ValidationError):\n44\t        UsageQueryParams(**_valid_query(window=too_future.isoformat()))\n45\t\n46\t\n47\t@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\n48\tdef test_rejects_injection_in_customer_id(customer_id):\n49\t    \"\"\"Injection payloads in customer_id are rejected at the boundary.\"\"\"\n50\t    with pytest.raises(ValidationError):\n51\t        UsageQueryParams(**_valid_query(customer_id=customer_id))\n52\t\n53\t\n54\tdef test_rejects_unknown_fields():\n55\t    \"\"\"`extra='forbid'` rejects an unexpected query parameter.\"\"\"\n56\t    with pytest.raises(ValidationError):\n57\t        UsageQueryParams(**_valid_query(api_key_id=999))\n58\t"}]},"uuid":"5919557a-cc57-4f08-a541-94b278c3387c","timestamp":"2026-07-09T18:11:19.949Z","sourceToolAssistantUUID":"c0b1d5cb-7a32-4a8e-a4b8-543d099cc4e7","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"5919557a-cc57-4f08-a541-94b278c3387c","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9gfsS4N6ckNGcDgSH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013aQwG2JjY9PrUgVqtTr5mn","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\routes\\quotas.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6464,"cache_read_input_tokens":65554,"cache_creation":{"ephemeral_5m_input_tokens":6464,"ephemeral_1h_input_tokens":0},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9epzK1WMFDHezZ8sR","attributionAgent":"implementation","type":"assistant","uuid":"663607bc-5c8a-4ab0-9c61-c248613c6818","timestamp":"2026-07-09T18:11:20.286Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"663607bc-5c8a-4ab0-9c61-c248613c6818","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013aQwG2JjY9PrUgVqtTr5mn","type":"tool_result","content":"1\t\"\"\"`PUT /v1/quotas` — admin-scoped create-or-replace of a per-customer,\n2\tper-metric usage cap.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\n7\tmirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\n8\tpattern (kept per-route, not shared, per the existing convention).\n9\t\"\"\"\n10\t\n11\tfrom fastapi import APIRouter, Depends, HTTPException, Request, Response, status\n12\t\n13\tfrom src.api.schemas.quotas import QuotaPutRequest, QuotaResponse\n14\tfrom src.auth import require_api_key\n15\tfrom src.auth.api_key import AuthenticatedPrincipal\n16\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n17\tfrom src.logging import get_logger\n18\tfrom src.services.quota_service import to_response, upsert_tenant_quota\n19\t\n20\trouter = APIRouter(tags=[\"quotas\"])\n21\tlogger = get_logger(service=\"meterly\")\n22\t\n23\t_ADMIN_SCOPE = \"admin\"\n24\t\n25\t\n26\tasync def _require_admin_and_throttled(\n27\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n28\t) -> AuthenticatedPrincipal:\n29\t    \"\"\"Compose auth, then the Tier-2 per-key throttle, then the admin-scope\n30\t    gate, in that order — mirrors `src/api/routes/events.py`'s dependency\n31\t    chain, extended with the function-level authorization check this route\n32\t    alone requires (ASVS 8.2.1).\n33\t    \"\"\"\n34\t    await enforce_tier2_rate_limit(request, principal)\n35\t    if principal.scope != _ADMIN_SCOPE:\n36\t        logger.warning(\n37\t            \"quota.forbidden\",\n38\t            userId=principal.api_key_id,\n39\t            action=\"deny\",\n40\t            reason=\"insufficient_scope\",\n41\t        )\n42\t        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"admin scope required\")\n43\t    return principal\n44\t\n45\t\n46\t@router.put(\"/v1/quotas\", response_model=QuotaResponse)\n47\tasync def put_quota(\n48\t    payload: QuotaPutRequest,\n49\t    response: Response,\n50\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n51\t) -> QuotaResponse:\n52\t    \"\"\"Create or replace the cap for `(customer_id, metric)` under the\n53\t    caller's own tenant — 201 on create, 200 on replace.\"\"\"\n54\t    outcome = await upsert_tenant_quota(principal, payload)\n55\t    response.status_code = outcome.http_status\n56\t    return to_response(outcome)\n57\t"}]},"uuid":"c3afe58d-efe9-4de8-ab4f-deb38a2f0ac3","timestamp":"2026-07-09T18:11:20.337Z","sourceToolAssistantUUID":"663607bc-5c8a-4ab0-9c61-c248613c6818","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"c3afe58d-efe9-4de8-ab4f-deb38a2f0ac3","isSidechain":true,"agentId":"ab73956eb6c77cae9","message":{"model":"claude-sonnet-5","id":"msg_011Ccrw9gfsS4N6ckNGcDgSH","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LPtBxEo6o8suVnY1sM12Xn","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_perf_smoke.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6464,"cache_read_input_tokens":65554,"cache_creation":{"ephemeral_5m_input_tokens":6464,"ephemeral_1h_input_tokens":0},"output_tokens":9,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccrw9epzK1WMFDHezZ8sR","attributionAgent":"implementation","type":"assistant","uuid":"957d27a2-3842-410e-b9bf-13fb95f8f3cd","timestamp":"2026-07-09T18:11:20.643Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"957d27a2-3842-410e-b9bf-13fb95f8f3cd","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LPtBxEo6o8suVnY1sM12Xn","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF smoke measurement.\n2\t\n3\tThis is a **smoke-sized** perf check against a real, separately-running\n4\tuvicorn process (real network stack, real Postgres + Redis testcontainers) —\n5\tnot a full k6/Locust load campaign (neither is installed in this sandboxed\n6\tWindows environment; see `.pipeline/test-results.json`'s `perf.scenario` for\n7\tthe honest disclosure of what this run actually drove). It is a directional\n8\tregression signal only. The declared budget (p95 < 50 ms @ >= 475 req/s\n9\tsustained, distributed key space) requires a dedicated load-test rig\n10\t(constant-arrival-rate k6 scenario against a deployed/staging environment) to\n11\tmeasure properly; this smoke run intentionally does not claim to satisfy it.\n12\t\"\"\"\n13\t\n14\timport asyncio\n15\timport socket\n16\timport subprocess\n17\timport sys\n18\timport time\n19\tfrom contextlib import closing\n20\tfrom pathlib import Path\n21\t\n22\timport httpx\n23\timport pytest\n24\t\n25\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n26\t\n27\t\n28\tdef _free_port() -> int:\n29\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n30\t        sock.bind((\"127.0.0.1\", 0))\n31\t        return sock.getsockname()[1]\n32\t\n33\t\n34\t@pytest.fixture\n35\tasync def running_server(postgres_url, redis_url, make_api_key, truncate_tables):\n36\t    \"\"\"Launch the real app under uvicorn, out-of-process, against the live containers.\"\"\"\n37\t    import os\n38\t\n39\t    port = _free_port()\n40\t    env = dict(os.environ)\n41\t    env[\"DATABASE_URL\"] = postgres_url\n42\t    env[\"METERLY_REDIS_URL\"] = redis_url\n43\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"100000\"\n44\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"100000\"\n45\t\n46\t    presented_key, _ = await make_api_key(rate_limit_per_sec=100000)\n47\t\n48\t    process = subprocess.Popen(\n49\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"127.0.0.1\", \"--port\", str(port)],\n50\t        cwd=str(_REPO_ROOT),\n51\t        env=env,\n52\t        stdout=subprocess.PIPE,\n53\t        stderr=subprocess.STDOUT,\n54\t        text=True,\n55\t    )\n56\t    base_url = f\"http://127.0.0.1:{port}\"\n57\t\n58\t    try:\n59\t        deadline = time.monotonic() + 20\n60\t        async with httpx.AsyncClient() as probe:\n61\t            while time.monotonic() < deadline:\n62\t                try:\n63\t                    response = await probe.get(f\"{base_url}/health\", timeout=1.0)\n64\t                    if response.status_code == 200:\n65\t                        break\n66\t                except httpx.TransportError:\n67\t                    pass\n68\t                await asyncio.sleep(0.3)\n69\t            else:\n70\t                pytest.skip(\"uvicorn did not become ready in time in this sandboxed environment\")\n71\t\n72\t        yield base_url, presented_key\n73\t    finally:\n74\t        process.terminate()\n75\t        try:\n76\t            process.wait(timeout=5)\n77\t        except subprocess.TimeoutExpired:\n78\t            process.kill()\n79\t\n80\t\n81\tdef _nearest_rank_percentile(sorted_samples: list, percentile: float) -> float:\n82\t    \"\"\"The budgeted percentile via nearest-rank over the captured per-request\n83\t    latencies (never a load tool's named-bucket field — see test-conventions).\"\"\"\n84\t    if not sorted_samples:\n85\t        return float(\"nan\")\n86\t    rank = max(1, int(round(percentile / 100 * len(sorted_samples))))\n87\t    return sorted_samples[min(rank, len(sorted_samples)) - 1]\n88\t\n89\t\n90\tasync def test_events_ingest_smoke_load(running_server):\n91\t    \"\"\"Drive a short, bounded-concurrency smoke load against `POST /v1/events`\n92\t    and record true p95 (nearest-rank) + achieved throughput — reported as a\n93\t    directional smoke signal, not a claim that the 500 req/s budget is met.\"\"\"\n94\t    base_url, presented_key = running_server\n95\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n96\t    concurrency = 5\n97\t    duration_seconds = 2\n98\t    latencies_ms: list[float] = []\n99\t    errors: list[str] = []\n100\t    stop_at = time.monotonic() + duration_seconds\n101\t\n102\t    async def _worker(worker_id: int, client: httpx.AsyncClient):\n103\t        request_index = 0\n104\t        while time.monotonic() < stop_at:\n105\t            payload = {\n106\t                \"customer_id\": f\"cust_{worker_id}\",\n107\t                \"metric\": \"api_calls\",\n108\t                \"quantity\": \"1\",\n109\t                \"idempotency_key\": f\"perf-{worker_id}-{request_index}\",\n110\t            }\n111\t            started = time.perf_counter()\n112\t            try:\n113\t                response = await client.post(f\"{base_url}/v1/events\", json=payload, headers=headers, timeout=15.0)\n114\t            except httpx.HTTPError as exc:  # noqa: PERF203 - a slow/failed request is data, not a hard failure here\n115\t                errors.append(str(exc))\n116\t                request_index += 1\n117\t                continue\n118\t            latencies_ms.append((time.perf_counter() - started) * 1000)\n119\t            if response.status_code not in (200, 201):\n120\t                errors.append(f\"unexpected status {response.status_code}\")\n121\t            request_index += 1\n122\t\n123\t    async with httpx.AsyncClient() as client:\n124\t        started_at = time.monotonic()\n125\t        await asyncio.gather(*(_worker(worker_id, client) for worker_id in range(concurrency)))\n126\t        elapsed = time.monotonic() - started_at\n127\t\n128\t    if not latencies_ms:\n129\t        pytest.skip(\n130\t            \"no successful requests completed in this sandboxed environment \"\n131\t            f\"(errors: {errors[:3]}) — perf.measured is recorded as null, not fabricated\"\n132\t        )\n133\t\n134\t    latencies_ms.sort()\n135\t    p95_ms = _nearest_rank_percentile(latencies_ms, 95)\n136\t    throughput_rps = len(latencies_ms) / elapsed if elapsed > 0 else 0.0\n137\t\n138\t    # Write the measured numbers where the results-writing step can pick them\n139\t    # up; this test's job is to produce an honest directional measurement,\n140\t    # not to assert against the full 500 req/s / p95<50ms budget (a smoke run\n141\t    # at concurrency=20 in a sandboxed dev environment cannot claim that).\n142\t    import json\n143\t    import os\n144\t    import tempfile\n145\t\n146\t    scratch_dir = os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())\n147\t    scratch_path = Path(scratch_dir) / \"meterly_perf_smoke_measurement.json\"\n148\t    scratch_path.write_text(\n149\t        json.dumps(\n150\t            {\n151\t                \"p95_ms\": round(p95_ms, 2),\n152\t                \"throughput_rps\": round(throughput_rps, 2),\n153\t                \"sample_count\": len(latencies_ms),\n154\t                \"concurrency\": concurrency,\n155\t                \"duration_seconds\": duration_seconds,\n156\t            }\n157\t        )\n158\t    )\n159\t\n160\t    assert len(latencies_ms) > 0\n161\t    # Note: this is a directional smoke measurement only (small concurrency,\n162\t    # short duration, no dedicated load-test rig) — it does NOT assert against\n163\t    # the full AC6 budget (p95<50ms @ >=475 req/s sustained), which requires a\n164\t    # real k6/Locust run against a deployed environment. See perf.scenario in\n165\t    # test-results.json for the honest disclosure of what this run measured.\n166\t"}]},"uuid":"faa75c23-bf04-4e95-9c27-f76c5d988a3c","timestamp":"2026-07-09T18:11:20.679Z","sourceToolAssistantUUID":"957d27a2-3842-410e-b9bf-13fb95f8f3cd","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
