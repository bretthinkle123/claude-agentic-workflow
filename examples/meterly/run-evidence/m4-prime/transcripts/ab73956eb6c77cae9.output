{"parentUuid":"c70e46b8-e018-48b5-a43b-645f1e893f65","isSidechain":true,"promptId":"42022266-80ed-4b1b-af25-460921b78a21","agentId":"ab73956eb6c77cae9","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XdDHXWEVReCpT1NrNKeQVB","type":"tool_result","content":"1\t\"\"\"Request-scoped logging middleware: assigns `requestId`/`traceId`, binds them\n2\tinto structlog's contextvars so every log line emitted during the request\n3\tcarries them, and logs one completion event with `duration`/`statusCode`.\n4\t\n5\tRegistered first in the middleware stack (`src/api/middleware.py`) — outermost —\n6\tso every mitigation below it (security headers, throttles, auth, the handler)\n7\tlogs with a correlation id already attached.\n8\t\"\"\"\n9\t\n10\timport time\n11\timport uuid\n12\tfrom collections.abc import Awaitable, Callable\n13\t\n14\timport structlog\n15\tfrom opentelemetry import trace\n16\tfrom starlette.middleware.base import BaseHTTPMiddleware\n17\tfrom starlette.requests import Request\n18\tfrom starlette.responses import Response\n19\t\n20\tfrom src.logging import get_logger\n21\t\n22\tlogger = get_logger(service=\"meterly\")\n23\t\n24\t_AWS_TRACE_HEADER = \"x-amzn-trace-id\"\n25\t\n26\t\n27\tdef _resolve_trace_id(request: Request) -> str:\n28\t    \"\"\"Resolve a trace id in priority order: active OTel span, then the AWS\n29\t    `X-Amzn-Trace-Id` header, then a freshly generated UUID.\"\"\"\n30\t    span = trace.get_current_span()\n31\t    span_context = span.get_span_context()\n32\t    if span_context is not None and span_context.is_valid:\n33\t        return format(span_context.trace_id, \"032x\")\n34\t\n35\t    aws_header = request.headers.get(_AWS_TRACE_HEADER)\n36\t    if aws_header:\n37\t        for segment in aws_header.split(\";\"):\n38\t            if segment.strip().startswith(\"Root=\"):\n39\t                return segment.strip()[len(\"Root=\") :]\n40\t\n41\t    return str(uuid.uuid4())\n42\t\n43\t\n44\tclass RequestContextMiddleware(BaseHTTPMiddleware):\n45\t    \"\"\"Binds `requestId`/`traceId` to the logging context for the lifetime of\n46\t    a request and emits one structured completion log per request.\"\"\"\n47\t\n48\t    async def dispatch(\n49\t        self, request: Request, call_next: Callable[[Request], Awaitable[Response]]\n50\t    ) -> Response:\n51\t        \"\"\"Assign correlation ids, run the request, and log its outcome.\"\"\"\n52\t        request_id = str(uuid.uuid4())\n53\t        trace_id = _resolve_trace_id(request)\n54\t        started_at = time.monotonic()\n55\t\n56\t        structlog.contextvars.clear_contextvars()\n57\t        structlog.contextvars.bind_contextvars(requestId=request_id, traceId=trace_id)\n58\t        request.state.request_id = request_id\n59\t\n60\t        try:\n61\t            response = await call_next(request)\n62\t        except Exception:\n63\t            duration_ms = round((time.monotonic() - started_at) * 1000, 2)\n64\t            logger.error(\n65\t                \"request.failed\",\n66\t                operation=f\"{request.method} {request.url.path}\",\n67\t                duration=duration_ms,\n68\t                method=request.method,\n69\t                endpoint=request.url.path,\n70\t            )\n71\t            raise\n72\t\n73\t        duration_ms = round((time.monotonic() - started_at) * 1000, 2)\n74\t        response.headers[\"X-Request-Id\"] = request_id\n75\t        logger.info(\n76\t            \"request.completed\",\n77\t            operation=f\"{request.method} {request.url.path}\",\n78\t            statusCode=response.status_code,\n79\t            duration=duration_ms,\n80\t            method=request.method,\n81\t            endpoint=request.url.path,\n82\t        )\n83\t        return response\n84\t"}]},"uuid":"3af2ab0f-ff31-4476-bd25-72b795de5097","timestamp":"2026-07-09T18:26:24.670Z","sourceToolAssistantUUID":"c70e46b8-e018-48b5-a43b-645f1e893f65","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
