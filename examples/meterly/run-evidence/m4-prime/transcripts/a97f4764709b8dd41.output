{"parentUuid":"c19c7707-ce2c-4d34-952c-318420399643","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S5BzfPB2vKA1CX6Fk1acFk","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage/export`.\n2\t\n3\tReuses the exact `customer_id`/`metric` anchored allowlists\n4\t`src/api/schemas/events.py` already enforces for the SQL sink these filters\n5\tshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\n6\tapplied here as an optional `[from, to]` range rather than a single\n7\tpoint-in-time window.\n8\t\"\"\"\n9\t\n10\tfrom datetime import datetime, timedelta, timezone\n11\t\n12\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n13\t\n14\tfrom src.api.schemas.events import CustomerId, Metric\n15\t\n16\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n17\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n18\t\n19\t\n20\tclass UsageExportQueryParams(BaseModel):\n21\t    \"\"\"Optional filters for `GET /v1/usage/export`.\n22\t\n23\t    Every field is optional; omitting all of them exports the caller's full\n24\t    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n25\t    unknown query parameter — the same mass-assignment posture the write\n26\t    schemas use, applied to a read (a client-supplied `api_key_id` is\n27\t    rejected rather than silently ignored).\n28\t    \"\"\"\n29\t\n30\t    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n31\t\n32\t    customer_id: CustomerId | None = None\n33\t    metric: Metric | None = None\n34\t    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n35\t    to: AwareDatetime | None = None\n36\t\n37\t    @model_validator(mode=\"after\")\n38\t    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n39\t        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n40\t        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n41\t        so a caller can't probe arbitrarily far into the past (unbounded\n42\t        query cost) or the future.\"\"\"\n43\t        now = datetime.now(timezone.utc)\n44\t        earliest = now - _MAX_WINDOW_LOOKBACK\n45\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n46\t\n47\t        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n48\t            if value is not None and not (earliest <= value <= latest):\n49\t                raise ValueError(\n50\t                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n51\t                )\n52\t\n53\t        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n54\t            raise ValueError(\"from must be <= to\")\n55\t\n56\t        return self\n57\t"}]},"uuid":"7871ae22-697b-49aa-8f95-fc48a54172da","timestamp":"2026-07-09T19:07:18.518Z","sourceToolAssistantUUID":"c19c7707-ce2c-4d34-952c-318420399643","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"7871ae22-697b-49aa-8f95-fc48a54172da","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1RNtwqyrJpJocfBmUa","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TPTuLE6TetsqjMzvLehW4Q","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_schemas_usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5938,"cache_read_input_tokens":57211,"output_tokens":219,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":5938},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":219,"cache_read_input_tokens":57211,"cache_creation_input_tokens":5938,"cache_creation":{"ephemeral_5m_input_tokens":5938,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccs1RMrCKwuVSUo2UWwZg","attributionAgent":"testing","type":"assistant","uuid":"742d0343-6467-412c-b4d9-59936209dca8","timestamp":"2026-07-09T19:07:18.700Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"742d0343-6467-412c-b4d9-59936209dca8","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TPTuLE6TetsqjMzvLehW4Q","type":"tool_result","content":"1\t\"\"\"Validation-contract tests for `UsageExportQueryParams` (AC2, AC3, AC4).\"\"\"\n2\t\n3\tfrom datetime import datetime, timedelta, timezone\n4\t\n5\timport pytest\n6\tfrom pydantic import ValidationError\n7\t\n8\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n9\t\n10\t\n11\tdef test_all_filters_omitted_is_valid():\n12\t    \"\"\"AC2: every filter is optional — an empty query parses successfully.\"\"\"\n13\t    query = UsageExportQueryParams()\n14\t    assert query.customer_id is None\n15\t    assert query.metric is None\n16\t    assert query.from_ is None\n17\t    assert query.to is None\n18\t\n19\t\n20\tdef test_accepts_well_formed_filters():\n21\t    \"\"\"AC2: customer_id/metric/from/to all parse when supplied together.\"\"\"\n22\t    now = datetime.now(timezone.utc)\n23\t    query = UsageExportQueryParams(\n24\t        customer_id=\"cust_123\",\n25\t        metric=\"api_calls\",\n26\t        **{\"from\": (now - timedelta(days=1)).isoformat()},\n27\t        to=now.isoformat(),\n28\t    )\n29\t    assert query.customer_id == \"cust_123\"\n30\t    assert query.metric == \"api_calls\"\n31\t    assert query.from_ is not None\n32\t    assert query.to is not None\n33\t\n34\t\n35\tdef test_from_alias_binds_to_from__field():\n36\t    \"\"\"AC3: the query param name `from` (a Python keyword) binds to `from_`.\"\"\"\n37\t    now = datetime.now(timezone.utc)\n38\t    query = UsageExportQueryParams(**{\"from\": now.isoformat()})\n39\t    assert query.from_ == now\n40\t\n41\t\n42\tdef test_rejects_naive_from_datetime():\n43\t    \"\"\"AC3: a naive (no-offset) `from` is rejected rather than silently assumed UTC.\"\"\"\n44\t    with pytest.raises(ValidationError):\n45\t        UsageExportQueryParams(**{\"from\": \"2026-01-01T00:00:00\"})\n46\t\n47\t\n48\tdef test_rejects_naive_to_datetime():\n49\t    \"\"\"AC3: a naive (no-offset) `to` is rejected.\"\"\"\n50\t    with pytest.raises(ValidationError):\n51\t        UsageExportQueryParams(to=\"2026-01-01T00:00:00\")\n52\t\n53\t\n54\tdef test_rejects_from_after_to():\n55\t    \"\"\"AC3: from > to is an invalid (inverted) range.\"\"\"\n56\t    now = datetime.now(timezone.utc)\n57\t    with pytest.raises(ValidationError):\n58\t        UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": (now - timedelta(days=1)).isoformat()})\n59\t\n60\t\n61\tdef test_accepts_from_equal_to_to():\n62\t    \"\"\"AC3: from == to is a valid (zero-width) range.\"\"\"\n63\t    now = datetime.now(timezone.utc)\n64\t    query = UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": now.isoformat()})\n65\t    assert query.from_ == query.to\n66\t\n67\t\n68\tdef test_rejects_from_too_far_in_the_past():\n69\t    \"\"\"AC3: from older than 90 days is rejected (unbounded query-cost guard).\"\"\"\n70\t    too_old = datetime.now(timezone.utc) - timedelta(days=91)\n71\t    with pytest.raises(ValidationError):\n72\t        UsageExportQueryParams(**{\"from\": too_old.isoformat()})\n73\t\n74\t\n75\tdef test_rejects_to_too_far_in_the_future():\n76\t    \"\"\"AC3: to more than 1 hour ahead is rejected.\"\"\"\n77\t    too_future = datetime.now(timezone.utc) + timedelta(hours=2)\n78\t    with pytest.raises(ValidationError):\n79\t        UsageExportQueryParams(to=too_future.isoformat())\n80\t\n81\t\n82\t@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\n83\tdef test_rejects_injection_in_customer_id(customer_id):\n84\t    \"\"\"AC4: injection payloads in customer_id are rejected at the boundary.\"\"\"\n85\t    with pytest.raises(ValidationError):\n86\t        UsageExportQueryParams(customer_id=customer_id)\n87\t\n88\t\n89\tdef test_rejects_unknown_fields():\n90\t    \"\"\"AC4: `extra='forbid'` rejects an unexpected query parameter (e.g. a\n91\t    client-supplied `api_key_id` probe).\"\"\"\n92\t    with pytest.raises(ValidationError):\n93\t        UsageExportQueryParams(api_key_id=999)\n94\t"}]},"uuid":"d37ac516-312b-4f32-b585-2ecfca5b8b85","timestamp":"2026-07-09T19:07:18.717Z","sourceToolAssistantUUID":"742d0343-6467-412c-b4d9-59936209dca8","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
