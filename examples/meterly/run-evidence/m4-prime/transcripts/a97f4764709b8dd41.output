{"parentUuid":"55e88601-5657-4138-9d4e-b49fa757c672","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0161reZsqZwiW4HanFy8hHk5","type":"tool_result","content":"1\t\"\"\"`GET /v1/usage/export` — streams the authenticated caller's own\n2\t`usage_rollup` rows as an RFC 4180 CSV.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> schema validation -> a two-phase pre-flight-cap +\n7\tstream service call, mirroring `src/api/routes/usage.py`'s composition. Kept\n8\tin its own module (not added to `usage.py`) so `GET /v1/usage`'s code path is\n9\tliterally untouched by this change — the brief's no-behavior-change\n10\tconstraint is then trivially auditable in the diff.\n11\t\"\"\"\n12\t\n13\tfrom datetime import datetime, timezone\n14\tfrom typing import Annotated\n15\t\n16\tfrom fastapi import APIRouter, Depends, Query, Request\n17\tfrom fastapi.responses import StreamingResponse\n18\t\n19\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n20\tfrom src.auth import require_api_key\n21\tfrom src.auth.api_key import AuthenticatedPrincipal\n22\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n23\tfrom src.services.usage_export_service import prepare_export, stream_export_csv\n24\t\n25\trouter = APIRouter(tags=[\"usage\"])\n26\t\n27\t# Explicit OpenAPI response metadata: a StreamingResponse has no `response_model`\n28\t# for FastAPI to introspect, so the served schema would otherwise omit the real\n29\t# response shape — this is what a DAST scanner (and AC19) reads.\n30\t_EXPORT_RESPONSES: dict = {\n31\t    200: {\n32\t        \"description\": \"The caller's usage_rollup rows as RFC 4180 CSV (header row always first).\",\n33\t        \"content\": {\"text/csv\": {\"schema\": {\"type\": \"string\", \"format\": \"binary\"}}},\n34\t    },\n35\t    422: {\n36\t        \"description\": \"Validation failure, or the filtered result exceeds the 100,000-row export cap.\",\n37\t        \"content\": {\n38\t            \"application/json\": {\n39\t                \"example\": {\n40\t                    \"error\": {\n41\t                        \"code\": \"validation_failed\",\n42\t                        \"message\": \"result exceeds 100000 rows; narrow with customer_id, metric, from, and/or to\",\n43\t                        \"requestId\": \"…\",\n44\t                    }\n45\t                }\n46\t            }\n47\t        },\n48\t    },\n49\t}\n50\t\n51\t\n52\tasync def _require_authenticated_and_throttled(\n53\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n54\t) -> AuthenticatedPrincipal:\n55\t    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (kept as\n56\t    a sibling, not a shared import, per the existing per-route convention —\n57\t    each route's dependency chain stays independently readable).\"\"\"\n58\t    await enforce_tier2_rate_limit(request, principal)\n59\t    return principal\n60\t\n61\t\n62\tdef _export_filename(now: datetime) -> str:\n63\t    \"\"\"Build the `Content-Disposition` filename: a UTC timestamp only — no\n64\t    tenant identifier, so the filename itself never leaks `api_key_id` or any\n65\t    caller identity (ASVS 14.3.2).\"\"\"\n66\t    return f\"usage-export-{now:%Y%m%dT%H%M%SZ}.csv\"\n67\t\n68\t\n69\t@router.get(\"/v1/usage/export\", responses=_EXPORT_RESPONSES)\n70\tasync def get_usage_export(\n71\t    params: Annotated[UsageExportQueryParams, Query()],\n72\t    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n73\t) -> StreamingResponse:\n74\t    \"\"\"Stream the caller's own `usage_rollup` rows as CSV, optionally\n75\t    narrowed by `customer_id`/`metric`/`from`/`to`.\n76\t\n77\t    Two-phase: `prepare_export` runs the pre-flight row-cap check (a clean\n78\t    422 over 100,000 rows, or a fail-closed generic 500 on an unexpected\n79\t    error — AC22) before any response byte; only then is the\n80\t    `StreamingResponse` constructed. Starlette pulls `stream_export_csv`\n81\t    after this handler returns, so the generator opens its own DB\n82\t    transaction rather than reusing one already closed by the time it runs.\n83\t    \"\"\"\n84\t    await prepare_export(principal, params)\n85\t\n86\t    filename = _export_filename(datetime.now(timezone.utc))\n87\t    return StreamingResponse(\n88\t        stream_export_csv(principal, params),\n89\t        media_type=\"text/csv; charset=utf-8\",\n90\t        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},\n91\t    )\n92\t"}]},"uuid":"d5055507-2a96-4d5e-810a-3366314c4dca","timestamp":"2026-07-09T19:07:22.249Z","sourceToolAssistantUUID":"55e88601-5657-4138-9d4e-b49fa757c672","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
