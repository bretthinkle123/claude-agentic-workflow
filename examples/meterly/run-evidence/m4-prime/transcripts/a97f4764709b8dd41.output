{"parentUuid":"4c432748-1643-4dda-9d31-55a91f2ed430","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1QcPHQBUL8971o14EE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y7N3vz86sFJ8FwFa1D7sBL","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_usage_export_endpoint.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":758,"cache_read_input_tokens":44246,"cache_creation":{"ephemeral_5m_input_tokens":758,"ephemeral_1h_input_tokens":0},"output_tokens":56,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs1QZsDvzbZof5ebgWe1","attributionAgent":"testing","type":"assistant","uuid":"8097d676-cfe9-4c01-b6f5-fe5fd1364125","timestamp":"2026-07-09T19:07:07.237Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"8097d676-cfe9-4c01-b6f5-fe5fd1364125","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y7N3vz86sFJ8FwFa1D7sBL","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/usage/export` against a real Postgres:\n2\tstreaming correctness, tenant isolation, the row cap, formula-escaping\n3\tend-to-end, response headers, and the pre-flight fail-closed safe-error path\n4\t(AC1-AC13, AC17, AC19, AC22).\n5\t\"\"\"\n6\t\n7\timport asyncio\n8\timport re\n9\timport socket\n10\timport subprocess\n11\timport sys\n12\timport time\n13\tfrom contextlib import closing\n14\tfrom datetime import datetime, timedelta, timezone\n15\tfrom pathlib import Path\n16\t\n17\timport httpx\n18\timport pytest\n19\tfrom httpx import ASGITransport, AsyncClient\n20\tfrom sqlalchemy import text\n21\t\n22\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n23\t\n24\t\n25\tdef _event_payload(**overrides) -> dict:\n26\t    payload = {\n27\t        \"customer_id\": \"cust_1\",\n28\t        \"metric\": \"api_calls\",\n29\t        \"quantity\": \"5\",\n30\t        \"idempotency_key\": \"idem-1\",\n31\t    }\n32\t    payload.update(overrides)\n33\t    return payload\n34\t\n35\t\n36\tasync def _bulk_insert_rollups(\n37\t    postgres_url, *, api_key_id: int, metric: str, window_start: datetime, count: int\n38\t) -> None:\n39\t    \"\"\"Directly seed `usage_rollup` rows via a single set-based INSERT — the\n40\t    cap/perf tests need tens of thousands of rows, which is impractical to\n41\t    seed one ingest POST at a time.\"\"\"\n42\t    from sqlalchemy.ext.asyncio import create_async_engine\n43\t\n44\t    engine = create_async_engine(postgres_url)\n45\t    async with engine.begin() as connection:\n46\t        await connection.execute(\n47\t            text(\n48\t                \"\"\"\n49\t                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n50\t                SELECT :api_key_id, 'cust_' || lpad(gs::text, 8, '0'), :metric, :window_start, 1, 1\n51\t                FROM generate_series(1, :count) AS gs\n52\t                \"\"\"\n53\t            ),\n54\t            {\"api_key_id\": api_key_id, \"metric\": metric, \"window_start\": window_start, \"count\": count},\n55\t        )\n56\t    await engine.dispose()\n57\t\n58\t\n59\tasync def test_export_is_header_only_csv_for_empty_result(client, make_api_key):\n60\t    \"\"\"AC12: a caller with no matching rollups gets 200 with a single header\n61\t    line, never 404.\"\"\"\n62\t    presented_key, _ = await make_api_key()\n63\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n64\t\n65\t    assert response.status_code == 200\n66\t    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n67\t\n68\t\n69\tasync def test_export_with_no_filters_returns_all_caller_rows(client, make_api_key):\n70\t    \"\"\"AC2: omitting every filter exports the caller's full row set.\"\"\"\n71\t    presented_key, _ = await make_api_key()\n72\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n73\t\n74\t    await client.post(\n75\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n76\t    )\n77\t    await client.post(\n78\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n79\t    )\n80\t\n81\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n82\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n83\t\n84\t    assert response.status_code == 200\n85\t    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n86\t    assert len(lines) == 3  # header + 2 rows\n87\t\n88\t\n89\tasync def test_export_customer_id_filter_narrows_the_result(client, make_api_key):\n90\t    \"\"\"AC2: a customer_id filter excludes rows for other customers.\"\"\"\n91\t    presented_key, _ = await make_api_key()\n92\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n93\t\n94\t    await client.post(\n95\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n96\t    )\n97\t    await client.post(\n98\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n99\t    )\n100\t\n101\t    response = await client.get(\n102\t        \"/v1/usage/export\", params={\"customer_id\": \"cust_a\"}, headers=headers\n103\t    )\n104\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n105\t\n106\t    assert len(lines) == 2  # header + cust_a only\n107\t    assert \"cust_a\" in lines[1]\n108\t    assert \"cust_b\" not in response.text\n109\t\n110\t\n111\tasync def test_export_metric_filter_narrows_the_result(client, make_api_key):\n112\t    \"\"\"AC2: a metric filter excludes rows for other metrics.\"\"\"\n113\t    presented_key, _ = await make_api_key()\n114\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n115\t\n116\t    await client.post(\n117\t        \"/v1/events\", json=_event_payload(metric=\"api_calls\", idempotency_key=\"a\"), headers=headers\n118\t    )\n119\t    await client.post(\n120\t        \"/v1/events\", json=_event_payload(metric=\"storage_bytes\", idempotency_key=\"b\"), headers=headers\n121\t    )\n122\t\n123\t    response = await client.get(\"/v1/usage/export\", params={\"metric\": \"api_calls\"}, headers=headers)\n124\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n125\t\n126\t    assert len(lines) == 2  # header + api_calls only\n127\t    assert \"api_calls\" in lines[1]\n128\t    assert \"storage_bytes\" not in response.text\n129\t\n130\t\n131\tasync def test_export_from_to_window_filter_narrows_the_result(client, make_api_key):\n132\t    \"\"\"AC2: `from`/`to` narrow the export to rows within the window; a row\n133\t    outside the range is excluded.\"\"\"\n134\t    presented_key, _ = await make_api_key()\n135\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n136\t\n137\t    await client.post(\n138\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_in_window\", idempotency_key=\"a\"), headers=headers\n139\t    )\n140\t\n141\t    now = datetime.now(timezone.utc)\n142\t    in_window_from = (now - timedelta(hours=1)).isoformat()\n143\t    in_window_to = (now + timedelta(hours=1)).isoformat()\n144\t    # A window entirely before the row's window_start (valid from<=to, but\n145\t    # both endpoints predate \"now\") — the row must be excluded.\n146\t    before_window_from = (now - timedelta(hours=4)).isoformat()\n147\t    before_window_to = (now - timedelta(hours=2)).isoformat()\n148\t\n149\t    in_window_response = await client.get(\n150\t        \"/v1/usage/export\", params={\"from\": in_window_from, \"to\": in_window_to}, headers=headers\n151\t    )\n152\t    before_window_response = await client.get(\n153\t        \"/v1/usage/export\", params={\"from\": before_window_from, \"to\": before_window_to}, headers=headers\n154\t    )\n155\t\n156\t    assert \"cust_in_window\" in in_window_response.text\n157\t    assert before_window_response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n158\t\n159\t\n160\tasync def test_export_malformed_query_param_returns_422(client, make_api_key):\n161\t    \"\"\"AC4: an out-of-window `from` returns 422 validation_failed.\"\"\"\n162\t    presented_key, _ = await make_api_key()\n163\t    too_old = (datetime.now(timezone.utc) - timedelta(days=91)).isoformat()\n164\t\n165\t    response = await client.get(\n166\t        \"/v1/usage/export\", params={\"from\": too_old}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n167\t    )\n168\t\n169\t    assert response.status_code == 422\n170\t    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n171\t\n172\t\n173\tasync def test_export_unknown_query_param_returns_422(client, make_api_key):\n174\t    \"\"\"AC4: `extra='forbid'` rejects an unexpected query param (e.g. api_key_id probe).\"\"\"\n175\t    presented_key, _ = await make_api_key()\n176\t\n177\t    response = await client.get(\n178\t        \"/v1/usage/export\", params={\"api_key_id\": \"999\"}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n179\t    )\n180\t\n181\t    assert response.status_code == 422\n182\t\n183\t\n184\tasync def test_export_requires_authentication(client, make_api_key):\n185\t    \"\"\"AC6: no/invalid key -> 401 before the handler runs.\"\"\"\n186\t    missing = await client.get(\"/v1/usage/export\")\n187\t    invalid = await client.get(\"/v1/usage/export\", headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"})\n188\t\n189\t    assert missing.status_code == 401\n190\t    assert invalid.status_code == 401\n191\t\n192\t\n193\tasync def test_export_any_authenticated_scope_may_export_ingest_and_admin(client, make_api_key):\n194\t    \"\"\"AC6: both an ingest-scoped and an admin-scoped key succeed (no scope gate).\"\"\"\n195\t    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n196\t    admin_key, _ = await make_api_key(label=\"admin\", scope=\"admin\")\n197\t\n198\t    ingest_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n199\t    admin_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {admin_key}\"})\n200\t\n201\t    assert ingest_response.status_code == 200\n202\t    assert admin_response.status_code == 200\n203\t\n204\t\n205\tasync def test_export_rate_limit_two_principals_one_ip_get_independent_buckets(truncate_tables, make_api_key):\n206\t    \"\"\"AC5: the reused Tier-2 throttle is keyed on `api_key_id`, not client\n207\t    IP — principal A exhausting its own tiny bucket must not affect\n208\t    principal B behind the same client IP (mirrors\n209\t    tests/integration/test_rate_limit.py's discriminating shape, applied to\n210\t    this route).\"\"\"\n211\t    from src.main import app\n212\t\n213\t    key_a, _ = await make_api_key(label=\"export-tenant-a\", rate_limit_per_sec=1)\n214\t    key_b, _ = await make_api_key(label=\"export-tenant-b\", rate_limit_per_sec=100)\n215\t\n216\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 5000))\n217\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as shared_ip_client:\n218\t        first = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n219\t        second = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n220\t\n221\t        assert first.status_code == 200\n222\t        assert second.status_code == 429\n223\t        assert \"Retry-After\" in second.headers\n224\t\n225\t        third = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n226\t        assert third.status_code == 200\n227\t\n228\t\n229\tasync def test_export_tenant_isolation_excludes_other_tenants_rows(client, make_api_key):\n230\t    \"\"\"AC7: tenant A's export never contains tenant B's rows (IDOR/BOLA).\"\"\"\n231\t    key_a, _ = await make_api_key(label=\"tenant-a\")\n232\t    key_b, _ = await make_api_key(label=\"tenant-b\")\n233\t\n234\t    await client.post(\n235\t        \"/v1/events\",\n236\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"a-1\", quantity=\"1000\"),\n237\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n238\t    )\n239\t    await client.post(\n240\t        \"/v1/events\",\n241\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"b-1\", quantity=\"2000\"),\n242\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n243\t    )\n244\t\n245\t    response_a = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n246\t    lines_a = response_a.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n247\t\n248\t    assert len(lines_a) == 2  # header + exactly tenant A's one row\n249\t    assert \"1000.000000\" in response_a.text\n250\t    assert \"2000.000000\" not in response_a.text\n251\t\n252\t\n253\tasync def test_export_row_cap_returns_422_with_no_partial_body(client, make_api_key, postgres_url):\n254\t    \"\"\"AC8: a result over 100,000 rows is rejected with a clean 422 and no\n255\t    partial CSV body — the pre-flight count runs before any response byte.\"\"\"\n256\t    presented_key, api_key_id = await make_api_key()\n257\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n258\t    await _bulk_insert_rollups(\n259\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=100_001\n260\t    )\n261\t\n262\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n263\t\n264\t    assert response.status_code == 422\n265\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n266\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")\n267\t    assert \"\\r\\n\" not in response.text  # no CSV line-terminated rows, ever streamed\n268\t    body = response.json()\n269\t    assert body[\"error\"][\"code\"] == \"validation_failed\"\n270\t    assert set(body[\"error\"].keys()) == {\"code\", \"message\", \"requestId\"}  # the envelope shape only\n271\t\n272\t\n273\tasync def test_export_deterministic_ordering(client, make_api_key):\n274\t    \"\"\"AC13: rows are ordered by window_start, customer_id, metric ascending.\"\"\"\n275\t    presented_key, _ = await make_api_key()\n276\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n277\t\n278\t    for customer_id in (\"cust_c\", \"cust_a\", \"cust_b\"):\n279\t        await client.post(\n280\t            \"/v1/events\",\n281\t            json=_event_payload(customer_id=customer_id, idempotency_key=customer_id),\n282\t            headers=headers,\n283\t        )\n284\t\n285\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n286\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")[1:]\n287\t    seen_customer_ids = [line.split(\",\")[0] for line in lines]\n288\t\n289\t    assert seen_customer_ids == [\"cust_a\", \"cust_b\", \"cust_c\"]\n290\t\n291\t\n292\tasync def test_export_formula_injection_is_escaped_end_to_end(client, make_api_key):\n293\t    \"\"\"AC10: a leading-'-' customer_id (permitted by the ingest allowlist) is\n294\t    quote-prefixed in the exported CSV.\"\"\"\n295\t    presented_key, _ = await make_api_key()\n296\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n297\t\n298\t    await client.post(\n299\t        \"/v1/events\", json=_event_payload(customer_id=\"-1\", idempotency_key=\"dash\"), headers=headers\n300\t    )\n301\t\n302\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n303\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n304\t\n305\t    assert lines[1].startswith(\"'-1,\")\n306\t\n307\t\n308\tasync def test_export_response_headers(client, make_api_key):\n309\t    \"\"\"AC11: text/csv content type, attachment filename (UTC timestamp only,\n310\t    no tenant identifier), nosniff + no-store inherited from the middleware\n311\t    stack. The filename is asserted against its exact expected shape (not a\n312\t    substring exclusion) — a strictly-pinned pattern is what actually proves\n313\t    no extra data, tenant id included, ever rides along in it.\"\"\"\n314\t    presented_key, _ = await make_api_key()\n315\t\n316\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n317\t\n318\t    assert response.headers[\"content-type\"] == \"text/csv; charset=utf-8\"\n319\t    content_disposition = response.headers[\"content-disposition\"]\n320\t    assert re.fullmatch(\n321\t        r'attachment; filename=\"usage-export-\\d{8}T\\d{6}Z\\.csv\"', content_disposition\n322\t    ), content_disposition\n323\t    assert response.headers[\"x-content-type-options\"] == \"nosniff\"\n324\t    assert response.headers[\"cache-control\"] == \"no-store\"\n325\t\n326\t\n327\tdef _free_port() -> int:\n328\t    \"\"\"Find an unused TCP port for the out-of-process uvicorn server below.\"\"\"\n329\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n330\t        sock.bind((\"127.0.0.1\", 0))\n331\t        return sock.getsockname()[1]\n332\t\n333\t\n334\t@pytest.fixture\n335\tasync def running_server(postgres_url, redis_url, make_api_key, truncate_tables):\n336\t    \"\"\"Launch the real app under uvicorn, out-of-process, against the live\n337\t    containers.\n338\t\n339\t    Needed specifically for the streaming-not-buffered sanity check:\n340\t    httpx's in-process `ASGITransport` joins the *entire* response body into\n341\t    one chunk before yielding it (`ASGIResponseStream.__aiter__` does\n342\t    `yield b\"\".join(self._body)`), which would make a chunk-count assertion\n343\t    pass or fail independent of whether the app actually streams — only a\n344\t    real socket exposes genuine chunk boundaries.\n345\t    \"\"\"\n346\t    port = _free_port()\n347\t    import os\n348\t\n349\t    env = dict(os.environ)\n350\t    env[\"DATABASE_URL\"] = postgres_url\n351\t    env[\"METERLY_REDIS_URL\"] = redis_url\n352\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"100000\"\n353\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"100000\"\n354\t\n355\t    presented_key, api_key_id = await make_api_key(rate_limit_per_sec=100000)\n356\t\n357\t    process = subprocess.Popen(\n358\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"127.0.0.1\", \"--port\", str(port)],\n359\t        cwd=str(_REPO_ROOT),\n360\t        env=env,\n361\t        stdout=subprocess.PIPE,\n362\t        stderr=subprocess.STDOUT,\n363\t        text=True,\n364\t    )\n365\t    base_url = f\"http://127.0.0.1:{port}\"\n366\t\n367\t    try:\n368\t        deadline = time.monotonic() + 20\n369\t        async with httpx.AsyncClient() as probe:\n370\t            while time.monotonic() < deadline:\n371\t                try:\n372\t                    response = await probe.get(f\"{base_url}/health\", timeout=1.0)\n373\t                    if response.status_code == 200:\n374\t                        break\n375\t                except httpx.TransportError:\n376\t                    pass\n377\t                await asyncio.sleep(0.3)\n378\t            else:\n379\t                pytest.skip(\"uvicorn did not become ready in time in this sandboxed environment\")\n380\t\n381\t        yield base_url, presented_key, api_key_id\n382\t    finally:\n383\t        process.terminate()\n384\t        try:\n385\t            process.wait(timeout=5)\n386\t        except subprocess.TimeoutExpired:\n387\t            process.kill()\n388\t\n389\t\n390\tasync def test_export_streaming_delivers_multiple_discrete_chunks(running_server, postgres_url):\n391\t    \"\"\"AC9: the response is streamed (multiple discrete chunks arrive over\n392\t    the real socket, not one fully-buffered write) for a multi-row export.\"\"\"\n393\t    base_url, presented_key, api_key_id = running_server\n394\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n395\t    # Large enough that a real streamed write can't coalesce into a single\n396\t    # TCP read on the client side (small payloads often do, even when the\n397\t    # server genuinely writes them incrementally).\n398\t    await _bulk_insert_rollups(\n399\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=20_000\n400\t    )\n401\t\n402\t    chunk_count = 0\n403\t    async with httpx.AsyncClient(timeout=30.0) as http_client:\n404\t        async with http_client.stream(\n405\t            \"GET\", f\"{base_url}/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n406\t        ) as response:\n407\t            assert response.status_code == 200\n408\t            async for _chunk in response.aiter_bytes():\n409\t                chunk_count += 1\n410\t\n411\t    # Proof the response isn't assembled into one buffered blob before being\n412\t    # sent — a genuinely streamed multi-row export arrives as more than one\n413\t    # discrete read on the wire.\n414\t    assert chunk_count > 1\n415\t\n416\t\n417\tasync def test_openapi_schema_exposes_the_export_route_and_responses(client):\n418\t    \"\"\"AC19 (DAST-1): the served /openapi.json includes GET /v1/usage/export\n419\t    with its 200 text/csv and 422 responses, matching the implemented route.\"\"\"\n420\t    response = await client.get(\"/openapi.json\")\n421\t\n422\t    assert response.status_code == 200\n423\t    schema = response.json()\n424\t    assert \"/v1/usage/export\" in schema[\"paths\"]\n425\t    export_operation = schema[\"paths\"][\"/v1/usage/export\"][\"get\"]\n426\t    assert \"200\" in export_operation[\"responses\"]\n427\t    assert \"422\" in export_operation[\"responses\"]\n428\t    assert \"text/csv\" in export_operation[\"responses\"][\"200\"][\"content\"]\n429\t\n430\t\n431\tasync def test_export_forced_pre_flight_count_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n432\t    \"\"\"AC22: a forced error during the pre-flight COUNT phase (before any\n433\t    response byte) returns the generic 500 internal envelope — no\n434\t    stack/SQL/internal-path leak, and no partial CSV body.\"\"\"\n435\t    from src.main import app\n436\t    from src.services import usage_export_service\n437\t\n438\t    async def _raising_count(session, **kwargs):\n439\t        raise RuntimeError(\"simulated connection drop mid-count\")\n440\t\n441\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n442\t\n443\t    presented_key, _ = await make_api_key()\n444\t\n445\t    # ASGITransport re-raises app exceptions by default (useful for debugging\n446\t    # a broken test); here we're deliberately exercising the app's own 500\n447\t    # handler, so this client must let it convert the exception to a response\n448\t    # (mirrors tests/integration/test_events_endpoint.py's AC19 pattern).\n449\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n450\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as client:\n451\t        response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n452\t\n453\t    assert response.status_code == 500\n454\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n455\t    body = response.json()\n456\t    assert body[\"error\"][\"code\"] == \"internal\"\n457\t    assert \"requestId\" in body[\"error\"]\n458\t    assert \"simulated connection drop\" not in response.text\n459\t    assert \"Traceback\" not in response.text\n460\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")  # no CSV body ever started\n461\t"}]},"uuid":"2cc3aaa8-3c13-41d8-a40d-fcb55a2b0489","timestamp":"2026-07-09T19:07:07.275Z","sourceToolAssistantUUID":"8097d676-cfe9-4c01-b6f5-fe5fd1364125","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"2cc3aaa8-3c13-41d8-a40d-fcb55a2b0489","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1Qpy53pMMXkiUa5Q4e","type":"message","role":"assistant","content":[{"type":"text","text":"Good coverage already. Let me check the unit test files and the other production files (csv_export.py, service, schema, repo, route) to assess quality and gaps."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8685,"cache_read_input_tokens":45004,"cache_creation":{"ephemeral_5m_input_tokens":8685,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs1QoewcPX4D6zakKvcf","attributionAgent":"testing","type":"assistant","uuid":"e27ddfca-4c33-4461-8add-bc809b51a7b5","timestamp":"2026-07-09T19:07:10.120Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"e27ddfca-4c33-4461-8add-bc809b51a7b5","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1Qpy53pMMXkiUa5Q4e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XJ2PTfB3bJnesbqgoMheXu","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\csv_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8685,"cache_read_input_tokens":45004,"cache_creation":{"ephemeral_5m_input_tokens":8685,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs1QoewcPX4D6zakKvcf","attributionAgent":"testing","type":"assistant","uuid":"1d257975-5c47-4397-ad17-5a9123f747f0","timestamp":"2026-07-09T19:07:10.828Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"1d257975-5c47-4397-ad17-5a9123f747f0","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XJ2PTfB3bJnesbqgoMheXu","type":"tool_result","content":"1\t\"\"\"CSV encoding facade for `GET /v1/usage/export`.\n2\t\n3\tThe single boundary that owns the RFC 4180 column contract and the OWASP\n4\tCSV/formula-injection escape (`code-standards` facade rule) — centralizing it\n5\there, rather than inlining it in the streaming generator, keeps the control\n6\tgreppable, independently unit-testable, and the one place the security agent\n7\tverifies it lives.\n8\t\"\"\"\n9\t\n10\tfrom decimal import Decimal\n11\tfrom datetime import datetime\n12\t\n13\tEXPORT_HEADER = [\"customer_id\", \"metric\", \"window_start\", \"total_quantity\"]\n14\t\n15\t# A spreadsheet application (Excel/Sheets) treats a cell beginning with any of\n16\t# these characters as the start of a formula/command — the OWASP CSV/formula-\n17\t# injection trigger set.\n18\t_FORMULA_TRIGGER_CHARS = (\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\")\n19\t\n20\t# Control characters other than tab/CR/LF, which RFC 4180 quoting (handled by\n21\t# `csv.writer`'s QUOTE_MINIMAL at the generator that calls this facade) already\n22\t# renders safely — everything else is a raw control byte with no legitimate\n23\t# reason to appear in a customer/metric identifier and is stripped outright.\n24\t_SAFE_WHITESPACE = (\"\\t\", \"\\r\", \"\\n\")\n25\t\n26\t\n27\tdef escape_csv_text_cell(value: str) -> str:\n28\t    \"\"\"Neutralize a text cell against spreadsheet formula-injection.\n29\t\n30\t    Applied at the CSV encoding *sink*, independent of upstream ingest\n31\t    validation: today's ingest allowlist (`^[A-Za-z0-9_.:-]{1,128}$`) permits\n32\t    a leading `-`, which is a live formula trigger in Excel/Sheets, so this is\n33\t    not hypothetical defense-in-depth — it is a real, reachable case. Strips\n34\t    embedded raw control characters, then prefixes a single quote `'` when the\n35\t    (post-strip) first character is a formula trigger; a spreadsheet then\n36\t    renders the cell as literal text rather than evaluating it. RFC 4180\n37\t    quoting itself (comma/quote/CR/LF) is the caller's `csv.writer`'s job, not\n38\t    this function's.\n39\t    \"\"\"\n40\t    if not value:\n41\t        return value\n42\t    cleaned = \"\".join(char for char in value if _is_safe_character(char))\n43\t    if cleaned and cleaned[0] in _FORMULA_TRIGGER_CHARS:\n44\t        return \"'\" + cleaned\n45\t    return cleaned\n46\t\n47\t\n48\tdef _is_safe_character(char: str) -> bool:\n49\t    \"\"\"True unless `char` is a raw control byte with no legitimate reason to\n50\t    appear in a customer/metric identifier (tab/CR/LF pass through — RFC 4180\n51\t    quoting already renders them safely).\"\"\"\n52\t    if char in _SAFE_WHITESPACE:\n53\t        return True\n54\t    codepoint = ord(char)\n55\t    return not (codepoint < 0x20 or codepoint == 0x7F)\n56\t\n57\t\n58\tdef format_window_start(window_start: datetime) -> str:\n59\t    \"\"\"Render `window_start` identically to the JSON `GET /v1/usage`\n60\t    response's string form: UTC ISO-8601 with an explicit offset.\"\"\"\n61\t    return window_start.isoformat()\n62\t\n63\t\n64\tdef format_total_quantity(total_quantity: Decimal) -> str:\n65\t    \"\"\"Render `total_quantity` as a plain decimal string.\n66\t\n67\t    `Decimal.__str__` never emits scientific notation and preserves\n68\t    `Numeric(38,6)` scale-6 trailing zeros, which keeps the export\n69\t    deterministic and diff-clean (the brief's \"plain decimal\" requirement).\n70\t    Numeric cells are server-generated and never attacker-controlled, so they\n71\t    are deliberately not passed through `escape_csv_text_cell` — doing so\n72\t    would corrupt the value.\n73\t    \"\"\"\n74\t    return str(total_quantity)\n75\t"}]},"uuid":"0e7dff83-0b38-4afc-8145-b2c62a795908","timestamp":"2026-07-09T19:07:10.853Z","sourceToolAssistantUUID":"1d257975-5c47-4397-ad17-5a9123f747f0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"0e7dff83-0b38-4afc-8145-b2c62a795908","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1Qpy53pMMXkiUa5Q4e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01YNxCNz4J8ACSMz35fY3DYB","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_csv_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8685,"cache_read_input_tokens":45004,"cache_creation":{"ephemeral_5m_input_tokens":8685,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs1QoewcPX4D6zakKvcf","attributionAgent":"testing","type":"assistant","uuid":"8d736ca7-d819-477f-b7d4-a896ce756817","timestamp":"2026-07-09T19:07:11.263Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"8d736ca7-d819-477f-b7d4-a896ce756817","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YNxCNz4J8ACSMz35fY3DYB","type":"tool_result","content":"1\t\"\"\"Unit tests for the CSV encoding facade (`src/api/csv_export.py`) — RFC 4180\n2\tquoting via stdlib `csv`, the OWASP formula-injection escape, and value\n3\tformatting (AC1, AC10, AC14).\"\"\"\n4\t\n5\timport csv\n6\timport io\n7\tfrom datetime import datetime, timezone\n8\tfrom decimal import Decimal\n9\t\n10\timport pytest\n11\t\n12\tfrom src.api.csv_export import (\n13\t    EXPORT_HEADER,\n14\t    escape_csv_text_cell,\n15\t    format_total_quantity,\n16\t    format_window_start,\n17\t)\n18\t\n19\t\n20\tdef test_export_header_matches_the_brief_column_order():\n21\t    \"\"\"AC1: the header row is exactly `customer_id,metric,window_start,total_quantity`.\"\"\"\n22\t    assert EXPORT_HEADER == [\"customer_id\", \"metric\", \"window_start\", \"total_quantity\"]\n23\t\n24\t\n25\t@pytest.mark.parametrize(\"trigger_char\", [\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\"])\n26\tdef test_leading_formula_trigger_is_quote_prefixed(trigger_char):\n27\t    \"\"\"AC10: a text cell whose first character is a formula trigger is\n28\t    prefixed with a single quote so a spreadsheet renders it as literal text.\"\"\"\n29\t    value = f\"{trigger_char}cmd|'/bin/calc'!A1\"\n30\t    escaped = escape_csv_text_cell(value)\n31\t    assert escaped.startswith(\"'\" + trigger_char)\n32\t\n33\t\n34\tdef test_leading_dash_customer_id_is_escaped():\n35\t    \"\"\"AC10: the ingest allowlist permits a leading `-` (e.g. customer_id\n36\t    '-1'); the CSV sink must still neutralize it independent of ingest\n37\t    validation having allowed it through.\"\"\"\n38\t    assert escape_csv_text_cell(\"-1\") == \"'-1\"\n39\t\n40\t\n41\tdef test_non_trigger_leading_character_is_left_untouched():\n42\t    \"\"\"A normal identifier with no formula-trigger leading character passes through unchanged.\"\"\"\n43\t    assert escape_csv_text_cell(\"cust_123\") == \"cust_123\"\n44\t\n45\t\n46\tdef test_embedded_control_characters_are_stripped():\n47\t    \"\"\"AC10: raw control characters (other than tab/CR/LF, which RFC 4180\n48\t    quoting already handles) are neutralized rather than passed through.\"\"\"\n49\t    value = \"cust\\x00_\\x07123\"\n50\t    assert escape_csv_text_cell(value) == \"cust_123\"\n51\t\n52\t\n53\tdef test_empty_string_is_returned_unchanged():\n54\t    \"\"\"An empty cell has no leading character to escape.\"\"\"\n55\t    assert escape_csv_text_cell(\"\") == \"\"\n56\t\n57\t\n58\tdef test_total_quantity_formats_as_plain_decimal_no_scientific_notation():\n59\t    \"\"\"AC14: total_quantity renders as str(Decimal) — no E-notation, scale-6\n60\t    trailing zeros preserved.\"\"\"\n61\t    assert format_total_quantity(Decimal(\"1000000.000000\")) == \"1000000.000000\"\n62\t    assert format_total_quantity(Decimal(\"0.000001\")) == \"0.000001\"\n63\t\n64\t\n65\tdef test_window_start_formats_as_utc_iso8601_with_offset():\n66\t    \"\"\"AC14: window_start renders identically to the JSON response's isoformat() form.\"\"\"\n67\t    value = datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc)\n68\t    assert format_window_start(value) == value.isoformat()\n69\t    assert format_window_start(value) == \"2026-07-08T14:00:00+00:00\"\n70\t\n71\t\n72\tdef test_numeric_and_timestamp_values_are_never_run_through_the_formula_escape():\n73\t    \"\"\"AC10: numeric/timestamp cells are server-generated and are not passed\n74\t    through escape_csv_text_cell — verified here by confirming a formatted\n75\t    numeric-looking string with a leading '-' is NOT what the escape does to\n76\t    it when used via the intended formatter, only via the text-cell path.\"\"\"\n77\t    quantity = Decimal(\"-5\")  # a hypothetical negative value would not be escaped by the formatter\n78\t    assert format_total_quantity(quantity) == \"-5\"\n79\t\n80\t\n81\tdef test_rfc4180_quoting_via_stdlib_csv_writer_for_comma_quote_and_newline():\n82\t    \"\"\"AC1: fields containing comma/quote/embedded newline are quoted per\n83\t    RFC 4180 by stdlib csv.writer with QUOTE_MINIMAL, CRLF line endings.\"\"\"\n84\t    buffer = io.StringIO()\n85\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n86\t    writer.writerow([\"a,b\", 'has\"quote', \"line1\\nline2\", \"plain\"])\n87\t    output = buffer.getvalue()\n88\t    assert output.endswith(\"\\r\\n\")\n89\t    assert '\"a,b\"' in output\n90\t    assert '\"has\"\"quote\"' in output\n91\t    assert '\"line1\\nline2\"' in output\n92\t    assert \",plain\" in output\n93\t"}]},"uuid":"348684a5-fae7-4ed3-9dc8-f0c6340008cd","timestamp":"2026-07-09T19:07:11.276Z","sourceToolAssistantUUID":"8d736ca7-d819-477f-b7d4-a896ce756817","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
