{"parentUuid":"afe8612a-10d2-472a-b649-ced4c97ff28d","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1R8KMd4sfnrxi3yVBK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NPeCz2dXhK3UCDewj1ftkU","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\services\\usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3522,"cache_read_input_tokens":53689,"cache_creation":{"ephemeral_5m_input_tokens":3522,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs1R7D8STSXwLyjTeDDU","attributionAgent":"testing","type":"assistant","uuid":"0255c62f-6173-4ff8-8852-26489e63de2a","timestamp":"2026-07-09T19:07:14.533Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"0255c62f-6173-4ff8-8852-26489e63de2a","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPeCz2dXhK3UCDewj1ftkU","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t\n35\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n36\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n37\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n38\t\n39\t    This must run and fully resolve *before* the route returns a\n40\t    `StreamingResponse` — once that response object exists the status line\n41\t    is already 200 and bytes may already be on the wire, so a 422 can no\n42\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n43\t    (a DB connection drop, a query error) is deliberately left to propagate\n44\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n45\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n46\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n47\t    \"\"\"\n48\t    async with scoped_transaction(principal.api_key_id) as session:\n49\t        row_count = await count_usage_rollups(\n50\t            session,\n51\t            api_key_id=principal.api_key_id,\n52\t            customer_id=params.customer_id,\n53\t            metric=params.metric,\n54\t            window_from=params.from_,\n55\t            window_to=params.to,\n56\t        )\n57\t\n58\t    if row_count > MAX_EXPORT_ROWS:\n59\t        logger.warning(\n60\t            \"usage.export.rejected\",\n61\t            userId=principal.api_key_id,\n62\t            action=\"deny\",\n63\t            reason=\"row_cap_exceeded\",\n64\t        )\n65\t        raise HTTPException(\n66\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n67\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n68\t        )\n69\t\n70\t\n71\tdef _drain(buffer: io.StringIO) -> bytes:\n72\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n73\t    place — this is what keeps the generator at constant memory: it never\n74\t    holds more than one row's encoded text at a time.\"\"\"\n75\t    data = buffer.getvalue().encode(\"utf-8\")\n76\t    buffer.seek(0)\n77\t    buffer.truncate(0)\n78\t    return data\n79\t\n80\t\n81\tasync def stream_export_csv(\n82\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n83\t) -> AsyncIterator[bytes]:\n84\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n85\t    CSV-encoded row per streamed `usage_rollup` record.\n86\t\n87\t    Yielding the header before touching the database means an empty result\n88\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n89\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n90\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n91\t    setting and the server-side cursor both stay valid for the whole stream.\n92\t    \"\"\"\n93\t    row_count = 0\n94\t    capped = False\n95\t    completed = False\n96\t\n97\t    buffer = io.StringIO()\n98\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n99\t\n100\t    try:\n101\t        writer.writerow(EXPORT_HEADER)\n102\t        yield _drain(buffer)\n103\t\n104\t        async with scoped_transaction(principal.api_key_id) as session:\n105\t            async for record in stream_usage_rollups(\n106\t                session,\n107\t                api_key_id=principal.api_key_id,\n108\t                customer_id=params.customer_id,\n109\t                metric=params.metric,\n110\t                window_from=params.from_,\n111\t                window_to=params.to,\n112\t                limit=MAX_EXPORT_ROWS,\n113\t            ):\n114\t                writer.writerow(\n115\t                    [\n116\t                        escape_csv_text_cell(record.customer_id),\n117\t                        escape_csv_text_cell(record.metric),\n118\t                        format_window_start(record.window_start),\n119\t                        format_total_quantity(record.total_quantity),\n120\t                    ]\n121\t                )\n122\t                yield _drain(buffer)\n123\t                row_count += 1\n124\t\n125\t        capped = row_count >= MAX_EXPORT_ROWS\n126\t        completed = True\n127\t    finally:\n128\t        # In `finally` so a client disconnect or a mid-stream DB error still\n129\t        # records what was actually sent (`completed=False` in that case) —\n130\t        # exactly one usage.export event per request either way (AC17).\n131\t        logger.info(\n132\t            \"usage.export\",\n133\t            userId=principal.api_key_id,\n134\t            action=\"read\",\n135\t            resource=\"usage_rollup\",\n136\t            rowCount=row_count,\n137\t            capped=capped,\n138\t            completed=completed,\n139\t            filtered_by_customer=params.customer_id is not None,\n140\t            filtered_by_metric=params.metric is not None,\n141\t            bounded_from=params.from_ is not None,\n142\t            bounded_to=params.to is not None,\n143\t        )\n144\t"}]},"uuid":"3266dfd0-94f4-4218-ae3d-3336d48593fc","timestamp":"2026-07-09T19:07:14.552Z","sourceToolAssistantUUID":"0255c62f-6173-4ff8-8852-26489e63de2a","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"3266dfd0-94f4-4218-ae3d-3336d48593fc","isSidechain":true,"agentId":"a97f4764709b8dd41","message":{"model":"claude-sonnet-5","id":"msg_011Ccs1R8KMd4sfnrxi3yVBK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XAYb9LvmGtij2T8aGwSV4y","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3522,"cache_read_input_tokens":53689,"output_tokens":213,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":3522},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":213,"cache_read_input_tokens":53689,"cache_creation_input_tokens":3522,"cache_creation":{"ephemeral_5m_input_tokens":3522,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccs1R7D8STSXwLyjTeDDU","attributionAgent":"testing","type":"assistant","uuid":"008fca74-4e53-4c62-9ff9-641cf4e21b6e","timestamp":"2026-07-09T19:07:14.900Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"008fca74-4e53-4c62-9ff9-641cf4e21b6e","isSidechain":true,"promptId":"ed4149fd-c5a8-4db4-bdd2-38a556acc251","agentId":"a97f4764709b8dd41","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XAYb9LvmGtij2T8aGwSV4y","type":"tool_result","content":"1\t\"\"\"Unit tests for `src/services/usage_export_service.py` — the pre-flight\n2\trow-cap check and the streaming generator, with the DB layer mocked out\n3\t(AC8, AC9, AC12, AC17, AC22).\n4\t\"\"\"\n5\t\n6\tfrom contextlib import asynccontextmanager\n7\tfrom datetime import datetime, timezone\n8\tfrom decimal import Decimal\n9\t\n10\timport pytest\n11\tfrom fastapi import HTTPException\n12\t\n13\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n14\tfrom src.auth.api_key import AuthenticatedPrincipal\n15\tfrom src.repositories.usage_repo import UsageRollupExportRecord\n16\tfrom src.services import usage_export_service\n17\t\n18\t\n19\tdef _principal(api_key_id: int = 42) -> AuthenticatedPrincipal:\n20\t    return AuthenticatedPrincipal(api_key_id=api_key_id, rate_limit_per_sec=100)\n21\t\n22\t\n23\tdef _no_filter_params() -> UsageExportQueryParams:\n24\t    return UsageExportQueryParams()\n25\t\n26\t\n27\tdef _fake_scoped_transaction_factory():\n28\t    \"\"\"A fake `scoped_transaction` async context manager yielding a sentinel\n29\t    'session' — the mocked repo functions never actually use it.\"\"\"\n30\t\n31\t    @asynccontextmanager\n32\t    async def _fake(api_key_id: int):\n33\t        yield \"fake-session\"\n34\t\n35\t    return _fake\n36\t\n37\t\n38\tasync def test_prepare_export_passes_when_under_cap(monkeypatch):\n39\t    \"\"\"AC8: a count under the cap raises nothing.\"\"\"\n40\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n41\t\n42\t    async def _fake_count(session, **kwargs):\n43\t        return 5\n44\t\n45\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _fake_count)\n46\t\n47\t    await usage_export_service.prepare_export(_principal(), _no_filter_params())\n48\t\n49\t\n50\tasync def test_prepare_export_rejects_over_cap_with_422(monkeypatch, capsys):\n51\t    \"\"\"AC8: a count over MAX_EXPORT_ROWS raises a 422 with no stream started,\n52\t    and logs the rejection at warn (AC17).\"\"\"\n53\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n54\t\n55\t    async def _fake_count(session, **kwargs):\n56\t        return usage_export_service.MAX_EXPORT_ROWS + 1\n57\t\n58\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _fake_count)\n59\t\n60\t    with pytest.raises(HTTPException) as excinfo:\n61\t        await usage_export_service.prepare_export(_principal(), _no_filter_params())\n62\t\n63\t    assert excinfo.value.status_code == 422\n64\t    captured = capsys.readouterr()\n65\t    assert \"usage.export.rejected\" in captured.out\n66\t    assert \"row_cap_exceeded\" in captured.out\n67\t\n68\t\n69\tasync def test_prepare_export_propagates_non_cap_error_uncaught(monkeypatch):\n70\t    \"\"\"AC22: an unexpected error during the pre-flight COUNT (e.g. a DB\n71\t    connection drop) is NOT caught or swallowed here — it propagates to the\n72\t    error-envelope boundary, fail-closed, so no stream is ever started.\"\"\"\n73\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n74\t\n75\t    async def _raising_count(session, **kwargs):\n76\t        raise RuntimeError(\"connection reset by peer\")\n77\t\n78\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n79\t\n80\t    with pytest.raises(RuntimeError, match=\"connection reset by peer\"):\n81\t        await usage_export_service.prepare_export(_principal(), _no_filter_params())\n82\t\n83\t\n84\tasync def test_stream_export_csv_is_header_only_on_empty_result(monkeypatch):\n85\t    \"\"\"AC12: an empty result still yields the header row first — a\n86\t    header-only CSV, never an empty body / 404.\"\"\"\n87\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n88\t\n89\t    async def _empty_stream(session, **kwargs):\n90\t        return\n91\t        yield  # pragma: no cover - makes this an async generator function\n92\t\n93\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _empty_stream)\n94\t\n95\t    chunks = [chunk async for chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params())]\n96\t    body = b\"\".join(chunks).decode(\"utf-8\")\n97\t\n98\t    assert body == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n99\t\n100\t\n101\tasync def test_stream_export_csv_rows_are_escaped_and_formatted(monkeypatch):\n102\t    \"\"\"AC1/AC10/AC14: streamed rows are formula-escaped on text cells and\n103\t    formatted per the value-format contract.\"\"\"\n104\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n105\t\n106\t    record = UsageRollupExportRecord(\n107\t        customer_id=\"-1\",\n108\t        metric=\"api_calls\",\n109\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n110\t        total_quantity=Decimal(\"12.500000\"),\n111\t    )\n112\t\n113\t    async def _one_row_stream(session, **kwargs):\n114\t        yield record\n115\t\n116\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _one_row_stream)\n117\t\n118\t    chunks = [chunk async for chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params())]\n119\t    body = b\"\".join(chunks).decode(\"utf-8\")\n120\t    lines = body.split(\"\\r\\n\")\n121\t\n122\t    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n123\t    assert lines[1] == \"'-1,api_calls,2026-07-08T14:00:00+00:00,12.500000\"\n124\t\n125\t\n126\tasync def test_stream_export_csv_logs_completion_audit_event(monkeypatch, capsys):\n127\t    \"\"\"AC17: exactly one `usage.export` info event at completion, with\n128\t    rowCount/capped/completed and no raw customer_id.\"\"\"\n129\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n130\t\n131\t    record = UsageRollupExportRecord(\n132\t        customer_id=\"cust_super_secret\",\n133\t        metric=\"api_calls\",\n134\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n135\t        total_quantity=Decimal(\"1.000000\"),\n136\t    )\n137\t\n138\t    async def _one_row_stream(session, **kwargs):\n139\t        yield record\n140\t\n141\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _one_row_stream)\n142\t\n143\t    async for _chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params()):\n144\t        pass\n145\t\n146\t    captured = capsys.readouterr()\n147\t    assert \"usage.export\" in captured.out\n148\t    assert '\"rowCount\": 1' in captured.out\n149\t    assert '\"capped\": false' in captured.out\n150\t    assert '\"completed\": true' in captured.out\n151\t    assert \"cust_super_secret\" not in captured.out\n152\t\n153\t\n154\tasync def test_stream_export_csv_completion_is_false_on_mid_stream_failure(monkeypatch, capsys):\n155\t    \"\"\"A mid-stream DB error still triggers exactly one completion log (via\n156\t    `finally`), but `completed=False` — records what was sent even though the\n157\t    body is truncated (plan's accepted risk R3, distinct from AC22's\n158\t    pre-flight case).\"\"\"\n159\t    monkeypatch.setattr(usage_export_service, \"scoped_transaction\", _fake_scoped_transaction_factory())\n160\t\n161\t    record = UsageRollupExportRecord(\n162\t        customer_id=\"cust_1\",\n163\t        metric=\"api_calls\",\n164\t        window_start=datetime(2026, 7, 8, 14, 0, 0, tzinfo=timezone.utc),\n165\t        total_quantity=Decimal(\"1.000000\"),\n166\t    )\n167\t\n168\t    async def _failing_stream(session, **kwargs):\n169\t        yield record\n170\t        raise RuntimeError(\"connection dropped mid-stream\")\n171\t\n172\t    monkeypatch.setattr(usage_export_service, \"stream_usage_rollups\", _failing_stream)\n173\t\n174\t    with pytest.raises(RuntimeError, match=\"connection dropped mid-stream\"):\n175\t        async for _chunk in usage_export_service.stream_export_csv(_principal(), _no_filter_params()):\n176\t            pass\n177\t\n178\t    captured = capsys.readouterr()\n179\t    assert '\"completed\": false' in captured.out\n180\t    assert '\"rowCount\": 1' in captured.out\n181\t"}]},"uuid":"038d57d1-8163-4ebf-9eb6-f5606d8270e0","timestamp":"2026-07-09T19:07:14.917Z","sourceToolAssistantUUID":"008fca74-4e53-4c62-9ff9-641cf4e21b6e","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
