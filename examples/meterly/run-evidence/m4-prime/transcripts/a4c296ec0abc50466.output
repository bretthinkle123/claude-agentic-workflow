{"parentUuid":"202c6d47-731c-45ba-9f08-55b464140c20","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a4c296ec0abc50466","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01T7N9fe6JsVMWGRpgVS5u3b","type":"tool_result","content":"1\t\"\"\"Validation-contract tests for `QuotaPutRequest` (AC5, AC18).\"\"\"\n2\t\n3\timport pytest\n4\tfrom hypothesis import given\n5\tfrom hypothesis import strategies as st\n6\tfrom pydantic import ValidationError\n7\t\n8\tfrom src.api.schemas.quotas import QuotaPutRequest\n9\t\n10\t\n11\tdef _valid_payload(**overrides) -> dict:\n12\t    payload = {\n13\t        \"customer_id\": \"cust_123\",\n14\t        \"metric\": \"api_calls\",\n15\t        \"limit_per_window\": 1000,\n16\t    }\n17\t    payload.update(overrides)\n18\t    return payload\n19\t\n20\t\n21\tdef test_accepts_a_well_formed_payload():\n22\t    \"\"\"A valid payload parses with the exact fields supplied.\"\"\"\n23\t    quota = QuotaPutRequest(**_valid_payload())\n24\t    assert quota.customer_id == \"cust_123\"\n25\t    assert quota.metric == \"api_calls\"\n26\t    assert quota.limit_per_window == 1000\n27\t\n28\t\n29\tdef test_rejects_unknown_fields_mass_assignment():\n30\t    \"\"\"`extra='forbid'` rejects a client-supplied `api_key_id`/`scope`\n31\t    (ASVS 15.3.3) — the server alone sets the tenant and never accepts a\n32\t    caller-supplied scope elevation.\"\"\"\n33\t    with pytest.raises(ValidationError):\n34\t        QuotaPutRequest(**_valid_payload(api_key_id=999))\n35\t    with pytest.raises(ValidationError):\n36\t        QuotaPutRequest(**_valid_payload(scope=\"admin\"))\n37\t\n38\t\n39\t@pytest.mark.parametrize(\"limit_per_window\", [0, -1, -1000])\n40\tdef test_rejects_non_positive_limit(limit_per_window):\n41\t    \"\"\"A cap must be >= 1 — zero/negative is rejected (no kill-switch this slice).\"\"\"\n42\t    with pytest.raises(ValidationError):\n43\t        QuotaPutRequest(**_valid_payload(limit_per_window=limit_per_window))\n44\t\n45\t\n46\t@pytest.mark.parametrize(\"limit_per_window\", [\"not-a-number\", 1.5, None])\n47\tdef test_rejects_non_integer_limit(limit_per_window):\n48\t    \"\"\"A non-integer limit is rejected.\"\"\"\n49\t    with pytest.raises(ValidationError):\n50\t        QuotaPutRequest(**_valid_payload(limit_per_window=limit_per_window))\n51\t\n52\t\n53\tdef test_rejects_absurdly_large_limit():\n54\t    \"\"\"A limit beyond the BIGINT-safe upper bound is rejected (overflow guard).\"\"\"\n55\t    with pytest.raises(ValidationError):\n56\t        QuotaPutRequest(**_valid_payload(limit_per_window=10**16))\n57\t\n58\t\n59\tdef test_accepts_the_upper_bound_limit():\n60\t    \"\"\"The declared upper bound itself (1e15) is accepted.\"\"\"\n61\t    quota = QuotaPutRequest(**_valid_payload(limit_per_window=10**15))\n62\t    assert quota.limit_per_window == 10**15\n63\t\n64\t\n65\t@pytest.mark.parametrize(\n66\t    \"customer_id\",\n67\t    [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\", \"a\" * 129, \"\"],\n68\t)\n69\tdef test_rejects_injection_and_oversized_customer_id(customer_id):\n70\t    \"\"\"SQLi/path-traversal/CRLF/oversized customer_id is rejected at the boundary (AC18).\"\"\"\n71\t    with pytest.raises(ValidationError):\n72\t        QuotaPutRequest(**_valid_payload(customer_id=customer_id))\n73\t\n74\t\n75\t@pytest.mark.parametrize(\"metric\", [\"' OR 1=1--\", \"a\" * 65, \"\"])\n76\tdef test_rejects_invalid_metric(metric):\n77\t    \"\"\"Injection/oversized metric is rejected at the boundary (AC18).\"\"\"\n78\t    with pytest.raises(ValidationError):\n79\t        QuotaPutRequest(**_valid_payload(metric=metric))\n80\t\n81\t\n82\t@given(customer_id=st.text(min_size=1, max_size=300))\n83\tdef test_property_customer_id_only_ever_accepts_the_allowlist(customer_id):\n84\t    \"\"\"Hypothesis: any customer_id that parses successfully matches the anchored allowlist.\"\"\"\n85\t    import re\n86\t\n87\t    try:\n88\t        quota = QuotaPutRequest(**_valid_payload(customer_id=customer_id))\n89\t    except ValidationError:\n90\t        return\n91\t    assert re.fullmatch(r\"[A-Za-z0-9_.:-]{1,128}\", quota.customer_id)\n92\t"}]},"uuid":"0716421c-56e7-4fb0-bb28-2a6a7fdb4419","timestamp":"2026-07-09T03:59:27.988Z","sourceToolAssistantUUID":"202c6d47-731c-45ba-9f08-55b464140c20","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
