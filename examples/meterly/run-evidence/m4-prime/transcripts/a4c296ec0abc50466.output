{"parentUuid":"ca7650e1-ebe7-41a4-aa5f-ee49198da2af","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a4c296ec0abc50466","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ALvyKKbTEJmTXoEPfZa19C","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF: a REAL sustained load run using k6 (via Docker), driving the\n2\tplan's declared scenario -- constant-arrival-rate at the target rate over a\n3\tsustained window, distributed key space -- against a real uvicorn process\n4\t(out-of-process, real network stack, multiple workers) backed by real\n5\tPostgres + Redis testcontainers.\n6\t\n7\tThis supersedes the best-effort in-process smoke in test_perf_smoke.py: k6\n8\truns in its own Docker container (grafana/k6) and reaches the host-run\n9\tuvicorn via `host.docker.internal`. True p95 is computed here by nearest-rank\n10\tover the raw per-request `http_req_duration` samples k6 writes to its JSON\n11\toutput (never trusting k6's own approximate percentile field blindly, per\n12\ttest-conventions) -- scoped to points tagged `scenario=ingest` so warm-up\n13\tcold-start latency is excluded from the measurement, the way a real load-test\n14\trig ramps up before recording.\n15\t\n16\tSkips (not fails) if Docker or the grafana/k6 image is unavailable -- this\n17\trecords an honest absence of measurement, never a fabricated one.\n18\t\"\"\"\n19\t\n20\timport asyncio\n21\timport datetime\n22\timport json\n23\timport os\n24\timport shutil\n25\timport socket\n26\timport subprocess\n27\timport sys\n28\timport tempfile\n29\timport time\n30\tfrom collections import Counter\n31\tfrom contextlib import closing\n32\tfrom pathlib import Path\n33\t\n34\timport httpx\n35\timport pytest\n36\t\n37\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n38\t_K6_SCRIPTS_DIR = Path(__file__).resolve().parent / \"k6\"\n39\t\n40\t# AC20 p95 debug (2026-07-08, see .pipeline/debug-notes.md): the quota-active\n41\t# perf run MUST use the same uvicorn-worker budget as the no-quota baseline it\n42\t# is compared against. An earlier 2-worker default for the quota fixture (vs\n43\t# the baseline's 5) starved it below the 500 rps constant-arrival target -- two\n44\t# worker processes could not service this workload's per-request CPU on the\n45\t# Docker-Desktop/Windows host, so excess arrivals queued and p95 inflated into\n46\t# the multi-second range from PURE QUEUEING, not from the quota FOR UPDATE\n47\t# read-and-decide (which adds ~3 ms p95 when measured under an equal worker\n48\t# budget). Confirmed empirically: raising the DB pool alone at 2 workers did\n49\t# NOT help (the ceiling is worker processes, not pooled connections); matching\n50\t# the baseline worker count did. The shared Postgres testcontainer runs\n51\t# max_connections=300, so 5 workers x (pool_size 10 + overflow 5) = 75\n52\t# connections is well within budget.\n53\t_DEFAULT_PERF_UVICORN_WORKERS = 5\n54\t\n55\t\n56\tdef _baseline_perf_workers() -> int:\n57\t    return int(os.environ.get(\"METERLY_PERF_UVICORN_WORKERS\", str(_DEFAULT_PERF_UVICORN_WORKERS)))\n58\t\n59\t\n60\tdef _quota_perf_workers() -> int:\n61\t    \"\"\"Worker count for the quota-active perf fixture. Defaults to the baseline\n62\t    worker count so AC20 is an apples-to-apples measurement; still independently\n63\t    overridable via `METERLY_PERF_QUOTA_UVICORN_WORKERS` for capacity tuning.\"\"\"\n64\t    return int(\n65\t        os.environ.get(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", str(_baseline_perf_workers()))\n66\t    )\n67\t\n68\t\n69\tdef _free_port() -> int:\n70\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n71\t        sock.bind((\"0.0.0.0\", 0))\n72\t        return sock.getsockname()[1]\n73\t\n74\t\n75\tdef _docker_available() -> bool:\n76\t    if shutil.which(\"docker\") is None:\n77\t        return False\n78\t    result = subprocess.run([\"docker\", \"info\"], capture_output=True, timeout=10)\n79\t    return result.returncode == 0\n80\t\n81\t\n82\tdef _nearest_rank_from_raw_jsonl(path: Path, scenario: str) -> dict:\n83\t    \"\"\"Parse k6's raw JSON-lines output and compute the TRUE percentiles via\n84\t    nearest-rank over the `http_req_duration` samples tagged with `scenario`\n85\t    -- this is what test-conventions requires instead of trusting k6's own\n86\t    (t-digest-approximated) percentile fields.\"\"\"\n87\t    durations: list[float] = []\n88\t    timestamps: list[str] = []\n89\t    statuses: list[str] = []\n90\t\n91\t    with path.open(encoding=\"utf-8\") as f:\n92\t        for line in f:\n93\t            line = line.strip()\n94\t            if not line:\n95\t                continue\n96\t            record = json.loads(line)\n97\t            if record.get(\"type\") != \"Point\" or record.get(\"metric\") != \"http_req_duration\":\n98\t                continue\n99\t            tags = record[\"data\"].get(\"tags\", {})\n100\t            if tags.get(\"scenario\") != scenario:\n101\t                continue\n102\t            durations.append(record[\"data\"][\"value\"])\n103\t            timestamps.append(record[\"data\"][\"time\"])\n104\t            statuses.append(tags.get(\"status\"))\n105\t\n106\t    if not durations:\n107\t        return {\"sample_count\": 0}\n108\t\n109\t    durations.sort()\n110\t    n = len(durations)\n111\t\n112\t    def nearest_rank(percentile: float) -> float:\n113\t        rank = max(1, round(percentile / 100 * n))\n114\t        return durations[min(rank, n) - 1]\n115\t\n116\t    sorted_timestamps = sorted(timestamps)\n117\t    first = datetime.datetime.fromisoformat(sorted_timestamps[0].replace(\"Z\", \"+00:00\"))\n118\t    last = datetime.datetime.fromisoformat(sorted_timestamps[-1].replace(\"Z\", \"+00:00\"))\n119\t    elapsed_seconds = (last - first).total_seconds()\n120\t\n121\t    return {\n122\t        \"sample_count\": n,\n123\t        \"status_counts\": dict(Counter(statuses)),\n124\t        \"p50_ms\": round(nearest_rank(50), 2),\n125\t        \"p90_ms\": round(nearest_rank(90), 2),\n126\t        \"p95_ms\": round(nearest_rank(95), 2),\n127\t        \"p99_ms\": round(nearest_rank(99), 2),\n128\t        \"max_ms\": round(durations[-1], 2),\n129\t        \"elapsed_seconds\": round(elapsed_seconds, 2),\n130\t        \"throughput_rps\": round(n / elapsed_seconds, 2) if elapsed_seconds > 0 else 0.0,\n131\t    }\n132\t\n133\t\n134\t@pytest.fixture\n135\tasync def k6_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n136\t    \"\"\"Launch the real app under uvicorn (multi-worker, out-of-process)\n137\t    against the live containers, ready for a k6 container to hit it via\n138\t    `host.docker.internal`.\"\"\"\n139\t    if not _docker_available():\n140\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n141\t\n142\t    pull_result = subprocess.run(\n143\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n144\t    )\n145\t    if pull_result.returncode != 0:\n146\t        pull_result = subprocess.run(\n147\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n148\t        )\n149\t        if pull_result.returncode != 0:\n150\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n151\t\n152\t    port = _free_port()\n153\t    env = dict(os.environ)\n154\t    env[\"DATABASE_URL\"] = postgres_url\n155\t    env[\"METERLY_REDIS_URL\"] = redis_url\n156\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n157\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n158\t\n159\t    presented_key, _ = await make_api_key(label=\"k6-perf-key\", rate_limit_per_sec=1_000_000)\n160\t\n161\t    workers = _baseline_perf_workers()\n162\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_perf\"\n163\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n164\t\n165\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n166\t    process = subprocess.Popen(\n167\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n168\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n169\t    )\n170\t\n171\t    try:\n172\t        deadline = time.monotonic() + 30\n173\t        async with httpx.AsyncClient() as probe:\n174\t            ready = False\n175\t            while time.monotonic() < deadline:\n176\t                try:\n177\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n178\t                    if response.status_code == 200:\n179\t                        ready = True\n180\t                        break\n181\t                except httpx.TransportError:\n182\t                    pass\n183\t                await asyncio.sleep(0.3)\n184\t            if not ready:\n185\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n186\t\n187\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n188\t    finally:\n189\t        process.terminate()\n190\t        try:\n191\t            process.wait(timeout=10)\n192\t        except subprocess.TimeoutExpired:\n193\t            process.kill()\n194\t        uvicorn_log.close()\n195\t\n196\t\n197\tdef _run_k6(script_name: str, port: int, api_key: str, scratch_dir: Path, target_rps: int, duration: str, warmup: str, out_name: str) -> subprocess.CompletedProcess:\n198\t    raw_out = scratch_dir / out_name\n199\t    if raw_out.exists():\n200\t        raw_out.unlink()\n201\t    return subprocess.run(\n202\t        [\n203\t            \"docker\", \"run\", \"--rm\",\n204\t            \"--add-host=host.docker.internal:host-gateway\",\n205\t            \"-v\", f\"{scratch_dir}:/perf_out\",\n206\t            \"-v\", f\"{_K6_SCRIPTS_DIR}:/perf_scripts:ro\",\n207\t            \"-e\", f\"BASE_URL=http://host.docker.internal:{port}\",\n208\t            \"-e\", f\"API_KEY={api_key}\",\n209\t            \"-e\", f\"TARGET_RPS={target_rps}\",\n210\t            \"-e\", f\"DURATION={duration}\",\n211\t            \"-e\", f\"WARMUP_DURATION={warmup}\",\n212\t            \"grafana/k6\", \"run\",\n213\t            \"--out\", f\"json=/perf_out/{out_name}\",\n214\t            f\"/perf_scripts/{script_name}\",\n215\t        ],\n216\t        capture_output=True, text=True, timeout=180,\n217\t    )\n218\t\n219\t\n220\tdef test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n221\t    \"\"\"Drive POST /v1/events at a real, sustained constant-arrival-rate of\n222\t    500 req/s (the AC6 budget's declared rate) over a real k6 container\n223\t    against a real out-of-process uvicorn + Postgres + Redis, with a\n224\t    distributed key space (unique idempotency_key + customer_id spread across\n225\t    50 buckets per request, no replay contention). Records true nearest-rank\n226\t    p95 + achieved throughput -- an honest measurement, not a claim the\n227\t    budget is met.\"\"\"\n228\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n229\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n230\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n231\t\n232\t    result = _run_k6(\n233\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n234\t        target_rps, duration, warmup, \"k6_events_raw.jsonl\",\n235\t    )\n236\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n237\t\n238\t    if result.returncode != 0:\n239\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_stdout.log\")\n240\t\n241\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_events_raw.jsonl\", scenario=\"ingest\")\n242\t    (k6_load_env[\"scratch_dir\"] / \"events_metrics.json\").write_text(json.dumps(metrics, indent=2))\n243\t    print(\"POST /v1/events k6 load metrics:\", json.dumps(metrics, indent=2))\n244\t\n245\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n246\t\n247\t\n248\t@pytest.fixture\n249\tasync def k6_quota_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n250\t    \"\"\"Like `k6_load_env`, but the provisioned key is admin-scoped and each\n251\t    `cust_0..cust_49` bucket the k6 script drives (`load_events_quota.js`)\n252\t    carries a pre-seeded, deliberately high quota (AC20) -- so the ingest\n253\t    path exercises the quota-check read-and-decide on every request without\n254\t    ever actually rejecting one, isolating the added latency of the `FOR\n255\t    UPDATE` lookup itself from the (much larger, transaction-aborting) cost\n256\t    of a rejection.\n257\t    \"\"\"\n258\t    if not _docker_available():\n259\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n260\t\n261\t    pull_result = subprocess.run(\n262\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n263\t    )\n264\t    if pull_result.returncode != 0:\n265\t        pull_result = subprocess.run(\n266\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n267\t        )\n268\t        if pull_result.returncode != 0:\n269\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n270\t\n271\t    port = _free_port()\n272\t    env = dict(os.environ)\n273\t    env[\"DATABASE_URL\"] = postgres_url\n274\t    env[\"METERLY_REDIS_URL\"] = redis_url\n275\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n276\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n277\t\n278\t    presented_key, api_key_id = await make_api_key(\n279\t        label=\"k6-quota-perf-key\", rate_limit_per_sec=1_000_000, scope=\"admin\"\n280\t    )\n281\t\n282\t    from sqlalchemy import text\n283\t    from sqlalchemy.ext.asyncio import create_async_engine\n284\t\n285\t    # A high-but-finite cap per bucket (well above anything a 15s run at the\n286\t    # target rate could accumulate) -- active enough to exercise the FOR\n287\t    # UPDATE read-and-decide on every request, never high enough to matter\n288\t    # for whether a single run's requests are accepted.\n289\t    quota_engine = create_async_engine(postgres_url)\n290\t    async with quota_engine.begin() as connection:\n291\t        for customer_index in range(50):\n292\t            await connection.execute(\n293\t                text(\n294\t                    \"\"\"\n295\t                    INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n296\t                    VALUES (:api_key_id, :customer_id, 'api_calls', 100000000, now())\n297\t                    ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n298\t                        limit_per_window = EXCLUDED.limit_per_window\n299\t                    \"\"\"\n300\t                ),\n301\t                {\"api_key_id\": api_key_id, \"customer_id\": f\"cust_{customer_index}\"},\n302\t            )\n303\t    await quota_engine.dispose()\n304\t\n305\t    # Match the baseline fixture's worker budget (default 5) so AC20 measures\n306\t    # the quota path under the SAME CPU/event-loop capacity it is compared\n307\t    # against -- a smaller budget starves the constant-arrival-rate scenario and\n308\t    # inflates p95 with queueing delay that has nothing to do with the quota\n309\t    # check (see _quota_perf_workers and .pipeline/debug-notes.md 2026-07-08).\n310\t    # The shared Postgres container runs max_connections=300 and these perf\n311\t    # fixtures are function-scoped (torn down before the next), so 5 workers x\n312\t    # 15 pooled connections is comfortably within the session's budget.\n313\t    workers = _quota_perf_workers()\n314\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_quota_perf\"\n315\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n316\t\n317\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n318\t    process = subprocess.Popen(\n319\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n320\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n321\t    )\n322\t\n323\t    try:\n324\t        deadline = time.monotonic() + 30\n325\t        async with httpx.AsyncClient() as probe:\n326\t            ready = False\n327\t            while time.monotonic() < deadline:\n328\t                try:\n329\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n330\t                    if response.status_code == 200:\n331\t                        ready = True\n332\t                        break\n333\t                except httpx.TransportError:\n334\t                    pass\n335\t                await asyncio.sleep(0.3)\n336\t            if not ready:\n337\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n338\t\n339\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n340\t    finally:\n341\t        process.terminate()\n342\t        try:\n343\t            process.wait(timeout=10)\n344\t        except subprocess.TimeoutExpired:\n345\t            process.kill()\n346\t        uvicorn_log.close()\n347\t        # Give Postgres a moment to reclaim the just-closed workers' backend\n348\t        # connection slots before the next test's fixtures open new ones\n349\t        # against the same shared container (mitigates TooManyConnectionsError\n350\t        # when this module's perf tests run back-to-back in one session).\n351\t        await asyncio.sleep(1.0)\n352\t\n353\t\n354\tdef test_events_ingest_with_quotas_p95_within_1_5x_baseline(k6_load_env, k6_quota_load_env):\n355\t    \"\"\"AC20 (human-revised 2026-07-09, see .pipeline/debug-notes.md and the\n356\t    AC20 row in .pipeline/acceptance.md): the original absolute \"p95 < 50ms\"\n357\t    form is unachievable on this Docker-Desktop/Windows host for ANY code\n358\t    (the no-quota baseline itself runs ~84-112ms here). AC20 is now a\n359\t    RELATIVE budget: quota-active p95 <= 1.5x the same-session no-quota\n360\t    baseline p95, both measured at equal uvicorn worker budget.\n361\t\n362\t    This test drives BOTH the no-quota baseline (`k6_load_env`, workers =\n363\t    `_baseline_perf_workers()`) and the quota-active path (`k6_quota_load_env`,\n364\t    workers = `_quota_perf_workers()`, which defaults to the SAME count) in\n365\t    the same test session, back-to-back, and asserts the relative bound\n366\t    directly -- closing the prior gap where this test only asserted\n367\t    `sample_count > 0` and let a real regression (measured 3362ms vs an 84ms\n368\t    baseline, ~40x) pass green (see test-quality.json's AC20 gap, now closed\n369\t    by this assertion).\"\"\"\n370\t    assert _quota_perf_workers() == _baseline_perf_workers(), (\n371\t        f\"AC20 requires an equal worker budget for the relative comparison to be \"\n372\t        f\"apples-to-apples, but quota={_quota_perf_workers()} != baseline={_baseline_perf_workers()}\"\n373\t    )\n374\t\n375\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n376\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n377\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n378\t\n379\t    baseline_result = _run_k6(\n380\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n381\t        target_rps, duration, warmup, \"k6_events_baseline_raw.jsonl\",\n382\t    )\n383\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_stdout.log\").write_text(\n384\t        baseline_result.stdout + \"\\n---STDERR---\\n\" + baseline_result.stderr\n385\t    )\n386\t    if baseline_result.returncode != 0:\n387\t        pytest.skip(\n388\t            f\"k6 baseline run failed to execute in this environment (rc={baseline_result.returncode}); \"\n389\t            \"see k6_events_baseline_stdout.log\"\n390\t        )\n391\t    baseline_metrics = _nearest_rank_from_raw_jsonl(\n392\t        k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_raw.jsonl\", scenario=\"ingest\"\n393\t    )\n394\t    (k6_load_env[\"scratch_dir\"] / \"events_baseline_metrics.json\").write_text(json.dumps(baseline_metrics, indent=2))\n395\t    print(\"POST /v1/events no-quota baseline k6 load metrics:\", json.dumps(baseline_metrics, indent=2))\n396\t\n397\t    quota_result = _run_k6(\n398\t        \"load_events_quota.js\", k6_quota_load_env[\"port\"], k6_quota_load_env[\"api_key\"], k6_quota_load_env[\"scratch_dir\"],\n399\t        target_rps, duration, warmup, \"k6_events_quota_raw.jsonl\",\n400\t    )\n401\t    (k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_stdout.log\").write_text(\n402\t        quota_result.stdout + \"\\n---STDERR---\\n\" + quota_result.stderr\n403\t    )\n404\t    if quota_result.returncode != 0:\n405\t        pytest.skip(\n406\t            f\"k6 quota run failed to execute in this environment (rc={quota_result.returncode}); \"\n407\t            \"see k6_events_quota_stdout.log\"\n408\t        )\n409\t    quota_metrics = _nearest_rank_from_raw_jsonl(\n410\t        k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_raw.jsonl\", scenario=\"ingest\"\n411\t    )\n412\t    (k6_quota_load_env[\"scratch_dir\"] / \"events_quota_metrics.json\").write_text(json.dumps(quota_metrics, indent=2))\n413\t    print(\"POST /v1/events (quotas active) k6 load metrics:\", json.dumps(quota_metrics, indent=2))\n414\t\n415\t    assert baseline_metrics[\"sample_count\"] > 0, \"the baseline k6 run produced no ingest-scenario samples -- unmeasured\"\n416\t    assert quota_metrics[\"sample_count\"] > 0, \"the quota k6 run produced no ingest-scenario samples -- unmeasured\"\n417\t\n418\t    budget_p95 = 1.5 * baseline_metrics[\"p95_ms\"]\n419\t    assert quota_metrics[\"p95_ms\"] <= budget_p95, (\n420\t        f\"AC20: quota-active p95 ({quota_metrics['p95_ms']}ms) exceeds 1.5x the same-session \"\n421\t        f\"no-quota baseline p95 ({baseline_metrics['p95_ms']}ms -> budget {budget_p95:.2f}ms) \"\n422\t        f\"at equal worker budget ({_quota_perf_workers()} workers)\"\n423\t    )\n424\t\n425\t\n426\tdef test_ac20_quota_perf_fixture_matches_baseline_worker_budget(monkeypatch):\n427\t    \"\"\"Regression guard for the AC20 p95 debug (.pipeline/debug-notes.md,\n428\t    2026-07-08). The quota-active perf fixture must not be provisioned with\n429\t    FEWER uvicorn workers than the no-quota baseline it is compared against.\n430\t\n431\t    A prior 2-worker default (vs the baseline's 5) starved the quota run below\n432\t    the 500 rps constant-arrival target, so its p95 inflated into the seconds\n433\t    purely from queueing -- masquerading as a quota-code-path regression that,\n434\t    measured under an equal worker budget, does not exist (~87 ms vs the ~85 ms\n435\t    baseline). This fast, Docker-free guard fails before the fix (2 < 5) and\n436\t    passes after (5 >= 5), locking the handicap out of the harness for good.\"\"\"\n437\t    monkeypatch.delenv(\"METERLY_PERF_UVICORN_WORKERS\", raising=False)\n438\t    monkeypatch.delenv(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", raising=False)\n439\t    assert _quota_perf_workers() >= _baseline_perf_workers(), (\n440\t        f\"quota perf fixture worker budget ({_quota_perf_workers()}) is below the \"\n441\t        f\"no-quota baseline ({_baseline_perf_workers()}); AC20 would be measured on a \"\n442\t        \"starved pool and its p95 would reflect queueing, not the quota check\"\n443\t    )\n444\t\n445\t\n446\tdef test_usage_read_sustained_100rps_k6_load(k6_load_env):\n447\t    \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n448\t    against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n449\t    target_rps = int(os.environ.get(\"METERLY_PERF_USAGE_TARGET_RPS\", \"100\"))\n450\t    duration = os.environ.get(\"METERLY_PERF_USAGE_DURATION\", \"10s\")\n451\t    warmup = os.environ.get(\"METERLY_PERF_USAGE_WARMUP\", \"3s\")\n452\t\n453\t    result = _run_k6(\n454\t        \"load_usage.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n455\t        target_rps, duration, warmup, \"k6_usage_raw.jsonl\",\n456\t    )\n457\t    (k6_load_env[\"scratch_dir\"] / \"k6_usage_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n458\t\n459\t    if result.returncode != 0:\n460\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_usage_stdout.log\")\n461\t\n462\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_usage_raw.jsonl\", scenario=\"ingest\")\n463\t    (k6_load_env[\"scratch_dir\"] / \"usage_metrics.json\").write_text(json.dumps(metrics, indent=2))\n464\t    print(\"GET /v1/usage k6 load metrics:\", json.dumps(metrics, indent=2))\n465\t\n466\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n467\t"}]},"uuid":"9730a22e-9472-4b79-b60a-a720bc01eb62","timestamp":"2026-07-09T03:59:02.776Z","sourceToolAssistantUUID":"ca7650e1-ebe7-41a4-aa5f-ee49198da2af","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
