{"parentUuid":"af9c8c27-b963-4b62-9bbc-06d356012681","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"aa91a4ccd0eafabe2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgMy7dBG2n6bSPBmdSAGe7","type":"tool_result","content":"1\t\"\"\"CSV encoding facade for `GET /v1/usage/export`.\n2\t\n3\tThe single boundary that owns the RFC 4180 column contract and the OWASP\n4\tCSV/formula-injection escape (`code-standards` facade rule) — centralizing it\n5\there, rather than inlining it in the streaming generator, keeps the control\n6\tgreppable, independently unit-testable, and the one place the security agent\n7\tverifies it lives.\n8\t\"\"\"\n9\t\n10\tfrom decimal import Decimal\n11\tfrom datetime import datetime\n12\t\n13\tEXPORT_HEADER = [\"customer_id\", \"metric\", \"window_start\", \"total_quantity\"]\n14\t\n15\t# A spreadsheet application (Excel/Sheets) treats a cell beginning with any of\n16\t# these characters as the start of a formula/command — the OWASP CSV/formula-\n17\t# injection trigger set.\n18\t_FORMULA_TRIGGER_CHARS = (\"=\", \"+\", \"-\", \"@\", \"\\t\", \"\\r\")\n19\t\n20\t# Control characters other than tab/CR/LF, which RFC 4180 quoting (handled by\n21\t# `csv.writer`'s QUOTE_MINIMAL at the generator that calls this facade) already\n22\t# renders safely — everything else is a raw control byte with no legitimate\n23\t# reason to appear in a customer/metric identifier and is stripped outright.\n24\t_SAFE_WHITESPACE = (\"\\t\", \"\\r\", \"\\n\")\n25\t\n26\t# Precomputed `str.translate` deletion table for exactly the control bytes the\n27\t# strip step removes: every C0 control (0x00–0x1F) except tab/CR/LF, plus DEL\n28\t# (0x7F). Encoding runs this per text cell for every exported row (up to 200,000\n29\t# cell escapes at the 100,000-row cap), so the strip is done by the C-level\n30\t# `str.translate` in a single pass rather than a per-character Python generator +\n31\t# function call + `ord()` (the previous hot path). Semantics are identical to the\n32\t# prior `_is_safe_character` filter — same characters kept, same characters\n33\t# removed — verified by the unchanged AC10 escape unit tests.\n34\t_CONTROL_STRIP_TABLE = {\n35\t    codepoint: None for codepoint in range(0x20) if chr(codepoint) not in _SAFE_WHITESPACE\n36\t}\n37\t_CONTROL_STRIP_TABLE[0x7F] = None\n38\t\n39\t\n40\tdef escape_csv_text_cell(value: str) -> str:\n41\t    \"\"\"Neutralize a text cell against spreadsheet formula-injection.\n42\t\n43\t    Applied at the CSV encoding *sink*, independent of upstream ingest\n44\t    validation: today's ingest allowlist (`^[A-Za-z0-9_.:-]{1,128}$`) permits\n45\t    a leading `-`, which is a live formula trigger in Excel/Sheets, so this is\n46\t    not hypothetical defense-in-depth — it is a real, reachable case. Strips\n47\t    embedded raw control characters, then prefixes a single quote `'` when the\n48\t    (post-strip) first character is a formula trigger; a spreadsheet then\n49\t    renders the cell as literal text rather than evaluating it. RFC 4180\n50\t    quoting itself (comma/quote/CR/LF) is the caller's `csv.writer`'s job, not\n51\t    this function's.\n52\t    \"\"\"\n53\t    if not value:\n54\t        return value\n55\t    cleaned = value.translate(_CONTROL_STRIP_TABLE)\n56\t    if cleaned and cleaned[0] in _FORMULA_TRIGGER_CHARS:\n57\t        return \"'\" + cleaned\n58\t    return cleaned\n59\t\n60\t\n61\tdef format_window_start(window_start: datetime) -> str:\n62\t    \"\"\"Render `window_start` identically to the JSON `GET /v1/usage`\n63\t    response's string form: UTC ISO-8601 with an explicit offset.\"\"\"\n64\t    return window_start.isoformat()\n65\t\n66\t\n67\tdef format_total_quantity(total_quantity: Decimal) -> str:\n68\t    \"\"\"Render `total_quantity` as a plain decimal string.\n69\t\n70\t    `Decimal.__str__` never emits scientific notation and preserves\n71\t    `Numeric(38,6)` scale-6 trailing zeros, which keeps the export\n72\t    deterministic and diff-clean (the brief's \"plain decimal\" requirement).\n73\t    Numeric cells are server-generated and never attacker-controlled, so they\n74\t    are deliberately not passed through `escape_csv_text_cell` — doing so\n75\t    would corrupt the value.\n76\t    \"\"\"\n77\t    return str(total_quantity)\n78\t"}]},"uuid":"f6ee236b-29e2-4a36-8ec8-83ae3f213534","timestamp":"2026-07-09T20:03:11.015Z","sourceToolAssistantUUID":"af9c8c27-b963-4b62-9bbc-06d356012681","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"f6ee236b-29e2-4a36-8ec8-83ae3f213534","isSidechain":true,"agentId":"aa91a4ccd0eafabe2","message":{"model":"claude-opus-4-8","id":"msg_011Ccs5g7LCvtAyz78UeyncC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ExotbaYMDWGhYDcSqQLfUb","name":"Read","input":{"file_path":"C:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/repositories/usage_repo.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8119,"cache_read_input_tokens":35492,"cache_creation":{"ephemeral_5m_input_tokens":8119,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs5g6S8egUTzKMM2LtCV","attributionAgent":"security","type":"assistant","uuid":"d005d12f-9f16-4a22-983c-148d0fa75d02","timestamp":"2026-07-09T20:03:11.484Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"d005d12f-9f16-4a22-983c-148d0fa75d02","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"aa91a4ccd0eafabe2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ExotbaYMDWGhYDcSqQLfUb","type":"tool_result","content":"1\t\"\"\"Repository for reading `usage_rollup` — the O(1) aggregate lookup behind\n2\t`GET /v1/usage`, and the count/stream queries behind `GET /v1/usage/export`.\n3\t\n4\tReads the pre-aggregated counter rather than summing `events` live, which is\n5\twhat keeps the GET p95 budget bounded as ingest volume grows (see the plan's\n6\t\"why reading the rollup\" writeup).\n7\t\"\"\"\n8\t\n9\tfrom collections.abc import AsyncIterator\n10\tfrom dataclasses import dataclass\n11\tfrom datetime import datetime\n12\tfrom decimal import Decimal\n13\t\n14\tfrom sqlalchemy import text\n15\tfrom sqlalchemy.ext.asyncio import AsyncSession\n16\t\n17\t\n18\t@dataclass(frozen=True)\n19\tclass UsageRollupRecord:\n20\t    \"\"\"The aggregate counter for one `(api_key_id, customer_id, metric, window_start)` bucket.\"\"\"\n21\t\n22\t    total_quantity: Decimal\n23\t    event_count: int\n24\t\n25\t\n26\tasync def find_usage_rollup(\n27\t    session: AsyncSession,\n28\t    *,\n29\t    api_key_id: int,\n30\t    customer_id: str,\n31\t    metric: str,\n32\t    window_start: datetime,\n33\t) -> UsageRollupRecord | None:\n34\t    \"\"\"Fetch the usage counter for a bucket, scoped by the authenticated\n35\t    `api_key_id` first — an authenticated key can never read another\n36\t    tenant's totals (IDOR/BOLA mitigation, AC17). None means no events have\n37\t    landed in this bucket yet (the caller returns zeros, not 404).\"\"\"\n38\t    result = await session.execute(\n39\t        text(\n40\t            \"\"\"\n41\t            SELECT total_quantity, event_count\n42\t            FROM usage_rollup\n43\t            WHERE api_key_id = :api_key_id\n44\t              AND customer_id = :customer_id\n45\t              AND metric = :metric\n46\t              AND window_start = :window_start\n47\t            \"\"\"\n48\t        ),\n49\t        {\n50\t            \"api_key_id\": api_key_id,\n51\t            \"customer_id\": customer_id,\n52\t            \"metric\": metric,\n53\t            \"window_start\": window_start,\n54\t        },\n55\t    )\n56\t    row = result.mappings().first()\n57\t    if row is None:\n58\t        return None\n59\t    return UsageRollupRecord(total_quantity=row[\"total_quantity\"], event_count=row[\"event_count\"])\n60\t\n61\t\n62\t@dataclass(frozen=True)\n63\tclass UsageRollupExportRecord:\n64\t    \"\"\"The four columns `GET /v1/usage/export` emits — deliberately excludes\n65\t    `event_count`, `updated_at`, and `api_key_id` (ASVS 15.3.1 minimal-\n66\t    projection rule; the caller's identity is never echoed back).\"\"\"\n67\t\n68\t    customer_id: str\n69\t    metric: str\n70\t    window_start: datetime\n71\t    total_quantity: Decimal\n72\t\n73\t\n74\tdef _export_filter_clause_and_params(\n75\t    *,\n76\t    api_key_id: int,\n77\t    customer_id: str | None,\n78\t    metric: str | None,\n79\t    window_from: datetime | None,\n80\t    window_to: datetime | None,\n81\t) -> tuple[str, dict]:\n82\t    \"\"\"Build the shared WHERE clause + bound-parameter dict for the export\n83\t    count and stream queries, so the two statements can never drift apart.\n84\t\n85\t    Every fragment is a fixed literal chosen only by which filters are\n86\t    *present*; the filter *values* always travel as bound parameters, never\n87\t    concatenated into the SQL string.\n88\t    \"\"\"\n89\t    clauses = [\"api_key_id = :api_key_id\"]\n90\t    params: dict = {\"api_key_id\": api_key_id}\n91\t    if customer_id is not None:\n92\t        clauses.append(\"customer_id = :customer_id\")\n93\t        params[\"customer_id\"] = customer_id\n94\t    if metric is not None:\n95\t        clauses.append(\"metric = :metric\")\n96\t        params[\"metric\"] = metric\n97\t    if window_from is not None:\n98\t        clauses.append(\"window_start >= :window_from\")\n99\t        params[\"window_from\"] = window_from\n100\t    if window_to is not None:\n101\t        clauses.append(\"window_start <= :window_to\")\n102\t        params[\"window_to\"] = window_to\n103\t    return \" AND \".join(clauses), params\n104\t\n105\t\n106\tasync def count_usage_rollups(\n107\t    session: AsyncSession,\n108\t    *,\n109\t    api_key_id: int,\n110\t    customer_id: str | None = None,\n111\t    metric: str | None = None,\n112\t    window_from: datetime | None = None,\n113\t    window_to: datetime | None = None,\n114\t) -> int:\n115\t    \"\"\"Count the caller's rollup rows matching the optional filters.\n116\t\n117\t    Backs the export's pre-flight row-cap check (AC8) — an index-prefix scan\n118\t    on `api_key_id`, scoped first (row-level-security invariant), cheap even\n119\t    without a covering index on the export's ORDER BY (see the plan's\n120\t    \"Ordering vs. index\" tradeoff writeup).\n121\t    \"\"\"\n122\t    where_clause, params = _export_filter_clause_and_params(\n123\t        api_key_id=api_key_id,\n124\t        customer_id=customer_id,\n125\t        metric=metric,\n126\t        window_from=window_from,\n127\t        window_to=window_to,\n128\t    )\n129\t    result = await session.execute(text(f\"SELECT count(*) FROM usage_rollup WHERE {where_clause}\"), params)\n130\t    return result.scalar_one()\n131\t\n132\t\n133\t# Rows fetched per server-side-cursor round-trip in `stream_usage_rollups`.\n134\t# Bounds the client-side buffer (at most one batch is held, regardless of the\n135\t# total result size — the constant-memory streaming invariant is preserved) and\n136\t# trades a handful of extra rows of memory for far fewer cursor round-trips when\n137\t# draining a large export.\n138\t_STREAM_FETCH_BATCH = 5000\n139\t\n140\t\n141\tasync def stream_usage_rollups(\n142\t    session: AsyncSession,\n143\t    *,\n144\t    api_key_id: int,\n145\t    customer_id: str | None = None,\n146\t    metric: str | None = None,\n147\t    window_from: datetime | None = None,\n148\t    window_to: datetime | None = None,\n149\t    limit: int,\n150\t) -> AsyncIterator[UsageRollupExportRecord]:\n151\t    \"\"\"Stream the caller's rollup rows matching the optional filters via a\n152\t    server-side cursor, in deterministic order (AC9, AC13).\n153\t\n154\t    The `ORDER BY` clause is a fixed literal built from server-side column\n155\t    names, never derived from client input, so the sort key is not a\n156\t    tampering sink. `session.stream(...)` fetches from PostgreSQL via a\n157\t    server-side cursor rather than buffering the whole result client-side —\n158\t    the property the constant-memory streaming design depends on.\n159\t\n160\t    `yield_per` tunes *how many* rows that server-side cursor fetches per\n161\t    round-trip (it does not abandon the cursor): the default single-row/small\n162\t    partition fetch cost ~1s to drain 100,000 rows, versus ~0.6s at\n163\t    `_STREAM_FETCH_BATCH`, while keeping memory bounded — at most one batch of\n164\t    rows is buffered client-side, independent of the total result size.\n165\t    \"\"\"\n166\t    where_clause, params = _export_filter_clause_and_params(\n167\t        api_key_id=api_key_id,\n168\t        customer_id=customer_id,\n169\t        metric=metric,\n170\t        window_from=window_from,\n171\t        window_to=window_to,\n172\t    )\n173\t    params[\"limit\"] = limit\n174\t    result = await session.stream(\n175\t        text(\n176\t            f\"\"\"\n177\t            SELECT customer_id, metric, window_start, total_quantity\n178\t            FROM usage_rollup\n179\t            WHERE {where_clause}\n180\t            ORDER BY window_start, customer_id, metric ASC\n181\t            LIMIT :limit\n182\t            \"\"\"\n183\t        ).execution_options(yield_per=_STREAM_FETCH_BATCH),\n184\t        params,\n185\t    )\n186\t    async for row in result.mappings():\n187\t        yield UsageRollupExportRecord(\n188\t            customer_id=row[\"customer_id\"],\n189\t            metric=row[\"metric\"],\n190\t            window_start=row[\"window_start\"],\n191\t            total_quantity=row[\"total_quantity\"],\n192\t        )\n193\t"}]},"uuid":"3bffa5c9-a032-4a23-8e4e-04c8d634d129","timestamp":"2026-07-09T20:03:11.501Z","sourceToolAssistantUUID":"d005d12f-9f16-4a22-983c-148d0fa75d02","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"3bffa5c9-a032-4a23-8e4e-04c8d634d129","isSidechain":true,"agentId":"aa91a4ccd0eafabe2","message":{"model":"claude-opus-4-8","id":"msg_011Ccs5g7LCvtAyz78UeyncC","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AyJS7rJbJbyMFGFaGVXNss","name":"Read","input":{"file_path":"C:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8119,"cache_read_input_tokens":35492,"output_tokens":742,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":8119},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":742,"cache_read_input_tokens":35492,"cache_creation_input_tokens":8119,"cache_creation":{"ephemeral_5m_input_tokens":8119,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccs5g6S8egUTzKMM2LtCV","attributionAgent":"security","type":"assistant","uuid":"547d609c-05fd-4eee-b078-ea87733bd3cc","timestamp":"2026-07-09T20:03:12.095Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"547d609c-05fd-4eee-b078-ea87733bd3cc","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"aa91a4ccd0eafabe2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AyJS7rJbJbyMFGFaGVXNss","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t# How many encoded data rows to accumulate in the buffer before handing one\n35\t# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n36\t# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n37\t# every streamed chunk through its own anyio memory-object-stream — ran once\n38\t# per row (100,000× at the cap), which dominated the export's wall-clock time\n39\t# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n40\t# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n41\t# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n42\t_ROWS_PER_CHUNK = 1000\n43\t\n44\t\n45\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n46\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n47\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n48\t\n49\t    This must run and fully resolve *before* the route returns a\n50\t    `StreamingResponse` — once that response object exists the status line\n51\t    is already 200 and bytes may already be on the wire, so a 422 can no\n52\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n53\t    (a DB connection drop, a query error) is deliberately left to propagate\n54\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n55\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n56\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n57\t    \"\"\"\n58\t    async with scoped_transaction(principal.api_key_id) as session:\n59\t        row_count = await count_usage_rollups(\n60\t            session,\n61\t            api_key_id=principal.api_key_id,\n62\t            customer_id=params.customer_id,\n63\t            metric=params.metric,\n64\t            window_from=params.from_,\n65\t            window_to=params.to,\n66\t        )\n67\t\n68\t    if row_count > MAX_EXPORT_ROWS:\n69\t        logger.warning(\n70\t            \"usage.export.rejected\",\n71\t            userId=principal.api_key_id,\n72\t            action=\"deny\",\n73\t            reason=\"row_cap_exceeded\",\n74\t        )\n75\t        raise HTTPException(\n76\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n77\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n78\t        )\n79\t\n80\t\n81\tdef _drain(buffer: io.StringIO) -> bytes:\n82\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n83\t    place — this is what keeps the generator at constant memory: it never\n84\t    holds more than one row's encoded text at a time.\"\"\"\n85\t    data = buffer.getvalue().encode(\"utf-8\")\n86\t    buffer.seek(0)\n87\t    buffer.truncate(0)\n88\t    return data\n89\t\n90\t\n91\tasync def stream_export_csv(\n92\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n93\t) -> AsyncIterator[bytes]:\n94\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n95\t    CSV-encoded row per streamed `usage_rollup` record.\n96\t\n97\t    Yielding the header before touching the database means an empty result\n98\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n99\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n100\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n101\t    setting and the server-side cursor both stay valid for the whole stream.\n102\t    \"\"\"\n103\t    row_count = 0\n104\t    capped = False\n105\t    completed = False\n106\t\n107\t    buffer = io.StringIO()\n108\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n109\t\n110\t    try:\n111\t        # Header first, always, as its own chunk — so an empty result is a\n112\t        # 200 header-only CSV (AC12) and the first bytes are observable before\n113\t        # the data rows stream (AC9), independent of the data-row batching below.\n114\t        writer.writerow(EXPORT_HEADER)\n115\t        yield _drain(buffer)\n116\t\n117\t        async with scoped_transaction(principal.api_key_id) as session:\n118\t            async for record in stream_usage_rollups(\n119\t                session,\n120\t                api_key_id=principal.api_key_id,\n121\t                customer_id=params.customer_id,\n122\t                metric=params.metric,\n123\t                window_from=params.from_,\n124\t                window_to=params.to,\n125\t                limit=MAX_EXPORT_ROWS,\n126\t            ):\n127\t                writer.writerow(\n128\t                    [\n129\t                        escape_csv_text_cell(record.customer_id),\n130\t                        escape_csv_text_cell(record.metric),\n131\t                        format_window_start(record.window_start),\n132\t                        format_total_quantity(record.total_quantity),\n133\t                    ]\n134\t                )\n135\t                row_count += 1\n136\t                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n137\t                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n138\t                # cap this yields ~100 chunks, never one buffered blob.\n139\t                if row_count % _ROWS_PER_CHUNK == 0:\n140\t                    yield _drain(buffer)\n141\t\n142\t        # Flush the trailing partial batch. For an empty result nothing is\n143\t        # buffered here (the header already went out above), so no stray chunk.\n144\t        if buffer.tell():\n145\t            yield _drain(buffer)\n146\t\n147\t        capped = row_count >= MAX_EXPORT_ROWS\n148\t        completed = True\n149\t    finally:\n150\t        # In `finally` so a client disconnect or a mid-stream DB error still\n151\t        # records what was actually sent (`completed=False` in that case) —\n152\t        # exactly one usage.export event per request either way (AC17).\n153\t        logger.info(\n154\t            \"usage.export\",\n155\t            userId=principal.api_key_id,\n156\t            action=\"read\",\n157\t            resource=\"usage_rollup\",\n158\t            rowCount=row_count,\n159\t            capped=capped,\n160\t            completed=completed,\n161\t            filtered_by_customer=params.customer_id is not None,\n162\t            filtered_by_metric=params.metric is not None,\n163\t            bounded_from=params.from_ is not None,\n164\t            bounded_to=params.to is not None,\n165\t        )\n166\t"}]},"uuid":"0eafbd67-b7d9-4485-a3d0-b22f904b844b","timestamp":"2026-07-09T20:03:12.117Z","sourceToolAssistantUUID":"547d609c-05fd-4eee-b078-ea87733bd3cc","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
