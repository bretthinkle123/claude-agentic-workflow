{"parentUuid":"6d250f4d-242f-46a4-9f7c-4f3bf79da497","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01J1SXnXDoPYmy7hkLiaUWDt","type":"tool_result","content":"1\t\"\"\"Application entry point: constructs the FastAPI app, registers the\n2\tmiddleware stack in the order `api-edge-conventions` requires, mounts the\n3\trouters, and wires the lifespan startup/shutdown hooks.\n4\t\n5\tDeliberately defers every *connecting* dependency (DB pool, Redis client) to\n6\tfirst use rather than import time, so `python -c \"import src.main\"` succeeds\n7\twith no PostgreSQL or Redis running — the smoke check's build-fallback mode\n8\tdepends on this. OTel/Sentry instrumentation is wired during app construction\n9\tinstead of inside the lifespan startup hook: Starlette forbids registering\n10\tASGI middleware (which `FastAPIInstrumentor` does) once the app has started\n11\tserving, and neither call performs a blocking network operation at\n12\tconfiguration time — exporting is async/background and a no-op when\n13\tunconfigured (`src/observability/otel.py`, `src/observability/sentry.py`).\n14\t\"\"\"\n15\t\n16\tfrom collections.abc import AsyncIterator\n17\tfrom contextlib import asynccontextmanager\n18\t\n19\tfrom fastapi import FastAPI\n20\t\n21\tfrom src.api.errors import register_error_handlers\n22\tfrom src.api.middleware import (\n23\t    BodySizeLimitMiddleware,\n24\t    SecurityHeadersMiddleware,\n25\t    Tier1EdgeThrottleMiddleware,\n26\t    configure_cors,\n27\t)\n28\tfrom src.api.routes.events import router as events_router\n29\tfrom src.api.routes.health import router as health_router\n30\tfrom src.api.routes.quotas import router as quotas_router\n31\tfrom src.api.routes.usage import router as usage_router\n32\tfrom src.config.settings import get_settings\n33\tfrom src.db.session import dispose_engine\n34\tfrom src.logging import get_logger\n35\tfrom src.logging.middleware import RequestContextMiddleware\n36\tfrom src.observability.otel import configure_otel\n37\tfrom src.observability.sentry import configure_sentry\n38\t\n39\tlogger = get_logger(service=\"meterly\")\n40\t\n41\t\n42\t@asynccontextmanager\n43\tasync def lifespan(app: FastAPI) -> AsyncIterator[None]:\n44\t    \"\"\"Startup: log readiness (DB/Redis pools are created lazily on first use,\n45\t    not here, so a slow/unreachable dependency at boot never blocks the\n46\t    process from becoming live). Shutdown: drain and close pools.\n47\t    \"\"\"\n48\t    settings = get_settings()\n49\t    logger.info(\"app.startup\", environment=settings.environment, release=settings.release_sha)\n50\t\n51\t    yield\n52\t\n53\t    logger.info(\"app.shutdown\")\n54\t    await dispose_engine()\n55\t    from src.auth.rate_limit import dispose_redis_client\n56\t\n57\t    await dispose_redis_client()\n58\t\n59\t\n60\tdef create_app() -> FastAPI:\n61\t    \"\"\"Build and configure the FastAPI application (the single app-construction\n62\t    entry point — nothing outside this function registers middleware or routes).\"\"\"\n63\t    settings = get_settings()\n64\t\n65\t    app = FastAPI(\n66\t        title=\"Meterly\",\n67\t        version=\"1.0.0\",\n68\t        lifespan=lifespan,\n69\t        docs_url=\"/docs\" if settings.enable_docs else None,\n70\t        redoc_url=\"/redoc\" if settings.enable_docs else None,\n71\t    )\n72\t\n73\t    # Middleware is applied in reverse-registration order by Starlette (the\n74\t    # last `add_middleware` call becomes the outermost layer), so this list\n75\t    # is written outermost-to-innermost per api-edge-conventions and then\n76\t    # reversed at registration to preserve that intent.\n77\t    app.add_middleware(Tier1EdgeThrottleMiddleware, capacity=settings.tier1_rate_limit_burst, refill_rate_per_second=settings.tier1_rate_limit_per_second)\n78\t    app.add_middleware(BodySizeLimitMiddleware, max_body_size_bytes=settings.max_body_size_bytes)\n79\t    configure_cors(app, settings)\n80\t    app.add_middleware(SecurityHeadersMiddleware)\n81\t    app.add_middleware(RequestContextMiddleware)\n82\t\n83\t    register_error_handlers(app)\n84\t\n85\t    app.include_router(health_router)\n86\t    app.include_router(events_router)\n87\t    app.include_router(usage_router)\n88\t    app.include_router(quotas_router)\n89\t\n90\t    # Must run after routes are mounted (FastAPIInstrumentor introspects them)\n91\t    # and before the app starts serving (it registers ASGI middleware, which\n92\t    # Starlette forbids once serving has begun) — so construction time, not\n93\t    # the lifespan hook, is the correct place for this.\n94\t    configure_sentry(settings)\n95\t    configure_otel(app, settings)\n96\t\n97\t    return app\n98\t\n99\t\n100\tapp = create_app()\n101\t"}]},"uuid":"fe97e42a-81be-45e3-8201-7fe4e3e4020a","timestamp":"2026-07-09T03:59:27.318Z","sourceToolAssistantUUID":"6d250f4d-242f-46a4-9f7c-4f3bf79da497","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"fe97e42a-81be-45e3-8201-7fe4e3e4020a","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011CcqpAwouaNQTwjdbpzQ72","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015VBFmEV9EzoEDKTizeKJ5w","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/k6/load_events_quota.js"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3365,"cache_read_input_tokens":41193,"cache_creation":{"ephemeral_5m_input_tokens":3365,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqpAvjArqcUpAqrJTuFS","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"49cc39c3-7797-402d-95a7-a6c35c401591","timestamp":"2026-07-09T03:59:27.824Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"49cc39c3-7797-402d-95a7-a6c35c401591","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015VBFmEV9EzoEDKTizeKJ5w","type":"tool_result","content":"1\timport http from 'k6/http';\n2\timport { check } from 'k6';\n3\t\n4\t// Quota-active variant of load_events.js (AC20): drives the identical\n5\t// sustained constant-arrival-rate ingest scenario, but against a caller\n6\t// whose (customer, metric) buckets each carry a pre-seeded, deliberately\n7\t// high quota (set directly in Postgres by the pytest fixture before this\n8\t// script runs) -- so the quota-check read-and-decide executes on every\n9\t// request (not the unlimited zero-lookup-cost path) while never actually\n10\t// rejecting, isolating the added latency of the FOR UPDATE lookup itself\n11\t// from any rejection-path cost.\n12\tconst BASE_URL = __ENV.BASE_URL;\n13\tconst API_KEY = __ENV.API_KEY;\n14\tconst TARGET_RPS = parseInt(__ENV.TARGET_RPS || '500', 10);\n15\tconst DURATION = __ENV.DURATION || '15s';\n16\tconst WARMUP_DURATION = __ENV.WARMUP_DURATION || '5s';\n17\tconst PREALLOC_VUS = parseInt(__ENV.PREALLOC_VUS || '120', 10);\n18\tconst MAX_VUS = parseInt(__ENV.MAX_VUS || '600', 10);\n19\t\n20\texport const options = {\n21\t  scenarios: {\n22\t    warmup: {\n23\t      executor: 'constant-arrival-rate',\n24\t      rate: 10,\n25\t      timeUnit: '1s',\n26\t      duration: WARMUP_DURATION,\n27\t      preAllocatedVUs: 20,\n28\t      maxVUs: 50,\n29\t      exec: 'postEvent',\n30\t    },\n31\t    ingest: {\n32\t      executor: 'constant-arrival-rate',\n33\t      rate: TARGET_RPS,\n34\t      timeUnit: '1s',\n35\t      duration: DURATION,\n36\t      preAllocatedVUs: PREALLOC_VUS,\n37\t      maxVUs: MAX_VUS,\n38\t      exec: 'postEvent',\n39\t      startTime: WARMUP_DURATION,\n40\t    },\n41\t  },\n42\t  discardResponseBodies: false,\n43\t};\n44\t\n45\tlet counter = 0;\n46\t\n47\texport function postEvent() {\n48\t  counter += 1;\n49\t  const randomSuffix = Math.floor(Math.random() * 1e9);\n50\t  const uniqueId = `${__VU}-${__ITER}-${counter}-${Date.now()}-${randomSuffix}`;\n51\t  // Must match the customer-bucket range the pytest fixture pre-seeds a\n52\t  // quota for (cust_0..cust_49) -- otherwise these requests would hit the\n53\t  // unlimited (no-quota-row) path instead of exercising the quota check.\n54\t  const payload = JSON.stringify({\n55\t    customer_id: `cust_${__VU % 50}`,\n56\t    metric: 'api_calls',\n57\t    quantity: '1',\n58\t    idempotency_key: `k6-quota-${uniqueId}`,\n59\t  });\n60\t\n61\t  const response = http.post(`${BASE_URL}/v1/events`, payload, {\n62\t    headers: {\n63\t      'Content-Type': 'application/json',\n64\t      Authorization: `Bearer ${API_KEY}`,\n65\t    },\n66\t  });\n67\t\n68\t  check(response, {\n69\t    'status is 201 (never 429 -- quota set high enough to never reject)': (r) => r.status === 201,\n70\t  });\n71\t}\n72\t"}]},"uuid":"e0d634c3-07ba-44a4-a60a-8137c28e802b","timestamp":"2026-07-09T03:59:27.839Z","sourceToolAssistantUUID":"49cc39c3-7797-402d-95a7-a6c35c401591","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"e0d634c3-07ba-44a4-a60a-8137c28e802b","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011CcqpAwouaNQTwjdbpzQ72","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_019SURhN3zaLkgrWuutwtazM","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/.github/workflows/pipeline-ci.yml"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3365,"cache_read_input_tokens":41193,"cache_creation":{"ephemeral_5m_input_tokens":3365,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqpAvjArqcUpAqrJTuFS","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"85fba304-bf31-4cae-9c4e-893524642a08","timestamp":"2026-07-09T03:59:28.769Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"85fba304-bf31-4cae-9c4e-893524642a08","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019SURhN3zaLkgrWuutwtazM","type":"tool_result","content":"1\t# pipeline-ci.yml — per-project CI merge gate (PR L, Layer 2).\n2\t# Written to .github/workflows/pipeline-ci.yml by bootstrap-project.sh, which fills\n3\t# pytest --cov=src --cov-branch/python -c \"import src.main\" from its --test/--build flags (same channel as smoke.env).\n4\t# <INSTALL_CMD> and <COVERAGE_FLOOR> are filled by the implementation/testing agents when\n5\t# the stack is known (the floor mirrors test-conventions — the SAME figure the local gate\n6\t# rides, so CI and the local gate can't disagree about the bar).\n7\t#\n8\t# WHY: the pipeline's gates run pre-merge on the AUTHOR'S machine. CI re-RUNS every\n9\t# objective check on the merge commit — it never re-reads .pipeline/ artifacts (those are\n10\t# the author's claims; re-execution is the only honest verification). Agent-judgment gates\n11\t# (criteria mapping, reconciliations) remain pre-merge guarantees; branch protection +\n12\t# required human review are their CI-side counterpart. See docs/ci-merge-gate-plan.md.\n13\t#\n14\t# The re-run scripts live in scripts/ci/ — copied INTO this repo at bootstrap (committed,\n15\t# human-reviewed, pinned at the bootstrap-time version) so CI never fetches them remotely.\n16\t# SCAN_BASE rescopes their diff to merge-base…HEAD (git diff HEAD is empty on a merge commit).\n17\t#\n18\t# Waivers: CI honors ONLY committed, tool-native ignore files (osv-scanner.toml,\n19\t# .trivyignore, .semgrepignore) — visible in the diff, human-reviewed. The local-only\n20\t# .pipeline/waivers.json never reaches CI by design. asvs-sast + source markers are\n21\t# fix-not-waive: no ignore path is offered.\n22\t#\n23\t# Supply-chain conventions: first-party actions pinned by commit SHA; scanners run from\n24\t# their official images, version-tagged — pin image DIGESTS on first CI run (same posture\n25\t# as exact-pin deps). Least-privilege permissions; per-ref concurrency; hard timeouts.\n26\tname: pipeline-ci\n27\t\n28\ton:\n29\t  push:\n30\t    branches: [main]\n31\t  pull_request:\n32\t    branches: [main]\n33\t\n34\tpermissions:\n35\t  contents: read\n36\t\n37\tconcurrency:\n38\t  group: pipeline-ci-${{ github.ref }}\n39\t  cancel-in-progress: true\n40\t\n41\tenv:\n42\t  # PRs: scan merge-base..HEAD. Pushes to main: scan the pushed range. RAW because on a\n43\t  # first/force push `github.event.before` is the all-zeros SHA — each diff-scoped job\n44\t  # resolves it via the \"Resolve scan base\" step (fallback HEAD^) instead of failing\n45\t  # closed on a non-reason.\n46\t  SCAN_BASE_RAW: ${{ github.event.pull_request.base.sha || github.event.before }}\n47\t\n48\tjobs:\n49\t  build-and-test:\n50\t    runs-on: ubuntu-latest\n51\t    timeout-minutes: 30\n52\t    steps:\n53\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n54\t      - uses: actions/setup-python@v5\n55\t        with:\n56\t          python-version: \"3.12\"\n57\t      - name: Install dependencies (from lockfile)\n58\t        run: |\n59\t          pip install poetry==2.4.1\n60\t          poetry install --no-root\n61\t        # `--no-root` (not `--only main`): the test job also needs the dev\n62\t        # group (pytest/httpx/testcontainers/hypothesis) to run the suite below.\n63\t      - name: Build\n64\t        run: poetry run python -c \"import src.main\"\n65\t      - name: Test with coverage (floor = the local gate's figure)\n66\t        run: poetry run pytest --cov=src --cov-branch\n67\t        # Fail under <COVERAGE_FLOOR>% combined lines — the same figure the local deploy\n68\t        # gate rides. Branch coverage: surface in the job summary, do NOT gate (mirrors\n69\t        # the local posture; see test-conventions).\n70\t\n71\t  # mutation — U-22: run mutation testing HERE, on the Linux runner, not on the author's\n72\t  # host. mutmut needs a POSIX environment (WSL on Windows), so the local pipeline honestly\n73\t  # skips it and writes quality_ok:false (WS3-1) — the *measurement* just never happened on\n74\t  # win32, two M3-series runs in a row. This job runs it where it works. ADVISORY: it reports\n75\t  # the score in the job summary and NEVER fails the merge gate (mutation quality is\n76\t  # settled-advisory; the local WS3-1 scope-honesty check stays the only deploy-side teeth).\n77\t  # OPT-IN: fill <MUTATION_CMD> + <MUTATION_SCOPE> (the logic-dense changed modules, matching\n78\t  # test-conventions) to enable; leave the placeholders and delete this job if not using it.\n79\t  mutation:\n80\t    if: false   # flip to `true` (or a repo/branch condition) once <MUTATION_CMD> is filled\n81\t    runs-on: ubuntu-latest\n82\t    timeout-minutes: 30\n83\t    steps:\n84\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n85\t      - uses: actions/setup-python@v5\n86\t        with:\n87\t          python-version: \"3.12\"\n88\t      - name: Install dependencies (from lockfile)\n89\t        run: |\n90\t          pip install poetry==2.4.1\n91\t          poetry install --no-root\n92\t      - name: Mutation testing (advisory — score to the summary, never fails the gate)\n93\t        run: |\n94\t          set +e\n95\t          <MUTATION_CMD>   # e.g. mutmut run --paths-to-mutate <MUTATION_SCOPE>\n96\t          echo \"Mutation run complete (advisory; see output). This job never fails the merge gate.\" >> \"$GITHUB_STEP_SUMMARY\"\n97\t          exit 0\n98\t\n99\t  sast:\n100\t    runs-on: ubuntu-latest\n101\t    timeout-minutes: 20\n102\t    steps:\n103\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n104\t      - name: Semgrep (full tree; criticals fail, warnings annotate)\n105\t        run: |\n106\t          docker run --rm -v \"$PWD:/src\" -w /src semgrep/semgrep:latest \\\n107\t            semgrep scan --config auto --severity ERROR --error .\n108\t          # Use the same rule packs the project's semgrep-ruleset-guide names; honors a\n109\t          # committed .semgrepignore. Pin the image digest on first run.\n110\t\n111\t  # codeql — deep SAST (roadmap row CQ): semantic taint/dataflow analysis beyond Semgrep's\n112\t  # pattern matching; findings surface as code-scanning ALERTS on the PR/merge commit (the\n113\t  # job fails only on analysis error, not on findings — added assurance, not a delivery\n114\t  # step). CI-only BY DESIGN: it builds a database and is slow, so it stays out of the local\n115\t  # security⇄debug⇄test loop (docs/ci-merge-gate-plan.md Layer 4). Free on public repos;\n116\t  # private repos need GitHub Advanced Security — if neither applies, delete this job (the\n117\t  # Semgrep/ASVS layers above still run). One include entry PER LANGUAGE, each paired with\n118\t  # its build mode (duplicate the entry for a second language):\n119\t  #   build-mode none — javascript-typescript, python, ruby, c-cpp, csharp, java-kotlin, rust\n120\t  #   build-mode autobuild — go\n121\t  #   swift — needs a macOS runner + autobuild/manual; deferred with the iOS roadmap row\n122\t  # NOTE: if the repo has CodeQL \"default setup\" enabled in Settings, disable it first —\n123\t  # it rejects uploads from advanced (workflow) configurations like this one.\n124\t  codeql:\n125\t    runs-on: ubuntu-latest\n126\t    timeout-minutes: 30\n127\t    permissions:\n128\t      contents: read\n129\t      security-events: write   # upload results to code scanning (per-job elevation)\n130\t    strategy:\n131\t      fail-fast: false\n132\t      matrix:\n133\t        include:\n134\t          - language: <CODEQL_LANGUAGE>       # e.g. python\n135\t            build-mode: <CODEQL_BUILD_MODE>   # none | autobuild — see the table above\n136\t    steps:\n137\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n138\t      - uses: github/codeql-action/init@8aad20d150bbac5944a9f9d289da16a4b0d87c1e # v4.36.2\n139\t        with:\n140\t          languages: ${{ matrix.language }}\n141\t          build-mode: ${{ matrix.build-mode }}\n142\t          queries: security-extended\n143\t      - uses: github/codeql-action/analyze@8aad20d150bbac5944a9f9d289da16a4b0d87c1e # v4.36.2\n144\t        with:\n145\t          category: \"/language:${{ matrix.language }}\"\n146\t\n147\t  deps:\n148\t    runs-on: ubuntu-latest\n149\t    timeout-minutes: 15\n150\t    steps:\n151\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n152\t        with: { fetch-depth: 0 }   # SCAN_BASE needs history\n153\t      - name: Resolve scan base (all-zeros on a first/force push → fall back to HEAD^)\n154\t        id: base\n155\t        run: |\n156\t          B=\"$SCAN_BASE_RAW\"\n157\t          case \"$B\" in \"\"|0000000000000000000000000000000000000000) B=\"\" ;; esac\n158\t          [ -n \"$B\" ] && git rev-parse --verify --quiet \"$B^{commit}\" >/dev/null || B=\"$(git rev-parse --verify --quiet HEAD^ || true)\"\n159\t          echo \"sha=$B\" >> \"$GITHUB_OUTPUT\"\n160\t          [ -n \"$B\" ] || echo \"::warning::no resolvable scan base (single-commit repo) — diff-scoped checks skipped this run\"\n161\t      - name: OSV scan (CVSS >= 7.0 fails — the B6 floor; honors committed osv-scanner.toml)\n162\t        run: |\n163\t          docker run --rm -v \"$PWD:/src\" -w /src ghcr.io/google/osv-scanner:latest \\\n164\t            scan --lockfile-scan-mode=all -r /src\n165\t      - name: Lockfile integrity vs merge base (exit 2 blocks; exit 1 = warn, annotated not failed)\n166\t        if: steps.base.outputs.sha != ''\n167\t        run: |\n168\t          set +e   # steps run bash -e; capture the tri-state exit code ourselves\n169\t          SCAN_BASE=\"${{ steps.base.outputs.sha }}\" bash scripts/ci/lockfile-check.sh\n170\t          rc=$?\n171\t          set -e\n172\t          if [ \"$rc\" -eq 1 ]; then echo \"::warning::lockfile-check reported warnings (see log)\"; exit 0; fi\n173\t          exit \"$rc\"\n174\t\n175\t  secrets:\n176\t    runs-on: ubuntu-latest\n177\t    timeout-minutes: 15\n178\t    steps:\n179\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n180\t        with: { fetch-depth: 0 }   # full history — CI can afford it (local hook is diff-scoped)\n181\t      - name: Resolve scan base\n182\t        id: base\n183\t        run: |\n184\t          B=\"$SCAN_BASE_RAW\"\n185\t          case \"$B\" in \"\"|0000000000000000000000000000000000000000) B=\"\" ;; esac\n186\t          [ -n \"$B\" ] && git rev-parse --verify --quiet \"$B^{commit}\" >/dev/null || B=\"$(git rev-parse --verify --quiet HEAD^ || true)\"\n187\t          echo \"sha=$B\" >> \"$GITHUB_OUTPUT\"\n188\t      - name: Gitleaks over branch history (full tree when no base resolves)\n189\t        run: |\n190\t          if [ -n \"${{ steps.base.outputs.sha }}\" ]; then\n191\t            docker run --rm -v \"$PWD:/src\" -w /src zricethezav/gitleaks:latest \\\n192\t              detect --source /src --log-opts=\"${{ steps.base.outputs.sha }}..HEAD\" --redact -v\n193\t          else\n194\t            docker run --rm -v \"$PWD:/src\" -w /src zricethezav/gitleaks:latest \\\n195\t              detect --source /src --redact -v\n196\t          fi\n197\t\n198\t  containers-iac:\n199\t    runs-on: ubuntu-latest\n200\t    timeout-minutes: 20\n201\t    steps:\n202\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n203\t      - name: Trivy fs (vuln + secret + misconfig; honors committed .trivyignore)\n204\t        run: |\n205\t          docker run --rm -v \"$PWD:/src\" -w /src aquasec/trivy:latest \\\n206\t            fs --scanners vuln,secret,misconfig --exit-code 1 --severity HIGH,CRITICAL /src\n207\t      - name: Checkov (only when infra/ exists)\n208\t        run: |\n209\t          if [ -d infra ]; then\n210\t            docker run --rm -v \"$PWD:/src\" -w /src bridgecrew/checkov:latest -d /src/infra\n211\t          else echo \"no infra/ — skipped\"; fi\n212\t\n213\t  asvs-markers:\n214\t    runs-on: ubuntu-latest\n215\t    timeout-minutes: 10\n216\t    steps:\n217\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n218\t        with: { fetch-depth: 0 }\n219\t      - name: Resolve scan base\n220\t        id: base\n221\t        run: |\n222\t          B=\"$SCAN_BASE_RAW\"\n223\t          case \"$B\" in \"\"|0000000000000000000000000000000000000000) B=\"\" ;; esac\n224\t          [ -n \"$B\" ] && git rev-parse --verify --quiet \"$B^{commit}\" >/dev/null || B=\"$(git rev-parse --verify --quiet HEAD^ || true)\"\n225\t          echo \"sha=$B\" >> \"$GITHUB_OUTPUT\"\n226\t      - name: ASVS Tier-1 patterns vs merge base (fix-not-waive; exit 2 fails)\n227\t        if: steps.base.outputs.sha != ''\n228\t        run: SCAN_BASE=\"${{ steps.base.outputs.sha }}\" bash scripts/ci/asvs-sast.sh\n229\t      - name: Experimental-revert / must-not-ship markers vs merge base (fix-not-waive; exit 2 fails)\n230\t        if: steps.base.outputs.sha != ''\n231\t        run: SCAN_BASE=\"${{ steps.base.outputs.sha }}\" bash scripts/ci/guard-source-markers.sh\n232\t\n233\t  store-compliance:\n234\t    runs-on: ubuntu-latest\n235\t    timeout-minutes: 10\n236\t    steps:\n237\t      - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0\n238\t      - name: App-store Tier-1 checks (repo-state scoped; no-ops on non-mobile projects)\n239\t        run: |\n240\t          mkdir -p .pipeline && echo '{}' > .pipeline/state.json   # satisfy the ambient guard\n241\t          bash scripts/ci/store-compliance.sh\n242\t          crit=$(jq -r '.critical // 0' .pipeline/store-compliance.json 2>/dev/null || echo 0)\n243\t          echo \"store-compliance critical=$crit\"\n244\t          [ \"$crit\" -eq 0 ] || exit 1   # mirror the local deploy-gate floor\n245\t\n246\t  # dast-baseline — filled per docs/dast-plan.md when the app has a bootable HTTP surface:\n247\t  # boot the app (service container or <START_CMD>), run the ZAP passive baseline against\n248\t  # it, then scripts/ci/dast-review.sh vs the committed dast-budget.json (blocking on High\n249\t  # here, per the DAST plan's promotion rule). Inert until wired.\n250\t  # dast-baseline:\n251\t\n252\t  # deploy-verify — the reborn post-deploy-check: probes DEPLOY_HEALTH_URL after PR N's\n253\t  # deploy workflow reports success. Inert (skipped) until PR N provides the URL.\n254\t  deploy-verify:\n255\t    if: ${{ vars.DEPLOY_HEALTH_URL != '' }}\n256\t    runs-on: ubuntu-latest\n257\t    timeout-minutes: 5\n258\t    steps:\n259\t      - name: Post-deploy health probe\n260\t        run: curl -sf -m 10 \"${{ vars.DEPLOY_HEALTH_URL }}\" >/dev/null\n261\t"}]},"uuid":"46cea2e3-0947-48ee-8efe-6f840330f1a1","timestamp":"2026-07-09T03:59:28.790Z","sourceToolAssistantUUID":"85fba304-bf31-4cae-9c4e-893524642a08","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"46cea2e3-0947-48ee-8efe-6f840330f1a1","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011CcqpCRtdYwCBNmu5EnhJo","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":10590,"cache_read_input_tokens":44558,"cache_creation":{"ephemeral_5m_input_tokens":10590,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqpCPgRhVUc3jx6Sr97x","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"96147bc4-3e55-4554-8185-72858981054c","timestamp":"2026-07-09T03:59:36.507Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"96147bc4-3e55-4554-8185-72858981054c","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011CcqpCRtdYwCBNmu5EnhJo","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GzqMLU1paDwZreyaNL8dMC","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_perf_k6_load.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":10590,"cache_read_input_tokens":44558,"cache_creation":{"ephemeral_5m_input_tokens":10590,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqpCPgRhVUc3jx6Sr97x","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"443c720c-8e1b-4cbc-af19-5c2031e1e0b6","timestamp":"2026-07-09T03:59:37.505Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"443c720c-8e1b-4cbc-af19-5c2031e1e0b6","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GzqMLU1paDwZreyaNL8dMC","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF: a REAL sustained load run using k6 (via Docker), driving the\n2\tplan's declared scenario -- constant-arrival-rate at the target rate over a\n3\tsustained window, distributed key space -- against a real uvicorn process\n4\t(out-of-process, real network stack, multiple workers) backed by real\n5\tPostgres + Redis testcontainers.\n6\t\n7\tThis supersedes the best-effort in-process smoke in test_perf_smoke.py: k6\n8\truns in its own Docker container (grafana/k6) and reaches the host-run\n9\tuvicorn via `host.docker.internal`. True p95 is computed here by nearest-rank\n10\tover the raw per-request `http_req_duration` samples k6 writes to its JSON\n11\toutput (never trusting k6's own approximate percentile field blindly, per\n12\ttest-conventions) -- scoped to points tagged `scenario=ingest` so warm-up\n13\tcold-start latency is excluded from the measurement, the way a real load-test\n14\trig ramps up before recording.\n15\t\n16\tSkips (not fails) if Docker or the grafana/k6 image is unavailable -- this\n17\trecords an honest absence of measurement, never a fabricated one.\n18\t\"\"\"\n19\t\n20\timport asyncio\n21\timport datetime\n22\timport json\n23\timport os\n24\timport shutil\n25\timport socket\n26\timport subprocess\n27\timport sys\n28\timport tempfile\n29\timport time\n30\tfrom collections import Counter\n31\tfrom contextlib import closing\n32\tfrom pathlib import Path\n33\t\n34\timport httpx\n35\timport pytest\n36\t\n37\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n38\t_K6_SCRIPTS_DIR = Path(__file__).resolve().parent / \"k6\"\n39\t\n40\t# AC20 p95 debug (2026-07-08, see .pipeline/debug-notes.md): the quota-active\n41\t# perf run MUST use the same uvicorn-worker budget as the no-quota baseline it\n42\t# is compared against. An earlier 2-worker default for the quota fixture (vs\n43\t# the baseline's 5) starved it below the 500 rps constant-arrival target -- two\n44\t# worker processes could not service this workload's per-request CPU on the\n45\t# Docker-Desktop/Windows host, so excess arrivals queued and p95 inflated into\n46\t# the multi-second range from PURE QUEUEING, not from the quota FOR UPDATE\n47\t# read-and-decide (which adds ~3 ms p95 when measured under an equal worker\n48\t# budget). Confirmed empirically: raising the DB pool alone at 2 workers did\n49\t# NOT help (the ceiling is worker processes, not pooled connections); matching\n50\t# the baseline worker count did. The shared Postgres testcontainer runs\n51\t# max_connections=300, so 5 workers x (pool_size 10 + overflow 5) = 75\n52\t# connections is well within budget.\n53\t_DEFAULT_PERF_UVICORN_WORKERS = 5\n54\t\n55\t\n56\tdef _baseline_perf_workers() -> int:\n57\t    return int(os.environ.get(\"METERLY_PERF_UVICORN_WORKERS\", str(_DEFAULT_PERF_UVICORN_WORKERS)))\n58\t\n59\t\n60\tdef _quota_perf_workers() -> int:\n61\t    \"\"\"Worker count for the quota-active perf fixture. Defaults to the baseline\n62\t    worker count so AC20 is an apples-to-apples measurement; still independently\n63\t    overridable via `METERLY_PERF_QUOTA_UVICORN_WORKERS` for capacity tuning.\"\"\"\n64\t    return int(\n65\t        os.environ.get(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", str(_baseline_perf_workers()))\n66\t    )\n67\t\n68\t\n69\tdef _free_port() -> int:\n70\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n71\t        sock.bind((\"0.0.0.0\", 0))\n72\t        return sock.getsockname()[1]\n73\t\n74\t\n75\tdef _docker_available() -> bool:\n76\t    if shutil.which(\"docker\") is None:\n77\t        return False\n78\t    result = subprocess.run([\"docker\", \"info\"], capture_output=True, timeout=10)\n79\t    return result.returncode == 0\n80\t\n81\t\n82\tdef _nearest_rank_from_raw_jsonl(path: Path, scenario: str) -> dict:\n83\t    \"\"\"Parse k6's raw JSON-lines output and compute the TRUE percentiles via\n84\t    nearest-rank over the `http_req_duration` samples tagged with `scenario`\n85\t    -- this is what test-conventions requires instead of trusting k6's own\n86\t    (t-digest-approximated) percentile fields.\"\"\"\n87\t    durations: list[float] = []\n88\t    timestamps: list[str] = []\n89\t    statuses: list[str] = []\n90\t\n91\t    with path.open(encoding=\"utf-8\") as f:\n92\t        for line in f:\n93\t            line = line.strip()\n94\t            if not line:\n95\t                continue\n96\t            record = json.loads(line)\n97\t            if record.get(\"type\") != \"Point\" or record.get(\"metric\") != \"http_req_duration\":\n98\t                continue\n99\t            tags = record[\"data\"].get(\"tags\", {})\n100\t            if tags.get(\"scenario\") != scenario:\n101\t                continue\n102\t            durations.append(record[\"data\"][\"value\"])\n103\t            timestamps.append(record[\"data\"][\"time\"])\n104\t            statuses.append(tags.get(\"status\"))\n105\t\n106\t    if not durations:\n107\t        return {\"sample_count\": 0}\n108\t\n109\t    durations.sort()\n110\t    n = len(durations)\n111\t\n112\t    def nearest_rank(percentile: float) -> float:\n113\t        rank = max(1, round(percentile / 100 * n))\n114\t        return durations[min(rank, n) - 1]\n115\t\n116\t    sorted_timestamps = sorted(timestamps)\n117\t    first = datetime.datetime.fromisoformat(sorted_timestamps[0].replace(\"Z\", \"+00:00\"))\n118\t    last = datetime.datetime.fromisoformat(sorted_timestamps[-1].replace(\"Z\", \"+00:00\"))\n119\t    elapsed_seconds = (last - first).total_seconds()\n120\t\n121\t    return {\n122\t        \"sample_count\": n,\n123\t        \"status_counts\": dict(Counter(statuses)),\n124\t        \"p50_ms\": round(nearest_rank(50), 2),\n125\t        \"p90_ms\": round(nearest_rank(90), 2),\n126\t        \"p95_ms\": round(nearest_rank(95), 2),\n127\t        \"p99_ms\": round(nearest_rank(99), 2),\n128\t        \"max_ms\": round(durations[-1], 2),\n129\t        \"elapsed_seconds\": round(elapsed_seconds, 2),\n130\t        \"throughput_rps\": round(n / elapsed_seconds, 2) if elapsed_seconds > 0 else 0.0,\n131\t    }\n132\t\n133\t\n134\t@pytest.fixture\n135\tasync def k6_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n136\t    \"\"\"Launch the real app under uvicorn (multi-worker, out-of-process)\n137\t    against the live containers, ready for a k6 container to hit it via\n138\t    `host.docker.internal`.\"\"\"\n139\t    if not _docker_available():\n140\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n141\t\n142\t    pull_result = subprocess.run(\n143\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n144\t    )\n145\t    if pull_result.returncode != 0:\n146\t        pull_result = subprocess.run(\n147\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n148\t        )\n149\t        if pull_result.returncode != 0:\n150\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n151\t\n152\t    port = _free_port()\n153\t    env = dict(os.environ)\n154\t    env[\"DATABASE_URL\"] = postgres_url\n155\t    env[\"METERLY_REDIS_URL\"] = redis_url\n156\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n157\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n158\t\n159\t    presented_key, _ = await make_api_key(label=\"k6-perf-key\", rate_limit_per_sec=1_000_000)\n160\t\n161\t    workers = _baseline_perf_workers()\n162\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_perf\"\n163\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n164\t\n165\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n166\t    process = subprocess.Popen(\n167\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n168\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n169\t    )\n170\t\n171\t    try:\n172\t        deadline = time.monotonic() + 30\n173\t        async with httpx.AsyncClient() as probe:\n174\t            ready = False\n175\t            while time.monotonic() < deadline:\n176\t                try:\n177\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n178\t                    if response.status_code == 200:\n179\t                        ready = True\n180\t                        break\n181\t                except httpx.TransportError:\n182\t                    pass\n183\t                await asyncio.sleep(0.3)\n184\t            if not ready:\n185\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n186\t\n187\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n188\t    finally:\n189\t        process.terminate()\n190\t        try:\n191\t            process.wait(timeout=10)\n192\t        except subprocess.TimeoutExpired:\n193\t            process.kill()\n194\t        uvicorn_log.close()\n195\t\n196\t\n197\tdef _run_k6(script_name: str, port: int, api_key: str, scratch_dir: Path, target_rps: int, duration: str, warmup: str, out_name: str) -> subprocess.CompletedProcess:\n198\t    raw_out = scratch_dir / out_name\n199\t    if raw_out.exists():\n200\t        raw_out.unlink()\n201\t    return subprocess.run(\n202\t        [\n203\t            \"docker\", \"run\", \"--rm\",\n204\t            \"--add-host=host.docker.internal:host-gateway\",\n205\t            \"-v\", f\"{scratch_dir}:/perf_out\",\n206\t            \"-v\", f\"{_K6_SCRIPTS_DIR}:/perf_scripts:ro\",\n207\t            \"-e\", f\"BASE_URL=http://host.docker.internal:{port}\",\n208\t            \"-e\", f\"API_KEY={api_key}\",\n209\t            \"-e\", f\"TARGET_RPS={target_rps}\",\n210\t            \"-e\", f\"DURATION={duration}\",\n211\t            \"-e\", f\"WARMUP_DURATION={warmup}\",\n212\t            \"grafana/k6\", \"run\",\n213\t            \"--out\", f\"json=/perf_out/{out_name}\",\n214\t            f\"/perf_scripts/{script_name}\",\n215\t        ],\n216\t        capture_output=True, text=True, timeout=180,\n217\t    )\n218\t\n219\t\n220\tdef test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n221\t    \"\"\"Drive POST /v1/events at a real, sustained constant-arrival-rate of\n222\t    500 req/s (the AC6 budget's declared rate) over a real k6 container\n223\t    against a real out-of-process uvicorn + Postgres + Redis, with a\n224\t    distributed key space (unique idempotency_key + customer_id spread across\n225\t    50 buckets per request, no replay contention). Records true nearest-rank\n226\t    p95 + achieved throughput -- an honest measurement, not a claim the\n227\t    budget is met.\"\"\"\n228\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n229\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n230\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n231\t\n232\t    result = _run_k6(\n233\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n234\t        target_rps, duration, warmup, \"k6_events_raw.jsonl\",\n235\t    )\n236\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n237\t\n238\t    if result.returncode != 0:\n239\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_stdout.log\")\n240\t\n241\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_events_raw.jsonl\", scenario=\"ingest\")\n242\t    (k6_load_env[\"scratch_dir\"] / \"events_metrics.json\").write_text(json.dumps(metrics, indent=2))\n243\t    print(\"POST /v1/events k6 load metrics:\", json.dumps(metrics, indent=2))\n244\t\n245\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n246\t\n247\t\n248\t@pytest.fixture\n249\tasync def k6_quota_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n250\t    \"\"\"Like `k6_load_env`, but the provisioned key is admin-scoped and each\n251\t    `cust_0..cust_49` bucket the k6 script drives (`load_events_quota.js`)\n252\t    carries a pre-seeded, deliberately high quota (AC20) -- so the ingest\n253\t    path exercises the quota-check read-and-decide on every request without\n254\t    ever actually rejecting one, isolating the added latency of the `FOR\n255\t    UPDATE` lookup itself from the (much larger, transaction-aborting) cost\n256\t    of a rejection.\n257\t    \"\"\"\n258\t    if not _docker_available():\n259\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n260\t\n261\t    pull_result = subprocess.run(\n262\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n263\t    )\n264\t    if pull_result.returncode != 0:\n265\t        pull_result = subprocess.run(\n266\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n267\t        )\n268\t        if pull_result.returncode != 0:\n269\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n270\t\n271\t    port = _free_port()\n272\t    env = dict(os.environ)\n273\t    env[\"DATABASE_URL\"] = postgres_url\n274\t    env[\"METERLY_REDIS_URL\"] = redis_url\n275\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n276\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n277\t\n278\t    presented_key, api_key_id = await make_api_key(\n279\t        label=\"k6-quota-perf-key\", rate_limit_per_sec=1_000_000, scope=\"admin\"\n280\t    )\n281\t\n282\t    from sqlalchemy import text\n283\t    from sqlalchemy.ext.asyncio import create_async_engine\n284\t\n285\t    # A high-but-finite cap per bucket (well above anything a 15s run at the\n286\t    # target rate could accumulate) -- active enough to exercise the FOR\n287\t    # UPDATE read-and-decide on every request, never high enough to matter\n288\t    # for whether a single run's requests are accepted.\n289\t    quota_engine = create_async_engine(postgres_url)\n290\t    async with quota_engine.begin() as connection:\n291\t        for customer_index in range(50):\n292\t            await connection.execute(\n293\t                text(\n294\t                    \"\"\"\n295\t                    INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n296\t                    VALUES (:api_key_id, :customer_id, 'api_calls', 100000000, now())\n297\t                    ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n298\t                        limit_per_window = EXCLUDED.limit_per_window\n299\t                    \"\"\"\n300\t                ),\n301\t                {\"api_key_id\": api_key_id, \"customer_id\": f\"cust_{customer_index}\"},\n302\t            )\n303\t    await quota_engine.dispose()\n304\t\n305\t    # Match the baseline fixture's worker budget (default 5) so AC20 measures\n306\t    # the quota path under the SAME CPU/event-loop capacity it is compared\n307\t    # against -- a smaller budget starves the constant-arrival-rate scenario and\n308\t    # inflates p95 with queueing delay that has nothing to do with the quota\n309\t    # check (see _quota_perf_workers and .pipeline/debug-notes.md 2026-07-08).\n310\t    # The shared Postgres container runs max_connections=300 and these perf\n311\t    # fixtures are function-scoped (torn down before the next), so 5 workers x\n312\t    # 15 pooled connections is comfortably within the session's budget.\n313\t    workers = _quota_perf_workers()\n314\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_quota_perf\"\n315\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n316\t\n317\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n318\t    process = subprocess.Popen(\n319\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n320\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n321\t    )\n322\t\n323\t    try:\n324\t        deadline = time.monotonic() + 30\n325\t        async with httpx.AsyncClient() as probe:\n326\t            ready = False\n327\t            while time.monotonic() < deadline:\n328\t                try:\n329\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n330\t                    if response.status_code == 200:\n331\t                        ready = True\n332\t                        break\n333\t                except httpx.TransportError:\n334\t                    pass\n335\t                await asyncio.sleep(0.3)\n336\t            if not ready:\n337\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n338\t\n339\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n340\t    finally:\n341\t        process.terminate()\n342\t        try:\n343\t            process.wait(timeout=10)\n344\t        except subprocess.TimeoutExpired:\n345\t            process.kill()\n346\t        uvicorn_log.close()\n347\t        # Give Postgres a moment to reclaim the just-closed workers' backend\n348\t        # connection slots before the next test's fixtures open new ones\n349\t        # against the same shared container (mitigates TooManyConnectionsError\n350\t        # when this module's perf tests run back-to-back in one session).\n351\t        await asyncio.sleep(1.0)\n352\t\n353\t\n354\tdef test_events_ingest_with_quotas_p95_within_1_5x_baseline(k6_load_env, k6_quota_load_env):\n355\t    \"\"\"AC20 (human-revised 2026-07-09, see .pipeline/debug-notes.md and the\n356\t    AC20 row in .pipeline/acceptance.md): the original absolute \"p95 < 50ms\"\n357\t    form is unachievable on this Docker-Desktop/Windows host for ANY code\n358\t    (the no-quota baseline itself runs ~84-112ms here). AC20 is now a\n359\t    RELATIVE budget: quota-active p95 <= 1.5x the same-session no-quota\n360\t    baseline p95, both measured at equal uvicorn worker budget.\n361\t\n362\t    This test drives BOTH the no-quota baseline (`k6_load_env`, workers =\n363\t    `_baseline_perf_workers()`) and the quota-active path (`k6_quota_load_env`,\n364\t    workers = `_quota_perf_workers()`, which defaults to the SAME count) in\n365\t    the same test session, back-to-back, and asserts the relative bound\n366\t    directly -- closing the prior gap where this test only asserted\n367\t    `sample_count > 0` and let a real regression (measured 3362ms vs an 84ms\n368\t    baseline, ~40x) pass green (see test-quality.json's AC20 gap, now closed\n369\t    by this assertion).\"\"\"\n370\t    assert _quota_perf_workers() == _baseline_perf_workers(), (\n371\t        f\"AC20 requires an equal worker budget for the relative comparison to be \"\n372\t        f\"apples-to-apples, but quota={_quota_perf_workers()} != baseline={_baseline_perf_workers()}\"\n373\t    )\n374\t\n375\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n376\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n377\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n378\t\n379\t    baseline_result = _run_k6(\n380\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n381\t        target_rps, duration, warmup, \"k6_events_baseline_raw.jsonl\",\n382\t    )\n383\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_stdout.log\").write_text(\n384\t        baseline_result.stdout + \"\\n---STDERR---\\n\" + baseline_result.stderr\n385\t    )\n386\t    if baseline_result.returncode != 0:\n387\t        pytest.skip(\n388\t            f\"k6 baseline run failed to execute in this environment (rc={baseline_result.returncode}); \"\n389\t            \"see k6_events_baseline_stdout.log\"\n390\t        )\n391\t    baseline_metrics = _nearest_rank_from_raw_jsonl(\n392\t        k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_raw.jsonl\", scenario=\"ingest\"\n393\t    )\n394\t    (k6_load_env[\"scratch_dir\"] / \"events_baseline_metrics.json\").write_text(json.dumps(baseline_metrics, indent=2))\n395\t    print(\"POST /v1/events no-quota baseline k6 load metrics:\", json.dumps(baseline_metrics, indent=2))\n396\t\n397\t    quota_result = _run_k6(\n398\t        \"load_events_quota.js\", k6_quota_load_env[\"port\"], k6_quota_load_env[\"api_key\"], k6_quota_load_env[\"scratch_dir\"],\n399\t        target_rps, duration, warmup, \"k6_events_quota_raw.jsonl\",\n400\t    )\n401\t    (k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_stdout.log\").write_text(\n402\t        quota_result.stdout + \"\\n---STDERR---\\n\" + quota_result.stderr\n403\t    )\n404\t    if quota_result.returncode != 0:\n405\t        pytest.skip(\n406\t            f\"k6 quota run failed to execute in this environment (rc={quota_result.returncode}); \"\n407\t            \"see k6_events_quota_stdout.log\"\n408\t        )\n409\t    quota_metrics = _nearest_rank_from_raw_jsonl(\n410\t        k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_raw.jsonl\", scenario=\"ingest\"\n411\t    )\n412\t    (k6_quota_load_env[\"scratch_dir\"] / \"events_quota_metrics.json\").write_text(json.dumps(quota_metrics, indent=2))\n413\t    print(\"POST /v1/events (quotas active) k6 load metrics:\", json.dumps(quota_metrics, indent=2))\n414\t\n415\t    assert baseline_metrics[\"sample_count\"] > 0, \"the baseline k6 run produced no ingest-scenario samples -- unmeasured\"\n416\t    assert quota_metrics[\"sample_count\"] > 0, \"the quota k6 run produced no ingest-scenario samples -- unmeasured\"\n417\t\n418\t    budget_p95 = 1.5 * baseline_metrics[\"p95_ms\"]\n419\t    assert quota_metrics[\"p95_ms\"] <= budget_p95, (\n420\t        f\"AC20: quota-active p95 ({quota_metrics['p95_ms']}ms) exceeds 1.5x the same-session \"\n421\t        f\"no-quota baseline p95 ({baseline_metrics['p95_ms']}ms -> budget {budget_p95:.2f}ms) \"\n422\t        f\"at equal worker budget ({_quota_perf_workers()} workers)\"\n423\t    )\n424\t\n425\t\n426\tdef test_ac20_quota_perf_fixture_matches_baseline_worker_budget(monkeypatch):\n427\t    \"\"\"Regression guard for the AC20 p95 debug (.pipeline/debug-notes.md,\n428\t    2026-07-08). The quota-active perf fixture must not be provisioned with\n429\t    FEWER uvicorn workers than the no-quota baseline it is compared against.\n430\t\n431\t    A prior 2-worker default (vs the baseline's 5) starved the quota run below\n432\t    the 500 rps constant-arrival target, so its p95 inflated into the seconds\n433\t    purely from queueing -- masquerading as a quota-code-path regression that,\n434\t    measured under an equal worker budget, does not exist (~87 ms vs the ~85 ms\n435\t    baseline). This fast, Docker-free guard fails before the fix (2 < 5) and\n436\t    passes after (5 >= 5), locking the handicap out of the harness for good.\"\"\"\n437\t    monkeypatch.delenv(\"METERLY_PERF_UVICORN_WORKERS\", raising=False)\n438\t    monkeypatch.delenv(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", raising=False)\n439\t    assert _quota_perf_workers() >= _baseline_perf_workers(), (\n440\t        f\"quota perf fixture worker budget ({_quota_perf_workers()}) is below the \"\n441\t        f\"no-quota baseline ({_baseline_perf_workers()}); AC20 would be measured on a \"\n442\t        \"starved pool and its p95 would reflect queueing, not the quota check\"\n443\t    )\n444\t\n445\t\n446\tdef test_usage_read_sustained_100rps_k6_load(k6_load_env):\n447\t    \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n448\t    against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n449\t    target_rps = int(os.environ.get(\"METERLY_PERF_USAGE_TARGET_RPS\", \"100\"))\n450\t    duration = os.environ.get(\"METERLY_PERF_USAGE_DURATION\", \"10s\")\n451\t    warmup = os.environ.get(\"METERLY_PERF_USAGE_WARMUP\", \"3s\")\n452\t\n453\t    result = _run_k6(\n454\t        \"load_usage.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n455\t        target_rps, duration, warmup, \"k6_usage_raw.jsonl\",\n456\t    )\n457\t    (k6_load_env[\"scratch_dir\"] / \"k6_usage_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n458\t\n459\t    if result.returncode != 0:\n460\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_usage_stdout.log\")\n461\t\n462\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_usage_raw.jsonl\", scenario=\"ingest\")\n463\t    (k6_load_env[\"scratch_dir\"] / \"usage_metrics.json\").write_text(json.dumps(metrics, indent=2))\n464\t    print(\"GET /v1/usage k6 load metrics:\", json.dumps(metrics, indent=2))\n465\t\n466\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n467\t"}]},"uuid":"2e016655-db9d-4a57-ba59-8220a8fcf582","timestamp":"2026-07-09T03:59:37.520Z","sourceToolAssistantUUID":"443c720c-8e1b-4cbc-af19-5c2031e1e0b6","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch"