{"parentUuid":"6838fd6e-61ae-4be3-8028-89bb320e7636","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp88JMeAEZZEW3bAaKG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TSGQvbgCLHUk1kDwaSnFAX","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":174,"cache_creation_input_tokens":7361,"cache_read_input_tokens":11457,"cache_creation":{"ephemeral_5m_input_tokens":7361,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccqp86pYvSZne8UTjiAug","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"dbdf08a2-b800-4b03-970c-6cb38990f8af","timestamp":"2026-07-09T03:58:35.181Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"dbdf08a2-b800-4b03-970c-6cb38990f8af","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TSGQvbgCLHUk1kDwaSnFAX","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"ef715ae8-e077-4662-ae01-4e316c3db12e","timestamp":"2026-07-09T03:58:35.212Z","sourceToolAssistantUUID":"dbdf08a2-b800-4b03-970c-6cb38990f8af","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"ef715ae8-e077-4662-ae01-4e316c3db12e","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp88JMeAEZZEW3bAaKG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Qpa4fcq53stw3DryPgnXnt","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/auth/api_key.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":174,"cache_creation_input_tokens":7361,"cache_read_input_tokens":11457,"cache_creation":{"ephemeral_5m_input_tokens":7361,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccqp86pYvSZne8UTjiAug","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"d9a457db-6546-4262-a70c-779f28aa5798","timestamp":"2026-07-09T03:58:35.365Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"d9a457db-6546-4262-a70c-779f28aa5798","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qpa4fcq53stw3DryPgnXnt","type":"tool_result","content":"1\t\"\"\"Split-token API-key parsing and Argon2id verification against `api_keys`.\n2\t\n3\tKey format: `mtr_live_<key_id>_<secret>` — `key_id` is a public, indexed lookup\n4\thandle; `secret` is a >=128-bit CSPRNG value whose Argon2id hash is the only\n5\tthing stored. Parsing is a strict anchored regex so a malformed header is\n6\trejected before any database work (`src/api/schemas` sibling contract for the\n7\t`Authorization` header, per the plan's validation-contract table).\n8\t\"\"\"\n9\t\n10\timport re\n11\timport secrets\n12\tfrom dataclasses import dataclass\n13\t\n14\tfrom sqlalchemy.ext.asyncio import AsyncConnection\n15\t\n16\tfrom src.crypto import hash_secret, verify_secret\n17\tfrom src.repositories.api_keys_repo import find_active_key_by_key_id\n18\t\n19\t_TOKEN_PATTERN = re.compile(r\"^mtr_live_(?P<key_id>[A-Za-z0-9]{1,32})_(?P<secret>[A-Za-z0-9]{1,64})$\")\n20\t_KEY_ID_BYTES = 16\n21\t_SECRET_BYTES = 32\n22\t\n23\t\n24\t@dataclass(frozen=True)\n25\tclass ParsedApiKey:\n26\t    \"\"\"The two halves of a presented split-token API key.\"\"\"\n27\t\n28\t    key_id: str\n29\t    secret: str\n30\t\n31\t\n32\t@dataclass(frozen=True)\n33\tclass AuthenticatedPrincipal:\n34\t    \"\"\"The authenticated caller: the internal `api_key_id`, its rate-limit\n35\t    budget, and its authorization `scope`.\n36\t\n37\t    `scope` defaults to `\"ingest\"` so any direct construction in existing unit\n38\t    tests keeps working unchanged; `verify_api_key` always populates it\n39\t    explicitly from the stored record. `\"admin\"` is a superset scope — an\n40\t    admin-scoped key may do everything an ingest key does, plus call\n41\t    `PUT /v1/quotas` (plan §\"The tenant model\").\n42\t    \"\"\"\n43\t\n44\t    api_key_id: int\n45\t    rate_limit_per_sec: int\n46\t    scope: str = \"ingest\"\n47\t\n48\t\n49\tdef parse_split_token(presented_key: str) -> ParsedApiKey | None:\n50\t    \"\"\"Parse `mtr_live_<key_id>_<secret>`; returns None for anything malformed.\n51\t\n52\t    A strict, anchored regex means a malformed token is rejected before any\n53\t    database work — no scanning, no partial parse (401 before any DB work).\n54\t    \"\"\"\n55\t    match = _TOKEN_PATTERN.match(presented_key)\n56\t    if match is None:\n57\t        return None\n58\t    return ParsedApiKey(key_id=match.group(\"key_id\"), secret=match.group(\"secret\"))\n59\t\n60\t\n61\tasync def verify_api_key(\n62\t    connection: AsyncConnection, presented_key: str\n63\t) -> AuthenticatedPrincipal | None:\n64\t    \"\"\"Verify a presented `Authorization` bearer value end to end.\n65\t\n66\t    Parses the split token, looks the key up by its public `key_id`, and runs\n67\t    an Argon2id verify against the stored hash. Returns None on any failure —\n68\t    malformed token, unknown/revoked key_id, or a wrong secret are all\n69\t    indistinguishable to the caller (no oracle for key enumeration).\n70\t    \"\"\"\n71\t    parsed = parse_split_token(presented_key)\n72\t    if parsed is None:\n73\t        return None\n74\t\n75\t    record = await find_active_key_by_key_id(connection, parsed.key_id)\n76\t    if record is None:\n77\t        return None\n78\t\n79\t    if not verify_secret(parsed.secret, record.secret_hash):\n80\t        return None\n81\t\n82\t    return AuthenticatedPrincipal(\n83\t        api_key_id=record.id, rate_limit_per_sec=record.rate_limit_per_sec, scope=record.scope\n84\t    )\n85\t\n86\t\n87\tdef generate_split_token() -> tuple[str, str, str]:\n88\t    \"\"\"Generate a new `(key_id, secret, presented_key)` triple for key\n89\t    provisioning (`scripts/seed_api_key.py`).\n90\t\n91\t    `secret_hash = hash_secret(secret)` is what the caller stores; `secret`\n92\t    and the full `presented_key` are shown to the operator exactly once and\n93\t    never persisted in plaintext.\n94\t    \"\"\"\n95\t    key_id = secrets.token_hex(_KEY_ID_BYTES)\n96\t    secret = secrets.token_hex(_SECRET_BYTES)\n97\t    presented_key = f\"mtr_live_{key_id}_{secret}\"\n98\t    return key_id, secret, presented_key\n99\t\n100\t\n101\tdef hash_new_secret(secret: str) -> str:\n102\t    \"\"\"Hash a freshly generated secret for storage — thin re-export of the\n103\t    crypto facade so callers of this module don't need a second import.\"\"\"\n104\t    return hash_secret(secret)\n105\t"}]},"uuid":"e3fc9859-9dac-4391-b12b-26abe12b7fca","timestamp":"2026-07-09T03:58:35.383Z","sourceToolAssistantUUID":"d9a457db-6546-4262-a70c-779f28aa5798","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"e3fc9859-9dac-4391-b12b-26abe12b7fca","isSidechain":true,"agentId":"acecf48983d445221","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp88JMeAEZZEW3bAaKG","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0169jMdB1BTEBAeDkRResWG4","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/quotas.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":174,"cache_creation_input_tokens":7361,"cache_read_input_tokens":11457,"output_tokens":296,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":7361},"inference_geo":"not_available","iterations":[{"input_tokens":174,"output_tokens":296,"cache_read_input_tokens":11457,"cache_creation_input_tokens":7361,"cache_creation":{"ephemeral_5m_input_tokens":7361,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccqp86pYvSZne8UTjiAug","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"12b52887-1098-410d-885d-55409758dcac","timestamp":"2026-07-09T03:58:35.719Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"12b52887-1098-410d-885d-55409758dcac","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"acecf48983d445221","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0169jMdB1BTEBAeDkRResWG4","type":"tool_result","content":"1\t\"\"\"`PUT /v1/quotas` — admin-scoped create-or-replace of a per-customer,\n2\tper-metric usage cap.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\n7\tmirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\n8\tpattern (kept per-route, not shared, per the existing convention).\n9\t\"\"\"\n10\t\n11\tfrom fastapi import APIRouter, Depends, HTTPException, Request, Response, status\n12\t\n13\tfrom src.api.schemas.quotas import QuotaPutRequest, QuotaResponse\n14\tfrom src.auth import require_api_key\n15\tfrom src.auth.api_key import AuthenticatedPrincipal\n16\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n17\tfrom src.logging import get_logger\n18\tfrom src.services.quota_service import to_response, upsert_tenant_quota\n19\t\n20\trouter = APIRouter(tags=[\"quotas\"])\n21\tlogger = get_logger(service=\"meterly\")\n22\t\n23\t_ADMIN_SCOPE = \"admin\"\n24\t\n25\t\n26\tasync def _require_admin_and_throttled(\n27\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n28\t) -> AuthenticatedPrincipal:\n29\t    \"\"\"Compose auth, then the Tier-2 per-key throttle, then the admin-scope\n30\t    gate, in that order — mirrors `src/api/routes/events.py`'s dependency\n31\t    chain, extended with the function-level authorization check this route\n32\t    alone requires (ASVS 8.2.1).\n33\t    \"\"\"\n34\t    await enforce_tier2_rate_limit(request, principal)\n35\t    if principal.scope != _ADMIN_SCOPE:\n36\t        logger.warning(\n37\t            \"quota.forbidden\",\n38\t            userId=principal.api_key_id,\n39\t            action=\"deny\",\n40\t            reason=\"insufficient_scope\",\n41\t        )\n42\t        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"admin scope required\")\n43\t    return principal\n44\t\n45\t\n46\t@router.put(\"/v1/quotas\", response_model=QuotaResponse)\n47\tasync def put_quota(\n48\t    payload: QuotaPutRequest,\n49\t    response: Response,\n50\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n51\t) -> QuotaResponse:\n52\t    \"\"\"Create or replace the cap for `(customer_id, metric)` under the\n53\t    caller's own tenant — 201 on create, 200 on replace.\"\"\"\n54\t    outcome = await upsert_tenant_quota(principal, payload)\n55\t    response.status_code = outcome.http_status\n56\t    return to_response(outcome)\n57\t"}]},"uuid":"8c7bbed5-6b66-4304-b231-1a40b60df30e","timestamp":"2026-07-09T03:58:35.734Z","sourceToolAssistantUUID":"12b52887-1098-410d-885d-55409758dcac","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
