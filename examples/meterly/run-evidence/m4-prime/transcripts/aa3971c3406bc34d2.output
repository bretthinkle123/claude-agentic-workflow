{"parentUuid":"78cbbb51-3caa-42b5-9067-ffbf0105b1f0","isSidechain":true,"agentId":"aa3971c3406bc34d2","message":{"model":"claude-sonnet-5","id":"msg_011Ccq3dMcrukoSREuQV3Yf3","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01W1PDZDUKysdo1XaCSkeW4V","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_logging_redaction.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1586,"cache_read_input_tokens":156144,"output_tokens":218,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":1586},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":218,"cache_read_input_tokens":156144,"cache_creation_input_tokens":1586,"cache_creation":{"ephemeral_5m_input_tokens":1586,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccq3dJZofoSsfYrBVii8k","attributionAgent":"implementation","type":"assistant","uuid":"b570e1f1-491d-495c-80c2-f9248de9550c","timestamp":"2026-07-08T18:15:03.902Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"b570e1f1-491d-495c-80c2-f9248de9550c","isSidechain":true,"promptId":"eca00838-5098-4dde-983a-34e68a423bb3","agentId":"aa3971c3406bc34d2","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01W1PDZDUKysdo1XaCSkeW4V","type":"tool_result","content":"1\t\"\"\"AC9 (data_protection log-sink half): a raw `customer_id` (or any other\n2\tsensitive field) must never reach the rendered log line, regardless of which\n3\tcall site logs it.\"\"\"\n4\t\n5\timport json\n6\t\n7\tfrom src.logging import _redact_sensitive_fields, _strip_control_characters, get_logger\n8\t\n9\t\n10\tdef test_redact_sensitive_fields_masks_customer_id():\n11\t    \"\"\"`customer_id` is redacted before rendering, wherever a call site logs it.\"\"\"\n12\t    event_dict = {\"event\": \"usage.read\", \"customer_id\": \"cust_super_secret_123\", \"userId\": 7}\n13\t    redacted = _redact_sensitive_fields(None, \"info\", event_dict)\n14\t    assert redacted[\"customer_id\"] == \"***redacted***\"\n15\t    assert redacted[\"userId\"] == 7\n16\t\n17\t\n18\tdef test_redact_sensitive_fields_masks_authorization_and_secret_keys():\n19\t    \"\"\"Every sensitive key name is redacted, not only customer_id.\"\"\"\n20\t    event_dict = {\n21\t        \"authorization\": \"Bearer mtr_live_abc_def\",\n22\t        \"api_key_secret\": \"shh\",\n23\t        \"secret_hash\": \"$argon2id$...\",\n24\t        \"password\": \"hunter2\",\n25\t        \"token\": \"abc123\",\n26\t    }\n27\t    redacted = _redact_sensitive_fields(None, \"info\", event_dict)\n28\t    assert all(value == \"***redacted***\" for value in redacted.values())\n29\t\n30\t\n31\tdef test_strip_control_characters_neutralizes_crlf_log_forging():\n32\t    \"\"\"A newline/CRLF in a logged string value is neutralized, not rendered raw.\"\"\"\n33\t    event_dict = {\"endpoint\": \"/v1/events\\r\\nfake: injected-header\"}\n34\t    stripped = _strip_control_characters(None, \"info\", event_dict)\n35\t    assert \"\\r\" not in stripped[\"endpoint\"]\n36\t    assert \"\\n\" not in stripped[\"endpoint\"]\n37\t    assert \"\\\\r\\\\n\" in stripped[\"endpoint\"]\n38\t\n39\t\n40\tdef test_get_logger_end_to_end_never_prints_raw_customer_id(capsys):\n41\t    \"\"\"A real log call through the configured structlog pipeline never emits\n42\t    the raw customer_id in the rendered (stdout JSON) output.\"\"\"\n43\t    logger = get_logger(service=\"meterly\")\n44\t    logger.info(\"usage.read\", userId=7, action=\"read\", customer_id=\"cust_should_never_appear\")\n45\t\n46\t    captured = capsys.readouterr()\n47\t    assert \"cust_should_never_appear\" not in captured.out\n48\t\n49\t    rendered = json.loads(captured.out.strip().splitlines()[-1])\n50\t    assert rendered[\"customer_id\"] == \"***redacted***\"\n51\t"}]},"uuid":"ce6a7c29-a777-46ac-ad22-1eaf4a1b95d3","timestamp":"2026-07-08T18:15:03.914Z","sourceToolAssistantUUID":"b570e1f1-491d-495c-80c2-f9248de9550c","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
