= timedelta(hours=1)\nsrc/api/schemas/usage_export.py:20:class UsageExportQueryParams(BaseModel):\nsrc/api/routes/usage_export.py:52:async def _require_authenticated_and_throttled(\nsrc/api/routes/usage_export.py:62:def _export_filename(now: datetime) -> str:\nsrc/api/routes/usage_export.py:70:async def get_usage_export(\nsrc/services/time_windows.py:12:def floor_to_hour_utc(timestamp: datetime) -> datetime:\nsrc/repositories/events_repo.py:18:class EventRecord:\nsrc/repositories/events_repo.py:30:async def insert_event_if_new(\nsrc/repositories/events_repo.py:76:async def find_event_by_idempotency_key(\nsrc/repositories/events_repo.py:101:async def increment_usage_rollup(","is_error":false}]},"uuid":"e7164ef2-198a-4d12-a91b-12a09c1075ec","timestamp":"2026-07-09T20:35:44.080Z","sourceToolAssistantUUID":"fa685c1c-40c2-43b8-8d6a-4da73862799c","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
