{"parentUuid":"559fd1af-0b30-438c-ba81-7c4e20804048","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a13995f3207b5009a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014PHZ7cCZWdSq75kJDCTKKc","type":"tool_result","content":"1\t\"\"\"Split-token API-key parsing and Argon2id verification against `api_keys`.\n2\t\n3\tKey format: `mtr_live_<key_id>_<secret>` — `key_id` is a public, indexed lookup\n4\thandle; `secret` is a >=128-bit CSPRNG value whose Argon2id hash is the only\n5\tthing stored. Parsing is a strict anchored regex so a malformed header is\n6\trejected before any database work (`src/api/schemas` sibling contract for the\n7\t`Authorization` header, per the plan's validation-contract table).\n8\t\"\"\"\n9\t\n10\timport re\n11\timport secrets\n12\tfrom dataclasses import dataclass\n13\t\n14\tfrom sqlalchemy.ext.asyncio import AsyncConnection\n15\t\n16\tfrom src.crypto import hash_secret, verify_secret\n17\tfrom src.repositories.api_keys_repo import find_active_key_by_key_id\n18\t\n19\t_TOKEN_PATTERN = re.compile(r\"^mtr_live_(?P<key_id>[A-Za-z0-9]{1,32})_(?P<secret>[A-Za-z0-9]{1,64})$\")\n20\t_KEY_ID_BYTES = 16\n21\t_SECRET_BYTES = 32\n22\t\n23\t\n24\t@dataclass(frozen=True)\n25\tclass ParsedApiKey:\n26\t    \"\"\"The two halves of a presented split-token API key.\"\"\"\n27\t\n28\t    key_id: str\n29\t    secret: str\n30\t\n31\t\n32\t@dataclass(frozen=True)\n33\tclass AuthenticatedPrincipal:\n34\t    \"\"\"The authenticated caller: the internal `api_key_id`, its rate-limit\n35\t    budget, and its authorization `scope`.\n36\t\n37\t    `scope` defaults to `\"ingest\"` so any direct construction in existing unit\n38\t    tests keeps working unchanged; `verify_api_key` always populates it\n39\t    explicitly from the stored record. `\"admin\"` is a superset scope — an\n40\t    admin-scoped key may do everything an ingest key does, plus call\n41\t    `PUT /v1/quotas` (plan §\"The tenant model\").\n42\t    \"\"\"\n43\t\n44\t    api_key_id: int\n45\t    rate_limit_per_sec: int\n46\t    scope: str = \"ingest\"\n47\t\n48\t\n49\tdef parse_split_token(presented_key: str) -> ParsedApiKey | None:\n50\t    \"\"\"Parse `mtr_live_<key_id>_<secret>`; returns None for anything malformed.\n51\t\n52\t    A strict, anchored regex means a malformed token is rejected before any\n53\t    database work — no scanning, no partial parse (401 before any DB work).\n54\t    \"\"\"\n55\t    match = _TOKEN_PATTERN.match(presented_key)\n56\t    if match is None:\n57\t        return None\n58\t    return ParsedApiKey(key_id=match.group(\"key_id\"), secret=match.group(\"secret\"))\n59\t\n60\t\n61\tasync def verify_api_key(\n62\t    connection: AsyncConnection, presented_key: str\n63\t) -> AuthenticatedPrincipal | None:\n64\t    \"\"\"Verify a presented `Authorization` bearer value end to end.\n65\t\n66\t    Parses the split token, looks the key up by its public `key_id`, and runs\n67\t    an Argon2id verify against the stored hash. Returns None on any failure —\n68\t    malformed token, unknown/revoked key_id, or a wrong secret are all\n69\t    indistinguishable to the caller (no oracle for key enumeration).\n70\t    \"\"\"\n71\t    parsed = parse_split_token(presented_key)\n72\t    if parsed is None:\n73\t        return None\n74\t\n75\t    record = await find_active_key_by_key_id(connection, parsed.key_id)\n76\t    if record is None:\n77\t        return None\n78\t\n79\t    if not verify_secret(parsed.secret, record.secret_hash):\n80\t        return None\n81\t\n82\t    return AuthenticatedPrincipal(\n83\t        api_key_id=record.id, rate_limit_per_sec=record.rate_limit_per_sec, scope=record.scope\n84\t    )\n85\t\n86\t\n87\tdef generate_split_token() -> tuple[str, str, str]:\n88\t    \"\"\"Generate a new `(key_id, secret, presented_key)` triple for key\n89\t    provisioning (`scripts/seed_api_key.py`).\n90\t\n91\t    `secret_hash = hash_secret(secret)` is what the caller stores; `secret`\n92\t    and the full `presented_key` are shown to the operator exactly once and\n93\t    never persisted in plaintext.\n94\t    \"\"\"\n95\t    key_id = secrets.token_hex(_KEY_ID_BYTES)\n96\t    secret = secrets.token_hex(_SECRET_BYTES)\n97\t    presented_key = f\"mtr_live_{key_id}_{secret}\"\n98\t    return key_id, secret, presented_key\n99\t\n100\t\n101\tdef hash_new_secret(secret: str) -> str:\n102\t    \"\"\"Hash a freshly generated secret for storage — thin re-export of the\n103\t    crypto facade so callers of this module don't need a second import.\"\"\"\n104\t    return hash_secret(secret)\n105\t"}]},"uuid":"5f6cf084-16e9-4134-a9f4-e5d9f484f31d","timestamp":"2026-07-09T03:58:54.443Z","sourceToolAssistantUUID":"559fd1af-0b30-438c-ba81-7c4e20804048","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"5f6cf084-16e9-4134-a9f4-e5d9f484f31d","isSidechain":true,"agentId":"a13995f3207b5009a","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp9af9e4TuQVYt5i25e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01REPvMJfNbFhDiNZrPTqzEk","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/conftest.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7945,"cache_read_input_tokens":18776,"cache_creation":{"ephemeral_5m_input_tokens":7945,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccqp9ZnosQdnnUEhkspP4","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"a910b1c8-8600-4a77-9bc5-d3a2feed6022","timestamp":"2026-07-09T03:58:54.928Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"a910b1c8-8600-4a77-9bc5-d3a2feed6022","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a13995f3207b5009a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01REPvMJfNbFhDiNZrPTqzEk","type":"tool_result","content":"1\t\"\"\"Shared fixtures for integration tests: a real PostgreSQL + Redis, each in a\n2\ttestcontainer, migrated with the project's actual Alembic revisions and wired\n3\tinto the app's process-wide singletons so requests through the ASGI app hit\n4\treal dependencies — the correctness guarantees under test here (ON CONFLICT\n5\tconcurrency, RLS tenant isolation, migration round-trips) are only real\n6\tagainst actual Postgres, not a mock.\n7\t\"\"\"\n8\t\n9\timport asyncio\n10\timport os\n11\timport subprocess\n12\timport sys\n13\tfrom pathlib import Path\n14\t\n15\timport pytest\n16\tfrom httpx import ASGITransport, AsyncClient\n17\tfrom testcontainers.postgres import PostgresContainer\n18\tfrom testcontainers.redis import RedisContainer\n19\t\n20\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n21\t\n22\t\n23\tdef _asyncpg_url(sync_url: str) -> str:\n24\t    \"\"\"Convert testcontainers' default `postgresql+psycopg2://` URL to the\n25\t    `postgresql+asyncpg://` dialect the application (and Alembic's env.py) uses.\"\"\"\n26\t    return sync_url.replace(\"postgresql+psycopg2://\", \"postgresql+asyncpg://\")\n27\t\n28\t\n29\t@pytest.fixture(scope=\"session\")\n30\tdef postgres_url():\n31\t    \"\"\"A session-scoped live Postgres, migrated to head once.\n32\t\n33\t    Raises `max_connections` above Postgres's default of 100: this container\n34\t    is shared across the whole integration-test session, including three k6\n35\t    perf fixtures that each launch a separate multi-worker uvicorn process\n36\t    (its own DB connection pool) against it — the default ceiling is too low\n37\t    for that cumulative demand when the full suite runs in one session and\n38\t    was observed to exhaust mid-suite (`TooManyConnectionsError`) with only\n39\t    the default. This is a test-container capacity knob, not a production\n40\t    change (the real RDS instance sizes `max_connections` independently).\n41\t    \"\"\"\n42\t    with PostgresContainer(\"postgres:16-alpine\").with_command(\n43\t        \"postgres -c max_connections=300\"\n44\t    ) as postgres:\n45\t        url = _asyncpg_url(postgres.get_connection_url())\n46\t        env = dict(os.environ)\n47\t        env[\"DATABASE_URL\"] = url\n48\t        # Run the project's real Alembic migrations (0001 + 0002) against the\n49\t        # container out-of-process, so this is the same upgrade path `alembic\n50\t        # upgrade head` runs in CI/deploy, not a re-implemented schema.\n51\t        result = subprocess.run(\n52\t            [sys.executable, \"-m\", \"alembic\", \"upgrade\", \"head\"],\n53\t            cwd=str(_REPO_ROOT),\n54\t            env=env,\n55\t            capture_output=True,\n56\t            text=True,\n57\t        )\n58\t        assert result.returncode == 0, f\"alembic upgrade head failed:\\n{result.stdout}\\n{result.stderr}\"\n59\t        yield url\n60\t\n61\t\n62\t@pytest.fixture(scope=\"session\")\n63\tdef redis_url():\n64\t    \"\"\"A session-scoped live Redis for the Tier-1/Tier-2 token-bucket limiters.\"\"\"\n65\t    with RedisContainer(\"redis:7-alpine\") as redis_container:\n66\t        host = redis_container.get_container_host_ip()\n67\t        port = redis_container.get_exposed_port(redis_container.port)\n68\t        yield f\"redis://{host}:{port}/0\"\n69\t\n70\t\n71\t@pytest.fixture\n72\tasync def app_env(postgres_url, redis_url, monkeypatch):\n73\t    \"\"\"Point the app's process-wide DB/Redis singletons at the live\n74\t    containers, then reset them so each test starts with fresh pools/caches\n75\t    and no leaked verification-cache entries from a previous test.\n76\t    \"\"\"\n77\t    monkeypatch.setenv(\"DATABASE_URL\", postgres_url)\n78\t    monkeypatch.setenv(\"METERLY_REDIS_URL\", redis_url)\n79\t\n80\t    from src import auth as auth_module\n81\t    from src.auth import rate_limit as rate_limit_module\n82\t    from src.config import secrets as secrets_module\n83\t    from src.config.settings import get_settings\n84\t    from src.db import session as session_module\n85\t\n86\t    get_settings.cache_clear()\n87\t    secrets_module._facade._cache.clear()\n88\t\n89\t    await session_module.dispose_engine()\n90\t    await rate_limit_module.dispose_redis_client()\n91\t    auth_module._verification_cache = None\n92\t\n93\t    yield\n94\t\n95\t    await session_module.dispose_engine()\n96\t    await rate_limit_module.dispose_redis_client()\n97\t    auth_module._verification_cache = None\n98\t    get_settings.cache_clear()\n99\t\n100\t\n101\t@pytest.fixture\n102\tasync def truncate_tables(app_env, postgres_url, redis_url):\n103\t    \"\"\"Truncate the mutable tables between tests so each test starts from a\n104\t    clean, empty schema (api_keys are re-seeded per test via `make_api_key`).\n105\t\n106\t    The DB truncate uses RESTART IDENTITY, so `api_keys.id` (the Tier-2 bucket\n107\t    key) resets to 1 each test. Redis is session-scoped and would otherwise\n108\t    retain the previous test's token buckets under those reused ids, leaking an\n109\t    exhausted bucket into the next test -> flush it here too so bucket state is\n110\t    isolated per test, mirroring the DB truncate.\n111\t    \"\"\"\n112\t    import redis.asyncio as redis_async\n113\t    from sqlalchemy.ext.asyncio import create_async_engine\n114\t\n115\t    engine = create_async_engine(postgres_url)\n116\t    async with engine.begin() as connection:\n117\t        from sqlalchemy import text\n118\t\n119\t        await connection.execute(\n120\t            text(\"TRUNCATE TABLE events, usage_rollup, quotas, api_keys RESTART IDENTITY CASCADE\")\n121\t        )\n122\t    await engine.dispose()\n123\t\n124\t    redis_client = redis_async.from_url(redis_url, decode_responses=True)\n125\t    await redis_client.flushdb()\n126\t    await redis_client.aclose()\n127\t    yield\n128\t\n129\t\n130\t@pytest.fixture\n131\tasync def client(truncate_tables):\n132\t    \"\"\"An async test client bound to the real app via ASGI transport, with\n133\t    live DB/Redis singletons already pointed at the containers.\"\"\"\n134\t    from src.main import app\n135\t\n136\t    transport = ASGITransport(app=app)\n137\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as async_client:\n138\t        yield async_client\n139\t\n140\t\n141\t@pytest.fixture\n142\tasync def make_api_key(truncate_tables):\n143\t    \"\"\"Factory fixture: provision a real API key row (Argon2id-hashed) and\n144\t    return `(presented_key, api_key_id)`.\"\"\"\n145\t    from src.auth.api_key import generate_split_token, hash_new_secret\n146\t    from src.db.session import get_engine\n147\t    from src.repositories.api_keys_repo import create_api_key\n148\t\n149\t    created_ids = []\n150\t\n151\t    async def _make(\n152\t        label: str = \"test-key\", rate_limit_per_sec: int = 100, scope: str = \"ingest\"\n153\t    ) -> tuple[str, int]:\n154\t        key_id, secret, presented_key = generate_split_token()\n155\t        secret_hash = hash_new_secret(secret)\n156\t        async with get_engine().begin() as connection:\n157\t            api_key_row_id = await create_api_key(\n158\t                connection,\n159\t                key_id=key_id,\n160\t                secret_hash=secret_hash,\n161\t                label=label,\n162\t                rate_limit_per_sec=rate_limit_per_sec,\n163\t                scope=scope,\n164\t            )\n165\t        created_ids.append(api_key_row_id)\n166\t        return presented_key, api_key_row_id\n167\t\n168\t    yield _make\n169\t"}]},"uuid":"281ec861-1214-44a8-b6c8-3a42ff42f329","timestamp":"2026-07-09T03:58:54.946Z","sourceToolAssistantUUID":"a910b1c8-8600-4a77-9bc5-d3a2feed6022","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"281ec861-1214-44a8-b6c8-3a42ff42f329","isSidechain":true,"agentId":"a13995f3207b5009a","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp9af9e4TuQVYt5i25e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_017iJb67d9cshXX4eAUGF5e1","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/db/session.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7945,"cache_read_input_tokens":18776,"output_tokens":404,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":7945},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":404,"cache_read_input_tokens":18776,"cache_creation_input_tokens":7945,"cache_creation":{"ephemeral_5m_input_tokens":7945,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccqp9ZnosQdnnUEhkspP4","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"3c0e02fc-42c6-45de-b659-cb54384df904","timestamp":"2026-07-09T03:58:55.430Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"3c0e02fc-42c6-45de-b659-cb54384df904","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a13995f3207b5009a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017iJb67d9cshXX4eAUGF5e1","type":"tool_result","content":"1\t\"\"\"Async database engine/session management.\n2\t\n3\tThe engine is created lazily (on first use / at lifespan startup), never at\n4\timport time — this is what lets `import src.main` succeed in the smoke-check\n5\tbuild-fallback mode with no database reachable. Every request runs inside a\n6\ttransaction that sets `app.current_api_key_id` via `SET LOCAL`, which backs the\n7\tPostgreSQL row-level-security policy on `events`/`usage_rollup` (defense in\n8\tdepth behind the application-level `api_key_id` scoping every repository query\n9\talready applies).\n10\t\"\"\"\n11\t\n12\tfrom collections.abc import AsyncIterator\n13\tfrom contextlib import asynccontextmanager\n14\t\n15\tfrom sqlalchemy.ext.asyncio import AsyncEngine, AsyncSession, async_sessionmaker, create_async_engine\n16\t\n17\tfrom src.config.secrets import get_database_url\n18\t\n19\t_engine: AsyncEngine | None = None\n20\t_session_factory: async_sessionmaker[AsyncSession] | None = None\n21\t\n22\t\n23\tdef get_engine() -> AsyncEngine:\n24\t    \"\"\"Return the process-wide async engine, creating it on first call.\n25\t\n26\t    Deferred creation (rather than at import time) keeps `import src.main`\n27\t    dependency-free for the smoke-check build-fallback path.\n28\t    \"\"\"\n29\t    global _engine\n30\t    if _engine is None:\n31\t        _engine = create_async_engine(\n32\t            get_database_url(),\n33\t            # Pin READ COMMITTED explicitly rather than inheriting the DB/role\n34\t            # default. quotas_repo.read_tenant_quota_state_locked locks the\n35\t            # quotas row (SELECT ... FOR UPDATE) then reads usage_rollup in a\n36\t            # SEPARATE statement; that read only sees the prior lock holder's\n37\t            # committed increment because each statement gets a fresh snapshot\n38\t            # under READ COMMITTED. Under REPEATABLE READ a lock-waiter would\n39\t            # read a stale rollup total and admit events past the quota cap\n40\t            # (see the read_tenant_quota_state_locked docstring).\n41\t            isolation_level=\"READ COMMITTED\",\n42\t            pool_pre_ping=True,\n43\t            pool_size=10,\n44\t            max_overflow=5,\n45\t        )\n46\t    return _engine\n47\t\n48\t\n49\tdef get_session_factory() -> async_sessionmaker[AsyncSession]:\n50\t    \"\"\"Return the process-wide session factory, creating it on first call.\"\"\"\n51\t    global _session_factory\n52\t    if _session_factory is None:\n53\t        _session_factory = async_sessionmaker(get_engine(), expire_on_commit=False)\n54\t    return _session_factory\n55\t\n56\t\n57\t@asynccontextmanager\n58\tasync def scoped_transaction(api_key_id: int) -> AsyncIterator[AsyncSession]:\n59\t    \"\"\"Open a transaction scoped to the authenticated `api_key_id`.\n60\t\n61\t    Sets `app.current_api_key_id` with `SET LOCAL` at the start of the\n62\t    transaction so the PostgreSQL RLS policy backstop applies even if a\n63\t    repository query were ever missing its own `api_key_id` filter. The\n64\t    setting is transaction-local and is discarded automatically on commit/\n65\t    rollback.\n66\t    \"\"\"\n67\t    session_factory = get_session_factory()\n68\t    async with session_factory() as session, session.begin():\n69\t        await session.execute(\n70\t            _set_local_statement(),\n71\t            {\"api_key_id\": str(api_key_id)},\n72\t        )\n73\t        yield session\n74\t\n75\t\n76\tdef _set_local_statement():\n77\t    \"\"\"Build the `SET LOCAL` statement for the current-tenant RLS setting.\n78\t\n79\t    A separate function keeps the (slightly unusual) `set_config` call —\n80\t    `SET LOCAL` does not accept a bound parameter directly in all drivers —\n81\t    isolated and documented in one place.\n82\t    \"\"\"\n83\t    from sqlalchemy import text\n84\t\n85\t    return text(\"SELECT set_config('app.current_api_key_id', :api_key_id, true)\")\n86\t\n87\t\n88\tasync def dispose_engine() -> None:\n89\t    \"\"\"Dispose of the engine's connection pool (called from lifespan shutdown).\"\"\"\n90\t    global _engine, _session_factory\n91\t    if _engine is not None:\n92\t        await _engine.dispose()\n93\t    _engine = None\n94\t    _session_factory = None\n95\t\n96\t\n97\tasync def check_database_ready() -> bool:\n98\t    \"\"\"Run a fast `SELECT 1` to back the `/health/ready` readiness probe.\"\"\"\n99\t    from sqlalchemy import text\n100\t\n101\t    try:\n102\t        async with get_engine().connect() as connection:\n103\t            await connection.execute(text(\"SELECT 1\"))\n104\t        return True\n105\t    except Exception:  # noqa: BLE001 - readiness must never raise, only report False\n106\t        return False\n107\t"}]},"uuid":"b362b3ab-8ec4-4ea5-ad46-83572e59149c","timestamp":"2026-07-09T03:58:55.459Z","sourceToolAssistantUUID":"3c0e02fc-42c6-45de-b659-cb54384df904","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"b362b3ab-8ec4-4ea5-ad46-83572e59149c","isSidechain":true,"agentId":"a13995f3207b5009a","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp9vzmPxGApjZPfZKkw","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8956,"cache_read_input_tokens":26721,"cache_creation":{"ephemeral_5m_input_tokens":8956,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccqp9vAuT3JmQiquDdeM6","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"bd7f7686-3b4c-447a-b88b-36bf1cead645","timestamp":"2026-07-09T03:58:59.763Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"bd7f7686-3b4c-447a-b88b-36bf1cead645","isSidechain":true,"agentId":"a13995f3207b5009a","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp9vzmPxGApjZPfZKkw","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QgM9QYYP5x857uqo8eSSdu","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_perf_k6_load.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":8956,"cache_read_input_tokens":26721,"output_tokens":165,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":8956},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":165,"cache_read_input_tokens":26721,"cache_creation_input_tokens":8956,"cache_creation":{"ephemeral_5m_input_tokens":8956,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccqp9vAuT3JmQiquDdeM6","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"17d52def-65fa-4fd8-9f64-201e1f4586c2","timestamp":"2026-07-09T03:59:00.794Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"17d52def-65fa-4fd8-9f64-201e1f4586c2","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a13995f3207b5009a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QgM9QYYP5x857uqo8eSSdu","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF: a REAL sustained load run using k6 (via Docker), driving the\n2\tplan's declared scenario -- constant-arrival-rate at the target rate over a\n3\tsustained window, distributed key space -- against a real uvicorn process\n4\t(out-of-process, real network stack, multiple workers) backed by real\n5\tPostgres + Redis testcontainers.\n6\t\n7\tThis supersedes the best-effort in-process smoke in test_perf_smoke.py: k6\n8\truns in its own Docker container (grafana/k6) and reaches the host-run\n9\tuvicorn via `host.docker.internal`. True p95 is computed here by nearest-rank\n10\tover the raw per-request `http_req_duration` samples k6 writes to its JSON\n11\toutput (never trusting k6's own approximate percentile field blindly, per\n12\ttest-conventions) -- scoped to points tagged `scenario=ingest` so warm-up\n13\tcold-start latency is excluded from the measurement, the way a real load-test\n14\trig ramps up before recording.\n15\t\n16\tSkips (not fails) if Docker or the grafana/k6 image is unavailable -- this\n17\trecords an honest absence of measurement, never a fabricated one.\n18\t\"\"\"\n19\t\n20\timport asyncio\n21\timport datetime\n22\timport json\n23\timport os\n24\timport shutil\n25\timport socket\n26\timport subprocess\n27\timport sys\n28\timport tempfile\n29\timport time\n30\tfrom collections import Counter\n31\tfrom contextlib import closing\n32\tfrom pathlib import Path\n33\t\n34\timport httpx\n35\timport pytest\n36\t\n37\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n38\t_K6_SCRIPTS_DIR = Path(__file__).resolve().parent / \"k6\"\n39\t\n40\t# AC20 p95 debug (2026-07-08, see .pipeline/debug-notes.md): the quota-active\n41\t# perf run MUST use the same uvicorn-worker budget as the no-quota baseline it\n42\t# is compared against. An earlier 2-worker default for the quota fixture (vs\n43\t# the baseline's 5) starved it below the 500 rps constant-arrival target -- two\n44\t# worker processes could not service this workload's per-request CPU on the\n45\t# Docker-Desktop/Windows host, so excess arrivals queued and p95 inflated into\n46\t# the multi-second range from PURE QUEUEING, not from the quota FOR UPDATE\n47\t# read-and-decide (which adds ~3 ms p95 when measured under an equal worker\n48\t# budget). Confirmed empirically: raising the DB pool alone at 2 workers did\n49\t# NOT help (the ceiling is worker processes, not pooled connections); matching\n50\t# the baseline worker count did. The shared Postgres testcontainer runs\n51\t# max_connections=300, so 5 workers x (pool_size 10 + overflow 5) = 75\n52\t# connections is well within budget.\n53\t_DEFAULT_PERF_UVICORN_WORKERS = 5\n54\t\n55\t\n56\tdef _baseline_perf_workers() -> int:\n57\t    return int(os.environ.get(\"METERLY_PERF_UVICORN_WORKERS\", str(_DEFAULT_PERF_UVICORN_WORKERS)))\n58\t\n59\t\n60\tdef _quota_perf_workers() -> int:\n61\t    \"\"\"Worker count for the quota-active perf fixture. Defaults to the baseline\n62\t    worker count so AC20 is an apples-to-apples measurement; still independently\n63\t    overridable via `METERLY_PERF_QUOTA_UVICORN_WORKERS` for capacity tuning.\"\"\"\n64\t    return int(\n65\t        os.environ.get(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", str(_baseline_perf_workers()))\n66\t    )\n67\t\n68\t\n69\tdef _free_port() -> int:\n70\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n71\t        sock.bind((\"0.0.0.0\", 0))\n72\t        return sock.getsockname()[1]\n73\t\n74\t\n75\tdef _docker_available() -> bool:\n76\t    if shutil.which(\"docker\") is None:\n77\t        return False\n78\t    result = subprocess.run([\"docker\", \"info\"], capture_output=True, timeout=10)\n79\t    return result.returncode == 0\n80\t\n81\t\n82\tdef _nearest_rank_from_raw_jsonl(path: Path, scenario: str) -> dict:\n83\t    \"\"\"Parse k6's raw JSON-lines output and compute the TRUE percentiles via\n84\t    nearest-rank over the `http_req_duration` samples tagged with `scenario`\n85\t    -- this is what test-conventions requires instead of trusting k6's own\n86\t    (t-digest-approximated) percentile fields.\"\"\"\n87\t    durations: list[float] = []\n88\t    timestamps: list[str] = []\n89\t    statuses: list[str] = []\n90\t\n91\t    with path.open(encoding=\"utf-8\") as f:\n92\t        for line in f:\n93\t            line = line.strip()\n94\t            if not line:\n95\t                continue\n96\t            record = json.loads(line)\n97\t            if record.get(\"type\") != \"Point\" or record.get(\"metric\") != \"http_req_duration\":\n98\t                continue\n99\t            tags = record[\"data\"].get(\"tags\", {})\n100\t            if tags.get(\"scenario\") != scenario:\n101\t                continue\n102\t            durations.append(record[\"data\"][\"value\"])\n103\t            timestamps.append(record[\"data\"][\"time\"])\n104\t            statuses.append(tags.get(\"status\"))\n105\t\n106\t    if not durations:\n107\t        return {\"sample_count\": 0}\n108\t\n109\t    durations.sort()\n110\t    n = len(durations)\n111\t\n112\t    def nearest_rank(percentile: float) -> float:\n113\t        rank = max(1, round(percentile / 100 * n))\n114\t        return durations[min(rank, n) - 1]\n115\t\n116\t    sorted_timestamps = sorted(timestamps)\n117\t    first = datetime.datetime.fromisoformat(sorted_timestamps[0].replace(\"Z\", \"+00:00\"))\n118\t    last = datetime.datetime.fromisoformat(sorted_timestamps[-1].replace(\"Z\", \"+00:00\"))\n119\t    elapsed_seconds = (last - first).total_seconds()\n120\t\n121\t    return {\n122\t        \"sample_count\": n,\n123\t        \"status_counts\": dict(Counter(statuses)),\n124\t        \"p50_ms\": round(nearest_rank(50), 2),\n125\t        \"p90_ms\": round(nearest_rank(90), 2),\n126\t        \"p95_ms\": round(nearest_rank(95), 2),\n127\t        \"p99_ms\": round(nearest_rank(99), 2),\n128\t        \"max_ms\": round(durations[-1], 2),\n129\t        \"elapsed_seconds\": round(elapsed_seconds, 2),\n130\t        \"throughput_rps\": round(n / elapsed_seconds, 2) if elapsed_seconds > 0 else 0.0,\n131\t    }\n132\t\n133\t\n134\t@pytest.fixture\n135\tasync def k6_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n136\t    \"\"\"Launch the real app under uvicorn (multi-worker, out-of-process)\n137\t    against the live containers, ready for a k6 container to hit it via\n138\t    `host.docker.internal`.\"\"\"\n139\t    if not _docker_available():\n140\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n141\t\n142\t    pull_result = subprocess.run(\n143\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n144\t    )\n145\t    if pull_result.returncode != 0:\n146\t        pull_result = subprocess.run(\n147\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n148\t        )\n149\t        if pull_result.returncode != 0:\n150\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n151\t\n152\t    port = _free_port()\n153\t    env = dict(os.environ)\n154\t    env[\"DATABASE_URL\"] = postgres_url\n155\t    env[\"METERLY_REDIS_URL\"] = redis_url\n156\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n157\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n158\t\n159\t    presented_key, _ = await make_api_key(label=\"k6-perf-key\", rate_limit_per_sec=1_000_000)\n160\t\n161\t    workers = _baseline_perf_workers()\n162\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_perf\"\n163\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n164\t\n165\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n166\t    process = subprocess.Popen(\n167\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n168\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n169\t    )\n170\t\n171\t    try:\n172\t        deadline = time.monotonic() + 30\n173\t        async with httpx.AsyncClient() as probe:\n174\t            ready = False\n175\t            while time.monotonic() < deadline:\n176\t                try:\n177\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n178\t                    if response.status_code == 200:\n179\t                        ready = True\n180\t                        break\n181\t                except httpx.TransportError:\n182\t                    pass\n183\t                await asyncio.sleep(0.3)\n184\t            if not ready:\n185\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n186\t\n187\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n188\t    finally:\n189\t        process.terminate()\n190\t        try:\n191\t            process.wait(timeout=10)\n192\t        except subprocess.TimeoutExpired:\n193\t            process.kill()\n194\t        uvicorn_log.close()\n195\t\n196\t\n197\tdef _run_k6(script_name: str, port: int, api_key: str, scratch_dir: Path, target_rps: int, duration: str, warmup: str, out_name: str) -> subprocess.CompletedProcess:\n198\t    raw_out = scratch_dir / out_name\n199\t    if raw_out.exists():\n200\t        raw_out.unlink()\n201\t    return subprocess.run(\n202\t        [\n203\t            \"docker\", \"run\", \"--rm\",\n204\t            \"--add-host=host.docker.internal:host-gateway\",\n205\t            \"-v\", f\"{scratch_dir}:/perf_out\",\n206\t            \"-v\", f\"{_K6_SCRIPTS_DIR}:/perf_scripts:ro\",\n207\t            \"-e\", f\"BASE_URL=http://host.docker.internal:{port}\",\n208\t            \"-e\", f\"API_KEY={api_key}\",\n209\t            \"-e\", f\"TARGET_RPS={target_rps}\",\n210\t            \"-e\", f\"DURATION={duration}\",\n211\t            \"-e\", f\"WARMUP_DURATION={warmup}\",\n212\t            \"grafana/k6\", \"run\",\n213\t            \"--out\", f\"json=/perf_out/{out_name}\",\n214\t            f\"/perf_scripts/{script_name}\",\n215\t        ],\n216\t        capture_output=True, text=True, timeout=180,\n217\t    )\n218\t\n219\t\n220\tdef test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n221\t    \"\"\"Drive POST /v1/events at a real, sustained constant-arrival-rate of\n222\t    500 req/s (the AC6 budget's declared rate) over a real k6 container\n223\t    against a real out-of-process uvicorn + Postgres + Redis, with a\n224\t    distributed key space (unique idempotency_key + customer_id spread across\n225\t    50 buckets per request, no replay contention). Records true nearest-rank\n226\t    p95 + achieved throughput -- an honest measurement, not a claim the\n227\t    budget is met.\"\"\"\n228\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n229\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n230\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n231\t\n232\t    result = _run_k6(\n233\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n234\t        target_rps, duration, warmup, \"k6_events_raw.jsonl\",\n235\t    )\n236\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n237\t\n238\t    if result.returncode != 0:\n239\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_stdout.log\")\n240\t\n241\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_events_raw.jsonl\", scenario=\"ingest\")\n242\t    (k6_load_env[\"scratch_dir\"] / \"events_metrics.json\").write_text(json.dumps(metrics, indent=2))\n243\t    print(\"POST /v1/events k6 load metrics:\", json.dumps(metrics, indent=2))\n244\t\n245\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n246\t\n247\t\n248\t@pytest.fixture\n249\tasync def k6_quota_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n250\t    \"\"\"Like `k6_load_env`, but the provisioned key is admin-scoped and each\n251\t    `cust_0..cust_49` bucket the k6 script drives (`load_events_quota.js`)\n252\t    carries a pre-seeded, deliberately high quota (AC20) -- so the ingest\n253\t    path exercises the quota-check read-and-decide on every request without\n254\t    ever actually rejecting one, isolating the added latency of the `FOR\n255\t    UPDATE` lookup itself from the (much larger, transaction-aborting) cost\n256\t    of a rejection.\n257\t    \"\"\"\n258\t    if not _docker_available():\n259\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n260\t\n261\t    pull_result = subprocess.run(\n262\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n263\t    )\n264\t    if pull_result.returncode != 0:\n265\t        pull_result = subprocess.run(\n266\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n267\t        )\n268\t        if pull_result.returncode != 0:\n269\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n270\t\n271\t    port = _free_port()\n272\t    env = dict(os.environ)\n273\t    env[\"DATABASE_URL\"] = postgres_url\n274\t    env[\"METERLY_REDIS_URL\"] = redis_url\n275\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n276\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n277\t\n278\t    presented_key, api_key_id = await make_api_key(\n279\t        label=\"k6-quota-perf-key\", rate_limit_per_sec=1_000_000, scope=\"admin\"\n280\t    )\n281\t\n282\t    from sqlalchemy import text\n283\t    from sqlalchemy.ext.asyncio import create_async_engine\n284\t\n285\t    # A high-but-finite cap per bucket (well above anything a 15s run at the\n286\t    # target rate could accumulate) -- active enough to exercise the FOR\n287\t    # UPDATE read-and-decide on every request, never high enough to matter\n288\t    # for whether a single run's requests are accepted.\n289\t    quota_engine = create_async_engine(postgres_url)\n290\t    async with quota_engine.begin() as connection:\n291\t        for customer_index in range(50):\n292\t            await connection.execute(\n293\t                text(\n294\t                    \"\"\"\n295\t                    INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n296\t                    VALUES (:api_key_id, :customer_id, 'api_calls', 100000000, now())\n297\t                    ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n298\t                        limit_per_window = EXCLUDED.limit_per_window\n299\t                    \"\"\"\n300\t                ),\n301\t                {\"api_key_id\": api_key_id, \"customer_id\": f\"cust_{customer_index}\"},\n302\t            )\n303\t    await quota_engine.dispose()\n304\t\n305\t    # Match the baseline fixture's worker budget (default 5) so AC20 measures\n306\t    # the quota path under the SAME CPU/event-loop capacity it is compared\n307\t    # against -- a smaller budget starves the constant-arrival-rate scenario and\n308\t    # inflates p95 with queueing delay that has nothing to do with the quota\n309\t    # check (see _quota_perf_workers and .pipeline/debug-notes.md 2026-07-08).\n310\t    # The shared Postgres container runs max_connections=300 and these perf\n311\t    # fixtures are function-scoped (torn down before the next), so 5 workers x\n312\t    # 15 pooled connections is comfortably within the session's budget.\n313\t    workers = _quota_perf_workers()\n314\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_quota_perf\"\n315\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n316\t\n317\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n318\t    process = subprocess.Popen(\n319\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n320\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n321\t    )\n322\t\n323\t    try:\n324\t        deadline = time.monotonic() + 30\n325\t        async with httpx.AsyncClient() as probe:\n326\t            ready = False\n327\t            while time.monotonic() < deadline:\n328\t                try:\n329\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n330\t                    if response.status_code == 200:\n331\t                        ready = True\n332\t                        break\n333\t                except httpx.TransportError:\n334\t                    pass\n335\t                await asyncio.sleep(0.3)\n336\t            if not ready:\n337\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n338\t\n339\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n340\t    finally:\n341\t        process.terminate()\n342\t        try:\n343\t            process.wait(timeout=10)\n344\t        except subprocess.TimeoutExpired:\n345\t            process.kill()\n346\t        uvicorn_log.close()\n347\t        # Give Postgres a moment to reclaim the just-closed workers' backend\n348\t        # connection slots before the next test's fixtures open new ones\n349\t        # against the same shared container (mitigates TooManyConnectionsError\n350\t        # when this module's perf tests run back-to-back in one session).\n351\t        await asyncio.sleep(1.0)\n352\t\n353\t\n354\tdef test_events_ingest_with_quotas_p95_within_1_5x_baseline(k6_load_env, k6_quota_load_env):\n355\t    \"\"\"AC20 (human-revised 2026-07-09, see .pipeline/debug-notes.md and the\n356\t    AC20 row in .pipeline/acceptance.md): the original absolute \"p95 < 50ms\"\n357\t    form is unachievable on this Docker-Desktop/Windows host for ANY code\n358\t    (the no-quota baseline itself runs ~84-112ms here). AC20 is now a\n359\t    RELATIVE budget: quota-active p95 <= 1.5x the same-session no-quota\n360\t    baseline p95, both measured at equal uvicorn worker budget.\n361\t\n362\t    This test drives BOTH the no-quota baseline (`k6_load_env`, workers =\n363\t    `_baseline_perf_workers()`) and the quota-active path (`k6_quota_load_env`,\n364\t    workers = `_quota_perf_workers()`, which defaults to the SAME count) in\n365\t    the same test session, back-to-back, and asserts the relative bound\n366\t    directly -- closing the prior gap where this test only asserted\n367\t    `sample_count > 0` and let a real regression (measured 3362ms vs an 84ms\n368\t    baseline, ~40x) pass green (see test-quality.json's AC20 gap, now closed\n369\t    by this assertion).\"\"\"\n370\t    assert _quota_perf_workers() == _baseline_perf_workers(), (\n371\t        f\"AC20 requires an equal worker budget for the relative comparison to be \"\n372\t        f\"apples-to-apples, but quota={_quota_perf_workers()} != baseline={_baseline_perf_workers()}\"\n373\t    )\n374\t\n375\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n376\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n377\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n378\t\n379\t    baseline_result = _run_k6(\n380\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n381\t        target_rps, duration, warmup, \"k6_events_baseline_raw.jsonl\",\n382\t    )\n383\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_stdout.log\").write_text(\n384\t        baseline_result.stdout + \"\\n---STDERR---\\n\" + baseline_result.stderr\n385\t    )\n386\t    if baseline_result.returncode != 0:\n387\t        pytest.skip(\n388\t            f\"k6 baseline run failed to execute in this environment (rc={baseline_result.returncode}); \"\n389\t            \"see k6_events_baseline_stdout.log\"\n390\t        )\n391\t    baseline_metrics = _nearest_rank_from_raw_jsonl(\n392\t        k6_load_env[\"scratch_dir\"] / \"k6_events_baseline_raw.jsonl\", scenario=\"ingest\"\n393\t    )\n394\t    (k6_load_env[\"scratch_dir\"] / \"events_baseline_metrics.json\").write_text(json.dumps(baseline_metrics, indent=2))\n395\t    print(\"POST /v1/events no-quota baseline k6 load metrics:\", json.dumps(baseline_metrics, indent=2))\n396\t\n397\t    quota_result = _run_k6(\n398\t        \"load_events_quota.js\", k6_quota_load_env[\"port\"], k6_quota_load_env[\"api_key\"], k6_quota_load_env[\"scratch_dir\"],\n399\t        target_rps, duration, warmup, \"k6_events_quota_raw.jsonl\",\n400\t    )\n401\t    (k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_stdout.log\").write_text(\n402\t        quota_result.stdout + \"\\n---STDERR---\\n\" + quota_result.stderr\n403\t    )\n404\t    if quota_result.returncode != 0:\n405\t        pytest.skip(\n406\t            f\"k6 quota run failed to execute in this environment (rc={quota_result.returncode}); \"\n407\t            \"see k6_events_quota_stdout.log\"\n408\t        )\n409\t    quota_metrics = _nearest_rank_from_raw_jsonl(\n410\t        k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_raw.jsonl\", scenario=\"ingest\"\n411\t    )\n412\t    (k6_quota_load_env[\"scratch_dir\"] / \"events_quota_metrics.json\").write_text(json.dumps(quota_metrics, indent=2))\n413\t    print(\"POST /v1/events (quotas active) k6 load metrics:\", json.dumps(quota_metrics, indent=2))\n414\t\n415\t    assert baseline_metrics[\"sample_count\"] > 0, \"the baseline k6 run produced no ingest-scenario samples -- unmeasured\"\n416\t    assert quota_metrics[\"sample_count\"] > 0, \"the quota k6 run produced no ingest-scenario samples -- unmeasured\"\n417\t\n418\t    budget_p95 = 1.5 * baseline_metrics[\"p95_ms\"]\n419\t    assert quota_metrics[\"p95_ms\"] <= budget_p95, (\n420\t        f\"AC20: quota-active p95 ({quota_metrics['p95_ms']}ms) exceeds 1.5x the same-session \"\n421\t        f\"no-quota baseline p95 ({baseline_metrics['p95_ms']}ms -> budget {budget_p95:.2f}ms) \"\n422\t        f\"at equal worker budget ({_quota_perf_workers()} workers)\"\n423\t    )\n424\t\n425\t\n426\tdef test_ac20_quota_perf_fixture_matches_baseline_worker_budget(monkeypatch):\n427\t    \"\"\"Regression guard for the AC20 p95 debug (.pipeline/debug-notes.md,\n428\t    2026-07-08). The quota-active perf fixture must not be provisioned with\n429\t    FEWER uvicorn workers than the no-quota baseline it is compared against.\n430\t\n431\t    A prior 2-worker default (vs the baseline's 5) starved the quota run below\n432\t    the 500 rps constant-arrival target, so its p95 inflated into the seconds\n433\t    purely from queueing -- masquerading as a quota-code-path regression that,\n434\t    measured under an equal worker budget, does not exist (~87 ms vs the ~85 ms\n435\t    baseline). This fast, Docker-free guard fails before the fix (2 < 5) and\n436\t    passes after (5 >= 5), locking the handicap out of the harness for good.\"\"\"\n437\t    monkeypatch.delenv(\"METERLY_PERF_UVICORN_WORKERS\", raising=False)\n438\t    monkeypatch.delenv(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", raising=False)\n439\t    assert _quota_perf_workers() >= _baseline_perf_workers(), (\n440\t        f\"quota perf fixture worker budget ({_quota_perf_workers()}) is below the \"\n441\t        f\"no-quota baseline ({_baseline_perf_workers()}); AC20 would be measured on a \"\n442\t        \"starved pool and its p95 would reflect queueing, not the quota check\"\n443\t    )\n444\t\n445\t\n446\tdef test_usage_read_sustained_100rps_k6_load(k6_load_env):\n447\t    \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n448\t    against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n449\t    target_rps = int(os.environ.get(\"METERLY_PERF_USAGE_TARGET_RPS\", \"100\"))\n450\t    duration = os.environ.get(\"METERLY_PERF_USAGE_DURATION\", \"10s\")\n451\t    warmup = os.environ.get(\"METERLY_PERF_USAGE_WARMUP\", \"3s\")\n452\t\n453\t    result = _run_k6(\n454\t        \"load_usage.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n455\t        target_rps, duration, warmup, \"k6_usage_raw.jsonl\",\n456\t    )\n457\t    (k6_load_env[\"scratch_dir\"] / \"k6_usage_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n458\t\n459\t    if result.returncode != 0:\n460\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_usage_stdout.log\")\n461\t\n462\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_usage_raw.jsonl\", scenario=\"ingest\")\n463\t    (k6_load_env[\"scratch_dir\"] / \"usage_metrics.json\").write_text(json.dumps(metrics, indent=2))\n464\t    print(\"GET /v1/usage k6 load metrics:\", json.dumps(metrics, indent=2))\n465\t\n466\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n467\t"}]},"uuid":"cce70928-d9bc-4184-8563-19d051b5194e","timestamp":"2026-07-09T03:59:00.829Z","sourceToolAssistantUUID":"17d52def-65fa-4fd8-9f64-201e1f4586c2","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
