{"parentUuid":"e2477b79-49ec-4305-a22f-e9d0d19ee604","isSidechain":true,"agentId":"a13995f3207b5009a","message":{"model":"claude-opus-4-8","id":"msg_011Ccqp9af9e4TuQVYt5i25e","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Lrw6TeB1cWMp2bTyZRdvbf","name":"Read","input":{"file_path":"c:/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7945,"cache_read_input_tokens":18776,"cache_creation":{"ephemeral_5m_input_tokens":7945,"ephemeral_1h_input_tokens":0},"output_tokens":6,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccqp9ZnosQdnnUEhkspP4","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"0de654fa-dc45-41fb-99af-56a8bff42176","timestamp":"2026-07-09T03:58:53.424Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"0de654fa-dc45-41fb-99af-56a8bff42176","isSidechain":true,"promptId":"8a0970a7-992a-482d-b1fb-9fa84d4f1b3d","agentId":"a13995f3207b5009a","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Lrw6TeB1cWMp2bTyZRdvbf","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"40725344-d5c4-4052-a06b-f244c1654880","timestamp":"2026-07-09T03:58:53.444Z","sourceToolAssistantUUID":"0de654fa-dc45-41fb-99af-56a8bff42176","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
