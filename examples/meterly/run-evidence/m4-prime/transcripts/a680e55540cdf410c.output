{"parentUuid":"347f6302-0e0b-44e2-ae13-d24f18761199","isSidechain":true,"agentId":"a680e55540cdf410c","message":{"model":"claude-opus-4-8","id":"msg_011Ccs978vFSrs3DsUJ9ndqi","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AP9sbp4vGyQgMmZfusSmHA","name":"Read","input":{"file_path":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\schemas\\usage.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":124,"cache_creation_input_tokens":2428,"cache_read_input_tokens":31390,"cache_creation":{"ephemeral_5m_input_tokens":2428,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs977tUyuKMxLGrCYcy6","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"e6259e2e-74e9-48c6-9c4d-acabc3357b6c","timestamp":"2026-07-09T20:48:24.578Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"e6259e2e-74e9-48c6-9c4d-acabc3357b6c","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a680e55540cdf410c","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AP9sbp4vGyQgMmZfusSmHA","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage`.\n2\t\n3\t`window` must be a timezone-aware ISO-8601 timestamp within `[now-90d, now+1h]`;\n4\ta naive datetime (no offset) is rejected rather than silently assumed-UTC, since\n5\tguessing wrong would silently misattribute a bucket.\n6\t\"\"\"\n7\t\n8\tfrom datetime import datetime, timedelta, timezone\n9\tfrom decimal import Decimal\n10\t\n11\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, field_validator\n12\t\n13\tfrom src.api.schemas.events import CustomerId, Metric\n14\t\n15\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n16\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n17\t\n18\t\n19\tclass UsageQueryParams(BaseModel):\n20\t    \"\"\"The three required query parameters of `GET /v1/usage`, validated as a\n21\t    single boundary schema rather than three ad-hoc query-param checks.\"\"\"\n22\t\n23\t    model_config = ConfigDict(extra=\"forbid\")\n24\t\n25\t    customer_id: CustomerId\n26\t    metric: Metric\n27\t    window: AwareDatetime\n28\t\n29\t    @field_validator(\"window\")\n30\t    @classmethod\n31\t    def _window_within_supported_range(cls, value: datetime) -> datetime:\n32\t        \"\"\"Reject a `window` timestamp outside the supported query range.\n33\t\n34\t        Pydantic's `AwareDatetime` already rejects naive datetimes; this\n35\t        validator adds the `[now-90d, now+1h]` bound so a caller can't probe\n36\t        arbitrarily far into the past (unbounded query cost) or the future\n37\t        (nothing to aggregate yet).\n38\t        \"\"\"\n39\t        now = datetime.now(timezone.utc)\n40\t        earliest = now - _MAX_WINDOW_LOOKBACK\n41\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n42\t        if not (earliest <= value <= latest):\n43\t            raise ValueError(\n44\t                f\"window must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n45\t            )\n46\t        return value\n47\t\n48\t\n49\tclass UsageResponse(BaseModel):\n50\t    \"\"\"The minimal response field set for a usage query (ASVS 15.3.1).\"\"\"\n51\t\n52\t    model_config = ConfigDict(extra=\"forbid\")\n53\t\n54\t    customer_id: str\n55\t    metric: str\n56\t    window_start: str\n57\t    total_quantity: Decimal\n58\t    event_count: int\n59\t"}]},"uuid":"1fbbf287-8faa-44a4-aee6-da0b2688b43c","timestamp":"2026-07-09T20:48:24.596Z","sourceToolAssistantUUID":"e6259e2e-74e9-48c6-9c4d-acabc3357b6c","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"1fbbf287-8faa-44a4-aee6-da0b2688b43c","isSidechain":true,"agentId":"a680e55540cdf410c","message":{"model":"claude-opus-4-8","id":"msg_011Ccs978vFSrs3DsUJ9ndqi","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MhZaXb9pSfFipx5Qv3uVed","name":"Read","input":{"file_path":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\db\\session.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":124,"cache_creation_input_tokens":2428,"cache_read_input_tokens":31390,"cache_creation":{"ephemeral_5m_input_tokens":2428,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs977tUyuKMxLGrCYcy6","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"82d1097d-54b7-4439-81f5-caff1934ea68","timestamp":"2026-07-09T20:48:25.160Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"82d1097d-54b7-4439-81f5-caff1934ea68","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a680e55540cdf410c","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01MhZaXb9pSfFipx5Qv3uVed","type":"tool_result","content":"1\t\"\"\"Async database engine/session management.\n2\t\n3\tThe engine is created lazily (on first use / at lifespan startup), never at\n4\timport time — this is what lets `import src.main` succeed in the smoke-check\n5\tbuild-fallback mode with no database reachable. Every request runs inside a\n6\ttransaction that sets `app.current_api_key_id` via `SET LOCAL`, which backs the\n7\tPostgreSQL row-level-security policy on `events`/`usage_rollup` (defense in\n8\tdepth behind the application-level `api_key_id` scoping every repository query\n9\talready applies).\n10\t\"\"\"\n11\t\n12\tfrom collections.abc import AsyncIterator\n13\tfrom contextlib import asynccontextmanager\n14\t\n15\tfrom sqlalchemy.ext.asyncio import AsyncEngine, AsyncSession, async_sessionmaker, create_async_engine\n16\t\n17\tfrom src.config.secrets import get_database_url\n18\t\n19\t_engine: AsyncEngine | None = None\n20\t_session_factory: async_sessionmaker[AsyncSession] | None = None\n21\t\n22\t\n23\tdef get_engine() -> AsyncEngine:\n24\t    \"\"\"Return the process-wide async engine, creating it on first call.\n25\t\n26\t    Deferred creation (rather than at import time) keeps `import src.main`\n27\t    dependency-free for the smoke-check build-fallback path.\n28\t    \"\"\"\n29\t    global _engine\n30\t    if _engine is None:\n31\t        _engine = create_async_engine(\n32\t            get_database_url(),\n33\t            # Pin READ COMMITTED explicitly rather than inheriting the DB/role\n34\t            # default. quotas_repo.read_tenant_quota_state_locked locks the\n35\t            # quotas row (SELECT ... FOR UPDATE) then reads usage_rollup in a\n36\t            # SEPARATE statement; that read only sees the prior lock holder's\n37\t            # committed increment because each statement gets a fresh snapshot\n38\t            # under READ COMMITTED. Under REPEATABLE READ a lock-waiter would\n39\t            # read a stale rollup total and admit events past the quota cap\n40\t            # (see the read_tenant_quota_state_locked docstring).\n41\t            isolation_level=\"READ COMMITTED\",\n42\t            pool_pre_ping=True,\n43\t            pool_size=10,\n44\t            max_overflow=5,\n45\t        )\n46\t    return _engine\n47\t\n48\t\n49\tdef get_session_factory() -> async_sessionmaker[AsyncSession]:\n50\t    \"\"\"Return the process-wide session factory, creating it on first call.\"\"\"\n51\t    global _session_factory\n52\t    if _session_factory is None:\n53\t        _session_factory = async_sessionmaker(get_engine(), expire_on_commit=False)\n54\t    return _session_factory\n55\t\n56\t\n57\t@asynccontextmanager\n58\tasync def scoped_transaction(api_key_id: int) -> AsyncIterator[AsyncSession]:\n59\t    \"\"\"Open a transaction scoped to the authenticated `api_key_id`.\n60\t\n61\t    Sets `app.current_api_key_id` with `SET LOCAL` at the start of the\n62\t    transaction so the PostgreSQL RLS policy backstop applies even if a\n63\t    repository query were ever missing its own `api_key_id` filter. The\n64\t    setting is transaction-local and is discarded automatically on commit/\n65\t    rollback.\n66\t    \"\"\"\n67\t    session_factory = get_session_factory()\n68\t    async with session_factory() as session, session.begin():\n69\t        await session.execute(\n70\t            _set_local_statement(),\n71\t            {\"api_key_id\": str(api_key_id)},\n72\t        )\n73\t        yield session\n74\t\n75\t\n76\tdef _set_local_statement():\n77\t    \"\"\"Build the `SET LOCAL` statement for the current-tenant RLS setting.\n78\t\n79\t    A separate function keeps the (slightly unusual) `set_config` call —\n80\t    `SET LOCAL` does not accept a bound parameter directly in all drivers —\n81\t    isolated and documented in one place.\n82\t    \"\"\"\n83\t    from sqlalchemy import text\n84\t\n85\t    return text(\"SELECT set_config('app.current_api_key_id', :api_key_id, true)\")\n86\t\n87\t\n88\tasync def dispose_engine() -> None:\n89\t    \"\"\"Dispose of the engine's connection pool (called from lifespan shutdown).\"\"\"\n90\t    global _engine, _session_factory\n91\t    if _engine is not None:\n92\t        await _engine.dispose()\n93\t    _engine = None\n94\t    _session_factory = None\n95\t\n96\t\n97\tasync def check_database_ready() -> bool:\n98\t    \"\"\"Run a fast `SELECT 1` to back the `/health/ready` readiness probe.\"\"\"\n99\t    from sqlalchemy import text\n100\t\n101\t    try:\n102\t        async with get_engine().connect() as connection:\n103\t            await connection.execute(text(\"SELECT 1\"))\n104\t        return True\n105\t    except Exception:  # noqa: BLE001 - readiness must never raise, only report False\n106\t        return False\n107\t"}]},"uuid":"03c08b18-ce05-4560-ae5d-ffb923e2cc48","timestamp":"2026-07-09T20:48:25.193Z","sourceToolAssistantUUID":"82d1097d-54b7-4439-81f5-caff1934ea68","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"03c08b18-ce05-4560-ae5d-ffb923e2cc48","isSidechain":true,"agentId":"a680e55540cdf410c","message":{"model":"claude-opus-4-8","id":"msg_011Ccs978vFSrs3DsUJ9ndqi","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BzqZpbYqS7U5PjqiXEBwme","name":"Read","input":{"file_path":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_usage_export_endpoint.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":124,"cache_creation_input_tokens":2428,"cache_read_input_tokens":31390,"cache_creation":{"ephemeral_5m_input_tokens":2428,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccs977tUyuKMxLGrCYcy6","attributionAgent":"Explore","attributionSkill":"code-review","type":"assistant","uuid":"055870ac-fc99-40e0-8257-3b831b670552","timestamp":"2026-07-09T20:48:25.773Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
{"parentUuid":"055870ac-fc99-40e0-8257-3b831b670552","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a680e55540cdf410c","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BzqZpbYqS7U5PjqiXEBwme","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/usage/export` against a real Postgres:\n2\tstreaming correctness, tenant isolation, the row cap, formula-escaping\n3\tend-to-end, response headers, and the pre-flight fail-closed safe-error path\n4\t(AC1-AC13, AC17, AC19, AC22).\n5\t\"\"\"\n6\t\n7\timport asyncio\n8\timport re\n9\timport socket\n10\timport subprocess\n11\timport sys\n12\timport time\n13\tfrom contextlib import closing\n14\tfrom datetime import datetime, timedelta, timezone\n15\tfrom pathlib import Path\n16\t\n17\timport httpx\n18\timport pytest\n19\tfrom httpx import ASGITransport, AsyncClient\n20\tfrom sqlalchemy import text\n21\t\n22\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n23\t\n24\t\n25\tdef _event_payload(**overrides) -> dict:\n26\t    payload = {\n27\t        \"customer_id\": \"cust_1\",\n28\t        \"metric\": \"api_calls\",\n29\t        \"quantity\": \"5\",\n30\t        \"idempotency_key\": \"idem-1\",\n31\t    }\n32\t    payload.update(overrides)\n33\t    return payload\n34\t\n35\t\n36\tasync def _bulk_insert_rollups(\n37\t    postgres_url, *, api_key_id: int, metric: str, window_start: datetime, count: int\n38\t) -> None:\n39\t    \"\"\"Directly seed `usage_rollup` rows via a single set-based INSERT — the\n40\t    cap/perf tests need tens of thousands of rows, which is impractical to\n41\t    seed one ingest POST at a time.\"\"\"\n42\t    from sqlalchemy.ext.asyncio import create_async_engine\n43\t\n44\t    engine = create_async_engine(postgres_url)\n45\t    async with engine.begin() as connection:\n46\t        await connection.execute(\n47\t            text(\n48\t                \"\"\"\n49\t                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n50\t                SELECT :api_key_id, 'cust_' || lpad(gs::text, 8, '0'), :metric, :window_start, 1, 1\n51\t                FROM generate_series(1, :count) AS gs\n52\t                \"\"\"\n53\t            ),\n54\t            {\"api_key_id\": api_key_id, \"metric\": metric, \"window_start\": window_start, \"count\": count},\n55\t        )\n56\t    await engine.dispose()\n57\t\n58\t\n59\tasync def test_export_is_header_only_csv_for_empty_result(client, make_api_key):\n60\t    \"\"\"AC12: a caller with no matching rollups gets 200 with a single header\n61\t    line, never 404.\"\"\"\n62\t    presented_key, _ = await make_api_key()\n63\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n64\t\n65\t    assert response.status_code == 200\n66\t    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n67\t\n68\t\n69\tasync def test_export_with_no_filters_returns_all_caller_rows(client, make_api_key):\n70\t    \"\"\"AC2: omitting every filter exports the caller's full row set.\"\"\"\n71\t    presented_key, _ = await make_api_key()\n72\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n73\t\n74\t    await client.post(\n75\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n76\t    )\n77\t    await client.post(\n78\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n79\t    )\n80\t\n81\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n82\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n83\t\n84\t    assert response.status_code == 200\n85\t    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n86\t    assert len(lines) == 3  # header + 2 rows\n87\t\n88\t\n89\tasync def test_export_customer_id_filter_narrows_the_result(client, make_api_key):\n90\t    \"\"\"AC2: a customer_id filter excludes rows for other customers.\"\"\"\n91\t    presented_key, _ = await make_api_key()\n92\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n93\t\n94\t    await client.post(\n95\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n96\t    )\n97\t    await client.post(\n98\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n99\t    )\n100\t\n101\t    response = await client.get(\n102\t        \"/v1/usage/export\", params={\"customer_id\": \"cust_a\"}, headers=headers\n103\t    )\n104\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n105\t\n106\t    assert len(lines) == 2  # header + cust_a only\n107\t    assert \"cust_a\" in lines[1]\n108\t    assert \"cust_b\" not in response.text\n109\t\n110\t\n111\tasync def test_export_metric_filter_narrows_the_result(client, make_api_key):\n112\t    \"\"\"AC2: a metric filter excludes rows for other metrics.\"\"\"\n113\t    presented_key, _ = await make_api_key()\n114\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n115\t\n116\t    await client.post(\n117\t        \"/v1/events\", json=_event_payload(metric=\"api_calls\", idempotency_key=\"a\"), headers=headers\n118\t    )\n119\t    await client.post(\n120\t        \"/v1/events\", json=_event_payload(metric=\"storage_bytes\", idempotency_key=\"b\"), headers=headers\n121\t    )\n122\t\n123\t    response = await client.get(\"/v1/usage/export\", params={\"metric\": \"api_calls\"}, headers=headers)\n124\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n125\t\n126\t    assert len(lines) == 2  # header + api_calls only\n127\t    assert \"api_calls\" in lines[1]\n128\t    assert \"storage_bytes\" not in response.text\n129\t\n130\t\n131\tasync def test_export_from_to_window_filter_narrows_the_result(client, make_api_key):\n132\t    \"\"\"AC2: `from`/`to` narrow the export to rows within the window; a row\n133\t    outside the range is excluded.\"\"\"\n134\t    presented_key, _ = await make_api_key()\n135\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n136\t\n137\t    await client.post(\n138\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_in_window\", idempotency_key=\"a\"), headers=headers\n139\t    )\n140\t\n141\t    now = datetime.now(timezone.utc)\n142\t    in_window_from = (now - timedelta(hours=1)).isoformat()\n143\t    in_window_to = (now + timedelta(hours=1)).isoformat()\n144\t    # A window entirely before the row's window_start (valid from<=to, but\n145\t    # both endpoints predate \"now\") — the row must be excluded.\n146\t    before_window_from = (now - timedelta(hours=4)).isoformat()\n147\t    before_window_to = (now - timedelta(hours=2)).isoformat()\n148\t\n149\t    in_window_response = await client.get(\n150\t        \"/v1/usage/export\", params={\"from\": in_window_from, \"to\": in_window_to}, headers=headers\n151\t    )\n152\t    before_window_response = await client.get(\n153\t        \"/v1/usage/export\", params={\"from\": before_window_from, \"to\": before_window_to}, headers=headers\n154\t    )\n155\t\n156\t    assert \"cust_in_window\" in in_window_response.text\n157\t    assert before_window_response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n158\t\n159\t\n160\tasync def test_export_malformed_query_param_returns_422(client, make_api_key):\n161\t    \"\"\"AC4: an out-of-window `from` returns 422 validation_failed.\"\"\"\n162\t    presented_key, _ = await make_api_key()\n163\t    too_old = (datetime.now(timezone.utc) - timedelta(days=91)).isoformat()\n164\t\n165\t    response = await client.get(\n166\t        \"/v1/usage/export\", params={\"from\": too_old}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n167\t    )\n168\t\n169\t    assert response.status_code == 422\n170\t    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n171\t\n172\t\n173\tasync def test_export_unknown_query_param_returns_422(client, make_api_key):\n174\t    \"\"\"AC4: `extra='forbid'` rejects an unexpected query param (e.g. api_key_id probe).\"\"\"\n175\t    presented_key, _ = await make_api_key()\n176\t\n177\t    response = await client.get(\n178\t        \"/v1/usage/export\", params={\"api_key_id\": \"999\"}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n179\t    )\n180\t\n181\t    assert response.status_code == 422\n182\t\n183\t\n184\tasync def test_export_requires_authentication(client, make_api_key):\n185\t    \"\"\"AC6: no/invalid key -> 401 before the handler runs.\"\"\"\n186\t    missing = await client.get(\"/v1/usage/export\")\n187\t    invalid = await client.get(\"/v1/usage/export\", headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"})\n188\t\n189\t    assert missing.status_code == 401\n190\t    assert invalid.status_code == 401\n191\t\n192\t\n193\tasync def test_export_any_authenticated_scope_may_export_ingest_and_admin(client, make_api_key):\n194\t    \"\"\"AC6: both an ingest-scoped and an admin-scoped key succeed (no scope gate).\"\"\"\n195\t    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n196\t    admin_key, _ = await make_api_key(label=\"admin\", scope=\"admin\")\n197\t\n198\t    ingest_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n199\t    admin_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {admin_key}\"})\n200\t\n201\t    assert ingest_response.status_code == 200\n202\t    assert admin_response.status_code == 200\n203\t\n204\t\n205\tasync def test_export_rate_limit_two_principals_one_ip_get_independent_buckets(truncate_tables, make_api_key):\n206\t    \"\"\"AC5: the reused Tier-2 throttle is keyed on `api_key_id`, not client\n207\t    IP — principal A exhausting its own tiny bucket must not affect\n208\t    principal B behind the same client IP (mirrors\n209\t    tests/integration/test_rate_limit.py's discriminating shape, applied to\n210\t    this route).\"\"\"\n211\t    from src.main import app\n212\t\n213\t    key_a, _ = await make_api_key(label=\"export-tenant-a\", rate_limit_per_sec=1)\n214\t    key_b, _ = await make_api_key(label=\"export-tenant-b\", rate_limit_per_sec=100)\n215\t\n216\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 5000))\n217\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as shared_ip_client:\n218\t        first = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n219\t        second = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n220\t\n221\t        assert first.status_code == 200\n222\t        assert second.status_code == 429\n223\t        assert \"Retry-After\" in second.headers\n224\t\n225\t        third = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n226\t        assert third.status_code == 200\n227\t\n228\t\n229\tasync def test_export_tenant_isolation_excludes_other_tenants_rows(client, make_api_key):\n230\t    \"\"\"AC7: tenant A's export never contains tenant B's rows (IDOR/BOLA).\"\"\"\n231\t    key_a, _ = await make_api_key(label=\"tenant-a\")\n232\t    key_b, _ = await make_api_key(label=\"tenant-b\")\n233\t\n234\t    await client.post(\n235\t        \"/v1/events\",\n236\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"a-1\", quantity=\"1000\"),\n237\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n238\t    )\n239\t    await client.post(\n240\t        \"/v1/events\",\n241\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"b-1\", quantity=\"2000\"),\n242\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n243\t    )\n244\t\n245\t    response_a = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n246\t    lines_a = response_a.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n247\t\n248\t    assert len(lines_a) == 2  # header + exactly tenant A's one row\n249\t    assert \"1000.000000\" in response_a.text\n250\t    assert \"2000.000000\" not in response_a.text\n251\t\n252\t\n253\tasync def test_export_row_cap_returns_422_with_no_partial_body(client, make_api_key, postgres_url):\n254\t    \"\"\"AC8: a result over 100,000 rows is rejected with a clean 422 and no\n255\t    partial CSV body — the pre-flight count runs before any response byte.\"\"\"\n256\t    presented_key, api_key_id = await make_api_key()\n257\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n258\t    await _bulk_insert_rollups(\n259\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=100_001\n260\t    )\n261\t\n262\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n263\t\n264\t    assert response.status_code == 422\n265\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n266\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")\n267\t    assert \"\\r\\n\" not in response.text  # no CSV line-terminated rows, ever streamed\n268\t    body = response.json()\n269\t    assert body[\"error\"][\"code\"] == \"validation_failed\"\n270\t    assert set(body[\"error\"].keys()) == {\"code\", \"message\", \"requestId\"}  # the envelope shape only\n271\t\n272\t\n273\tasync def test_export_deterministic_ordering(client, make_api_key):\n274\t    \"\"\"AC13: rows are ordered by window_start, customer_id, metric ascending.\"\"\"\n275\t    presented_key, _ = await make_api_key()\n276\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n277\t\n278\t    for customer_id in (\"cust_c\", \"cust_a\", \"cust_b\"):\n279\t        await client.post(\n280\t            \"/v1/events\",\n281\t            json=_event_payload(customer_id=customer_id, idempotency_key=customer_id),\n282\t            headers=headers,\n283\t        )\n284\t\n285\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n286\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")[1:]\n287\t    seen_customer_ids = [line.split(\",\")[0] for line in lines]\n288\t\n289\t    assert seen_customer_ids == [\"cust_a\", \"cust_b\", \"cust_c\"]\n290\t\n291\t\n292\tasync def test_export_formula_injection_is_escaped_end_to_end(client, make_api_key):\n293\t    \"\"\"AC10: a leading-'-' customer_id (permitted by the ingest allowlist) is\n294\t    quote-prefixed in the exported CSV.\"\"\"\n295\t    presented_key, _ = await make_api_key()\n296\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n297\t\n298\t    await client.post(\n299\t        \"/v1/events\", json=_event_payload(customer_id=\"-1\", idempotency_key=\"dash\"), headers=headers\n300\t    )\n301\t\n302\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n303\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n304\t\n305\t    assert lines[1].startswith(\"'-1,\")\n306\t\n307\t\n308\tasync def test_export_response_headers(client, make_api_key):\n309\t    \"\"\"AC11: text/csv content type, attachment filename (UTC timestamp only,\n310\t    no tenant identifier), nosniff + no-store inherited from the middleware\n311\t    stack. The filename is asserted against its exact expected shape (not a\n312\t    substring exclusion) — a strictly-pinned pattern is what actually proves\n313\t    no extra data, tenant id included, ever rides along in it.\"\"\"\n314\t    presented_key, _ = await make_api_key()\n315\t\n316\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n317\t\n318\t    assert response.headers[\"content-type\"] == \"text/csv; charset=utf-8\"\n319\t    content_disposition = response.headers[\"content-disposition\"]\n320\t    assert re.fullmatch(\n321\t        r'attachment; filename=\"usage-export-\\d{8}T\\d{6}Z\\.csv\"', content_disposition\n322\t    ), content_disposition\n323\t    assert response.headers[\"x-content-type-options\"] == \"nosniff\"\n324\t    assert response.headers[\"cache-control\"] == \"no-store\"\n325\t\n326\t\n327\tdef _free_port() -> int:\n328\t    \"\"\"Find an unused TCP port for the out-of-process uvicorn server below.\"\"\"\n329\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n330\t        sock.bind((\"127.0.0.1\", 0))\n331\t        return sock.getsockname()[1]\n332\t\n333\t\n334\t@pytest.fixture\n335\tasync def running_server(postgres_url, redis_url, make_api_key, truncate_tables):\n336\t    \"\"\"Launch the real app under uvicorn, out-of-process, against the live\n337\t    containers.\n338\t\n339\t    Needed specifically for the streaming-not-buffered sanity check:\n340\t    httpx's in-process `ASGITransport` joins the *entire* response body into\n341\t    one chunk before yielding it (`ASGIResponseStream.__aiter__` does\n342\t    `yield b\"\".join(self._body)`), which would make a chunk-count assertion\n343\t    pass or fail independent of whether the app actually streams — only a\n344\t    real socket exposes genuine chunk boundaries.\n345\t    \"\"\"\n346\t    port = _free_port()\n347\t    import os\n348\t\n349\t    env = dict(os.environ)\n350\t    env[\"DATABASE_URL\"] = postgres_url\n351\t    env[\"METERLY_REDIS_URL\"] = redis_url\n352\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"100000\"\n353\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"100000\"\n354\t\n355\t    presented_key, api_key_id = await make_api_key(rate_limit_per_sec=100000)\n356\t\n357\t    process = subprocess.Popen(\n358\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"127.0.0.1\", \"--port\", str(port)],\n359\t        cwd=str(_REPO_ROOT),\n360\t        env=env,\n361\t        stdout=subprocess.PIPE,\n362\t        stderr=subprocess.STDOUT,\n363\t        text=True,\n364\t    )\n365\t    base_url = f\"http://127.0.0.1:{port}\"\n366\t\n367\t    try:\n368\t        deadline = time.monotonic() + 20\n369\t        async with httpx.AsyncClient() as probe:\n370\t            while time.monotonic() < deadline:\n371\t                try:\n372\t                    response = await probe.get(f\"{base_url}/health\", timeout=1.0)\n373\t                    if response.status_code == 200:\n374\t                        break\n375\t                except httpx.TransportError:\n376\t                    pass\n377\t                await asyncio.sleep(0.3)\n378\t            else:\n379\t                pytest.skip(\"uvicorn did not become ready in time in this sandboxed environment\")\n380\t\n381\t        yield base_url, presented_key, api_key_id\n382\t    finally:\n383\t        process.terminate()\n384\t        try:\n385\t            process.wait(timeout=5)\n386\t        except subprocess.TimeoutExpired:\n387\t            process.kill()\n388\t\n389\t\n390\tasync def test_export_streaming_delivers_multiple_discrete_chunks(running_server, postgres_url):\n391\t    \"\"\"AC9: the response is streamed (multiple discrete chunks arrive over\n392\t    the real socket, not one fully-buffered write) for a multi-row export.\"\"\"\n393\t    base_url, presented_key, api_key_id = running_server\n394\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n395\t    # Large enough that a real streamed write can't coalesce into a single\n396\t    # TCP read on the client side (small payloads often do, even when the\n397\t    # server genuinely writes them incrementally).\n398\t    await _bulk_insert_rollups(\n399\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=20_000\n400\t    )\n401\t\n402\t    chunk_count = 0\n403\t    async with httpx.AsyncClient(timeout=30.0) as http_client:\n404\t        async with http_client.stream(\n405\t            \"GET\", f\"{base_url}/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n406\t        ) as response:\n407\t            assert response.status_code == 200\n408\t            async for _chunk in response.aiter_bytes():\n409\t                chunk_count += 1\n410\t\n411\t    # Proof the response isn't assembled into one buffered blob before being\n412\t    # sent — a genuinely streamed multi-row export arrives as more than one\n413\t    # discrete read on the wire.\n414\t    assert chunk_count > 1\n415\t\n416\t\n417\tasync def test_openapi_schema_exposes_the_export_route_and_responses(client):\n418\t    \"\"\"AC19 (DAST-1): the served /openapi.json includes GET /v1/usage/export\n419\t    with its 200 text/csv and 422 responses, matching the implemented route.\"\"\"\n420\t    response = await client.get(\"/openapi.json\")\n421\t\n422\t    assert response.status_code == 200\n423\t    schema = response.json()\n424\t    assert \"/v1/usage/export\" in schema[\"paths\"]\n425\t    export_operation = schema[\"paths\"][\"/v1/usage/export\"][\"get\"]\n426\t    assert \"200\" in export_operation[\"responses\"]\n427\t    assert \"422\" in export_operation[\"responses\"]\n428\t    assert \"text/csv\" in export_operation[\"responses\"][\"200\"][\"content\"]\n429\t\n430\t\n431\tasync def test_export_seeded_dast_key_can_call_the_export(postgres_url, truncate_tables):\n432\t    \"\"\"AC20 (DAST-2): a key provisioned by the real `scripts/seed_api_key.py`\n433\t    (not the fast `make_api_key` test fixture) can successfully call\n434\t    `GET /v1/usage/export` and get a 200 header-only CSV. The pre-existing\n435\t    `tests/integration/test_seed_api_key_script.py` proves the script\n436\t    persists a working key row, but never actually calls an endpoint with the\n437\t    key it prints — this closes that gap for the export route specifically,\n438\t    which is what AC20 requires ('can call the export').\"\"\"\n439\t    import os\n440\t\n441\t    from src.main import app\n442\t\n443\t    env = dict(os.environ)\n444\t    env[\"DATABASE_URL\"] = postgres_url\n445\t\n446\t    result = subprocess.run(\n447\t        [sys.executable, \"scripts/seed_api_key.py\", \"--label\", \"dast-export-key\", \"--rate-limit\", \"50\"],\n448\t        cwd=str(_REPO_ROOT),\n449\t        env=env,\n450\t        capture_output=True,\n451\t        text=True,\n452\t    )\n453\t    assert result.returncode == 0, f\"seed script failed:\\n{result.stdout}\\n{result.stderr}\"\n454\t    presented_key = result.stdout.strip().splitlines()[-1]\n455\t    assert presented_key.startswith(\"mtr_live_\")\n456\t\n457\t    transport = ASGITransport(app=app)\n458\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as seeded_client:\n459\t        response = await seeded_client.get(\n460\t            \"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n461\t        )\n462\t\n463\t    assert response.status_code == 200\n464\t    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n465\t\n466\t\n467\tasync def test_export_forced_pre_flight_count_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n468\t    \"\"\"AC22: a forced error during the pre-flight COUNT phase (before any\n469\t    response byte) returns the generic 500 internal envelope — no\n470\t    stack/SQL/internal-path leak, and no partial CSV body.\"\"\"\n471\t    from src.main import app\n472\t    from src.services import usage_export_service\n473\t\n474\t    async def _raising_count(session, **kwargs):\n475\t        raise RuntimeError(\"simulated connection drop mid-count\")\n476\t\n477\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n478\t\n479\t    presented_key, _ = await make_api_key()\n480\t\n481\t    # ASGITransport re-raises app exceptions by default (useful for debugging\n482\t    # a broken test); here we're deliberately exercising the app's own 500\n483\t    # handler, so this client must let it convert the exception to a response\n484\t    # (mirrors tests/integration/test_events_endpoint.py's AC19 pattern).\n485\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n486\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as client:\n487\t        response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n488\t\n489\t    assert response.status_code == 500\n490\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n491\t    body = response.json()\n492\t    assert body[\"error\"][\"code\"] == \"internal\"\n493\t    assert \"requestId\" in body[\"error\"]\n494\t    assert \"simulated connection drop\" not in response.text\n495\t    assert \"Traceback\" not in response.text\n496\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")  # no CSV body ever started\n497\t"}]},"uuid":"b5194450-874c-45c4-811a-aa330c3ffd8a","timestamp":"2026-07-09T20:48:25.793Z","sourceToolAssistantUUID":"055870ac-fc99-40e0-8257-3b831b670552","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
