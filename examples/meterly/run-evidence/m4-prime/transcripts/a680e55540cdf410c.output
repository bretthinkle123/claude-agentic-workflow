{"parentUuid":"8c0b8f66-6023-40f7-a671-e48c84d5be17","isSidechain":true,"promptId":"795b6292-899f-43d1-822d-8e0cc35d6b7d","agentId":"a680e55540cdf410c","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012BEA14itCP5nNuGEZ1L1YG","type":"tool_result","content":"136\tasync def enforce_tier2_rate_limit(request: \"Request\", principal: \"AuthenticatedPrincipal\") -> None:\n137\t    \"\"\"Tier-2 dependency: enforce the caller's per-`api_key_id` token bucket.\n138\t\n139\t    Registered on a dependency that runs strictly **after** `require_api_key`\n140\t    (both endpoint routes depend on this ordering), so the bucket key is\n141\t    always the authenticated principal, never the client IP — this is the\n142\t    property the two-principals-one-IP test verifies (AC14/AC16).\n143\t\n144\t    Fails **open** (logs a warning, allows the request) on a Redis connection\n145\t    error — a cache outage degrading every authenticated call to \"temporarily\n146\t    unlimited\" is preferable to a full ingest outage; the durable UNIQUE-\n147\t    constraint/transaction guarantees are unaffected either way.\n148\t    \"\"\"\n149\t    from fastapi import HTTPException, status\n150\t\n151\t    try:\n152\t        decision = await get_tier2_limiter().check(\n153\t            str(principal.api_key_id),\n154\t            capacity=principal.rate_limit_per_sec,\n155\t            refill_rate_per_second=principal.rate_limit_per_sec,\n156\t        )\n157\t    except Exception:  # noqa: BLE001 - a Redis outage must not take down the whole API\n158\t        get_logger(service=\"meterly\").warning(\n159\t            \"ratelimit.backend_unavailable\", endpoint=request.url.path, tier=\"tier2\"\n160\t        )\n161\t        return\n162\t\n163\t    if not decision.allowed:\n164\t        get_logger(service=\"meterly\").warning(\n165\t            \"ratelimit.exceeded\",\n166\t            userId=principal.api_key_id,\n167\t            action=\"deny\",\n168\t            endpoint=request.url.path,\n169\t            reason=\"tier2_bucket_exhausted\",\n170\t        )\n171\t        raise HTTPException(\n172\t            status_code=status.HTTP_429_TOO_MANY_REQUESTS,\n173\t            detail=\"rate limit exceeded\",\n174\t            headers={\"Retry-After\": str(max(1, int(decision.retry_after_seconds) or 1))},\n175\t        )"}]},"uuid":"40c0b1ea-c907-455f-9a0e-770e3c3e5fbe","timestamp":"2026-07-09T20:50:00.434Z","sourceToolAssistantUUID":"8c0b8f66-6023-40f7-a671-e48c84d5be17","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/usage-export"}
