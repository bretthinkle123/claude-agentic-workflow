{"parentUuid":"a5c89459-9929-4d0c-9ed7-8d1cb639a27b","isSidechain":true,"agentId":"afb19ee80f80ebca5","message":{"model":"claude-opus-4-8","id":"msg_011CcqhuRqjUZ8RGP7sh2h1q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SnZJrb4cxQPEerqB2Q9Cv9","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\k6\\load_events_quota.js"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":9783,"cache_read_input_tokens":10931,"cache_creation":{"ephemeral_5m_input_tokens":9783,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqhuR27rVYYUBkKiLfn1","attributionAgent":"debugging","type":"assistant","uuid":"c73a2068-287f-4b55-ac6e-2a15d4678447","timestamp":"2026-07-09T02:37:04.418Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"c73a2068-287f-4b55-ac6e-2a15d4678447","isSidechain":true,"promptId":"ab5f8963-cf84-4410-bcde-8011a87d1e73","agentId":"afb19ee80f80ebca5","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SnZJrb4cxQPEerqB2Q9Cv9","type":"tool_result","content":"1\timport http from 'k6/http';\n2\timport { check } from 'k6';\n3\t\n4\t// Quota-active variant of load_events.js (AC20): drives the identical\n5\t// sustained constant-arrival-rate ingest scenario, but against a caller\n6\t// whose (customer, metric) buckets each carry a pre-seeded, deliberately\n7\t// high quota (set directly in Postgres by the pytest fixture before this\n8\t// script runs) -- so the quota-check read-and-decide executes on every\n9\t// request (not the unlimited zero-lookup-cost path) while never actually\n10\t// rejecting, isolating the added latency of the FOR UPDATE lookup itself\n11\t// from any rejection-path cost.\n12\tconst BASE_URL = __ENV.BASE_URL;\n13\tconst API_KEY = __ENV.API_KEY;\n14\tconst TARGET_RPS = parseInt(__ENV.TARGET_RPS || '500', 10);\n15\tconst DURATION = __ENV.DURATION || '15s';\n16\tconst WARMUP_DURATION = __ENV.WARMUP_DURATION || '5s';\n17\tconst PREALLOC_VUS = parseInt(__ENV.PREALLOC_VUS || '120', 10);\n18\tconst MAX_VUS = parseInt(__ENV.MAX_VUS || '600', 10);\n19\t\n20\texport const options = {\n21\t  scenarios: {\n22\t    warmup: {\n23\t      executor: 'constant-arrival-rate',\n24\t      rate: 10,\n25\t      timeUnit: '1s',\n26\t      duration: WARMUP_DURATION,\n27\t      preAllocatedVUs: 20,\n28\t      maxVUs: 50,\n29\t      exec: 'postEvent',\n30\t    },\n31\t    ingest: {\n32\t      executor: 'constant-arrival-rate',\n33\t      rate: TARGET_RPS,\n34\t      timeUnit: '1s',\n35\t      duration: DURATION,\n36\t      preAllocatedVUs: PREALLOC_VUS,\n37\t      maxVUs: MAX_VUS,\n38\t      exec: 'postEvent',\n39\t      startTime: WARMUP_DURATION,\n40\t    },\n41\t  },\n42\t  discardResponseBodies: false,\n43\t};\n44\t\n45\tlet counter = 0;\n46\t\n47\texport function postEvent() {\n48\t  counter += 1;\n49\t  const randomSuffix = Math.floor(Math.random() * 1e9);\n50\t  const uniqueId = `${__VU}-${__ITER}-${counter}-${Date.now()}-${randomSuffix}`;\n51\t  // Must match the customer-bucket range the pytest fixture pre-seeds a\n52\t  // quota for (cust_0..cust_49) -- otherwise these requests would hit the\n53\t  // unlimited (no-quota-row) path instead of exercising the quota check.\n54\t  const payload = JSON.stringify({\n55\t    customer_id: `cust_${__VU % 50}`,\n56\t    metric: 'api_calls',\n57\t    quantity: '1',\n58\t    idempotency_key: `k6-quota-${uniqueId}`,\n59\t  });\n60\t\n61\t  const response = http.post(`${BASE_URL}/v1/events`, payload, {\n62\t    headers: {\n63\t      'Content-Type': 'application/json',\n64\t      Authorization: `Bearer ${API_KEY}`,\n65\t    },\n66\t  });\n67\t\n68\t  check(response, {\n69\t    'status is 201 (never 429 -- quota set high enough to never reject)': (r) => r.status === 201,\n70\t  });\n71\t}\n72\t"}]},"uuid":"4cbf2dff-6772-4bf6-977f-8aa0a2457384","timestamp":"2026-07-09T02:37:04.437Z","sourceToolAssistantUUID":"c73a2068-287f-4b55-ac6e-2a15d4678447","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"4cbf2dff-6772-4bf6-977f-8aa0a2457384","isSidechain":true,"agentId":"afb19ee80f80ebca5","message":{"model":"claude-opus-4-8","id":"msg_011CcqhuRqjUZ8RGP7sh2h1q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01BkBncpcWjPVJ4rHH3mHQbd","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_perf_k6_load.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":9783,"cache_read_input_tokens":10931,"cache_creation":{"ephemeral_5m_input_tokens":9783,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcqhuR27rVYYUBkKiLfn1","attributionAgent":"debugging","type":"assistant","uuid":"01a0a129-0ef0-4966-9871-c46751a850e4","timestamp":"2026-07-09T02:37:05.422Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"d6fd840f-4c15-4ec4-8e2b-f4a42b2cbb1a","version":"2.1.204","gitBranch":"feature/metric-quotas"}
{"parentUuid":"01a0a129-0ef0-4966-9871-c46751a850e4","isSidechain":true,"promptId":"ab5f8963-cf84-4410-bcde-8011a87d1e73","agentId":"afb19ee80f80ebca5","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BkBncpcWjPVJ4rHH3mHQbd","type":"tool_result","content":"1\t\"\"\"AC6/AC-PERF: a REAL sustained load run using k6 (via Docker), driving the\n2\tplan's declared scenario -- constant-arrival-rate at the target rate over a\n3\tsustained window, distributed key space -- against a real uvicorn process\n4\t(out-of-process, real network stack, multiple workers) backed by real\n5\tPostgres + Redis testcontainers.\n6\t\n7\tThis supersedes the best-effort in-process smoke in test_perf_smoke.py: k6\n8\truns in its own Docker container (grafana/k6) and reaches the host-run\n9\tuvicorn via `host.docker.internal`. True p95 is computed here by nearest-rank\n10\tover the raw per-request `http_req_duration` samples k6 writes to its JSON\n11\toutput (never trusting k6's own approximate percentile field blindly, per\n12\ttest-conventions) -- scoped to points tagged `scenario=ingest` so warm-up\n13\tcold-start latency is excluded from the measurement, the way a real load-test\n14\trig ramps up before recording.\n15\t\n16\tSkips (not fails) if Docker or the grafana/k6 image is unavailable -- this\n17\trecords an honest absence of measurement, never a fabricated one.\n18\t\"\"\"\n19\t\n20\timport asyncio\n21\timport datetime\n22\timport json\n23\timport os\n24\timport shutil\n25\timport socket\n26\timport subprocess\n27\timport sys\n28\timport tempfile\n29\timport time\n30\tfrom collections import Counter\n31\tfrom contextlib import closing\n32\tfrom pathlib import Path\n33\t\n34\timport httpx\n35\timport pytest\n36\t\n37\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n38\t_K6_SCRIPTS_DIR = Path(__file__).resolve().parent / \"k6\"\n39\t\n40\t\n41\tdef _free_port() -> int:\n42\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n43\t        sock.bind((\"0.0.0.0\", 0))\n44\t        return sock.getsockname()[1]\n45\t\n46\t\n47\tdef _docker_available() -> bool:\n48\t    if shutil.which(\"docker\") is None:\n49\t        return False\n50\t    result = subprocess.run([\"docker\", \"info\"], capture_output=True, timeout=10)\n51\t    return result.returncode == 0\n52\t\n53\t\n54\tdef _nearest_rank_from_raw_jsonl(path: Path, scenario: str) -> dict:\n55\t    \"\"\"Parse k6's raw JSON-lines output and compute the TRUE percentiles via\n56\t    nearest-rank over the `http_req_duration` samples tagged with `scenario`\n57\t    -- this is what test-conventions requires instead of trusting k6's own\n58\t    (t-digest-approximated) percentile fields.\"\"\"\n59\t    durations: list[float] = []\n60\t    timestamps: list[str] = []\n61\t    statuses: list[str] = []\n62\t\n63\t    with path.open(encoding=\"utf-8\") as f:\n64\t        for line in f:\n65\t            line = line.strip()\n66\t            if not line:\n67\t                continue\n68\t            record = json.loads(line)\n69\t            if record.get(\"type\") != \"Point\" or record.get(\"metric\") != \"http_req_duration\":\n70\t                continue\n71\t            tags = record[\"data\"].get(\"tags\", {})\n72\t            if tags.get(\"scenario\") != scenario:\n73\t                continue\n74\t            durations.append(record[\"data\"][\"value\"])\n75\t            timestamps.append(record[\"data\"][\"time\"])\n76\t            statuses.append(tags.get(\"status\"))\n77\t\n78\t    if not durations:\n79\t        return {\"sample_count\": 0}\n80\t\n81\t    durations.sort()\n82\t    n = len(durations)\n83\t\n84\t    def nearest_rank(percentile: float) -> float:\n85\t        rank = max(1, round(percentile / 100 * n))\n86\t        return durations[min(rank, n) - 1]\n87\t\n88\t    sorted_timestamps = sorted(timestamps)\n89\t    first = datetime.datetime.fromisoformat(sorted_timestamps[0].replace(\"Z\", \"+00:00\"))\n90\t    last = datetime.datetime.fromisoformat(sorted_timestamps[-1].replace(\"Z\", \"+00:00\"))\n91\t    elapsed_seconds = (last - first).total_seconds()\n92\t\n93\t    return {\n94\t        \"sample_count\": n,\n95\t        \"status_counts\": dict(Counter(statuses)),\n96\t        \"p50_ms\": round(nearest_rank(50), 2),\n97\t        \"p90_ms\": round(nearest_rank(90), 2),\n98\t        \"p95_ms\": round(nearest_rank(95), 2),\n99\t        \"p99_ms\": round(nearest_rank(99), 2),\n100\t        \"max_ms\": round(durations[-1], 2),\n101\t        \"elapsed_seconds\": round(elapsed_seconds, 2),\n102\t        \"throughput_rps\": round(n / elapsed_seconds, 2) if elapsed_seconds > 0 else 0.0,\n103\t    }\n104\t\n105\t\n106\t@pytest.fixture\n107\tasync def k6_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n108\t    \"\"\"Launch the real app under uvicorn (multi-worker, out-of-process)\n109\t    against the live containers, ready for a k6 container to hit it via\n110\t    `host.docker.internal`.\"\"\"\n111\t    if not _docker_available():\n112\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n113\t\n114\t    pull_result = subprocess.run(\n115\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n116\t    )\n117\t    if pull_result.returncode != 0:\n118\t        pull_result = subprocess.run(\n119\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n120\t        )\n121\t        if pull_result.returncode != 0:\n122\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n123\t\n124\t    port = _free_port()\n125\t    env = dict(os.environ)\n126\t    env[\"DATABASE_URL\"] = postgres_url\n127\t    env[\"METERLY_REDIS_URL\"] = redis_url\n128\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n129\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n130\t\n131\t    presented_key, _ = await make_api_key(label=\"k6-perf-key\", rate_limit_per_sec=1_000_000)\n132\t\n133\t    workers = int(os.environ.get(\"METERLY_PERF_UVICORN_WORKERS\", \"5\"))\n134\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_perf\"\n135\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n136\t\n137\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n138\t    process = subprocess.Popen(\n139\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n140\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n141\t    )\n142\t\n143\t    try:\n144\t        deadline = time.monotonic() + 30\n145\t        async with httpx.AsyncClient() as probe:\n146\t            ready = False\n147\t            while time.monotonic() < deadline:\n148\t                try:\n149\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n150\t                    if response.status_code == 200:\n151\t                        ready = True\n152\t                        break\n153\t                except httpx.TransportError:\n154\t                    pass\n155\t                await asyncio.sleep(0.3)\n156\t            if not ready:\n157\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n158\t\n159\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n160\t    finally:\n161\t        process.terminate()\n162\t        try:\n163\t            process.wait(timeout=10)\n164\t        except subprocess.TimeoutExpired:\n165\t            process.kill()\n166\t        uvicorn_log.close()\n167\t\n168\t\n169\tdef _run_k6(script_name: str, port: int, api_key: str, scratch_dir: Path, target_rps: int, duration: str, warmup: str, out_name: str) -> subprocess.CompletedProcess:\n170\t    raw_out = scratch_dir / out_name\n171\t    if raw_out.exists():\n172\t        raw_out.unlink()\n173\t    return subprocess.run(\n174\t        [\n175\t            \"docker\", \"run\", \"--rm\",\n176\t            \"--add-host=host.docker.internal:host-gateway\",\n177\t            \"-v\", f\"{scratch_dir}:/perf_out\",\n178\t            \"-v\", f\"{_K6_SCRIPTS_DIR}:/perf_scripts:ro\",\n179\t            \"-e\", f\"BASE_URL=http://host.docker.internal:{port}\",\n180\t            \"-e\", f\"API_KEY={api_key}\",\n181\t            \"-e\", f\"TARGET_RPS={target_rps}\",\n182\t            \"-e\", f\"DURATION={duration}\",\n183\t            \"-e\", f\"WARMUP_DURATION={warmup}\",\n184\t            \"grafana/k6\", \"run\",\n185\t            \"--out\", f\"json=/perf_out/{out_name}\",\n186\t            f\"/perf_scripts/{script_name}\",\n187\t        ],\n188\t        capture_output=True, text=True, timeout=180,\n189\t    )\n190\t\n191\t\n192\tdef test_events_ingest_sustained_500rps_k6_load(k6_load_env):\n193\t    \"\"\"Drive POST /v1/events at a real, sustained constant-arrival-rate of\n194\t    500 req/s (the AC6 budget's declared rate) over a real k6 container\n195\t    against a real out-of-process uvicorn + Postgres + Redis, with a\n196\t    distributed key space (unique idempotency_key + customer_id spread across\n197\t    50 buckets per request, no replay contention). Records true nearest-rank\n198\t    p95 + achieved throughput -- an honest measurement, not a claim the\n199\t    budget is met.\"\"\"\n200\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n201\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n202\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n203\t\n204\t    result = _run_k6(\n205\t        \"load_events.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n206\t        target_rps, duration, warmup, \"k6_events_raw.jsonl\",\n207\t    )\n208\t    (k6_load_env[\"scratch_dir\"] / \"k6_events_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n209\t\n210\t    if result.returncode != 0:\n211\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_stdout.log\")\n212\t\n213\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_events_raw.jsonl\", scenario=\"ingest\")\n214\t    (k6_load_env[\"scratch_dir\"] / \"events_metrics.json\").write_text(json.dumps(metrics, indent=2))\n215\t    print(\"POST /v1/events k6 load metrics:\", json.dumps(metrics, indent=2))\n216\t\n217\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n218\t\n219\t\n220\t@pytest.fixture\n221\tasync def k6_quota_load_env(postgres_url, redis_url, make_api_key, truncate_tables):\n222\t    \"\"\"Like `k6_load_env`, but the provisioned key is admin-scoped and each\n223\t    `cust_0..cust_49` bucket the k6 script drives (`load_events_quota.js`)\n224\t    carries a pre-seeded, deliberately high quota (AC20) -- so the ingest\n225\t    path exercises the quota-check read-and-decide on every request without\n226\t    ever actually rejecting one, isolating the added latency of the `FOR\n227\t    UPDATE` lookup itself from the (much larger, transaction-aborting) cost\n228\t    of a rejection.\n229\t    \"\"\"\n230\t    if not _docker_available():\n231\t        pytest.skip(\"Docker is not available in this environment -- cannot run a real k6 load test\")\n232\t\n233\t    pull_result = subprocess.run(\n234\t        [\"docker\", \"image\", \"inspect\", \"grafana/k6:latest\"], capture_output=True, timeout=10\n235\t    )\n236\t    if pull_result.returncode != 0:\n237\t        pull_result = subprocess.run(\n238\t            [\"docker\", \"pull\", \"grafana/k6:latest\"], capture_output=True, timeout=120\n239\t        )\n240\t        if pull_result.returncode != 0:\n241\t            pytest.skip(\"grafana/k6 image could not be pulled in this environment\")\n242\t\n243\t    port = _free_port()\n244\t    env = dict(os.environ)\n245\t    env[\"DATABASE_URL\"] = postgres_url\n246\t    env[\"METERLY_REDIS_URL\"] = redis_url\n247\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"1000000\"\n248\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"1000000\"\n249\t\n250\t    presented_key, api_key_id = await make_api_key(\n251\t        label=\"k6-quota-perf-key\", rate_limit_per_sec=1_000_000, scope=\"admin\"\n252\t    )\n253\t\n254\t    from sqlalchemy import text\n255\t    from sqlalchemy.ext.asyncio import create_async_engine\n256\t\n257\t    # A high-but-finite cap per bucket (well above anything a 15s run at the\n258\t    # target rate could accumulate) -- active enough to exercise the FOR\n259\t    # UPDATE read-and-decide on every request, never high enough to matter\n260\t    # for whether a single run's requests are accepted.\n261\t    quota_engine = create_async_engine(postgres_url)\n262\t    async with quota_engine.begin() as connection:\n263\t        for customer_index in range(50):\n264\t            await connection.execute(\n265\t                text(\n266\t                    \"\"\"\n267\t                    INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window, updated_at)\n268\t                    VALUES (:api_key_id, :customer_id, 'api_calls', 100000000, now())\n269\t                    ON CONFLICT (api_key_id, customer_id, metric) DO UPDATE SET\n270\t                        limit_per_window = EXCLUDED.limit_per_window\n271\t                    \"\"\"\n272\t                ),\n273\t                {\"api_key_id\": api_key_id, \"customer_id\": f\"cust_{customer_index}\"},\n274\t            )\n275\t    await quota_engine.dispose()\n276\t\n277\t    # A dedicated (lower) default worker count, not the shared\n278\t    # METERLY_PERF_UVICORN_WORKERS knob: this is the third heavy multi-worker\n279\t    # uvicorn+DB-pool fixture in this module, and all three share ONE\n280\t    # session-scoped Postgres container with a fixed max_connections budget\n281\t    # -- keeping this fixture's footprint smaller avoids exhausting that\n282\t    # budget when the whole suite (all three perf fixtures) runs in one\n283\t    # pytest session, without changing the existing two tests' tuning.\n284\t    workers = int(os.environ.get(\"METERLY_PERF_QUOTA_UVICORN_WORKERS\", \"2\"))\n285\t    scratch_dir = Path(os.environ.get(\"METERLY_TEST_SCRATCH_DIR\", tempfile.gettempdir())) / \"meterly_k6_quota_perf\"\n286\t    scratch_dir.mkdir(parents=True, exist_ok=True)\n287\t\n288\t    uvicorn_log = open(scratch_dir / \"uvicorn_stdout.log\", \"w\")\n289\t    process = subprocess.Popen(\n290\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"0.0.0.0\", \"--port\", str(port), \"--workers\", str(workers)],\n291\t        cwd=str(_REPO_ROOT), env=env, stdout=uvicorn_log, stderr=subprocess.STDOUT,\n292\t    )\n293\t\n294\t    try:\n295\t        deadline = time.monotonic() + 30\n296\t        async with httpx.AsyncClient() as probe:\n297\t            ready = False\n298\t            while time.monotonic() < deadline:\n299\t                try:\n300\t                    response = await probe.get(f\"http://127.0.0.1:{port}/health\", timeout=1.0)\n301\t                    if response.status_code == 200:\n302\t                        ready = True\n303\t                        break\n304\t                except httpx.TransportError:\n305\t                    pass\n306\t                await asyncio.sleep(0.3)\n307\t            if not ready:\n308\t                pytest.skip(\"uvicorn did not become ready in time in this environment\")\n309\t\n310\t        yield {\"base_url_from_host\": f\"http://127.0.0.1:{port}\", \"port\": port, \"api_key\": presented_key, \"scratch_dir\": scratch_dir}\n311\t    finally:\n312\t        process.terminate()\n313\t        try:\n314\t            process.wait(timeout=10)\n315\t        except subprocess.TimeoutExpired:\n316\t            process.kill()\n317\t        uvicorn_log.close()\n318\t        # Give Postgres a moment to reclaim the just-closed workers' backend\n319\t        # connection slots before the next test's fixtures open new ones\n320\t        # against the same shared container (mitigates TooManyConnectionsError\n321\t        # when this module's perf tests run back-to-back in one session).\n322\t        await asyncio.sleep(1.0)\n323\t\n324\t\n325\tdef test_events_ingest_with_quotas_p95_under_50ms(k6_quota_load_env):\n326\t    \"\"\"AC20: drive POST /v1/events at the same sustained 500 req/s scenario\n327\t    with quotas active (high limits, no rejection) -- records the true\n328\t    nearest-rank p95 so the quota-check path's added latency is measured\n329\t    against the existing ingest budget, an honest measurement rather than a\n330\t    fabricated pass/fail claim (mirrors test_events_ingest_sustained_500rps_k6_load).\"\"\"\n331\t    target_rps = int(os.environ.get(\"METERLY_PERF_TARGET_RPS\", \"500\"))\n332\t    duration = os.environ.get(\"METERLY_PERF_DURATION\", \"15s\")\n333\t    warmup = os.environ.get(\"METERLY_PERF_WARMUP\", \"5s\")\n334\t\n335\t    result = _run_k6(\n336\t        \"load_events_quota.js\", k6_quota_load_env[\"port\"], k6_quota_load_env[\"api_key\"], k6_quota_load_env[\"scratch_dir\"],\n337\t        target_rps, duration, warmup, \"k6_events_quota_raw.jsonl\",\n338\t    )\n339\t    (k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n340\t\n341\t    if result.returncode != 0:\n342\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_events_quota_stdout.log\")\n343\t\n344\t    metrics = _nearest_rank_from_raw_jsonl(k6_quota_load_env[\"scratch_dir\"] / \"k6_events_quota_raw.jsonl\", scenario=\"ingest\")\n345\t    (k6_quota_load_env[\"scratch_dir\"] / \"events_quota_metrics.json\").write_text(json.dumps(metrics, indent=2))\n346\t    print(\"POST /v1/events (quotas active) k6 load metrics:\", json.dumps(metrics, indent=2))\n347\t\n348\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n349\t\n350\t\n351\tdef test_usage_read_sustained_100rps_k6_load(k6_load_env):\n352\t    \"\"\"Drive GET /v1/usage at a sustained 100 req/s via k6, recording true p95\n353\t    against the AC6 budget's declared <100ms usage-read p95.\"\"\"\n354\t    target_rps = int(os.environ.get(\"METERLY_PERF_USAGE_TARGET_RPS\", \"100\"))\n355\t    duration = os.environ.get(\"METERLY_PERF_USAGE_DURATION\", \"10s\")\n356\t    warmup = os.environ.get(\"METERLY_PERF_USAGE_WARMUP\", \"3s\")\n357\t\n358\t    result = _run_k6(\n359\t        \"load_usage.js\", k6_load_env[\"port\"], k6_load_env[\"api_key\"], k6_load_env[\"scratch_dir\"],\n360\t        target_rps, duration, warmup, \"k6_usage_raw.jsonl\",\n361\t    )\n362\t    (k6_load_env[\"scratch_dir\"] / \"k6_usage_stdout.log\").write_text(result.stdout + \"\\n---STDERR---\\n\" + result.stderr)\n363\t\n364\t    if result.returncode != 0:\n365\t        pytest.skip(f\"k6 run failed to execute in this environment (rc={result.returncode}); see k6_usage_stdout.log\")\n366\t\n367\t    metrics = _nearest_rank_from_raw_jsonl(k6_load_env[\"scratch_dir\"] / \"k6_usage_raw.jsonl\", scenario=\"ingest\")\n368\t    (k6_load_env[\"scratch_dir\"] / \"usage_metrics.json\").write_text(json.dumps(metrics, indent=2))\n369\t    print(\"GET /v1/usage k6 load metrics:\", json.dumps(metrics, indent=2))\n370\t\n371\t    assert metrics[\"sample_count\"] > 0, \"the k6 run produced no ingest-scenario samples -- treat as unmeasured, not zero\"\n372\t"}]},"uuid":"c9ccab81-8380-4eaf-94dd-6fd0f2c34cb2","timestamp":"2026-07-09T02:37:05.438Z","sourceToolAssistantUUID":"01a0a129-0ef0-4966-9871-c46751a850e4","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHu