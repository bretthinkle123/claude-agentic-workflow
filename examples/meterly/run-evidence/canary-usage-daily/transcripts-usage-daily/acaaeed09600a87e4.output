{"parentUuid":"1b242c85-3d86-455a-b95d-d303463da64b","isSidechain":true,"agentId":"acaaeed09600a87e4","message":{"model":"claude-opus-4-8","id":"msg_011CcvuyhJC392voeBAQdf57","type":"message","role":"assistant","content":[{"type":"text","text":"Let me examine the sibling error-handling pattern and the central error envelope so I mirror them accurately."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21973,"cache_read_input_tokens":27552,"cache_creation":{"ephemeral_5m_input_tokens":21973,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccvuycyjezyj7bqLid9qm","attributionAgent":"planning","type":"assistant","uuid":"ada01268-59e8-40a6-ac64-7bfba53e233c","timestamp":"2026-07-11T20:38:21.600Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"ada01268-59e8-40a6-ac64-7bfba53e233c","isSidechain":true,"agentId":"acaaeed09600a87e4","message":{"model":"claude-opus-4-8","id":"msg_011CcvuyhJC392voeBAQdf57","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Ji2FKXumsYh8jum7DZeusQ","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21973,"cache_read_input_tokens":27552,"cache_creation":{"ephemeral_5m_input_tokens":21973,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccvuycyjezyj7bqLid9qm","attributionAgent":"planning","type":"assistant","uuid":"d2a722d1-c012-42a0-885b-542369664cbd","timestamp":"2026-07-11T20:38:23.223Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"d2a722d1-c012-42a0-885b-542369664cbd","isSidechain":true,"promptId":"771ae553-fb60-4132-94f8-c6a928145268","agentId":"acaaeed09600a87e4","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ji2FKXumsYh8jum7DZeusQ","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"c54aebbb-8518-4776-815e-053f0d4d856a","timestamp":"2026-07-11T20:38:23.278Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py","content":"\"\"\"The error-envelope facade — every exception a handler raises terminates\nhere, at one centralized boundary, as the single response shape:\n`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n\nNever leaks a stack trace, exception type, SQL, or internal path to the\nclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\ngets a generic, stable `code` plus the `requestId` that ties a user report\nback to the server log line.\n\"\"\"\n\nfrom fastapi import FastAPI, HTTPException, Request, status\nfrom fastapi.exceptions import RequestValidationError\nfrom fastapi.responses import JSONResponse\nfrom starlette.exceptions import HTTPException as StarletteHTTPException\n\nfrom src.logging import get_logger\n\nlogger = get_logger(service=\"meterly\")\n\n_STATUS_TO_CODE = {\n    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n    status.HTTP_403_FORBIDDEN: \"forbidden\",\n    status.HTTP_404_NOT_FOUND: \"not_found\",\n    status.HTTP_409_CONFLICT: \"conflict\",\n    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n}\n\n\ndef _request_id(request: Request) -> str:\n    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n    return getattr(request.state, \"request_id\", \"unknown\")\n\n\ndef _envelope(code: str, message: str, request_id: str) -> dict:\n    \"\"\"Build the one response shape every error returns.\"\"\"\n    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n\n\nclass AppError(HTTPException):\n    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n    rejection needs its own, distinct `quota_exceeded` code on the same\n    status. `handle_http_exception` prefers `app_code` over the status map\n    when present, so this is the minimal single-boundary extension rather\n    than reshaping the map itself.\n    \"\"\"\n\n    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n        super().__init__(status_code=status_code, detail=detail, headers=headers)\n        self.app_code = app_code\n\n\ndef register_error_handlers(app: FastAPI) -> None:\n    \"\"\"Register the centralized exception handlers on `app`.\n\n    Called once from `src/main.py` at app construction — no route ever builds\n    its own error response; it raises and lets this boundary map it.\n    \"\"\"\n\n    @app.exception_handler(RequestValidationError)\n    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n        request_id = _request_id(request)\n        logger.warning(\n            \"validation.failed\",\n            requestId=request_id,\n            endpoint=request.url.path,\n            errorCount=len(exc.errors()),\n        )\n        return JSONResponse(\n            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n        )\n\n    @app.exception_handler(StarletteHTTPException)\n    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n\n        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n        map — this is what lets two different exceptions share one HTTP status\n        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n        \"\"\"\n        request_id = _request_id(request)\n        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n        return JSONResponse(\n            status_code=exc.status_code,\n            content=_envelope(code, message, request_id),\n            headers=getattr(exc, \"headers\", None) or {},\n        )\n\n    @app.exception_handler(Exception)\n    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n\n        This is the fail-closed boundary — an unhandled exception mid-write\n        never leaks stack/SQL/secret detail, and because the events + rollup\n        write happens in one transaction (`src/services/events_service.py`),\n        an exception here means that transaction was rolled back, not\n        partially applied.\n        \"\"\"\n        request_id = _request_id(request)\n        logger.error(\n            \"request.unhandled_error\",\n            requestId=request_id,\n            endpoint=request.url.path,\n            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n            exc_info=True,\n        )\n        return JSONResponse(\n            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n        )\n\n\n__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n","numLines":121,"startLine":1,"totalLines":121}},"sourceToolAssistantUUID":"d2a722d1-c012-42a0-885b-542369664cbd","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"c54aebbb-8518-4776-815e-053f0d4d856a","isSidechain":true,"agentId":"acaaeed09600a87e4","message":{"model":"claude-opus-4-8","id":"msg_011CcvuyhJC392voeBAQdf57","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01B2qqkgKVUisdbqGARvgLKg","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_usage_export_endpoint.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":21973,"cache_read_input_tokens":27552,"output_tokens":568,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":21973},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":568,"cache_read_input_tokens":27552,"cache_creation_input_tokens":21973,"cache_creation":{"ephemeral_5m_input_tokens":21973,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccvuycyjezyj7bqLid9qm","attributionAgent":"planning","type":"assistant","uuid":"44910a48-b485-480e-a55b-0d6236e44ecb","timestamp":"2026-07-11T20:38:23.414Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"44910a48-b485-480e-a55b-0d6236e44ecb","isSidechain":true,"promptId":"771ae553-fb60-4132-94f8-c6a928145268","agentId":"acaaeed09600a87e4","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01B2qqkgKVUisdbqGARvgLKg","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/usage/export` against a real Postgres:\n2\tstreaming correctness, tenant isolation, the row cap, formula-escaping\n3\tend-to-end, response headers, and the pre-flight fail-closed safe-error path\n4\t(AC1-AC13, AC17, AC19, AC22).\n5\t\"\"\"\n6\t\n7\timport asyncio\n8\timport re\n9\timport socket\n10\timport subprocess\n11\timport sys\n12\timport time\n13\tfrom contextlib import closing\n14\tfrom datetime import datetime, timedelta, timezone\n15\tfrom pathlib import Path\n16\t\n17\timport httpx\n18\timport pytest\n19\tfrom httpx import ASGITransport, AsyncClient\n20\tfrom sqlalchemy import text\n21\t\n22\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n23\t\n24\t\n25\tdef _event_payload(**overrides) -> dict:\n26\t    payload = {\n27\t        \"customer_id\": \"cust_1\",\n28\t        \"metric\": \"api_calls\",\n29\t        \"quantity\": \"5\",\n30\t        \"idempotency_key\": \"idem-1\",\n31\t    }\n32\t    payload.update(overrides)\n33\t    return payload\n34\t\n35\t\n36\tasync def _bulk_insert_rollups(\n37\t    postgres_url, *, api_key_id: int, metric: str, window_start: datetime, count: int\n38\t) -> None:\n39\t    \"\"\"Directly seed `usage_rollup` rows via a single set-based INSERT — the\n40\t    cap/perf tests need tens of thousands of rows, which is impractical to\n41\t    seed one ingest POST at a time.\"\"\"\n42\t    from sqlalchemy.ext.asyncio import create_async_engine\n43\t\n44\t    engine = create_async_engine(postgres_url)\n45\t    async with engine.begin() as connection:\n46\t        await connection.execute(\n47\t            text(\n48\t                \"\"\"\n49\t                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n50\t                SELECT :api_key_id, 'cust_' || lpad(gs::text, 8, '0'), :metric, :window_start, 1, 1\n51\t                FROM generate_series(1, :count) AS gs\n52\t                \"\"\"\n53\t            ),\n54\t            {\"api_key_id\": api_key_id, \"metric\": metric, \"window_start\": window_start, \"count\": count},\n55\t        )\n56\t    await engine.dispose()\n57\t\n58\t\n59\tasync def test_export_is_header_only_csv_for_empty_result(client, make_api_key):\n60\t    \"\"\"AC12: a caller with no matching rollups gets 200 with a single header\n61\t    line, never 404.\"\"\"\n62\t    presented_key, _ = await make_api_key()\n63\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n64\t\n65\t    assert response.status_code == 200\n66\t    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n67\t\n68\t\n69\tasync def test_export_with_no_filters_returns_all_caller_rows(client, make_api_key):\n70\t    \"\"\"AC2: omitting every filter exports the caller's full row set.\"\"\"\n71\t    presented_key, _ = await make_api_key()\n72\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n73\t\n74\t    await client.post(\n75\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n76\t    )\n77\t    await client.post(\n78\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n79\t    )\n80\t\n81\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n82\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n83\t\n84\t    assert response.status_code == 200\n85\t    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n86\t    assert len(lines) == 3  # header + 2 rows\n87\t\n88\t\n89\tasync def test_export_customer_id_filter_narrows_the_result(client, make_api_key):\n90\t    \"\"\"AC2: a customer_id filter excludes rows for other customers.\"\"\"\n91\t    presented_key, _ = await make_api_key()\n92\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n93\t\n94\t    await client.post(\n95\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n96\t    )\n97\t    await client.post(\n98\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n99\t    )\n100\t\n101\t    response = await client.get(\n102\t        \"/v1/usage/export\", params={\"customer_id\": \"cust_a\"}, headers=headers\n103\t    )\n104\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n105\t\n106\t    assert len(lines) == 2  # header + cust_a only\n107\t    assert \"cust_a\" in lines[1]\n108\t    assert \"cust_b\" not in response.text\n109\t\n110\t\n111\tasync def test_export_metric_filter_narrows_the_result(client, make_api_key):\n112\t    \"\"\"AC2: a metric filter excludes rows for other metrics.\"\"\"\n113\t    presented_key, _ = await make_api_key()\n114\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n115\t\n116\t    await client.post(\n117\t        \"/v1/events\", json=_event_payload(metric=\"api_calls\", idempotency_key=\"a\"), headers=headers\n118\t    )\n119\t    await client.post(\n120\t        \"/v1/events\", json=_event_payload(metric=\"storage_bytes\", idempotency_key=\"b\"), headers=headers\n121\t    )\n122\t\n123\t    response = await client.get(\"/v1/usage/export\", params={\"metric\": \"api_calls\"}, headers=headers)\n124\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n125\t\n126\t    assert len(lines) == 2  # header + api_calls only\n127\t    assert \"api_calls\" in lines[1]\n128\t    assert \"storage_bytes\" not in response.text\n129\t\n130\t\n131\tasync def test_export_from_to_window_filter_narrows_the_result(client, make_api_key):\n132\t    \"\"\"AC2: `from`/`to` narrow the export to rows within the window; a row\n133\t    outside the range is excluded.\"\"\"\n134\t    presented_key, _ = await make_api_key()\n135\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n136\t\n137\t    await client.post(\n138\t        \"/v1/events\", json=_event_payload(customer_id=\"cust_in_window\", idempotency_key=\"a\"), headers=headers\n139\t    )\n140\t\n141\t    now = datetime.now(timezone.utc)\n142\t    in_window_from = (now - timedelta(hours=1)).isoformat()\n143\t    in_window_to = (now + timedelta(hours=1)).isoformat()\n144\t    # A window entirely before the row's window_start (valid from<=to, but\n145\t    # both endpoints predate \"now\") — the row must be excluded.\n146\t    before_window_from = (now - timedelta(hours=4)).isoformat()\n147\t    before_window_to = (now - timedelta(hours=2)).isoformat()\n148\t\n149\t    in_window_response = await client.get(\n150\t        \"/v1/usage/export\", params={\"from\": in_window_from, \"to\": in_window_to}, headers=headers\n151\t    )\n152\t    before_window_response = await client.get(\n153\t        \"/v1/usage/export\", params={\"from\": before_window_from, \"to\": before_window_to}, headers=headers\n154\t    )\n155\t\n156\t    assert \"cust_in_window\" in in_window_response.text\n157\t    assert before_window_response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n158\t\n159\t\n160\tasync def test_export_malformed_query_param_returns_422(client, make_api_key):\n161\t    \"\"\"AC4: an out-of-window `from` returns 422 validation_failed.\"\"\"\n162\t    presented_key, _ = await make_api_key()\n163\t    too_old = (datetime.now(timezone.utc) - timedelta(days=91)).isoformat()\n164\t\n165\t    response = await client.get(\n166\t        \"/v1/usage/export\", params={\"from\": too_old}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n167\t    )\n168\t\n169\t    assert response.status_code == 422\n170\t    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n171\t\n172\t\n173\tasync def test_export_unknown_query_param_returns_422(client, make_api_key):\n174\t    \"\"\"AC4: `extra='forbid'` rejects an unexpected query param (e.g. api_key_id probe).\"\"\"\n175\t    presented_key, _ = await make_api_key()\n176\t\n177\t    response = await client.get(\n178\t        \"/v1/usage/export\", params={\"api_key_id\": \"999\"}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n179\t    )\n180\t\n181\t    assert response.status_code == 422\n182\t\n183\t\n184\tasync def test_export_requires_authentication(client, make_api_key):\n185\t    \"\"\"AC6: no/invalid key -> 401 before the handler runs.\"\"\"\n186\t    missing = await client.get(\"/v1/usage/export\")\n187\t    invalid = await client.get(\"/v1/usage/export\", headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"})\n188\t\n189\t    assert missing.status_code == 401\n190\t    assert invalid.status_code == 401\n191\t\n192\t\n193\tasync def test_export_any_authenticated_scope_may_export_ingest_and_admin(client, make_api_key):\n194\t    \"\"\"AC6: both an ingest-scoped and an admin-scoped key succeed (no scope gate).\"\"\"\n195\t    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n196\t    admin_key, _ = await make_api_key(label=\"admin\", scope=\"admin\")\n197\t\n198\t    ingest_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n199\t    admin_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {admin_key}\"})\n200\t\n201\t    assert ingest_response.status_code == 200\n202\t    assert admin_response.status_code == 200\n203\t\n204\t\n205\tasync def test_export_rate_limit_two_principals_one_ip_get_independent_buckets(truncate_tables, make_api_key):\n206\t    \"\"\"AC5: the reused Tier-2 throttle is keyed on `api_key_id`, not client\n207\t    IP — principal A exhausting its own tiny bucket must not affect\n208\t    principal B behind the same client IP (mirrors\n209\t    tests/integration/test_rate_limit.py's discriminating shape, applied to\n210\t    this route).\"\"\"\n211\t    from src.main import app\n212\t\n213\t    key_a, _ = await make_api_key(label=\"export-tenant-a\", rate_limit_per_sec=1)\n214\t    key_b, _ = await make_api_key(label=\"export-tenant-b\", rate_limit_per_sec=100)\n215\t\n216\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 5000))\n217\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as shared_ip_client:\n218\t        first = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n219\t        second = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n220\t\n221\t        assert first.status_code == 200\n222\t        assert second.status_code == 429\n223\t        assert \"Retry-After\" in second.headers\n224\t\n225\t        third = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n226\t        assert third.status_code == 200\n227\t\n228\t\n229\tasync def test_export_tenant_isolation_excludes_other_tenants_rows(client, make_api_key):\n230\t    \"\"\"AC7: tenant A's export never contains tenant B's rows (IDOR/BOLA).\"\"\"\n231\t    key_a, _ = await make_api_key(label=\"tenant-a\")\n232\t    key_b, _ = await make_api_key(label=\"tenant-b\")\n233\t\n234\t    await client.post(\n235\t        \"/v1/events\",\n236\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"a-1\", quantity=\"1000\"),\n237\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n238\t    )\n239\t    await client.post(\n240\t        \"/v1/events\",\n241\t        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"b-1\", quantity=\"2000\"),\n242\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n243\t    )\n244\t\n245\t    response_a = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n246\t    lines_a = response_a.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n247\t\n248\t    assert len(lines_a) == 2  # header + exactly tenant A's one row\n249\t    assert \"1000.000000\" in response_a.text\n250\t    assert \"2000.000000\" not in response_a.text\n251\t\n252\t\n253\tasync def test_export_row_cap_returns_422_with_no_partial_body(client, make_api_key, postgres_url):\n254\t    \"\"\"AC8: a result over 100,000 rows is rejected with a clean 422 and no\n255\t    partial CSV body — the pre-flight count runs before any response byte.\"\"\"\n256\t    presented_key, api_key_id = await make_api_key()\n257\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n258\t    await _bulk_insert_rollups(\n259\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=100_001\n260\t    )\n261\t\n262\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n263\t\n264\t    assert response.status_code == 422\n265\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n266\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")\n267\t    assert \"\\r\\n\" not in response.text  # no CSV line-terminated rows, ever streamed\n268\t    body = response.json()\n269\t    assert body[\"error\"][\"code\"] == \"validation_failed\"\n270\t    assert set(body[\"error\"].keys()) == {\"code\", \"message\", \"requestId\"}  # the envelope shape only\n271\t\n272\t\n273\tasync def test_export_deterministic_ordering(client, make_api_key):\n274\t    \"\"\"AC13: rows are ordered by window_start, customer_id, metric ascending.\"\"\"\n275\t    presented_key, _ = await make_api_key()\n276\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n277\t\n278\t    for customer_id in (\"cust_c\", \"cust_a\", \"cust_b\"):\n279\t        await client.post(\n280\t            \"/v1/events\",\n281\t            json=_event_payload(customer_id=customer_id, idempotency_key=customer_id),\n282\t            headers=headers,\n283\t        )\n284\t\n285\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n286\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")[1:]\n287\t    seen_customer_ids = [line.split(\",\")[0] for line in lines]\n288\t\n289\t    assert seen_customer_ids == [\"cust_a\", \"cust_b\", \"cust_c\"]\n290\t\n291\t\n292\tasync def test_export_formula_injection_is_escaped_end_to_end(client, make_api_key):\n293\t    \"\"\"AC10: a leading-'-' customer_id (permitted by the ingest allowlist) is\n294\t    quote-prefixed in the exported CSV.\"\"\"\n295\t    presented_key, _ = await make_api_key()\n296\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n297\t\n298\t    await client.post(\n299\t        \"/v1/events\", json=_event_payload(customer_id=\"-1\", idempotency_key=\"dash\"), headers=headers\n300\t    )\n301\t\n302\t    response = await client.get(\"/v1/usage/export\", headers=headers)\n303\t    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n304\t\n305\t    assert lines[1].startswith(\"'-1,\")\n306\t\n307\t\n308\tasync def test_export_response_headers(client, make_api_key):\n309\t    \"\"\"AC11: text/csv content type, attachment filename (UTC timestamp only,\n310\t    no tenant identifier), nosniff + no-store inherited from the middleware\n311\t    stack. The filename is asserted against its exact expected shape (not a\n312\t    substring exclusion) — a strictly-pinned pattern is what actually proves\n313\t    no extra data, tenant id included, ever rides along in it.\"\"\"\n314\t    presented_key, _ = await make_api_key()\n315\t\n316\t    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n317\t\n318\t    assert response.headers[\"content-type\"] == \"text/csv; charset=utf-8\"\n319\t    content_disposition = response.headers[\"content-disposition\"]\n320\t    assert re.fullmatch(\n321\t        r'attachment; filename=\"usage-export-\\d{8}T\\d{6}Z\\.csv\"', content_disposition\n322\t    ), content_disposition\n323\t    assert response.headers[\"x-content-type-options\"] == \"nosniff\"\n324\t    assert response.headers[\"cache-control\"] == \"no-store\"\n325\t\n326\t\n327\tdef _free_port() -> int:\n328\t    \"\"\"Find an unused TCP port for the out-of-process uvicorn server below.\"\"\"\n329\t    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n330\t        sock.bind((\"127.0.0.1\", 0))\n331\t        return sock.getsockname()[1]\n332\t\n333\t\n334\t@pytest.fixture\n335\tasync def running_server(postgres_url, redis_url, make_api_key, truncate_tables):\n336\t    \"\"\"Launch the real app under uvicorn, out-of-process, against the live\n337\t    containers.\n338\t\n339\t    Needed specifically for the streaming-not-buffered sanity check:\n340\t    httpx's in-process `ASGITransport` joins the *entire* response body into\n341\t    one chunk before yielding it (`ASGIResponseStream.__aiter__` does\n342\t    `yield b\"\".join(self._body)`), which would make a chunk-count assertion\n343\t    pass or fail independent of whether the app actually streams — only a\n344\t    real socket exposes genuine chunk boundaries.\n345\t    \"\"\"\n346\t    port = _free_port()\n347\t    import os\n348\t\n349\t    env = dict(os.environ)\n350\t    env[\"DATABASE_URL\"] = postgres_url\n351\t    env[\"METERLY_REDIS_URL\"] = redis_url\n352\t    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"100000\"\n353\t    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"100000\"\n354\t\n355\t    presented_key, api_key_id = await make_api_key(rate_limit_per_sec=100000)\n356\t\n357\t    process = subprocess.Popen(\n358\t        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"127.0.0.1\", \"--port\", str(port)],\n359\t        cwd=str(_REPO_ROOT),\n360\t        env=env,\n361\t        stdout=subprocess.PIPE,\n362\t        stderr=subprocess.STDOUT,\n363\t        text=True,\n364\t    )\n365\t    base_url = f\"http://127.0.0.1:{port}\"\n366\t\n367\t    try:\n368\t        deadline = time.monotonic() + 20\n369\t        async with httpx.AsyncClient() as probe:\n370\t            while time.monotonic() < deadline:\n371\t                try:\n372\t                    response = await probe.get(f\"{base_url}/health\", timeout=1.0)\n373\t                    if response.status_code == 200:\n374\t                        break\n375\t                except httpx.TransportError:\n376\t                    pass\n377\t                await asyncio.sleep(0.3)\n378\t            else:\n379\t                pytest.skip(\"uvicorn did not become ready in time in this sandboxed environment\")\n380\t\n381\t        yield base_url, presented_key, api_key_id\n382\t    finally:\n383\t        process.terminate()\n384\t        try:\n385\t            process.wait(timeout=5)\n386\t        except subprocess.TimeoutExpired:\n387\t            process.kill()\n388\t\n389\t\n390\tasync def test_export_streaming_delivers_multiple_discrete_chunks(running_server, postgres_url):\n391\t    \"\"\"AC9: the response is streamed (multiple discrete chunks arrive over\n392\t    the real socket, not one fully-buffered write) for a multi-row export.\"\"\"\n393\t    base_url, presented_key, api_key_id = running_server\n394\t    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n395\t    # Large enough that a real streamed write can't coalesce into a single\n396\t    # TCP read on the client side (small payloads often do, even when the\n397\t    # server genuinely writes them incrementally).\n398\t    await _bulk_insert_rollups(\n399\t        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=20_000\n400\t    )\n401\t\n402\t    chunk_count = 0\n403\t    async with httpx.AsyncClient(timeout=30.0) as http_client:\n404\t        async with http_client.stream(\n405\t            \"GET\", f\"{base_url}/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n406\t        ) as response:\n407\t            assert response.status_code == 200\n408\t            async for _chunk in response.aiter_bytes():\n409\t                chunk_count += 1\n410\t\n411\t    # Proof the response isn't assembled into one buffered blob before being\n412\t    # sent — a genuinely streamed multi-row export arrives as more than one\n413\t    # discrete read on the wire.\n414\t    assert chunk_count > 1\n415\t\n416\t\n417\tasync def test_openapi_schema_exposes_the_export_route_and_responses(client):\n418\t    \"\"\"AC19 (DAST-1): the served /openapi.json includes GET /v1/usage/export\n419\t    with its 200 text/csv and 422 responses, matching the implemented route.\"\"\"\n420\t    response = await client.get(\"/openapi.json\")\n421\t\n422\t    assert response.status_code == 200\n423\t    schema = response.json()\n424\t    assert \"/v1/usage/export\" in schema[\"paths\"]\n425\t    export_operation = schema[\"paths\"][\"/v1/usage/export\"][\"get\"]\n426\t    assert \"200\" in export_operation[\"responses\"]\n427\t    assert \"422\" in export_operation[\"responses\"]\n428\t    assert \"text/csv\" in export_operation[\"responses\"][\"200\"][\"content\"]\n429\t\n430\t\n431\tasync def test_export_seeded_dast_key_can_call_the_export(postgres_url, truncate_tables):\n432\t    \"\"\"AC20 (DAST-2): a key provisioned by the real `scripts/seed_api_key.py`\n433\t    (not the fast `make_api_key` test fixture) can successfully call\n434\t    `GET /v1/usage/export` and get a 200 header-only CSV. The pre-existing\n435\t    `tests/integration/test_seed_api_key_script.py` proves the script\n436\t    persists a working key row, but never actually calls an endpoint with the\n437\t    key it prints — this closes that gap for the export route specifically,\n438\t    which is what AC20 requires ('can call the export').\"\"\"\n439\t    import os\n440\t\n441\t    from src.main import app\n442\t\n443\t    env = dict(os.environ)\n444\t    env[\"DATABASE_URL\"] = postgres_url\n445\t\n446\t    result = subprocess.run(\n447\t        [sys.executable, \"scripts/seed_api_key.py\", \"--label\", \"dast-export-key\", \"--rate-limit\", \"50\"],\n448\t        cwd=str(_REPO_ROOT),\n449\t        env=env,\n450\t        capture_output=True,\n451\t        text=True,\n452\t    )\n453\t    assert result.returncode == 0, f\"seed script failed:\\n{result.stdout}\\n{result.stderr}\"\n454\t    presented_key = result.stdout.strip().splitlines()[-1]\n455\t    assert presented_key.startswith(\"mtr_live_\")\n456\t\n457\t    transport = ASGITransport(app=app)\n458\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as seeded_client:\n459\t        response = await seeded_client.get(\n460\t            \"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n461\t        )\n462\t\n463\t    assert response.status_code == 200\n464\t    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n465\t\n466\t\n467\tasync def test_export_forced_pre_flight_count_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n468\t    \"\"\"AC22: a forced error during the pre-flight COUNT phase (before any\n469\t    response byte) returns the generic 500 internal envelope — no\n470\t    stack/SQL/internal-path leak, and no partial CSV body.\"\"\"\n471\t    from src.main import app\n472\t    from src.services import usage_export_service\n473\t\n474\t    async def _raising_count(session, **kwargs):\n475\t        raise RuntimeError(\"simulated connection drop mid-count\")\n476\t\n477\t    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n478\t\n479\t    presented_key, _ = await make_api_key()\n480\t\n481\t    # ASGITransport re-raises app exceptions by default (useful for debugging\n482\t    # a broken test); here we're deliberately exercising the app's own 500\n483\t    # handler, so this client must let it convert the exception to a response\n484\t    # (mirrors tests/integration/test_events_endpoint.py's AC19 pattern).\n485\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n486\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as client:\n487\t        response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n488\t\n489\t    assert response.status_code == 500\n490\t    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n491\t    body = response.json()\n492\t    assert body[\"error\"][\"code\"] == \"internal\"\n493\t    assert \"requestId\" in body[\"error\"]\n494\t    assert \"simulated connection drop\" not in response.text\n495\t    assert \"Traceback\" not in response.text\n496\t    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")  # no CSV body ever started\n497\t"}]},"uuid":"c4b95403-e3c1-4031-bd0b-0d4212a31a0e","timestamp":"2026-07-11T20:38:23.458Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_usage_export_endpoint.py","content":"\"\"\"Integration tests for `GET /v1/usage/export` against a real Postgres:\nstreaming correctness, tenant isolation, the row cap, formula-escaping\nend-to-end, response headers, and the pre-flight fail-closed safe-error path\n(AC1-AC13, AC17, AC19, AC22).\n\"\"\"\n\nimport asyncio\nimport re\nimport socket\nimport subprocess\nimport sys\nimport time\nfrom contextlib import closing\nfrom datetime import datetime, timedelta, timezone\nfrom pathlib import Path\n\nimport httpx\nimport pytest\nfrom httpx import ASGITransport, AsyncClient\nfrom sqlalchemy import text\n\n_REPO_ROOT = Path(__file__).resolve().parents[2]\n\n\ndef _event_payload(**overrides) -> dict:\n    payload = {\n        \"customer_id\": \"cust_1\",\n        \"metric\": \"api_calls\",\n        \"quantity\": \"5\",\n        \"idempotency_key\": \"idem-1\",\n    }\n    payload.update(overrides)\n    return payload\n\n\nasync def _bulk_insert_rollups(\n    postgres_url, *, api_key_id: int, metric: str, window_start: datetime, count: int\n) -> None:\n    \"\"\"Directly seed `usage_rollup` rows via a single set-based INSERT — the\n    cap/perf tests need tens of thousands of rows, which is impractical to\n    seed one ingest POST at a time.\"\"\"\n    from sqlalchemy.ext.asyncio import create_async_engine\n\n    engine = create_async_engine(postgres_url)\n    async with engine.begin() as connection:\n        await connection.execute(\n            text(\n                \"\"\"\n                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n                SELECT :api_key_id, 'cust_' || lpad(gs::text, 8, '0'), :metric, :window_start, 1, 1\n                FROM generate_series(1, :count) AS gs\n                \"\"\"\n            ),\n            {\"api_key_id\": api_key_id, \"metric\": metric, \"window_start\": window_start, \"count\": count},\n        )\n    await engine.dispose()\n\n\nasync def test_export_is_header_only_csv_for_empty_result(client, make_api_key):\n    \"\"\"AC12: a caller with no matching rollups gets 200 with a single header\n    line, never 404.\"\"\"\n    presented_key, _ = await make_api_key()\n    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n\n    assert response.status_code == 200\n    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n\n\nasync def test_export_with_no_filters_returns_all_caller_rows(client, make_api_key):\n    \"\"\"AC2: omitting every filter exports the caller's full row set.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n    )\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n    )\n\n    response = await client.get(\"/v1/usage/export\", headers=headers)\n    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n\n    assert response.status_code == 200\n    assert lines[0] == \"customer_id,metric,window_start,total_quantity\"\n    assert len(lines) == 3  # header + 2 rows\n\n\nasync def test_export_customer_id_filter_narrows_the_result(client, make_api_key):\n    \"\"\"AC2: a customer_id filter excludes rows for other customers.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"cust_a\", idempotency_key=\"a\"), headers=headers\n    )\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"cust_b\", idempotency_key=\"b\"), headers=headers\n    )\n\n    response = await client.get(\n        \"/v1/usage/export\", params={\"customer_id\": \"cust_a\"}, headers=headers\n    )\n    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n\n    assert len(lines) == 2  # header + cust_a only\n    assert \"cust_a\" in lines[1]\n    assert \"cust_b\" not in response.text\n\n\nasync def test_export_metric_filter_narrows_the_result(client, make_api_key):\n    \"\"\"AC2: a metric filter excludes rows for other metrics.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    await client.post(\n        \"/v1/events\", json=_event_payload(metric=\"api_calls\", idempotency_key=\"a\"), headers=headers\n    )\n    await client.post(\n        \"/v1/events\", json=_event_payload(metric=\"storage_bytes\", idempotency_key=\"b\"), headers=headers\n    )\n\n    response = await client.get(\"/v1/usage/export\", params={\"metric\": \"api_calls\"}, headers=headers)\n    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n\n    assert len(lines) == 2  # header + api_calls only\n    assert \"api_calls\" in lines[1]\n    assert \"storage_bytes\" not in response.text\n\n\nasync def test_export_from_to_window_filter_narrows_the_result(client, make_api_key):\n    \"\"\"AC2: `from`/`to` narrow the export to rows within the window; a row\n    outside the range is excluded.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"cust_in_window\", idempotency_key=\"a\"), headers=headers\n    )\n\n    now = datetime.now(timezone.utc)\n    in_window_from = (now - timedelta(hours=1)).isoformat()\n    in_window_to = (now + timedelta(hours=1)).isoformat()\n    # A window entirely before the row's window_start (valid from<=to, but\n    # both endpoints predate \"now\") — the row must be excluded.\n    before_window_from = (now - timedelta(hours=4)).isoformat()\n    before_window_to = (now - timedelta(hours=2)).isoformat()\n\n    in_window_response = await client.get(\n        \"/v1/usage/export\", params={\"from\": in_window_from, \"to\": in_window_to}, headers=headers\n    )\n    before_window_response = await client.get(\n        \"/v1/usage/export\", params={\"from\": before_window_from, \"to\": before_window_to}, headers=headers\n    )\n\n    assert \"cust_in_window\" in in_window_response.text\n    assert before_window_response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n\n\nasync def test_export_malformed_query_param_returns_422(client, make_api_key):\n    \"\"\"AC4: an out-of-window `from` returns 422 validation_failed.\"\"\"\n    presented_key, _ = await make_api_key()\n    too_old = (datetime.now(timezone.utc) - timedelta(days=91)).isoformat()\n\n    response = await client.get(\n        \"/v1/usage/export\", params={\"from\": too_old}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n    )\n\n    assert response.status_code == 422\n    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n\n\nasync def test_export_unknown_query_param_returns_422(client, make_api_key):\n    \"\"\"AC4: `extra='forbid'` rejects an unexpected query param (e.g. api_key_id probe).\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/export\", params={\"api_key_id\": \"999\"}, headers={\"Authorization\": f\"Bearer {presented_key}\"}\n    )\n\n    assert response.status_code == 422\n\n\nasync def test_export_requires_authentication(client, make_api_key):\n    \"\"\"AC6: no/invalid key -> 401 before the handler runs.\"\"\"\n    missing = await client.get(\"/v1/usage/export\")\n    invalid = await client.get(\"/v1/usage/export\", headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"})\n\n    assert missing.status_code == 401\n    assert invalid.status_code == 401\n\n\nasync def test_export_any_authenticated_scope_may_export_ingest_and_admin(client, make_api_key):\n    \"\"\"AC6: both an ingest-scoped and an admin-scoped key succeed (no scope gate).\"\"\"\n    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n    admin_key, _ = await make_api_key(label=\"admin\", scope=\"admin\")\n\n    ingest_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n    admin_response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {admin_key}\"})\n\n    assert ingest_response.status_code == 200\n    assert admin_response.status_code == 200\n\n\nasync def test_export_rate_limit_two_principals_one_ip_get_independent_buckets(truncate_tables, make_api_key):\n    \"\"\"AC5: the reused Tier-2 throttle is keyed on `api_key_id`, not client\n    IP — principal A exhausting its own tiny bucket must not affect\n    principal B behind the same client IP (mirrors\n    tests/integration/test_rate_limit.py's discriminating shape, applied to\n    this route).\"\"\"\n    from src.main import app\n\n    key_a, _ = await make_api_key(label=\"export-tenant-a\", rate_limit_per_sec=1)\n    key_b, _ = await make_api_key(label=\"export-tenant-b\", rate_limit_per_sec=100)\n\n    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 5000))\n    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as shared_ip_client:\n        first = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n        second = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n\n        assert first.status_code == 200\n        assert second.status_code == 429\n        assert \"Retry-After\" in second.headers\n\n        third = await shared_ip_client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n        assert third.status_code == 200\n\n\nasync def test_export_tenant_isolation_excludes_other_tenants_rows(client, make_api_key):\n    \"\"\"AC7: tenant A's export never contains tenant B's rows (IDOR/BOLA).\"\"\"\n    key_a, _ = await make_api_key(label=\"tenant-a\")\n    key_b, _ = await make_api_key(label=\"tenant-b\")\n\n    await client.post(\n        \"/v1/events\",\n        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"a-1\", quantity=\"1000\"),\n        headers={\"Authorization\": f\"Bearer {key_a}\"},\n    )\n    await client.post(\n        \"/v1/events\",\n        json=_event_payload(customer_id=\"cust_shared_name\", idempotency_key=\"b-1\", quantity=\"2000\"),\n        headers={\"Authorization\": f\"Bearer {key_b}\"},\n    )\n\n    response_a = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n    lines_a = response_a.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n\n    assert len(lines_a) == 2  # header + exactly tenant A's one row\n    assert \"1000.000000\" in response_a.text\n    assert \"2000.000000\" not in response_a.text\n\n\nasync def test_export_row_cap_returns_422_with_no_partial_body(client, make_api_key, postgres_url):\n    \"\"\"AC8: a result over 100,000 rows is rejected with a clean 422 and no\n    partial CSV body — the pre-flight count runs before any response byte.\"\"\"\n    presented_key, api_key_id = await make_api_key()\n    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n    await _bulk_insert_rollups(\n        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=100_001\n    )\n\n    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n\n    assert response.status_code == 422\n    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")\n    assert \"\\r\\n\" not in response.text  # no CSV line-terminated rows, ever streamed\n    body = response.json()\n    assert body[\"error\"][\"code\"] == \"validation_failed\"\n    assert set(body[\"error\"].keys()) == {\"code\", \"message\", \"requestId\"}  # the envelope shape only\n\n\nasync def test_export_deterministic_ordering(client, make_api_key):\n    \"\"\"AC13: rows are ordered by window_start, customer_id, metric ascending.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    for customer_id in (\"cust_c\", \"cust_a\", \"cust_b\"):\n        await client.post(\n            \"/v1/events\",\n            json=_event_payload(customer_id=customer_id, idempotency_key=customer_id),\n            headers=headers,\n        )\n\n    response = await client.get(\"/v1/usage/export\", headers=headers)\n    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")[1:]\n    seen_customer_ids = [line.split(\",\")[0] for line in lines]\n\n    assert seen_customer_ids == [\"cust_a\", \"cust_b\", \"cust_c\"]\n\n\nasync def test_export_formula_injection_is_escaped_end_to_end(client, make_api_key):\n    \"\"\"AC10: a leading-'-' customer_id (permitted by the ingest allowlist) is\n    quote-prefixed in the exported CSV.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    await client.post(\n        \"/v1/events\", json=_event_payload(customer_id=\"-1\", idempotency_key=\"dash\"), headers=headers\n    )\n\n    response = await client.get(\"/v1/usage/export\", headers=headers)\n    lines = response.text.strip(\"\\r\\n\").split(\"\\r\\n\")\n\n    assert lines[1].startswith(\"'-1,\")\n\n\nasync def test_export_response_headers(client, make_api_key):\n    \"\"\"AC11: text/csv content type, attachment filename (UTC timestamp only,\n    no tenant identifier), nosniff + no-store inherited from the middleware\n    stack. The filename is asserted against its exact expected shape (not a\n    substring exclusion) — a strictly-pinned pattern is what actually proves\n    no extra data, tenant id included, ever rides along in it.\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n\n    assert response.headers[\"content-type\"] == \"text/csv; charset=utf-8\"\n    content_disposition = response.headers[\"content-disposition\"]\n    assert re.fullmatch(\n        r'attachment; filename=\"usage-export-\\d{8}T\\d{6}Z\\.csv\"', content_disposition\n    ), content_disposition\n    assert response.headers[\"x-content-type-options\"] == \"nosniff\"\n    assert response.headers[\"cache-control\"] == \"no-store\"\n\n\ndef _free_port() -> int:\n    \"\"\"Find an unused TCP port for the out-of-process uvicorn server below.\"\"\"\n    with closing(socket.socket(socket.AF_INET, socket.SOCK_STREAM)) as sock:\n        sock.bind((\"127.0.0.1\", 0))\n        return sock.getsockname()[1]\n\n\n@pytest.fixture\nasync def running_server(postgres_url, redis_url, make_api_key, truncate_tables):\n    \"\"\"Launch the real app under uvicorn, out-of-process, against the live\n    containers.\n\n    Needed specifically for the streaming-not-buffered sanity check:\n    httpx's in-process `ASGITransport` joins the *entire* response body into\n    one chunk before yielding it (`ASGIResponseStream.__aiter__` does\n    `yield b\"\".join(self._body)`), which would make a chunk-count assertion\n    pass or fail independent of whether the app actually streams — only a\n    real socket exposes genuine chunk boundaries.\n    \"\"\"\n    port = _free_port()\n    import os\n\n    env = dict(os.environ)\n    env[\"DATABASE_URL\"] = postgres_url\n    env[\"METERLY_REDIS_URL\"] = redis_url\n    env[\"METERLY_TIER1_RATE_LIMIT_PER_SECOND\"] = \"100000\"\n    env[\"METERLY_TIER1_RATE_LIMIT_BURST\"] = \"100000\"\n\n    presented_key, api_key_id = await make_api_key(rate_limit_per_sec=100000)\n\n    process = subprocess.Popen(\n        [sys.executable, \"-m\", \"uvicorn\", \"src.main:app\", \"--host\", \"127.0.0.1\", \"--port\", str(port)],\n        cwd=str(_REPO_ROOT),\n        env=env,\n        stdout=subprocess.PIPE,\n        stderr=subprocess.STDOUT,\n        text=True,\n    )\n    base_url = f\"http://127.0.0.1:{port}\"\n\n    try:\n        deadline = time.monotonic() + 20\n        async with httpx.AsyncClient() as probe:\n            while time.monotonic() < deadline:\n                try:\n                    response = await probe.get(f\"{base_url}/health\", timeout=1.0)\n                    if response.status_code == 200:\n                        break\n                except httpx.TransportError:\n                    pass\n                await asyncio.sleep(0.3)\n            else:\n                pytest.skip(\"uvicorn did not become ready in time in this sandboxed environment\")\n\n        yield base_url, presented_key, api_key_id\n    finally:\n        process.terminate()\n        try:\n            process.wait(timeout=5)\n        except subprocess.TimeoutExpired:\n            process.kill()\n\n\nasync def test_export_streaming_delivers_multiple_discrete_chunks(running_server, postgres_url):\n    \"\"\"AC9: the response is streamed (multiple discrete chunks arrive over\n    the real socket, not one fully-buffered write) for a multi-row export.\"\"\"\n    base_url, presented_key, api_key_id = running_server\n    window_start = datetime.now(timezone.utc).replace(minute=0, second=0, microsecond=0)\n    # Large enough that a real streamed write can't coalesce into a single\n    # TCP read on the client side (small payloads often do, even when the\n    # server genuinely writes them incrementally).\n    await _bulk_insert_rollups(\n        postgres_url, api_key_id=api_key_id, metric=\"api_calls\", window_start=window_start, count=20_000\n    )\n\n    chunk_count = 0\n    async with httpx.AsyncClient(timeout=30.0) as http_client:\n        async with http_client.stream(\n            \"GET\", f\"{base_url}/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n        ) as response:\n            assert response.status_code == 200\n            async for _chunk in response.aiter_bytes():\n                chunk_count += 1\n\n    # Proof the response isn't assembled into one buffered blob before being\n    # sent — a genuinely streamed multi-row export arrives as more than one\n    # discrete read on the wire.\n    assert chunk_count > 1\n\n\nasync def test_openapi_schema_exposes_the_export_route_and_responses(client):\n    \"\"\"AC19 (DAST-1): the served /openapi.json includes GET /v1/usage/export\n    with its 200 text/csv and 422 responses, matching the implemented route.\"\"\"\n    response = await client.get(\"/openapi.json\")\n\n    assert response.status_code == 200\n    schema = response.json()\n    assert \"/v1/usage/export\" in schema[\"paths\"]\n    export_operation = schema[\"paths\"][\"/v1/usage/export\"][\"get\"]\n    assert \"200\" in export_operation[\"responses\"]\n    assert \"422\" in export_operation[\"responses\"]\n    assert \"text/csv\" in export_operation[\"responses\"][\"200\"][\"content\"]\n\n\nasync def test_export_seeded_dast_key_can_call_the_export(postgres_url, truncate_tables):\n    \"\"\"AC20 (DAST-2): a key provisioned by the real `scripts/seed_api_key.py`\n    (not the fast `make_api_key` test fixture) can successfully call\n    `GET /v1/usage/export` and get a 200 header-only CSV. The pre-existing\n    `tests/integration/test_seed_api_key_script.py` proves the script\n    persists a working key row, but never actually calls an endpoint with the\n    key it prints — this closes that gap for the export route specifically,\n    which is what AC20 requires ('can call the export').\"\"\"\n    import os\n\n    from src.main import app\n\n    env = dict(os.environ)\n    env[\"DATABASE_URL\"] = postgres_url\n\n    result = subprocess.run(\n        [sys.executable, \"scripts/seed_api_key.py\", \"--label\", \"dast-export-key\", \"--rate-limit\", \"50\"],\n        cwd=str(_REPO_ROOT),\n        env=env,\n        capture_output=True,\n        text=True,\n    )\n    assert result.returncode == 0, f\"seed script failed:\\n{result.stdout}\\n{result.stderr}\"\n    presented_key = result.stdout.strip().splitlines()[-1]\n    assert presented_key.startswith(\"mtr_live_\")\n\n    transport = ASGITransport(app=app)\n    async with AsyncClient(transport=transport, base_url=\"http://test\") as seeded_client:\n        response = await seeded_client.get(\n            \"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n        )\n\n    assert response.status_code == 200\n    assert response.text == \"customer_id,metric,window_start,total_quantity\\r\\n\"\n\n\nasync def test_export_forced_pre_flight_count_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n    \"\"\"AC22: a forced error during the pre-flight COUNT phase (before any\n    response byte) returns the generic 500 internal envelope — no\n    stack/SQL/internal-path leak, and no partial CSV body.\"\"\"\n    from src.main import app\n    from src.services import usage_export_service\n\n    async def _raising_count(session, **kwargs):\n        raise RuntimeError(\"simulated connection drop mid-count\")\n\n    monkeypatch.setattr(usage_export_service, \"count_usage_rollups\", _raising_count)\n\n    presented_key, _ = await make_api_key()\n\n    # ASGITransport re-raises app exceptions by default (useful for debugging\n    # a broken test); here we're deliberately exercising the app's own 500\n    # handler, so this client must let it convert the exception to a response\n    # (mirrors tests/integration/test_events_endpoint.py's AC19 pattern).\n    transport = ASGITransport(app=app, raise_app_exceptions=False)\n    async with AsyncClient(transport=transport, base_url=\"http://test\") as client:\n        response = await client.get(\"/v1/usage/export\", headers={\"Authorization\": f\"Bearer {presented_key}\"})\n\n    assert response.status_code == 500\n    assert response.headers[\"content-type\"].startswith(\"application/json\")  # not text/csv\n    body = response.json()\n    assert body[\"error\"][\"code\"] == \"internal\"\n    assert \"requestId\" in body[\"error\"]\n    assert \"simulated connection drop\" not in response.text\n    assert \"Traceback\" not in response.text\n    assert not response.text.startswith(\"customer_id,metric,window_start,total_quantity\")  # no CSV body ever started\n","numLines":497,"startLine":1,"totalLines":497}},"sourceToolAssistantUUID":"44910a48-b485-480e-a55b-0d6236e44ecb","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
