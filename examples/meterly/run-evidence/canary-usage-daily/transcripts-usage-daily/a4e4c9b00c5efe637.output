{"parentUuid":"05c8f71e-cff8-4a3e-8bbf-f033310cc87e","isSidechain":true,"agentId":"a4e4c9b00c5efe637","message":{"model":"claude-opus-4-8","id":"msg_011Ccvte9C16QmZ3paEnYgHy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011dfDA28g3MzGDLCbbMrMxd","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7532,"cache_read_input_tokens":44701,"cache_creation":{"ephemeral_5m_input_tokens":7532,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccvte6iRRoMBemuTFyuUn","attributionAgent":"planning","type":"assistant","uuid":"49b7103f-325f-4396-8d48-92bee978b523","timestamp":"2026-07-11T20:21:10.108Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"49b7103f-325f-4396-8d48-92bee978b523","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011dfDA28g3MzGDLCbbMrMxd","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage/export`.\n2\t\n3\tReuses the exact `customer_id`/`metric` anchored allowlists\n4\t`src/api/schemas/events.py` already enforces for the SQL sink these filters\n5\tshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\n6\tapplied here as an optional `[from, to]` range rather than a single\n7\tpoint-in-time window.\n8\t\"\"\"\n9\t\n10\tfrom datetime import datetime, timedelta, timezone\n11\t\n12\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n13\t\n14\tfrom src.api.schemas.events import CustomerId, Metric\n15\t\n16\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n17\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n18\t\n19\t\n20\tclass UsageExportQueryParams(BaseModel):\n21\t    \"\"\"Optional filters for `GET /v1/usage/export`.\n22\t\n23\t    Every field is optional; omitting all of them exports the caller's full\n24\t    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n25\t    unknown query parameter — the same mass-assignment posture the write\n26\t    schemas use, applied to a read (a client-supplied `api_key_id` is\n27\t    rejected rather than silently ignored).\n28\t    \"\"\"\n29\t\n30\t    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n31\t\n32\t    customer_id: CustomerId | None = None\n33\t    metric: Metric | None = None\n34\t    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n35\t    to: AwareDatetime | None = None\n36\t\n37\t    @model_validator(mode=\"after\")\n38\t    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n39\t        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n40\t        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n41\t        so a caller can't probe arbitrarily far into the past (unbounded\n42\t        query cost) or the future.\"\"\"\n43\t        now = datetime.now(timezone.utc)\n44\t        earliest = now - _MAX_WINDOW_LOOKBACK\n45\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n46\t\n47\t        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n48\t            if value is not None and not (earliest <= value <= latest):\n49\t                raise ValueError(\n50\t                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n51\t                )\n52\t\n53\t        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n54\t            raise ValueError(\"from must be <= to\")\n55\t\n56\t        return self\n57\t"}]},"uuid":"70f592d5-f7aa-446c-b645-b6e345aafdb6","timestamp":"2026-07-11T20:21:10.172Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage_export.py","content":"\"\"\"Validation contract for `GET /v1/usage/export`.\n\nReuses the exact `customer_id`/`metric` anchored allowlists\n`src/api/schemas/events.py` already enforces for the SQL sink these filters\nshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\napplied here as an optional `[from, to]` range rather than a single\npoint-in-time window.\n\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\n\nfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n\nfrom src.api.schemas.events import CustomerId, Metric\n\n_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n\n\nclass UsageExportQueryParams(BaseModel):\n    \"\"\"Optional filters for `GET /v1/usage/export`.\n\n    Every field is optional; omitting all of them exports the caller's full\n    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n    unknown query parameter — the same mass-assignment posture the write\n    schemas use, applied to a read (a client-supplied `api_key_id` is\n    rejected rather than silently ignored).\n    \"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n\n    customer_id: CustomerId | None = None\n    metric: Metric | None = None\n    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n    to: AwareDatetime | None = None\n\n    @model_validator(mode=\"after\")\n    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n        so a caller can't probe arbitrarily far into the past (unbounded\n        query cost) or the future.\"\"\"\n        now = datetime.now(timezone.utc)\n        earliest = now - _MAX_WINDOW_LOOKBACK\n        latest = now + _MAX_WINDOW_LOOKAHEAD\n\n        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n            if value is not None and not (earliest <= value <= latest):\n                raise ValueError(\n                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n                )\n\n        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n            raise ValueError(\"from must be <= to\")\n\n        return self\n","numLines":57,"startLine":1,"totalLines":57}},"sourceToolAssistantUUID":"49b7103f-325f-4396-8d48-92bee978b523","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"70f592d5-f7aa-446c-b645-b6e345aafdb6","isSidechain":true,"agentId":"a4e4c9b00c5efe637","message":{"model":"claude-opus-4-8","id":"msg_011Ccvte9C16QmZ3paEnYgHy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01QisADPiU4goHDpTMSJ13Hw","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7532,"cache_read_input_tokens":44701,"cache_creation":{"ephemeral_5m_input_tokens":7532,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccvte6iRRoMBemuTFyuUn","attributionAgent":"planning","type":"assistant","uuid":"fc6b09c6-78f3-4ca3-9182-7946b40335d0","timestamp":"2026-07-11T20:21:10.516Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"fc6b09c6-78f3-4ca3-9182-7946b40335d0","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QisADPiU4goHDpTMSJ13Hw","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t# How many encoded data rows to accumulate in the buffer before handing one\n35\t# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n36\t# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n37\t# every streamed chunk through its own anyio memory-object-stream — ran once\n38\t# per row (100,000× at the cap), which dominated the export's wall-clock time\n39\t# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n40\t# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n41\t# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n42\t_ROWS_PER_CHUNK = 1000\n43\t\n44\t\n45\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n46\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n47\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n48\t\n49\t    This must run and fully resolve *before* the route returns a\n50\t    `StreamingResponse` — once that response object exists the status line\n51\t    is already 200 and bytes may already be on the wire, so a 422 can no\n52\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n53\t    (a DB connection drop, a query error) is deliberately left to propagate\n54\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n55\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n56\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n57\t    \"\"\"\n58\t    async with scoped_transaction(principal.api_key_id) as session:\n59\t        row_count = await count_usage_rollups(\n60\t            session,\n61\t            api_key_id=principal.api_key_id,\n62\t            customer_id=params.customer_id,\n63\t            metric=params.metric,\n64\t            window_from=params.from_,\n65\t            window_to=params.to,\n66\t        )\n67\t\n68\t    if row_count > MAX_EXPORT_ROWS:\n69\t        logger.warning(\n70\t            \"usage.export.rejected\",\n71\t            userId=principal.api_key_id,\n72\t            action=\"deny\",\n73\t            reason=\"row_cap_exceeded\",\n74\t        )\n75\t        raise HTTPException(\n76\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n77\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n78\t        )\n79\t\n80\t\n81\tdef _drain(buffer: io.StringIO) -> bytes:\n82\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n83\t    place — this is what keeps the generator at constant memory: it never\n84\t    holds more than one row's encoded text at a time.\"\"\"\n85\t    data = buffer.getvalue().encode(\"utf-8\")\n86\t    buffer.seek(0)\n87\t    buffer.truncate(0)\n88\t    return data\n89\t\n90\t\n91\tasync def stream_export_csv(\n92\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n93\t) -> AsyncIterator[bytes]:\n94\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n95\t    CSV-encoded row per streamed `usage_rollup` record.\n96\t\n97\t    Yielding the header before touching the database means an empty result\n98\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n99\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n100\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n101\t    setting and the server-side cursor both stay valid for the whole stream.\n102\t    \"\"\"\n103\t    row_count = 0\n104\t    capped = False\n105\t    completed = False\n106\t\n107\t    buffer = io.StringIO()\n108\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n109\t\n110\t    try:\n111\t        # Header first, always, as its own chunk — so an empty result is a\n112\t        # 200 header-only CSV (AC12) and the first bytes are observable before\n113\t        # the data rows stream (AC9), independent of the data-row batching below.\n114\t        writer.writerow(EXPORT_HEADER)\n115\t        yield _drain(buffer)\n116\t\n117\t        async with scoped_transaction(principal.api_key_id) as session:\n118\t            async for record in stream_usage_rollups(\n119\t                session,\n120\t                api_key_id=principal.api_key_id,\n121\t                customer_id=params.customer_id,\n122\t                metric=params.metric,\n123\t                window_from=params.from_,\n124\t                window_to=params.to,\n125\t                limit=MAX_EXPORT_ROWS,\n126\t            ):\n127\t                writer.writerow(\n128\t                    [\n129\t                        escape_csv_text_cell(record.customer_id),\n130\t                        escape_csv_text_cell(record.metric),\n131\t                        format_window_start(record.window_start),\n132\t                        format_total_quantity(record.total_quantity),\n133\t                    ]\n134\t                )\n135\t                row_count += 1\n136\t                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n137\t                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n138\t                # cap this yields ~100 chunks, never one buffered blob.\n139\t                if row_count % _ROWS_PER_CHUNK == 0:\n140\t                    yield _drain(buffer)\n141\t\n142\t        # Flush the trailing partial batch. For an empty result nothing is\n143\t        # buffered here (the header already went out above), so no stray chunk.\n144\t        if buffer.tell():\n145\t            yield _drain(buffer)\n146\t\n147\t        capped = row_count >= MAX_EXPORT_ROWS\n148\t        completed = True\n149\t    finally:\n150\t        # In `finally` so a client disconnect or a mid-stream DB error still\n151\t        # records what was actually sent (`completed=False` in that case) —\n152\t        # exactly one usage.export event per request either way (AC17).\n153\t        logger.info(\n154\t            \"usage.export\",\n155\t            userId=principal.api_key_id,\n156\t            action=\"read\",\n157\t            resource=\"usage_rollup\",\n158\t            rowCount=row_count,\n159\t            capped=capped,\n160\t            completed=completed,\n161\t            filtered_by_customer=params.customer_id is not None,\n162\t            filtered_by_metric=params.metric is not None,\n163\t            bounded_from=params.from_ is not None,\n164\t            bounded_to=params.to is not None,\n165\t        )\n166\t"}]},"uuid":"bef67c2c-cbcb-433b-8282-6d68fd74a7dd","timestamp":"2026-07-11T20:21:10.588Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_export_service.py","content":"\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\nconstant-memory CSV streaming generator.\n\nTwo-phase by design: `prepare_export` runs to completion (and can still\ncleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\nis the response body, pulled by Starlette only after the handler returns, so\nit opens its own transaction rather than reusing one the handler already closed.\n\"\"\"\n\nimport csv\nimport io\nfrom collections.abc import AsyncIterator\n\nfrom fastapi import HTTPException, status\n\nfrom src.api.csv_export import (\n    EXPORT_HEADER,\n    escape_csv_text_cell,\n    format_total_quantity,\n    format_window_start,\n)\nfrom src.api.schemas.usage_export import UsageExportQueryParams\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.db.session import scoped_transaction\nfrom src.logging import get_logger\nfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n\nlogger = get_logger(service=\"meterly\")\n\nMAX_EXPORT_ROWS = 100_000\nEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n\n# How many encoded data rows to accumulate in the buffer before handing one\n# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n# every streamed chunk through its own anyio memory-object-stream — ran once\n# per row (100,000× at the cap), which dominated the export's wall-clock time\n# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n_ROWS_PER_CHUNK = 1000\n\n\nasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n\n    This must run and fully resolve *before* the route returns a\n    `StreamingResponse` — once that response object exists the status line\n    is already 200 and bytes may already be on the wire, so a 422 can no\n    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n    (a DB connection drop, a query error) is deliberately left to propagate\n    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n    handler): fail-closed generic `500 internal`, the pre-flight transaction\n    rolled back, and no `StreamingResponse` ever constructed (AC22).\n    \"\"\"\n    async with scoped_transaction(principal.api_key_id) as session:\n        row_count = await count_usage_rollups(\n            session,\n            api_key_id=principal.api_key_id,\n            customer_id=params.customer_id,\n            metric=params.metric,\n            window_from=params.from_,\n            window_to=params.to,\n        )\n\n    if row_count > MAX_EXPORT_ROWS:\n        logger.warning(\n            \"usage.export.rejected\",\n            userId=principal.api_key_id,\n            action=\"deny\",\n            reason=\"row_cap_exceeded\",\n        )\n        raise HTTPException(\n            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n        )\n\n\ndef _drain(buffer: io.StringIO) -> bytes:\n    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n    place — this is what keeps the generator at constant memory: it never\n    holds more than one row's encoded text at a time.\"\"\"\n    data = buffer.getvalue().encode(\"utf-8\")\n    buffer.seek(0)\n    buffer.truncate(0)\n    return data\n\n\nasync def stream_export_csv(\n    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n) -> AsyncIterator[bytes]:\n    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n    CSV-encoded row per streamed `usage_rollup` record.\n\n    Yielding the header before touching the database means an empty result\n    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n    setting and the server-side cursor both stay valid for the whole stream.\n    \"\"\"\n    row_count = 0\n    capped = False\n    completed = False\n\n    buffer = io.StringIO()\n    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n\n    try:\n        # Header first, always, as its own chunk — so an empty result is a\n        # 200 header-only CSV (AC12) and the first bytes are observable before\n        # the data rows stream (AC9), independent of the data-row batching below.\n        writer.writerow(EXPORT_HEADER)\n        yield _drain(buffer)\n\n        async with scoped_transaction(principal.api_key_id) as session:\n            async for record in stream_usage_rollups(\n                session,\n                api_key_id=principal.api_key_id,\n                customer_id=params.customer_id,\n                metric=params.metric,\n                window_from=params.from_,\n                window_to=params.to,\n                limit=MAX_EXPORT_ROWS,\n            ):\n                writer.writerow(\n                    [\n                        escape_csv_text_cell(record.customer_id),\n                        escape_csv_text_cell(record.metric),\n                        format_window_start(record.window_start),\n                        format_total_quantity(record.total_quantity),\n                    ]\n                )\n                row_count += 1\n                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n                # cap this yields ~100 chunks, never one buffered blob.\n                if row_count % _ROWS_PER_CHUNK == 0:\n                    yield _drain(buffer)\n\n        # Flush the trailing partial batch. For an empty result nothing is\n        # buffered here (the header already went out above), so no stray chunk.\n        if buffer.tell():\n            yield _drain(buffer)\n\n        capped = row_count >= MAX_EXPORT_ROWS\n        completed = True\n    finally:\n        # In `finally` so a client disconnect or a mid-stream DB error still\n        # records what was actually sent (`completed=False` in that case) —\n        # exactly one usage.export event per request either way (AC17).\n        logger.info(\n            \"usage.export\",\n            userId=principal.api_key_id,\n            action=\"read\",\n            resource=\"usage_rollup\",\n            rowCount=row_count,\n            capped=capped,\n            completed=completed,\n            filtered_by_customer=params.customer_id is not None,\n            filtered_by_metric=params.metric is not None,\n            bounded_from=params.from_ is not None,\n            bounded_to=params.to is not None,\n        )\n","numLines":166,"startLine":1,"totalLines":166}},"sourceToolAssistantUUID":"fc6b09c6-78f3-4ca3-9182-7946b40335d0","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"bef67c2c-cbcb-433b-8282-6d68fd74a7dd","isSidechain":true,"agentId":"a4e4c9b00c5efe637","message":{"model":"claude-opus-4-8","id":"msg_011Ccvte9C16QmZ3paEnYgHy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_0195j9m5ZgY7ozyvmY7neK4x","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7532,"cache_read_input_tokens":44701,"cache_creation":{"ephemeral_5m_input_tokens":7532,"ephemeral_1h_input_tokens":0},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011Ccvte6iRRoMBemuTFyuUn","attributionAgent":"planning","type":"assistant","uuid":"9e872385-f554-48aa-a2d4-ce25a16616e8","timestamp":"2026-07-11T20:21:11.531Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"9e872385-f554-48aa-a2d4-ce25a16616e8","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0195j9m5ZgY7ozyvmY7neK4x","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"40a283a3-f966-4fa3-86ea-92bddb0ae8bc","timestamp":"2026-07-11T20:21:11.583Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/errors.py","content":"\"\"\"The error-envelope facade — every exception a handler raises terminates\nhere, at one centralized boundary, as the single response shape:\n`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n\nNever leaks a stack trace, exception type, SQL, or internal path to the\nclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\ngets a generic, stable `code` plus the `requestId` that ties a user report\nback to the server log line.\n\"\"\"\n\nfrom fastapi import FastAPI, HTTPException, Request, status\nfrom fastapi.exceptions import RequestValidationError\nfrom fastapi.responses import JSONResponse\nfrom starlette.exceptions import HTTPException as StarletteHTTPException\n\nfrom src.logging import get_logger\n\nlogger = get_logger(service=\"meterly\")\n\n_STATUS_TO_CODE = {\n    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n    status.HTTP_403_FORBIDDEN: \"forbidden\",\n    status.HTTP_404_NOT_FOUND: \"not_found\",\n    status.HTTP_409_CONFLICT: \"conflict\",\n    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n}\n\n\ndef _request_id(request: Request) -> str:\n    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n    return getattr(request.state, \"request_id\", \"unknown\")\n\n\ndef _envelope(code: str, message: str, request_id: str) -> dict:\n    \"\"\"Build the one response shape every error returns.\"\"\"\n    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n\n\nclass AppError(HTTPException):\n    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n    rejection needs its own, distinct `quota_exceeded` code on the same\n    status. `handle_http_exception` prefers `app_code` over the status map\n    when present, so this is the minimal single-boundary extension rather\n    than reshaping the map itself.\n    \"\"\"\n\n    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n        super().__init__(status_code=status_code, detail=detail, headers=headers)\n        self.app_code = app_code\n\n\ndef register_error_handlers(app: FastAPI) -> None:\n    \"\"\"Register the centralized exception handlers on `app`.\n\n    Called once from `src/main.py` at app construction — no route ever builds\n    its own error response; it raises and lets this boundary map it.\n    \"\"\"\n\n    @app.exception_handler(RequestValidationError)\n    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n        request_id = _request_id(request)\n        logger.warning(\n            \"validation.failed\",\n            requestId=request_id,\n            endpoint=request.url.path,\n            errorCount=len(exc.errors()),\n        )\n        return JSONResponse(\n            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n        )\n\n    @app.exception_handler(StarletteHTTPException)\n    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n\n        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n        map — this is what lets two different exceptions share one HTTP status\n        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n        \"\"\"\n        request_id = _request_id(request)\n        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n        return JSONResponse(\n            status_code=exc.status_code,\n            content=_envelope(code, message, request_id),\n            headers=getattr(exc, \"headers\", None) or {},\n        )\n\n    @app.exception_handler(Exception)\n    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n\n        This is the fail-closed boundary — an unhandled exception mid-write\n        never leaks stack/SQL/secret detail, and because the events + rollup\n        write happens in one transaction (`src/services/events_service.py`),\n        an exception here means that transaction was rolled back, not\n        partially applied.\n        \"\"\"\n        request_id = _request_id(request)\n        logger.error(\n            \"request.unhandled_error\",\n            requestId=request_id,\n            endpoint=request.url.path,\n            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n            exc_info=True,\n        )\n        return JSONResponse(\n            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n        )\n\n\n__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n","numLines":121,"startLine":1,"totalLines":121}},"sourceToolAssistantUUID":"9e872385-f554-48aa-a2d4-ce25a16616e8","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"40a283a3-f966-4fa3-86ea-92bddb0ae8bc","isSidechain":true,"agentId":"a4e4c9b00c5efe637","message":{"model":"claude-opus-4-8","id":"msg_011Ccvte9C16QmZ3paEnYgHy","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01C3Dry1NRhRM8MZDpWvEMDC","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/auth/rate_limit.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":7532,"cache_read_input_tokens":44701,"output_tokens":2228,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":7532},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":2228,"cache_read_input_tokens":44701,"cache_creation_input_tokens":7532,"cache_creation":{"ephemeral_5m_input_tokens":7532,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccvte6iRRoMBemuTFyuUn","attributionAgent":"planning","type":"assistant","uuid":"f090ec9a-1e9a-457e-8cad-c1ec371b2b09","timestamp":"2026-07-11T20:21:11.845Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"f090ec9a-1e9a-457e-8cad-c1ec371b2b09","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C3Dry1NRhRM8MZDpWvEMDC","type":"tool_result","content":"1\t\"\"\"Redis-backed token-bucket rate limiting — Tier 1 (pre-auth, IP+route) and\n2\tTier 2 (post-auth, per-`api_key_id`).\n3\t\n4\tState lives in Redis, never in-process: an in-process counter is per-task and\n5\tfails open behind the ALB once there is more than one Fargate task\n6\t(`api-edge-conventions`). The bucket check-and-decrement is a single atomic\n7\tLua script so concurrent requests against the same bucket can't race past the\n8\tlimit (the same TOCTOU concern the events idempotency mechanism addresses,\n9\tapplied to a counter instead of a unique constraint).\n10\t\"\"\"\n11\t\n12\tfrom dataclasses import dataclass\n13\t\n14\timport redis.asyncio as redis\n15\t\n16\tfrom src.config.settings import get_settings\n17\tfrom src.logging import get_logger\n18\t\n19\t# Atomic token-bucket refill + consume: KEYS[1] = bucket key.\n20\t# ARGV: capacity, refill_rate_per_second, now_ms, cost.\n21\t# Returns {allowed (0/1), tokens_remaining, retry_after_ms}.\n22\t_TOKEN_BUCKET_LUA = \"\"\"\n23\tlocal key = KEYS[1]\n24\tlocal capacity = tonumber(ARGV[1])\n25\tlocal refill_rate = tonumber(ARGV[2])\n26\tlocal now_ms = tonumber(ARGV[3])\n27\tlocal cost = tonumber(ARGV[4])\n28\t\n29\tlocal bucket = redis.call('HMGET', key, 'tokens', 'updated_at')\n30\tlocal tokens = tonumber(bucket[1])\n31\tlocal updated_at = tonumber(bucket[2])\n32\t\n33\tif tokens == nil then\n34\t  tokens = capacity\n35\t  updated_at = now_ms\n36\tend\n37\t\n38\tlocal elapsed_seconds = math.max(0, (now_ms - updated_at) / 1000)\n39\ttokens = math.min(capacity, tokens + elapsed_seconds * refill_rate)\n40\t\n41\tlocal allowed = 0\n42\tlocal retry_after_ms = 0\n43\tif tokens >= cost then\n44\t  tokens = tokens - cost\n45\t  allowed = 1\n46\telse\n47\t  local deficit = cost - tokens\n48\t  retry_after_ms = math.ceil((deficit / refill_rate) * 1000)\n49\tend\n50\t\n51\tredis.call('HMSET', key, 'tokens', tokens, 'updated_at', now_ms)\n52\tredis.call('PEXPIRE', key, 60000)\n53\t\n54\treturn {allowed, tostring(tokens), retry_after_ms}\n55\t\"\"\"\n56\t\n57\t\n58\t@dataclass(frozen=True)\n59\tclass RateLimitDecision:\n60\t    \"\"\"The outcome of a rate-limit check: whether the request is allowed and,\n61\t    if not, how long the caller should wait before retrying.\"\"\"\n62\t\n63\t    allowed: bool\n64\t    retry_after_seconds: float\n65\t\n66\t\n67\tclass RedisTokenBucketLimiter:\n68\t    \"\"\"A shared, atomic Redis token-bucket limiter used by both throttle tiers.\n69\t\n70\t    Each tier instantiates this with its own key prefix and capacity/refill\n71\t    policy; the Lua script guarantees the check-then-decrement is race-free\n72\t    across concurrently arriving requests and across Fargate tasks.\n73\t    \"\"\"\n74\t\n75\t    def __init__(self, redis_client: redis.Redis, *, key_prefix: str) -> None:\n76\t        self._redis = redis_client\n77\t        self._key_prefix = key_prefix\n78\t        self._script = self._redis.register_script(_TOKEN_BUCKET_LUA)\n79\t\n80\t    async def check(\n81\t        self, bucket_identity: str, *, capacity: int, refill_rate_per_second: float, cost: float = 1.0\n82\t    ) -> RateLimitDecision:\n83\t        \"\"\"Consume `cost` tokens from `bucket_identity`'s bucket; returns the decision.\"\"\"\n84\t        import time\n85\t\n86\t        now_ms = int(time.time() * 1000)\n87\t        allowed, _tokens_remaining, retry_after_ms = await self._script(\n88\t            keys=[f\"{self._key_prefix}:{bucket_identity}\"],\n89\t            args=[capacity, refill_rate_per_second, now_ms, cost],\n90\t        )\n91\t        return RateLimitDecision(\n92\t            allowed=bool(int(allowed)), retry_after_seconds=round(int(retry_after_ms) / 1000, 3)\n93\t        )\n94\t\n95\t\n96\t_redis_client: redis.Redis | None = None\n97\t_tier1_limiter: RedisTokenBucketLimiter | None = None\n98\t_tier2_limiter: RedisTokenBucketLimiter | None = None\n99\t\n100\t\n101\tdef get_redis_client() -> redis.Redis:\n102\t    \"\"\"Return the process-wide async Redis client, creating it on first use\n103\t    (deferred, like the DB engine, so import stays dependency-free).\"\"\"\n104\t    global _redis_client\n105\t    if _redis_client is None:\n106\t        _redis_client = redis.from_url(get_settings().redis_url, decode_responses=True)\n107\t    return _redis_client\n108\t\n109\t\n110\tdef get_tier1_limiter() -> RedisTokenBucketLimiter:\n111\t    \"\"\"Return the Tier-1 (pre-auth, IP+route-keyed) limiter singleton.\"\"\"\n112\t    global _tier1_limiter\n113\t    if _tier1_limiter is None:\n114\t        _tier1_limiter = RedisTokenBucketLimiter(get_redis_client(), key_prefix=\"ratelimit:tier1\")\n115\t    return _tier1_limiter\n116\t\n117\t\n118\tdef get_tier2_limiter() -> RedisTokenBucketLimiter:\n119\t    \"\"\"Return the Tier-2 (post-auth, `api_key_id`-keyed) limiter singleton.\"\"\"\n120\t    global _tier2_limiter\n121\t    if _tier2_limiter is None:\n122\t        _tier2_limiter = RedisTokenBucketLimiter(get_redis_client(), key_prefix=\"ratelimit:tier2\")\n123\t    return _tier2_limiter\n124\t\n125\t\n126\tasync def dispose_redis_client() -> None:\n127\t    \"\"\"Close the Redis client (called from lifespan shutdown).\"\"\"\n128\t    global _redis_client, _tier1_limiter, _tier2_limiter\n129\t    if _redis_client is not None:\n130\t        await _redis_client.aclose()\n131\t    _redis_client = None\n132\t    _tier1_limiter = None\n133\t    _tier2_limiter = None\n134\t\n135\t\n136\tasync def enforce_tier2_rate_limit(request: \"Request\", principal: \"AuthenticatedPrincipal\") -> None:\n137\t    \"\"\"Tier-2 dependency: enforce the caller's per-`api_key_id` token bucket.\n138\t\n139\t    Registered on a dependency that runs strictly **after** `require_api_key`\n140\t    (both endpoint routes depend on this ordering), so the bucket key is\n141\t    always the authenticated principal, never the client IP — this is the\n142\t    property the two-principals-one-IP test verifies (AC14/AC16).\n143\t\n144\t    Fails **open** (logs a warning, allows the request) on a Redis connection\n145\t    error — a cache outage degrading every authenticated call to \"temporarily\n146\t    unlimited\" is preferable to a full ingest outage; the durable UNIQUE-\n147\t    constraint/transaction guarantees are unaffected either way.\n148\t    \"\"\"\n149\t    from fastapi import HTTPException, status\n150\t\n151\t    try:\n152\t        decision = await get_tier2_limiter().check(\n153\t            str(principal.api_key_id),\n154\t            capacity=principal.rate_limit_per_sec,\n155\t            refill_rate_per_second=principal.rate_limit_per_sec,\n156\t        )\n157\t    except Exception:  # noqa: BLE001 - a Redis outage must not take down the whole API\n158\t        get_logger(service=\"meterly\").warning(\n159\t            \"ratelimit.backend_unavailable\", endpoint=request.url.path, tier=\"tier2\"\n160\t        )\n161\t        return\n162\t\n163\t    if not decision.allowed:\n164\t        get_logger(service=\"meterly\").warning(\n165\t            \"ratelimit.exceeded\",\n166\t            userId=principal.api_key_id,\n167\t            action=\"deny\",\n168\t            endpoint=request.url.path,\n169\t            reason=\"tier2_bucket_exhausted\",\n170\t        )\n171\t        raise HTTPException(\n172\t            status_code=status.HTTP_429_TOO_MANY_REQUESTS,\n173\t            detail=\"rate limit exceeded\",\n174\t            headers={\"Retry-After\": str(max(1, int(decision.retry_after_seconds) or 1))},\n175\t        )\n176\t"}]},"uuid":"fb9aaa67-759e-40fe-95b1-e0081b4a96fe","timestamp":"2026-07-11T20:21:11.888Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/auth/rate_limit.py","content":"\"\"\"Redis-backed token-bucket rate limiting — Tier 1 (pre-auth, IP+route) and\nTier 2 (post-auth, per-`api_key_id`).\n\nState lives in Redis, never in-process: an in-process counter is per-task and\nfails open behind the ALB once there is more than one Fargate task\n(`api-edge-conventions`). The bucket check-and-decrement is a single atomic\nLua script so concurrent requests against the same bucket can't race past the\nlimit (the same TOCTOU concern the events idempotency mechanism addresses,\napplied to a counter instead of a unique constraint).\n\"\"\"\n\nfrom dataclasses import dataclass\n\nimport redis.asyncio as redis\n\nfrom src.config.settings import get_settings\nfrom src.logging import get_logger\n\n# Atomic token-bucket refill + consume: KEYS[1] = bucket key.\n# ARGV: capacity, refill_rate_per_second, now_ms, cost.\n# Returns {allowed (0/1), tokens_remaining, retry_after_ms}.\n_TOKEN_BUCKET_LUA = \"\"\"\nlocal key = KEYS[1]\nlocal capacity = tonumber(ARGV[1])\nlocal refill_rate = tonumber(ARGV[2])\nlocal now_ms = tonumber(ARGV[3])\nlocal cost = tonumber(ARGV[4])\n\nlocal bucket = redis.call('HMGET', key, 'tokens', 'updated_at')\nlocal tokens = tonumber(bucket[1])\nlocal updated_at = tonumber(bucket[2])\n\nif tokens == nil then\n  tokens = capacity\n  updated_at = now_ms\nend\n\nlocal elapsed_seconds = math.max(0, (now_ms - updated_at) / 1000)\ntokens = math.min(capacity, tokens + elapsed_seconds * refill_rate)\n\nlocal allowed = 0\nlocal retry_after_ms = 0\nif tokens >= cost then\n  tokens = tokens - cost\n  allowed = 1\nelse\n  local deficit = cost - tokens\n  retry_after_ms = math.ceil((deficit / refill_rate) * 1000)\nend\n\nredis.call('HMSET', key, 'tokens', tokens, 'updated_at', now_ms)\nredis.call('PEXPIRE', key, 60000)\n\nreturn {allowed, tostring(tokens), retry_after_ms}\n\"\"\"\n\n\n@dataclass(frozen=True)\nclass RateLimitDecision:\n    \"\"\"The outcome of a rate-limit check: whether the request is allowed and,\n    if not, how long the caller should wait before retrying.\"\"\"\n\n    allowed: bool\n    retry_after_seconds: float\n\n\nclass RedisTokenBucketLimiter:\n    \"\"\"A shared, atomic Redis token-bucket limiter used by both throttle tiers.\n\n    Each tier instantiates this with its own key prefix and capacity/refill\n    policy; the Lua script guarantees the check-then-decrement is race-free\n    across concurrently arriving requests and across Fargate tasks.\n    \"\"\"\n\n    def __init__(self, redis_client: redis.Redis, *, key_prefix: str) -> None:\n        self._redis = redis_client\n        self._key_prefix = key_prefix\n        self._script = self._redis.register_script(_TOKEN_BUCKET_LUA)\n\n    async def check(\n        self, bucket_identity: str, *, capacity: int, refill_rate_per_second: float, cost: float = 1.0\n    ) -> RateLimitDecision:\n        \"\"\"Consume `cost` tokens from `bucket_identity`'s bucket; returns the decision.\"\"\"\n        import time\n\n        now_ms = int(time.time() * 1000)\n        allowed, _tokens_remaining, retry_after_ms = await self._script(\n            keys=[f\"{self._key_prefix}:{bucket_identity}\"],\n            args=[capacity, refill_rate_per_second, now_ms, cost],\n        )\n        return RateLimitDecision(\n            allowed=bool(int(allowed)), retry_after_seconds=round(int(retry_after_ms) / 1000, 3)\n        )\n\n\n_redis_client: redis.Redis | None = None\n_tier1_limiter: RedisTokenBucketLimiter | None = None\n_tier2_limiter: RedisTokenBucketLimiter | None = None\n\n\ndef get_redis_client() -> redis.Redis:\n    \"\"\"Return the process-wide async Redis client, creating it on first use\n    (deferred, like the DB engine, so import stays dependency-free).\"\"\"\n    global _redis_client\n    if _redis_client is None:\n        _redis_client = redis.from_url(get_settings().redis_url, decode_responses=True)\n    return _redis_client\n\n\ndef get_tier1_limiter() -> RedisTokenBucketLimiter:\n    \"\"\"Return the Tier-1 (pre-auth, IP+route-keyed) limiter singleton.\"\"\"\n    global _tier1_limiter\n    if _tier1_limiter is None:\n        _tier1_limiter = RedisTokenBucketLimiter(get_redis_client(), key_prefix=\"ratelimit:tier1\")\n    return _tier1_limiter\n\n\ndef get_tier2_limiter() -> RedisTokenBucketLimiter:\n    \"\"\"Return the Tier-2 (post-auth, `api_key_id`-keyed) limiter singleton.\"\"\"\n    global _tier2_limiter\n    if _tier2_limiter is None:\n        _tier2_limiter = RedisTokenBucketLimiter(get_redis_client(), key_prefix=\"ratelimit:tier2\")\n    return _tier2_limiter\n\n\nasync def dispose_redis_client() -> None:\n    \"\"\"Close the Redis client (called from lifespan shutdown).\"\"\"\n    global _redis_client, _tier1_limiter, _tier2_limiter\n    if _redis_client is not None:\n        await _redis_client.aclose()\n    _redis_client = None\n    _tier1_limiter = None\n    _tier2_limiter = None\n\n\nasync def enforce_tier2_rate_limit(request: \"Request\", principal: \"AuthenticatedPrincipal\") -> None:\n    \"\"\"Tier-2 dependency: enforce the caller's per-`api_key_id` token bucket.\n\n    Registered on a dependency that runs strictly **after** `require_api_key`\n    (both endpoint routes depend on this ordering), so the bucket key is\n    always the authenticated principal, never the client IP — this is the\n    property the two-principals-one-IP test verifies (AC14/AC16).\n\n    Fails **open** (logs a warning, allows the request) on a Redis connection\n    error — a cache outage degrading every authenticated call to \"temporarily\n    unlimited\" is preferable to a full ingest outage; the durable UNIQUE-\n    constraint/transaction guarantees are unaffected either way.\n    \"\"\"\n    from fastapi import HTTPException, status\n\n    try:\n        decision = await get_tier2_limiter().check(\n            str(principal.api_key_id),\n            capacity=principal.rate_limit_per_sec,\n            refill_rate_per_second=principal.rate_limit_per_sec,\n        )\n    except Exception:  # noqa: BLE001 - a Redis outage must not take down the whole API\n        get_logger(service=\"meterly\").warning(\n            \"ratelimit.backend_unavailable\", endpoint=request.url.path, tier=\"tier2\"\n        )\n        return\n\n    if not decision.allowed:\n        get_logger(service=\"meterly\").warning(\n            \"ratelimit.exceeded\",\n            userId=principal.api_key_id,\n            action=\"deny\",\n            endpoint=request.url.path,\n            reason=\"tier2_bucket_exhausted\",\n        )\n        raise HTTPException(\n            status_code=status.HTTP_429_TOO_MANY_REQUESTS,\n            detail=\"rate limit exceeded\",\n            headers={\"Retry-After\": str(max(1, int(decision.retry_after_seconds) or 1))},\n        )\n","numLines":176,"startLine":1,"totalLines":176}},"sourceToolAssistantUUID":"f090ec9a-1e9a-457e-8cad-c1ec371b2b09","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
