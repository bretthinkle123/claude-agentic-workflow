{"parentUuid":"94b3fa1a-96af-4a67-ab18-1d009490686a","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018R1BC4BdrJKQkuo2d6YBNA","type":"tool_result","content":"1\t\"\"\"`/v1/quotas` — admin-scoped create-or-replace (`PUT`), list (`GET`), and\n2\tremove (`DELETE`) of a per-customer, per-metric usage cap.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; every route on this router wires\n6\tauth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\n7\tmirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\n8\tpattern (kept per-route, not shared, per the existing convention). All three\n9\tverbs depend on the same `_require_admin_and_throttled` chain — GET/DELETE\n10\treuse it verbatim rather than introducing a new scope or auth path.\n11\t\"\"\"\n12\t\n13\tfrom typing import Annotated\n14\t\n15\tfrom fastapi import APIRouter, Depends, HTTPException, Query, Request, Response, status\n16\t\n17\tfrom src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\n18\tfrom src.auth import require_api_key\n19\tfrom src.auth.api_key import AuthenticatedPrincipal\n20\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n21\tfrom src.logging import get_logger\n22\tfrom src.services.quota_service import (\n23\t    delete_tenant_quota,\n24\t    list_tenant_quotas,\n25\t    to_response,\n26\t    upsert_tenant_quota,\n27\t)\n28\t\n29\trouter = APIRouter(tags=[\"quotas\"])\n30\tlogger = get_logger(service=\"meterly\")\n31\t\n32\t_ADMIN_SCOPE = \"admin\"\n33\t\n34\t\n35\tasync def _require_admin_and_throttled(\n36\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n37\t) -> AuthenticatedPrincipal:\n38\t    \"\"\"Compose auth, then the Tier-2 per-key throttle, then the admin-scope\n39\t    gate, in that order — mirrors `src/api/routes/events.py`'s dependency\n40\t    chain, extended with the function-level authorization check this route\n41\t    alone requires (ASVS 8.2.1).\n42\t    \"\"\"\n43\t    await enforce_tier2_rate_limit(request, principal)\n44\t    if principal.scope != _ADMIN_SCOPE:\n45\t        logger.warning(\n46\t            \"quota.forbidden\",\n47\t            userId=principal.api_key_id,\n48\t            action=\"deny\",\n49\t            reason=\"insufficient_scope\",\n50\t        )\n51\t        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"admin scope required\")\n52\t    return principal\n53\t\n54\t\n55\t@router.put(\"/v1/quotas\", response_model=QuotaResponse)\n56\tasync def put_quota(\n57\t    payload: QuotaPutRequest,\n58\t    response: Response,\n59\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n60\t) -> QuotaResponse:"}]},"uuid":"24839981-4bde-49fd-a6f4-0c1581612670","timestamp":"2026-07-11T20:28:08.142Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/quotas.py","content":"\"\"\"`/v1/quotas` — admin-scoped create-or-replace (`PUT`), list (`GET`), and\nremove (`DELETE`) of a per-customer, per-metric usage cap.\n\nEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\ninherited from the middleware stack; every route on this router wires\nauth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\nmirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\npattern (kept per-route, not shared, per the existing convention). All three\nverbs depend on the same `_require_admin_and_throttled` chain — GET/DELETE\nreuse it verbatim rather than introducing a new scope or auth path.\n\"\"\"\n\nfrom typing import Annotated\n\nfrom fastapi import APIRouter, Depends, HTTPException, Query, Request, Response, status\n\nfrom src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\nfrom src.auth import require_api_key\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.auth.rate_limit import enforce_tier2_rate_limit\nfrom src.logging import get_logger\nfrom src.services.quota_service import (\n    delete_tenant_quota,\n    list_tenant_quotas,\n    to_response,\n    upsert_tenant_quota,\n)\n\nrouter = APIRouter(tags=[\"quotas\"])\nlogger = get_logger(service=\"meterly\")\n\n_ADMIN_SCOPE = \"admin\"\n\n\nasync def _require_admin_and_throttled(\n    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n) -> AuthenticatedPrincipal:\n    \"\"\"Compose auth, then the Tier-2 per-key throttle, then the admin-scope\n    gate, in that order — mirrors `src/api/routes/events.py`'s dependency\n    chain, extended with the function-level authorization check this route\n    alone requires (ASVS 8.2.1).\n    \"\"\"\n    await enforce_tier2_rate_limit(request, principal)\n    if principal.scope != _ADMIN_SCOPE:\n        logger.warning(\n            \"quota.forbidden\",\n            userId=principal.api_key_id,\n            action=\"deny\",\n            reason=\"insufficient_scope\",\n        )\n        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"admin scope required\")\n    return principal\n\n\n@router.put(\"/v1/quotas\", response_model=QuotaResponse)\nasync def put_quota(\n    payload: QuotaPutRequest,\n    response: Response,\n    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n) -> QuotaResponse:","numLines":60,"startLine":1,"totalLines":88}},"sourceToolAssistantUUID":"94b3fa1a-96af-4a67-ab18-1d009490686a","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
