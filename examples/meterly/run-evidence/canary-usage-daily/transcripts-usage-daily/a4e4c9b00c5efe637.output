{"parentUuid":"e9849128-a5d9-42e5-9b58-0d91457f9632","isSidechain":true,"promptId":"65871126-fcc0-41d2-a9f9-a85b1fd15ac2","agentId":"a4e4c9b00c5efe637","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PHGnJZpwRLQ2j8G7GBTmbi","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage`.\n2\t\n3\t`window` must be a timezone-aware ISO-8601 timestamp within `[now-90d, now+1h]`;\n4\ta naive datetime (no offset) is rejected rather than silently assumed-UTC, since\n5\tguessing wrong would silently misattribute a bucket.\n6\t\"\"\"\n7\t\n8\tfrom datetime import datetime, timedelta, timezone\n9\tfrom decimal import Decimal\n10\t\n11\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, field_validator\n12\t\n13\tfrom src.api.schemas.events import CustomerId, Metric\n14\t\n15\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n16\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n17\t\n18\t\n19\tclass UsageQueryParams(BaseModel):\n20\t    \"\"\"The three required query parameters of `GET /v1/usage`, validated as a\n21\t    single boundary schema rather than three ad-hoc query-param checks.\"\"\"\n22\t\n23\t    model_config = ConfigDict(extra=\"forbid\")\n24\t\n25\t    customer_id: CustomerId\n26\t    metric: Metric\n27\t    window: AwareDatetime\n28\t\n29\t    @field_validator(\"window\")\n30\t    @classmethod\n31\t    def _window_within_supported_range(cls, value: datetime) -> datetime:\n32\t        \"\"\"Reject a `window` timestamp outside the supported query range.\n33\t\n34\t        Pydantic's `AwareDatetime` already rejects naive datetimes; this\n35\t        validator adds the `[now-90d, now+1h]` bound so a caller can't probe\n36\t        arbitrarily far into the past (unbounded query cost) or the future\n37\t        (nothing to aggregate yet).\n38\t        \"\"\"\n39\t        now = datetime.now(timezone.utc)\n40\t        earliest = now - _MAX_WINDOW_LOOKBACK\n41\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n42\t        if not (earliest <= value <= latest):\n43\t            raise ValueError(\n44\t                f\"window must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n45\t            )\n46\t        return value\n47\t\n48\t\n49\tclass UsageResponse(BaseModel):\n50\t    \"\"\"The minimal response field set for a usage query (ASVS 15.3.1).\"\"\"\n51\t\n52\t    model_config = ConfigDict(extra=\"forbid\")\n53\t\n54\t    customer_id: str\n55\t    metric: str\n56\t    window_start: str\n57\t    total_quantity: Decimal\n58\t    event_count: int\n59\t"}]},"uuid":"cd3be7ac-c3f7-4c79-bf9c-28ca748d627f","timestamp":"2026-07-11T20:20:17.848Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage.py","content":"\"\"\"Validation contract for `GET /v1/usage`.\n\n`window` must be a timezone-aware ISO-8601 timestamp within `[now-90d, now+1h]`;\na naive datetime (no offset) is rejected rather than silently assumed-UTC, since\nguessing wrong would silently misattribute a bucket.\n\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\nfrom decimal import Decimal\n\nfrom pydantic import AwareDatetime, BaseModel, ConfigDict, field_validator\n\nfrom src.api.schemas.events import CustomerId, Metric\n\n_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n\n\nclass UsageQueryParams(BaseModel):\n    \"\"\"The three required query parameters of `GET /v1/usage`, validated as a\n    single boundary schema rather than three ad-hoc query-param checks.\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    customer_id: CustomerId\n    metric: Metric\n    window: AwareDatetime\n\n    @field_validator(\"window\")\n    @classmethod\n    def _window_within_supported_range(cls, value: datetime) -> datetime:\n        \"\"\"Reject a `window` timestamp outside the supported query range.\n\n        Pydantic's `AwareDatetime` already rejects naive datetimes; this\n        validator adds the `[now-90d, now+1h]` bound so a caller can't probe\n        arbitrarily far into the past (unbounded query cost) or the future\n        (nothing to aggregate yet).\n        \"\"\"\n        now = datetime.now(timezone.utc)\n        earliest = now - _MAX_WINDOW_LOOKBACK\n        latest = now + _MAX_WINDOW_LOOKAHEAD\n        if not (earliest <= value <= latest):\n            raise ValueError(\n                f\"window must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n            )\n        return value\n\n\nclass UsageResponse(BaseModel):\n    \"\"\"The minimal response field set for a usage query (ASVS 15.3.1).\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    customer_id: str\n    metric: str\n    window_start: str\n    total_quantity: Decimal\n    event_count: int\n","numLines":59,"startLine":1,"totalLines":59}},"sourceToolAssistantUUID":"e9849128-a5d9-42e5-9b58-0d91457f9632","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
