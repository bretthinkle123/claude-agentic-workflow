{"parentUuid":"66e2052a-a80c-4d7b-a86a-345c5161bd20","isSidechain":true,"promptId":"3ec49c5b-ea47-4406-aa22-ead73596f6c4","agentId":"a043ee07da5273413","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ACwmZXstAWCXFsu3hraxa1","type":"tool_result","content":"1\t\"\"\"Shared fixtures for integration tests: a real PostgreSQL + Redis, each in a\n2\ttestcontainer, migrated with the project's actual Alembic revisions and wired\n3\tinto the app's process-wide singletons so requests through the ASGI app hit\n4\treal dependencies — the correctness guarantees under test here (ON CONFLICT\n5\tconcurrency, RLS tenant isolation, migration round-trips) are only real\n6\tagainst actual Postgres, not a mock.\n7\t\"\"\"\n8\t\n9\timport asyncio\n10\timport os\n11\timport subprocess\n12\timport sys\n13\tfrom pathlib import Path\n14\t\n15\timport pytest\n16\tfrom httpx import ASGITransport, AsyncClient\n17\tfrom testcontainers.postgres import PostgresContainer\n18\tfrom testcontainers.redis import RedisContainer\n19\t\n20\t_REPO_ROOT = Path(__file__).resolve().parents[2]\n21\t\n22\t\n23\tdef _asyncpg_url(sync_url: str) -> str:\n24\t    \"\"\"Convert testcontainers' default `postgresql+psycopg2://` URL to the\n25\t    `postgresql+asyncpg://` dialect the application (and Alembic's env.py) uses.\"\"\"\n26\t    return sync_url.replace(\"postgresql+psycopg2://\", \"postgresql+asyncpg://\")\n27\t\n28\t\n29\t@pytest.fixture(scope=\"session\")\n30\tdef postgres_url():\n31\t    \"\"\"A session-scoped live Postgres, migrated to head once.\n32\t\n33\t    Raises `max_connections` above Postgres's default of 100: this container\n34\t    is shared across the whole integration-test session, including three k6\n35\t    perf fixtures that each launch a separate multi-worker uvicorn process\n36\t    (its own DB connection pool) against it — the default ceiling is too low\n37\t    for that cumulative demand when the full suite runs in one session and\n38\t    was observed to exhaust mid-suite (`TooManyConnectionsError`) with only\n39\t    the default. This is a test-container capacity knob, not a production\n40\t    change (the real RDS instance sizes `max_connections` independently).\n41\t    \"\"\"\n42\t    with PostgresContainer(\"postgres:16-alpine\").with_command(\n43\t        \"postgres -c max_connections=300\"\n44\t    ) as postgres:\n45\t        url = _asyncpg_url(postgres.get_connection_url())\n46\t        env = dict(os.environ)\n47\t        env[\"DATABASE_URL\"] = url\n48\t        # Run the project's real Alembic migrations (0001 + 0002) against the\n49\t        # container out-of-process, so this is the same upgrade path `alembic\n50\t        # upgrade head` runs in CI/deploy, not a re-implemented schema.\n51\t        result = subprocess.run(\n52\t            [sys.executable, \"-m\", \"alembic\", \"upgrade\", \"head\"],\n53\t            cwd=str(_REPO_ROOT),\n54\t            env=env,\n55\t            capture_output=True,\n56\t            text=True,\n57\t        )\n58\t        assert result.returncode == 0, f\"alembic upgrade head failed:\\n{result.stdout}\\n{result.stderr}\"\n59\t        yield url\n60\t\n61\t\n62\t@pytest.fixture(scope=\"session\")\n63\tdef redis_url():\n64\t    \"\"\"A session-scoped live Redis for the Tier-1/Tier-2 token-bucket limiters.\"\"\"\n65\t    with RedisContainer(\"redis:7-alpine\") as redis_container:\n66\t        host = redis_container.get_container_host_ip()\n67\t        port = redis_container.get_exposed_port(redis_container.port)\n68\t        yield f\"redis://{host}:{port}/0\"\n69\t\n70\t\n71\t@pytest.fixture\n72\tasync def app_env(postgres_url, redis_url, monkeypatch):\n73\t    \"\"\"Point the app's process-wide DB/Redis singletons at the live\n74\t    containers, then reset them so each test starts with fresh pools/caches\n75\t    and no leaked verification-cache entries from a previous test.\n76\t    \"\"\"\n77\t    monkeypatch.setenv(\"DATABASE_URL\", postgres_url)\n78\t    monkeypatch.setenv(\"METERLY_REDIS_URL\", redis_url)\n79\t\n80\t    from src import auth as auth_module\n81\t    from src.auth import rate_limit as rate_limit_module\n82\t    from src.config import secrets as secrets_module\n83\t    from src.config.settings import get_settings\n84\t    from src.db import session as session_module\n85\t\n86\t    get_settings.cache_clear()\n87\t    secrets_module._facade._cache.clear()\n88\t\n89\t    await session_module.dispose_engine()\n90\t    await rate_limit_module.dispose_redis_client()\n91\t    auth_module._verification_cache = None\n92\t\n93\t    yield\n94\t\n95\t    await session_module.dispose_engine()\n96\t    await rate_limit_module.dispose_redis_client()\n97\t    auth_module._verification_cache = None\n98\t    get_settings.cache_clear()\n99\t\n100\t\n101\t@pytest.fixture\n102\tasync def truncate_tables(app_env, postgres_url, redis_url):\n103\t    \"\"\"Truncate the mutable tables between tests so each test starts from a\n104\t    clean, empty schema (api_keys are re-seeded per test via `make_api_key`).\n105\t\n106\t    The DB truncate uses RESTART IDENTITY, so `api_keys.id` (the Tier-2 bucket\n107\t    key) resets to 1 each test. Redis is session-scoped and would otherwise\n108\t    retain the previous test's token buckets under those reused ids, leaking an\n109\t    exhausted bucket into the next test -> flush it here too so bucket state is\n110\t    isolated per test, mirroring the DB truncate.\n111\t    \"\"\"\n112\t    import redis.asyncio as redis_async\n113\t    from sqlalchemy.ext.asyncio import create_async_engine\n114\t\n115\t    engine = create_async_engine(postgres_url)\n116\t    async with engine.begin() as connection:\n117\t        from sqlalchemy import text\n118\t\n119\t        await connection.execute(\n120\t            text(\"TRUNCATE TABLE events, usage_rollup, quotas, api_keys RESTART IDENTITY CASCADE\")\n121\t        )\n122\t    await engine.dispose()\n123\t\n124\t    redis_client = redis_async.from_url(redis_url, decode_responses=True)\n125\t    await redis_client.flushdb()\n126\t    await redis_client.aclose()\n127\t    yield\n128\t\n129\t\n130\t@pytest.fixture\n131\tasync def client(truncate_tables):\n132\t    \"\"\"An async test client bound to the real app via ASGI transport, with\n133\t    live DB/Redis singletons already pointed at the containers.\"\"\"\n134\t    from src.main import app\n135\t\n136\t    transport = ASGITransport(app=app)\n137\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as async_client:\n138\t        yield async_client\n139\t\n140\t\n141\t@pytest.fixture\n142\tasync def make_api_key(truncate_tables):\n143\t    \"\"\"Factory fixture: provision a real API key row (Argon2id-hashed) and\n144\t    return `(presented_key, api_key_id)`.\"\"\"\n145\t    from src.auth.api_key import generate_split_token, hash_new_secret\n146\t    from src.db.session import get_engine\n147\t    from src.repositories.api_keys_repo import create_api_key\n148\t\n149\t    created_ids = []\n150\t\n151\t    async def _make(\n152\t        label: str = \"test-key\", rate_limit_per_sec: int = 100, scope: str = \"ingest\"\n153\t    ) -> tuple[str, int]:\n154\t        key_id, secret, presented_key = generate_split_token()\n155\t        secret_hash = hash_new_secret(secret)\n156\t        async with get_engine().begin() as connection:\n157\t            api_key_row_id = await create_api_key(\n158\t                connection,\n159\t                key_id=key_id,\n160\t                secret_hash=secret_hash,\n161\t                label=label,\n162\t                rate_limit_per_sec=rate_limit_per_sec,\n163\t                scope=scope,\n164\t            )\n165\t        created_ids.append(api_key_row_id)\n166\t        return presented_key, api_key_row_id\n167\t\n168\t    yield _make\n169\t"}]},"uuid":"cf2279a3-692a-4d0b-9690-a081c6ed1ca1","timestamp":"2026-07-11T21:54:27.292Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/conftest.py","content":"\"\"\"Shared fixtures for integration tests: a real PostgreSQL + Redis, each in a\ntestcontainer, migrated with the project's actual Alembic revisions and wired\ninto the app's process-wide singletons so requests through the ASGI app hit\nreal dependencies — the correctness guarantees under test here (ON CONFLICT\nconcurrency, RLS tenant isolation, migration round-trips) are only real\nagainst actual Postgres, not a mock.\n\"\"\"\n\nimport asyncio\nimport os\nimport subprocess\nimport sys\nfrom pathlib import Path\n\nimport pytest\nfrom httpx import ASGITransport, AsyncClient\nfrom testcontainers.postgres import PostgresContainer\nfrom testcontainers.redis import RedisContainer\n\n_REPO_ROOT = Path(__file__).resolve().parents[2]\n\n\ndef _asyncpg_url(sync_url: str) -> str:\n    \"\"\"Convert testcontainers' default `postgresql+psycopg2://` URL to the\n    `postgresql+asyncpg://` dialect the application (and Alembic's env.py) uses.\"\"\"\n    return sync_url.replace(\"postgresql+psycopg2://\", \"postgresql+asyncpg://\")\n\n\n@pytest.fixture(scope=\"session\")\ndef postgres_url():\n    \"\"\"A session-scoped live Postgres, migrated to head once.\n\n    Raises `max_connections` above Postgres's default of 100: this container\n    is shared across the whole integration-test session, including three k6\n    perf fixtures that each launch a separate multi-worker uvicorn process\n    (its own DB connection pool) against it — the default ceiling is too low\n    for that cumulative demand when the full suite runs in one session and\n    was observed to exhaust mid-suite (`TooManyConnectionsError`) with only\n    the default. This is a test-container capacity knob, not a production\n    change (the real RDS instance sizes `max_connections` independently).\n    \"\"\"\n    with PostgresContainer(\"postgres:16-alpine\").with_command(\n        \"postgres -c max_connections=300\"\n    ) as postgres:\n        url = _asyncpg_url(postgres.get_connection_url())\n        env = dict(os.environ)\n        env[\"DATABASE_URL\"] = url\n        # Run the project's real Alembic migrations (0001 + 0002) against the\n        # container out-of-process, so this is the same upgrade path `alembic\n        # upgrade head` runs in CI/deploy, not a re-implemented schema.\n        result = subprocess.run(\n            [sys.executable, \"-m\", \"alembic\", \"upgrade\", \"head\"],\n            cwd=str(_REPO_ROOT),\n            env=env,\n            capture_output=True,\n            text=True,\n        )\n        assert result.returncode == 0, f\"alembic upgrade head failed:\\n{result.stdout}\\n{result.stderr}\"\n        yield url\n\n\n@pytest.fixture(scope=\"session\")\ndef redis_url():\n    \"\"\"A session-scoped live Redis for the Tier-1/Tier-2 token-bucket limiters.\"\"\"\n    with RedisContainer(\"redis:7-alpine\") as redis_container:\n        host = redis_container.get_container_host_ip()\n        port = redis_container.get_exposed_port(redis_container.port)\n        yield f\"redis://{host}:{port}/0\"\n\n\n@pytest.fixture\nasync def app_env(postgres_url, redis_url, monkeypatch):\n    \"\"\"Point the app's process-wide DB/Redis singletons at the live\n    containers, then reset them so each test starts with fresh pools/caches\n    and no leaked verification-cache entries from a previous test.\n    \"\"\"\n    monkeypatch.setenv(\"DATABASE_URL\", postgres_url)\n    monkeypatch.setenv(\"METERLY_REDIS_URL\", redis_url)\n\n    from src import auth as auth_module\n    from src.auth import rate_limit as rate_limit_module\n    from src.config import secrets as secrets_module\n    from src.config.settings import get_settings\n    from src.db import session as session_module\n\n    get_settings.cache_clear()\n    secrets_module._facade._cache.clear()\n\n    await session_module.dispose_engine()\n    await rate_limit_module.dispose_redis_client()\n    auth_module._verification_cache = None\n\n    yield\n\n    await session_module.dispose_engine()\n    await rate_limit_module.dispose_redis_client()\n    auth_module._verification_cache = None\n    get_settings.cache_clear()\n\n\n@pytest.fixture\nasync def truncate_tables(app_env, postgres_url, redis_url):\n    \"\"\"Truncate the mutable tables between tests so each test starts from a\n    clean, empty schema (api_keys are re-seeded per test via `make_api_key`).\n\n    The DB truncate uses RESTART IDENTITY, so `api_keys.id` (the Tier-2 bucket\n    key) resets to 1 each test. Redis is session-scoped and would otherwise\n    retain the previous test's token buckets under those reused ids, leaking an\n    exhausted bucket into the next test -> flush it here too so bucket state is\n    isolated per test, mirroring the DB truncate.\n    \"\"\"\n    import redis.asyncio as redis_async\n    from sqlalchemy.ext.asyncio import create_async_engine\n\n    engine = create_async_engine(postgres_url)\n    async with engine.begin() as connection:\n        from sqlalchemy import text\n\n        await connection.execute(\n            text(\"TRUNCATE TABLE events, usage_rollup, quotas, api_keys RESTART IDENTITY CASCADE\")\n        )\n    await engine.dispose()\n\n    redis_client = redis_async.from_url(redis_url, decode_responses=True)\n    await redis_client.flushdb()\n    await redis_client.aclose()\n    yield\n\n\n@pytest.fixture\nasync def client(truncate_tables):\n    \"\"\"An async test client bound to the real app via ASGI transport, with\n    live DB/Redis singletons already pointed at the containers.\"\"\"\n    from src.main import app\n\n    transport = ASGITransport(app=app)\n    async with AsyncClient(transport=transport, base_url=\"http://test\") as async_client:\n        yield async_client\n\n\n@pytest.fixture\nasync def make_api_key(truncate_tables):\n    \"\"\"Factory fixture: provision a real API key row (Argon2id-hashed) and\n    return `(presented_key, api_key_id)`.\"\"\"\n    from src.auth.api_key import generate_split_token, hash_new_secret\n    from src.db.session import get_engine\n    from src.repositories.api_keys_repo import create_api_key\n\n    created_ids = []\n\n    async def _make(\n        label: str = \"test-key\", rate_limit_per_sec: int = 100, scope: str = \"ingest\"\n    ) -> tuple[str, int]:\n        key_id, secret, presented_key = generate_split_token()\n        secret_hash = hash_new_secret(secret)\n        async with get_engine().begin() as connection:\n            api_key_row_id = await create_api_key(\n                connection,\n                key_id=key_id,\n                secret_hash=secret_hash,\n                label=label,\n                rate_limit_per_sec=rate_limit_per_sec,\n                scope=scope,\n            )\n        created_ids.append(api_key_row_id)\n        return presented_key, api_key_row_id\n\n    yield _make\n","numLines":169,"startLine":1,"totalLines":169}},"sourceToolAssistantUUID":"66e2052a-a80c-4d7b-a86a-345c5161bd20","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
