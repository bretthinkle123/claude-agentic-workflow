{"parentUuid":"d47d3676-75f7-41a2-a540-d85b90fae386","isSidechain":true,"agentId":"a1fd16c8a07de7f7f","message":{"model":"claude-sonnet-5","id":"msg_011Ccw7a6NVDJ36tRKkPvkoq","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TXJbCMDfdaWMUwvqBS9U3U","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_usage_daily_endpoint.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":723,"cache_read_input_tokens":34019,"output_tokens":106,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":723},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":106,"cache_read_input_tokens":34019,"cache_creation_input_tokens":723,"cache_creation":{"ephemeral_5m_input_tokens":723,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011Ccw7a5JFCAizXod7iCMSd","attributionAgent":"testing","type":"assistant","uuid":"63cb6082-3981-4fe0-89a9-0c7252bb53dc","timestamp":"2026-07-11T23:10:18.485Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"63cb6082-3981-4fe0-89a9-0c7252bb53dc","isSidechain":true,"promptId":"87a0d7b9-4e1c-446d-ac37-238ab83013b2","agentId":"a1fd16c8a07de7f7f","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TXJbCMDfdaWMUwvqBS9U3U","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/usage/daily` against a real Postgres:\n2\thappy-path aggregation, empty-day, the 400/422 validation split, cross-tenant\n3\tisolation, non-admin access, auth, the Tier-2 throttle wiring, the UTC\n4\tday-seam boundary, the read-audit log, OpenAPI documentation, existing-route\n5\tno-regression, and the forced-internal-error fail-closed 500 path (AC1-AC15).\n6\t\"\"\"\n7\t\n8\tfrom datetime import datetime, timedelta, timezone\n9\tfrom decimal import Decimal\n10\t\n11\tfrom httpx import ASGITransport, AsyncClient\n12\tfrom sqlalchemy import text\n13\t\n14\t\n15\tdef _event_payload(**overrides) -> dict:\n16\t    payload = {\n17\t        \"customer_id\": \"cust_1\",\n18\t        \"metric\": \"api_calls\",\n19\t        \"quantity\": \"5\",\n20\t        \"idempotency_key\": \"idem-1\",\n21\t    }\n22\t    payload.update(overrides)\n23\t    return payload\n24\t\n25\t\n26\tasync def _insert_rollup_row(\n27\t    postgres_url,\n28\t    *,\n29\t    api_key_id: int,\n30\t    customer_id: str,\n31\t    metric: str,\n32\t    window_start: datetime,\n33\t    event_count: int,\n34\t    total_quantity: str = \"1\",\n35\t) -> None:\n36\t    \"\"\"Seed a `usage_rollup` row directly — used for the day-boundary and\n37\t    multi-customer aggregation tests, where seeding via `POST /v1/events`\n38\t    can't pin an exact `window_start` (the write path floors to \"now\").\"\"\"\n39\t    from sqlalchemy.ext.asyncio import create_async_engine\n40\t\n41\t    engine = create_async_engine(postgres_url)\n42\t    async with engine.begin() as connection:\n43\t        await connection.execute(\n44\t            text(\n45\t                \"\"\"\n46\t                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n47\t                VALUES (:api_key_id, :customer_id, :metric, :window_start, :total_quantity, :event_count)\n48\t                ON CONFLICT (api_key_id, customer_id, metric, window_start)\n49\t                DO UPDATE SET event_count = usage_rollup.event_count + EXCLUDED.event_count\n50\t                \"\"\"\n51\t            ),\n52\t            {\n53\t                \"api_key_id\": api_key_id,\n54\t                \"customer_id\": customer_id,\n55\t                \"metric\": metric,\n56\t                \"window_start\": window_start,\n57\t                \"total_quantity\": total_quantity,\n58\t                \"event_count\": event_count,\n59\t            },\n60\t        )\n61\t    await engine.dispose()\n62\t\n63\t\n64\tdef _today_utc_str() -> str:\n65\t    return datetime.now(timezone.utc).date().isoformat()\n66\t\n67\t\n68\tasync def test_daily_counts_aggregate_per_metric(client, make_api_key, postgres_url):\n69\t    \"\"\"AC1: events across multiple metrics, multiple customer_ids, and\n70\t    multiple hour-buckets on the same UTC day sum to the correct per-metric\n71\t    total, ordered by metric.\"\"\"\n72\t    presented_key, api_key_id = await make_api_key()\n73\t    today = datetime.now(timezone.utc).date()\n74\t    hour_a = datetime(today.year, today.month, today.day, 2, tzinfo=timezone.utc)\n75\t    hour_b = datetime(today.year, today.month, today.day, 14, tzinfo=timezone.utc)\n76\t\n77\t    await _insert_rollup_row(\n78\t        postgres_url, api_key_id=api_key_id, customer_id=\"cust_a\", metric=\"api_calls\",\n79\t        window_start=hour_a, event_count=3,\n80\t    )\n81\t    await _insert_rollup_row(\n82\t        postgres_url, api_key_id=api_key_id, customer_id=\"cust_b\", metric=\"api_calls\",\n83\t        window_start=hour_b, event_count=4,\n84\t    )\n85\t    await _insert_rollup_row(\n86\t        postgres_url, api_key_id=api_key_id, customer_id=\"cust_a\", metric=\"storage_bytes\",\n87\t        window_start=hour_a, event_count=1,\n88\t    )\n89\t\n90\t    response = await client.get(\n91\t        \"/v1/usage/daily\",\n92\t        params={\"date\": today.isoformat()},\n93\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n94\t    )\n95\t\n96\t    assert response.status_code == 200\n97\t    body = response.json()\n98\t    assert body[\"date\"] == today.isoformat()\n99\t    assert body[\"metrics\"] == [\n100\t        {\"metric\": \"api_calls\", \"event_count\": 7},\n101\t        {\"metric\": \"storage_bytes\", \"event_count\": 1},\n102\t    ]\n103\t\n104\t\n105\tasync def test_empty_day_returns_200_empty_list(client, make_api_key):\n106\t    \"\"\"AC2: a tenant with no events on the given date gets 200 with an empty\n107\t    metrics list, never 404.\"\"\"\n108\t    presented_key, _ = await make_api_key()\n109\t\n110\t    response = await client.get(\n111\t        \"/v1/usage/daily\",\n112\t        params={\"date\": _today_utc_str()},\n113\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n114\t    )\n115\t\n116\t    assert response.status_code == 200\n117\t    body = response.json()\n118\t    assert body[\"metrics\"] == []\n119\t\n120\t\n121\tasync def test_missing_date_returns_400(client, make_api_key):\n122\t    \"\"\"AC3: omitting `date` entirely returns 400 bad_request, not 422/200.\"\"\"\n123\t    presented_key, _ = await make_api_key()\n124\t\n125\t    response = await client.get(\n126\t        \"/v1/usage/daily\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n127\t    )\n128\t\n129\t    assert response.status_code == 400\n130\t    body = response.json()\n131\t    assert body[\"error\"][\"code\"] == \"bad_request\"\n132\t\n133\t\n134\tasync def test_malformed_date_returns_400(client, make_api_key):\n135\t    \"\"\"AC4: a malformed (but present) `date` value returns 400, not 422.\"\"\"\n136\t    presented_key, _ = await make_api_key()\n137\t\n138\t    response = await client.get(\n139\t        \"/v1/usage/daily\",\n140\t        params={\"date\": \"2026-13-40\"},\n141\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n142\t    )\n143\t\n144\t    assert response.status_code == 400\n145\t    assert response.json()[\"error\"][\"code\"] == \"bad_request\"\n146\t\n147\t\n148\tasync def test_out_of_range_date_returns_400(client, make_api_key):\n149\t    \"\"\"AC5: a well-formed date outside [today-90d, today+1d] returns 400.\"\"\"\n150\t    presented_key, _ = await make_api_key()\n151\t    too_old = (datetime.now(timezone.utc).date() - timedelta(days=200)).isoformat()\n152\t\n153\t    response = await client.get(\n154\t        \"/v1/usage/daily\",\n155\t        params={\"date\": too_old},\n156\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n157\t    )\n158\t\n159\t    assert response.status_code == 400\n160\t    assert response.json()[\"error\"][\"code\"] == \"bad_request\"\n161\t\n162\t\n163\tasync def test_unknown_query_param_rejected_422(client, make_api_key):\n164\t    \"\"\"AC6: an undeclared query param (e.g. a smuggled api_key_id) returns\n165\t    422 validation_failed via extra='forbid', distinct from the 400 date\n166\t    contract.\"\"\"\n167\t    presented_key, _ = await make_api_key()\n168\t\n169\t    response = await client.get(\n170\t        \"/v1/usage/daily\",\n171\t        params={\"date\": _today_utc_str(), \"api_key_id\": \"9\"},\n172\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n173\t    )\n174\t\n175\t    assert response.status_code == 422\n176\t    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n177\t\n178\t\n179\tasync def test_cross_tenant_cannot_see_others_counts(client, make_api_key):\n180\t    \"\"\"AC7 (IDOR/BOLA): tenant B querying the same date after tenant A\n181\t    ingests sees B's own empty result, never A's counts.\"\"\"\n182\t    key_a, _ = await make_api_key(label=\"tenant-a\")\n183\t    key_b, _ = await make_api_key(label=\"tenant-b\")\n184\t\n185\t    await client.post(\n186\t        \"/v1/events\",\n187\t        json=_event_payload(idempotency_key=\"a-1\", quantity=\"1000\"),\n188\t        headers={\"Authorization\": f\"Bearer {key_a}\"},\n189\t    )\n190\t\n191\t    response = await client.get(\n192\t        \"/v1/usage/daily\",\n193\t        params={\"date\": _today_utc_str()},\n194\t        headers={\"Authorization\": f\"Bearer {key_b}\"},\n195\t    )\n196\t\n197\t    assert response.status_code == 200\n198\t    assert response.json()[\"metrics\"] == []\n199\t\n200\t\n201\tasync def test_requires_api_key(client):\n202\t    \"\"\"AC8: no Authorization header, and an invalid/malformed key, both 401.\"\"\"\n203\t    missing = await client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()})\n204\t    invalid = await client.get(\n205\t        \"/v1/usage/daily\",\n206\t        params={\"date\": _today_utc_str()},\n207\t        headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"},\n208\t    )\n209\t\n210\t    assert missing.status_code == 401\n211\t    assert invalid.status_code == 401\n212\t\n213\t\n214\tasync def test_ingest_key_allowed_not_admin_gated(client, make_api_key):\n215\t    \"\"\"AC9: a plain ingest-scoped (non-admin) key gets 200 — no admin scope\n216\t    is required for this customer-scoped read.\"\"\"\n217\t    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n218\t\n219\t    response = await client.get(\n220\t        \"/v1/usage/daily\",\n221\t        params={\"date\": _today_utc_str()},\n222\t        headers={\"Authorization\": f\"Bearer {ingest_key}\"},\n223\t    )\n224\t\n225\t    assert response.status_code == 200\n226\t\n227\t\n228\tasync def test_utc_day_boundary_is_half_open(client, make_api_key, postgres_url):\n229\t    \"\"\"AC10: an event at 23:xxZ of date D is counted for D; an event at\n230\t    00:00Z of D+1 is not — the half-open [day_start, day_end) window.\"\"\"\n231\t    presented_key, api_key_id = await make_api_key()\n232\t    today = datetime.now(timezone.utc).date()\n233\t    # Use a date safely inside the accepted range so D+1's 00:00Z boundary\n234\t    # doesn't itself risk landing outside [today-90d, today+1d].\n235\t    target_day = today - timedelta(days=5)\n236\t    end_of_target_day = datetime(target_day.year, target_day.month, target_day.day, 23, 30, tzinfo=timezone.utc)\n237\t    start_of_next_day = end_of_target_day + timedelta(hours=1)  # 00:30Z of target_day + 1\n238\t\n239\t    await _insert_rollup_row(\n240\t        postgres_url, api_key_id=api_key_id, customer_id=\"cust_seam\", metric=\"api_calls\",\n241\t        window_start=end_of_target_day, event_count=1,\n242\t    )\n243\t    await _insert_rollup_row(\n244\t        postgres_url, api_key_id=api_key_id, customer_id=\"cust_seam\", metric=\"api_calls\",\n245\t        window_start=start_of_next_day, event_count=100,\n246\t    )\n247\t\n248\t    response = await client.get(\n249\t        \"/v1/usage/daily\",\n250\t        params={\"date\": target_day.isoformat()},\n251\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n252\t    )\n253\t\n254\t    assert response.status_code == 200\n255\t    body = response.json()\n256\t    assert body[\"metrics\"] == [{\"metric\": \"api_calls\", \"event_count\": 1}]\n257\t\n258\t\n259\tasync def test_existing_usage_endpoint_unchanged(client, make_api_key):\n260\t    \"\"\"AC11: mounting the new route doesn't disturb POST /v1/events or\n261\t    GET /v1/usage's existing behavior.\"\"\"\n262\t    presented_key, _ = await make_api_key()\n263\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n264\t\n265\t    post_response = await client.post(\"/v1/events\", json=_event_payload(idempotency_key=\"sanity\"), headers=headers)\n266\t    assert post_response.status_code == 201\n267\t\n268\t    now = datetime.now(timezone.utc).isoformat()\n269\t    usage_response = await client.get(\n270\t        \"/v1/usage\",\n271\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": now},\n272\t        headers=headers,\n273\t    )\n274\t    assert usage_response.status_code == 200\n275\t    body = usage_response.json()\n276\t    assert Decimal(str(body[\"total_quantity\"])) == Decimal(\"5\")\n277\t    assert body[\"event_count\"] == 1\n278\t\n279\t\n280\tasync def test_emits_usage_daily_read_log(client, make_api_key, capsys):\n281\t    \"\"\"AC12: a `usage.daily.read` structured event is emitted with\n282\t    userId/action/resource/date and no customer_id value (structlog prints\n283\t    JSON to stdout — see test_logging_redaction.py).\"\"\"\n284\t    import json\n285\t\n286\t    presented_key, api_key_id = await make_api_key()\n287\t\n288\t    response = await client.get(\n289\t        \"/v1/usage/daily\",\n290\t        params={\"date\": _today_utc_str()},\n291\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n292\t    )\n293\t\n294\t    assert response.status_code == 200\n295\t    captured = capsys.readouterr()\n296\t    matching = [\n297\t        json.loads(line)\n298\t        for line in captured.out.splitlines()\n299\t        if '\"event\": \"usage.daily.read\"' in line\n300\t    ]\n301\t    assert len(matching) == 1\n302\t    record = matching[0]\n303\t    assert record[\"userId\"] == api_key_id\n304\t    assert record[\"action\"] == \"read\"\n305\t    assert record[\"resource\"] == \"usage_rollup\"\n306\t    assert record[\"date\"] == _today_utc_str()\n307\t    assert \"customer_id\" not in record\n308\t\n309\t\n310\tasync def test_route_behind_tier2_throttle(truncate_tables, make_api_key):\n311\t    \"\"\"AC13: the route resolves the Tier-2 per-api_key_id throttle — a key\n312\t    with a tiny bucket gets 429 on the second call within the same second.\"\"\"\n313\t    from src.main import app\n314\t\n315\t    presented_key, _ = await make_api_key(rate_limit_per_sec=1)\n316\t\n317\t    transport = ASGITransport(app=app)\n318\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as scoped_client:\n319\t        headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n320\t        first = await scoped_client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()}, headers=headers)\n321\t        second = await scoped_client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()}, headers=headers)\n322\t\n323\t    assert first.status_code == 200\n324\t    assert second.status_code == 429\n325\t    assert \"Retry-After\" in second.headers\n326\t\n327\t\n328\tasync def test_openapi_documents_daily_route(client):\n329\t    \"\"\"AC14: the served /openapi.json includes GET /v1/usage/daily with its\n330\t    DailyUsageResponse schema.\"\"\"\n331\t    response = await client.get(\"/openapi.json\")\n332\t\n333\t    assert response.status_code == 200\n334\t    schema = response.json()\n335\t    assert \"/v1/usage/daily\" in schema[\"paths\"]\n336\t    operation = schema[\"paths\"][\"/v1/usage/daily\"][\"get\"]\n337\t    assert \"200\" in operation[\"responses\"]\n338\t    content_schema = operation[\"responses\"][\"200\"][\"content\"][\"application/json\"][\"schema\"]\n339\t    assert \"$ref\" in content_schema or \"properties\" in content_schema\n340\t\n341\t\n342\tasync def test_daily_forced_repo_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n343\t    \"\"\"AC15: a forced failure inside aggregate_daily_event_counts (simulating\n344\t    a DB/connection drop) returns the generic 500 internal envelope — no\n345\t    stack/SQL/detail leak, no error-swallowing try/except in the route or\n346\t    service (mirrors the usage_export sibling test).\"\"\"\n347\t    from src.main import app\n348\t    from src.services import usage_daily_service\n349\t\n350\t    async def _raising_aggregate(session, **kwargs):\n351\t        raise RuntimeError(\"simulated connection drop mid-aggregate\")\n352\t\n353\t    monkeypatch.setattr(usage_daily_service, \"aggregate_daily_event_counts\", _raising_aggregate)\n354\t\n355\t    presented_key, _ = await make_api_key()\n356\t\n357\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n358\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as forced_client:\n359\t        response = await forced_client.get(\n360\t            \"/v1/usage/daily\",\n361\t            params={\"date\": _today_utc_str()},\n362\t            headers={\"Authorization\": f\"Bearer {presented_key}\"},\n363\t        )\n364\t\n365\t    assert response.status_code == 500\n366\t    body = response.json()\n367\t    assert body[\"error\"][\"code\"] == \"internal\"\n368\t    assert \"requestId\" in body[\"error\"]\n369\t    assert \"simulated connection drop\" not in response.text\n370\t    assert \"Traceback\" not in response.text\n371\t"}]},"uuid":"7e9c2f8d-effc-4c9c-b4c7-6a756eee413c","timestamp":"2026-07-11T23:10:18.587Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/integration/test_usage_daily_endpoint.py","content":"\"\"\"Integration tests for `GET /v1/usage/daily` against a real Postgres:\nhappy-path aggregation, empty-day, the 400/422 validation split, cross-tenant\nisolation, non-admin access, auth, the Tier-2 throttle wiring, the UTC\nday-seam boundary, the read-audit log, OpenAPI documentation, existing-route\nno-regression, and the forced-internal-error fail-closed 500 path (AC1-AC15).\n\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\nfrom decimal import Decimal\n\nfrom httpx import ASGITransport, AsyncClient\nfrom sqlalchemy import text\n\n\ndef _event_payload(**overrides) -> dict:\n    payload = {\n        \"customer_id\": \"cust_1\",\n        \"metric\": \"api_calls\",\n        \"quantity\": \"5\",\n        \"idempotency_key\": \"idem-1\",\n    }\n    payload.update(overrides)\n    return payload\n\n\nasync def _insert_rollup_row(\n    postgres_url,\n    *,\n    api_key_id: int,\n    customer_id: str,\n    metric: str,\n    window_start: datetime,\n    event_count: int,\n    total_quantity: str = \"1\",\n) -> None:\n    \"\"\"Seed a `usage_rollup` row directly — used for the day-boundary and\n    multi-customer aggregation tests, where seeding via `POST /v1/events`\n    can't pin an exact `window_start` (the write path floors to \"now\").\"\"\"\n    from sqlalchemy.ext.asyncio import create_async_engine\n\n    engine = create_async_engine(postgres_url)\n    async with engine.begin() as connection:\n        await connection.execute(\n            text(\n                \"\"\"\n                INSERT INTO usage_rollup (api_key_id, customer_id, metric, window_start, total_quantity, event_count)\n                VALUES (:api_key_id, :customer_id, :metric, :window_start, :total_quantity, :event_count)\n                ON CONFLICT (api_key_id, customer_id, metric, window_start)\n                DO UPDATE SET event_count = usage_rollup.event_count + EXCLUDED.event_count\n                \"\"\"\n            ),\n            {\n                \"api_key_id\": api_key_id,\n                \"customer_id\": customer_id,\n                \"metric\": metric,\n                \"window_start\": window_start,\n                \"total_quantity\": total_quantity,\n                \"event_count\": event_count,\n            },\n        )\n    await engine.dispose()\n\n\ndef _today_utc_str() -> str:\n    return datetime.now(timezone.utc).date().isoformat()\n\n\nasync def test_daily_counts_aggregate_per_metric(client, make_api_key, postgres_url):\n    \"\"\"AC1: events across multiple metrics, multiple customer_ids, and\n    multiple hour-buckets on the same UTC day sum to the correct per-metric\n    total, ordered by metric.\"\"\"\n    presented_key, api_key_id = await make_api_key()\n    today = datetime.now(timezone.utc).date()\n    hour_a = datetime(today.year, today.month, today.day, 2, tzinfo=timezone.utc)\n    hour_b = datetime(today.year, today.month, today.day, 14, tzinfo=timezone.utc)\n\n    await _insert_rollup_row(\n        postgres_url, api_key_id=api_key_id, customer_id=\"cust_a\", metric=\"api_calls\",\n        window_start=hour_a, event_count=3,\n    )\n    await _insert_rollup_row(\n        postgres_url, api_key_id=api_key_id, customer_id=\"cust_b\", metric=\"api_calls\",\n        window_start=hour_b, event_count=4,\n    )\n    await _insert_rollup_row(\n        postgres_url, api_key_id=api_key_id, customer_id=\"cust_a\", metric=\"storage_bytes\",\n        window_start=hour_a, event_count=1,\n    )\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": today.isoformat()},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 200\n    body = response.json()\n    assert body[\"date\"] == today.isoformat()\n    assert body[\"metrics\"] == [\n        {\"metric\": \"api_calls\", \"event_count\": 7},\n        {\"metric\": \"storage_bytes\", \"event_count\": 1},\n    ]\n\n\nasync def test_empty_day_returns_200_empty_list(client, make_api_key):\n    \"\"\"AC2: a tenant with no events on the given date gets 200 with an empty\n    metrics list, never 404.\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str()},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 200\n    body = response.json()\n    assert body[\"metrics\"] == []\n\n\nasync def test_missing_date_returns_400(client, make_api_key):\n    \"\"\"AC3: omitting `date` entirely returns 400 bad_request, not 422/200.\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/daily\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n    )\n\n    assert response.status_code == 400\n    body = response.json()\n    assert body[\"error\"][\"code\"] == \"bad_request\"\n\n\nasync def test_malformed_date_returns_400(client, make_api_key):\n    \"\"\"AC4: a malformed (but present) `date` value returns 400, not 422.\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": \"2026-13-40\"},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 400\n    assert response.json()[\"error\"][\"code\"] == \"bad_request\"\n\n\nasync def test_out_of_range_date_returns_400(client, make_api_key):\n    \"\"\"AC5: a well-formed date outside [today-90d, today+1d] returns 400.\"\"\"\n    presented_key, _ = await make_api_key()\n    too_old = (datetime.now(timezone.utc).date() - timedelta(days=200)).isoformat()\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": too_old},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 400\n    assert response.json()[\"error\"][\"code\"] == \"bad_request\"\n\n\nasync def test_unknown_query_param_rejected_422(client, make_api_key):\n    \"\"\"AC6: an undeclared query param (e.g. a smuggled api_key_id) returns\n    422 validation_failed via extra='forbid', distinct from the 400 date\n    contract.\"\"\"\n    presented_key, _ = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str(), \"api_key_id\": \"9\"},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 422\n    assert response.json()[\"error\"][\"code\"] == \"validation_failed\"\n\n\nasync def test_cross_tenant_cannot_see_others_counts(client, make_api_key):\n    \"\"\"AC7 (IDOR/BOLA): tenant B querying the same date after tenant A\n    ingests sees B's own empty result, never A's counts.\"\"\"\n    key_a, _ = await make_api_key(label=\"tenant-a\")\n    key_b, _ = await make_api_key(label=\"tenant-b\")\n\n    await client.post(\n        \"/v1/events\",\n        json=_event_payload(idempotency_key=\"a-1\", quantity=\"1000\"),\n        headers={\"Authorization\": f\"Bearer {key_a}\"},\n    )\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str()},\n        headers={\"Authorization\": f\"Bearer {key_b}\"},\n    )\n\n    assert response.status_code == 200\n    assert response.json()[\"metrics\"] == []\n\n\nasync def test_requires_api_key(client):\n    \"\"\"AC8: no Authorization header, and an invalid/malformed key, both 401.\"\"\"\n    missing = await client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()})\n    invalid = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str()},\n        headers={\"Authorization\": \"Bearer mtr_live_bogus_bogus\"},\n    )\n\n    assert missing.status_code == 401\n    assert invalid.status_code == 401\n\n\nasync def test_ingest_key_allowed_not_admin_gated(client, make_api_key):\n    \"\"\"AC9: a plain ingest-scoped (non-admin) key gets 200 — no admin scope\n    is required for this customer-scoped read.\"\"\"\n    ingest_key, _ = await make_api_key(label=\"ingest\", scope=\"ingest\")\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str()},\n        headers={\"Authorization\": f\"Bearer {ingest_key}\"},\n    )\n\n    assert response.status_code == 200\n\n\nasync def test_utc_day_boundary_is_half_open(client, make_api_key, postgres_url):\n    \"\"\"AC10: an event at 23:xxZ of date D is counted for D; an event at\n    00:00Z of D+1 is not — the half-open [day_start, day_end) window.\"\"\"\n    presented_key, api_key_id = await make_api_key()\n    today = datetime.now(timezone.utc).date()\n    # Use a date safely inside the accepted range so D+1's 00:00Z boundary\n    # doesn't itself risk landing outside [today-90d, today+1d].\n    target_day = today - timedelta(days=5)\n    end_of_target_day = datetime(target_day.year, target_day.month, target_day.day, 23, 30, tzinfo=timezone.utc)\n    start_of_next_day = end_of_target_day + timedelta(hours=1)  # 00:30Z of target_day + 1\n\n    await _insert_rollup_row(\n        postgres_url, api_key_id=api_key_id, customer_id=\"cust_seam\", metric=\"api_calls\",\n        window_start=end_of_target_day, event_count=1,\n    )\n    await _insert_rollup_row(\n        postgres_url, api_key_id=api_key_id, customer_id=\"cust_seam\", metric=\"api_calls\",\n        window_start=start_of_next_day, event_count=100,\n    )\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": target_day.isoformat()},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 200\n    body = response.json()\n    assert body[\"metrics\"] == [{\"metric\": \"api_calls\", \"event_count\": 1}]\n\n\nasync def test_existing_usage_endpoint_unchanged(client, make_api_key):\n    \"\"\"AC11: mounting the new route doesn't disturb POST /v1/events or\n    GET /v1/usage's existing behavior.\"\"\"\n    presented_key, _ = await make_api_key()\n    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n\n    post_response = await client.post(\"/v1/events\", json=_event_payload(idempotency_key=\"sanity\"), headers=headers)\n    assert post_response.status_code == 201\n\n    now = datetime.now(timezone.utc).isoformat()\n    usage_response = await client.get(\n        \"/v1/usage\",\n        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"window\": now},\n        headers=headers,\n    )\n    assert usage_response.status_code == 200\n    body = usage_response.json()\n    assert Decimal(str(body[\"total_quantity\"])) == Decimal(\"5\")\n    assert body[\"event_count\"] == 1\n\n\nasync def test_emits_usage_daily_read_log(client, make_api_key, capsys):\n    \"\"\"AC12: a `usage.daily.read` structured event is emitted with\n    userId/action/resource/date and no customer_id value (structlog prints\n    JSON to stdout — see test_logging_redaction.py).\"\"\"\n    import json\n\n    presented_key, api_key_id = await make_api_key()\n\n    response = await client.get(\n        \"/v1/usage/daily\",\n        params={\"date\": _today_utc_str()},\n        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n    )\n\n    assert response.status_code == 200\n    captured = capsys.readouterr()\n    matching = [\n        json.loads(line)\n        for line in captured.out.splitlines()\n        if '\"event\": \"usage.daily.read\"' in line\n    ]\n    assert len(matching) == 1\n    record = matching[0]\n    assert record[\"userId\"] == api_key_id\n    assert record[\"action\"] == \"read\"\n    assert record[\"resource\"] == \"usage_rollup\"\n    assert record[\"date\"] == _today_utc_str()\n    assert \"customer_id\" not in record\n\n\nasync def test_route_behind_tier2_throttle(truncate_tables, make_api_key):\n    \"\"\"AC13: the route resolves the Tier-2 per-api_key_id throttle — a key\n    with a tiny bucket gets 429 on the second call within the same second.\"\"\"\n    from src.main import app\n\n    presented_key, _ = await make_api_key(rate_limit_per_sec=1)\n\n    transport = ASGITransport(app=app)\n    async with AsyncClient(transport=transport, base_url=\"http://test\") as scoped_client:\n        headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n        first = await scoped_client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()}, headers=headers)\n        second = await scoped_client.get(\"/v1/usage/daily\", params={\"date\": _today_utc_str()}, headers=headers)\n\n    assert first.status_code == 200\n    assert second.status_code == 429\n    assert \"Retry-After\" in second.headers\n\n\nasync def test_openapi_documents_daily_route(client):\n    \"\"\"AC14: the served /openapi.json includes GET /v1/usage/daily with its\n    DailyUsageResponse schema.\"\"\"\n    response = await client.get(\"/openapi.json\")\n\n    assert response.status_code == 200\n    schema = response.json()\n    assert \"/v1/usage/daily\" in schema[\"paths\"]\n    operation = schema[\"paths\"][\"/v1/usage/daily\"][\"get\"]\n    assert \"200\" in operation[\"responses\"]\n    content_schema = operation[\"responses\"][\"200\"][\"content\"][\"application/json\"][\"schema\"]\n    assert \"$ref\" in content_schema or \"properties\" in content_schema\n\n\nasync def test_daily_forced_repo_error_returns_generic_500(truncate_tables, make_api_key, monkeypatch):\n    \"\"\"AC15: a forced failure inside aggregate_daily_event_counts (simulating\n    a DB/connection drop) returns the generic 500 internal envelope — no\n    stack/SQL/detail leak, no error-swallowing try/except in the route or\n    service (mirrors the usage_export sibling test).\"\"\"\n    from src.main import app\n    from src.services import usage_daily_service\n\n    async def _raising_aggregate(session, **kwargs):\n        raise RuntimeError(\"simulated connection drop mid-aggregate\")\n\n    monkeypatch.setattr(usage_daily_service, \"aggregate_daily_event_counts\", _raising_aggregate)\n\n    presented_key, _ = await make_api_key()\n\n    transport = ASGITransport(app=app, raise_app_exceptions=False)\n    async with AsyncClient(transport=transport, base_url=\"http://test\") as forced_client:\n        response = await forced_client.get(\n            \"/v1/usage/daily\",\n            params={\"date\": _today_utc_str()},\n            headers={\"Authorization\": f\"Bearer {presented_key}\"},\n        )\n\n    assert response.status_code == 500\n    body = response.json()\n    assert body[\"error\"][\"code\"] == \"internal\"\n    assert \"requestId\" in body[\"error\"]\n    assert \"simulated connection drop\" not in response.text\n    assert \"Traceback\" not in response.text\n","numLines":371,"startLine":1,"totalLines":371}},"sourceToolAssistantUUID":"63cb6082-3981-4fe0-89a9-0c7252bb53dc","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
