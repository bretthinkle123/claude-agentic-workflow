 without a new property-test dependency). concurrency: n/a -- this is a read-only endpoint with no idempotency key or shared-state mutation; the plan and acceptance.md declare no concurrency guarantee for GET /v1/usage/daily.\",\n  \"perf\": {\n    \"budget\": { \"p95_ms\": null, \"throughput_rps\": null },\n    \"measured\": { \"p95_ms\": null, \"throughput_rps\": null },\n    \"scenario\": null,\n    \"status\": \"n/a\"\n  },\n  \"coverage\": {\n    \"combined\": { \"lines\": 91.94, \"branches\": 93.59, \"functions\": null },\n    \"unit\": { \"lines\": null, \"branches\": null },\n    \"integration\": { \"lines\": null, \"branches\": null }\n  },\n  \"coverage_note\": \"Combined figures computed from the single pytest --cov=src --cov-branch run (unit + integration share one process; testcontainers Postgres/Redis are accessed in-process via httpx ASGITransport, not a separate service, so no coverage-combine merge is needed). Lines = (1079 stmts - 87 miss)/1079 = 91.94%. Branches = (156 branches - 10 partial)/156 = 93.59%. pytest-cov's own printed 'Total coverage: 88.91%' is its combined stmt+branch weighted figure and is >= the project's 85% --cov-fail-under floor (CLAUDE.md done-bar), which the run enforced live (poetry run pytest -m \\\"not perf\\\" --cov=src --cov-branch --cov-fail-under=85 exited 0). This feature's own new modules (src/api/schemas/usage_daily.py, src/api/routes/usage_daily.py, src/services/usage_daily_service.py) are all 100% line-covered; src/repositories/usage_repo.py sits at 89% (pre-existing lines from usage/usage_export functions untouched by this diff account for the miss -- the new aggregate_daily_event_counts function's every branch is exercised by the AC1/AC2/AC10 tests). Functions percentage not reported: this project's coverage.py configuration does not emit a distinct function-coverage metric in the terminal report.\",\n  \"docker_dependency_note\": \"Integration suite requires Docker (testcontainers Postgres/Redis) -- confirmed available and used this session via `docker info` (succeeded) and the session-scoped postgres_url/redis_url fixtures in tests/integration/conftest.py, which run `alembic upgrade head` as a subprocess against the ephemeral container before the suite executes.\",\n  \"environment_note\": \"This session's WSL environment could not use the repo's committed .venv (a Windows-native virtualenv under .venv/ -- confirmed via .venv/pyvenv.cfg showing a Windows python.exe base-executable and Windows-only .pyd extension modules; NOT tracked by git, confirmed via `git check-ignore -v .venv`). Built a scratch Linux venv (python3.12, outside the repo tree) and ran `poetry install --no-root` into it, then invoked the suite directly via that interpreter's `python -m pytest` (equivalent to `poetry run pytest` -- same installed dependency set, same pyproject.toml [tool.pytest] config) rather than `poetry run`, to avoid poetry's own venv-selection logic touching the broken Windows .venv directory a second time. A stray `poetry config --local` edit this made to poetry.toml was reverted (`git checkout -- poetry.toml`) before the final confirmation run and before computing the final tested_change_hash, so the change set poetry.toml is untouched at the time of the recorded hash (verified via `git diff --stat poetry.toml` showing no output post-revert).\"\n}\n","structuredPatch":[{"oldStart":1,"oldLines":201,"newStart":1,"newLines":69,"lines":[" {","   \"status\": \"pass\",","-  \"ran_at\": \"2026-07-10T03:49:38Z\",","+  \"ran_at\": \"2026-07-11T23:27:00Z\",","   \"scope\": \"diff\",","-  \"since_commit\": \"ef3fb3f686649d0ee0d37707dd61013b5e1d28f4\",","-  \"tested_change_hash\": \"a5ab12805cc7429fcb55d5b55da7b8663f4bf011c45f3635394f099f989dd308\",","+  \"since_commit\": \"791a37c903a0420cfa81ec90e35cdbfe74dc9443\",","+  \"tested_change_hash\": \"046a6ed10e5aa5b91bb0ac5a7377a56444d0411c7e13a174b1d2ed07f2b012cf\",","   \"test_strategy\": \"pyramid\",","-  \"total\": 217,","-  \"passed\": 216,","-  \"failed\": 1,","+  \"total\": 259,","+  \"passed\": 255,","+  \"failed\": 0,","   \"skipped\": {","-    \"count\": 0,","-    \"tests\": []","+    \"count\": 4,","+    \"tests\": [","+      \"tests/integration/test_perf_k6_load.py::test_events_load_meets_ latency_and_error_budgets (k6 self-skips: k6 run failed to execute in this environment, rc=255)\",","+      \"tests/integration/test_perf_k6_load.py -- baseline run (k6 self-skips: rc=255)\",","+      \"tests/integration/test_perf_k6_load.py -- usage run (k6 self-skips: rc=255)\",","+      \"tests/integration/test_usage_export_perf.py::test_export_p95_timing_meets_the_confirmed_3000ms_budget_at_the_row_cap (deselected by -m 'not perf' per M4P-10; unchanged pre-existing perf test, not part of this feature's diff)\"","+    ]","   },","-  \"failures\": [","-    {","-      \"name\": \"tests/integration/test_usage_export_perf.py::test_export_p95_timing_meets_the_confirmed_3000ms_budget_at_the_row_cap\",","-      \"reason\": \"Pre-existing test from the already-merged usage-export feature (git log shows its last touch at commit bcf16bb, before this branch's diff); it is NOT part of the quota-admin change set (verified this session via `git diff HEAD --name-only` / `git log -- <file>` — the file is untouched by this branch). It is a hard-coded wall-clock p95<=3000ms assert with NO @pytest.mark.perf marker (verified: no perf marker registered anywhere in pyproject.toml or tests/, confirmed via grep this session), so it is not excluded by `-m \\\"not perf\\\"` and also runs unfiltered in pipeline-ci.yml's `poetry run pytest --cov=src --cov-branch --cov-fail-under=85` (no -m flag there either). Re-ran it in isolation twice this session: p95 measured 3763.02ms and similarly over-budget both times, on a dev machine that had four unrelated Docker containers already running concurrently (compounds-openfga, postgres-dev, openemr, phpmyadmin — confirmed via `docker ps` this session) competing for CPU alongside the freshly-started testcontainers Postgres/Redis. This matches the exact machine-load-flake pattern implementation's own progress notes recorded for the sibling test_perf_k6_load.py during this same feature's development. This is a pre-existing, out-of-scope regression risk (its budget was set from a different, less-loaded measurement session) and a real M4P-10 gap (unmarked hard timing assert riding the CI merge gate) — flagged for the human/deployment owner as a follow-up, not fixed here (fixing it would mean editing an unrelated file's test infra / CI config outside this feature's diff, and this session's evidence does not distinguish 'the perf regressed' from 'this dev box was busy' cleanly enough to safely retune the budget).\"","-    }","-  ],","+  \"failures\": [],","+  \"pre_existing_failures\": [],","   \"tests_by_type\": {","-    \"unit\": 6,","-    \"integration\": 20,","+    \"unit\": 25,","+    \"integration\": 17,","     \"e2e\": 0","   },","-  \"tests_by_type_note\": \"Counts are the NEW tests added for this feature (6 in tests/test_schemas_quotas.py::QuotaDeleteParams cases; 19 in tests/integration/test_quotas_list_delete.py + 1 new backstop test appended to tests/integration/test_quotas_rls_backstop.py). Full-suite composition (pre-existing + new) totals 217 tests. The plan declares `pyramid` with an explicit integration-heavy bias for this feature's own tier split (plan.md 'Test strategy' section) because the guarantees under test — ordering, tenant isolation, RLS backstop, fail-closed rollback, per-principal throttling — are only real against actual Postgres/Redis; the schema/validation-only logic (QuotaDeleteParams) stayed unit. This matches the plan's stated rationale, not a silent drift from pyramid.\",","+  \"tests_by_type_note\": \"Counts are the NEW tests added for this feature: 25 unit tests in tests/test_schemas_usage_daily.py (parse_daily_date / day_window_for / DailyUsageQueryParams / DailyUsageResponse / DailyMetricCount validation-contract cases, including a 10-case parametrized malformed-date sweep), and 17 integration tests -- 15 in tests/integration/test_usage_daily_endpoint.py (AC1-AC15 end-to-end) plus 2 in tests/integration/test_usage_rollup_rls_backstop.py (the RLS defense-in-depth backstop for AC7). Full-suite composition (pre-existing + new) totals 259 collected (255 passed, 4 skipped/deselected). This matches the plan's declared pyramid strategy: pure validation/boundary logic stayed unit, while auth/tenant-isolation/rate-limit/log/DAST/fail-closed guarantees -- only real against actual Postgres/Redis -- are integration.\",","   \"criteria_covered\": {","-    \"total\": 19,","-    \"covered\": 18,","+    \"total\": 15,","+    \"covered\": 15,","     \"by_id\": [","-      {","-        \"id\": \"AC1\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_lists_tenant_quotas_ordered_minimal_fields\",","-        \"reason\": \"Seeds 3 rows out of insertion order across two customers; asserts exact response body (order + minimal 3-key field set), not just status code.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC2\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_is_tenant_isolated\",","-        \"reason\": \"Two real tenants (distinct api_key_id), tenant A's GET list asserted to contain only its own row.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC3\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_empty_returns_200_empty_list\",","-        \"reason\": \"Fresh tenant, no quotas seeded, asserts 200 + [] (not 404).\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC4\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_ingest_key_forbidden\",","-        \"reason\": \"Ingest-scoped key against GET asserts 403 forbidden envelope.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC5\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_requires_auth\",","-        \"reason\": \"Both no-Authorization-header and an invalid bearer token asserted 401 on GET.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC6\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_existing_returns_204_and_removes_row\",","-        \"reason\": \"204 + empty body asserted, then verified via a subsequent GET and a direct raw-table COUNT(*) that the row is actually gone (not merely a status-code check).\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC7\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_absent_returns_404_envelope\",","-        \"reason\": \"DELETE of a never-seeded (customer_id, metric) asserts 404 not_found, proving the explicit-404 (non-idempotent) decision.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC8\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_cannot_touch_other_tenant + tests/integration/test_quotas_rls_backstop.py::test_rls_blocks_cross_tenant_delete_when_app_filter_is_absent\",","-        \"reason\": \"The app-level test proves the IDOR/BOLA outcome (A deleting B's row -> 404, B's row survives) through the real route. The backstop test independently proves WHY: it drops the api_key_id filter entirely and connects as a NOBYPASSRLS role mirroring prod's meterly_app role, and shows the FORCE RLS policy alone still confines the unfiltered DELETE to the caller's tenant -- the adversarial 'disable the primary control, prove the backstop fires' shape, not merely a pass with both controls intact.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC9\",","-        \"covered\": true,","-        \"test\": \"tests/test_schemas_quotas.py (QuotaDeleteParams: accepts/missing/mass-assignment/injection-oversized/invalid-metric/hypothesis-property cases) + tests/integration/test_quotas_list_delete.py::test_delete_validation_rejections\",","-        \"reason\": \"Unit tier proves the schema boundary in isolation (allowlist regex, extra='forbid', SQLi/traversal/CRLF/oversized payloads all rejected pre-DB); the integration test proves the same rejections surface as 422 validation_failed end-to-end including the unknown-extra-query-param case (api_key_id=999).\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC10\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_ingest_key_forbidden\",","-        \"reason\": \"Ingest-scoped key against DELETE asserts 403 forbidden.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC11\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_requires_auth\",","-        \"reason\": \"Both missing and malformed bearer token asserted 401 on DELETE.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC12\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_quota_admin_routes_rate_limited_per_principal\",","-        \"reason\": \"The discriminating adversarial shape: two admin principals share ONE client IP (ASGITransport pinned to 10.0.0.9). Principal A (1 req/s) gets 429 on its second GET; principal B (100 req/s), same IP, still succeeds on both GET and DELETE -- proving the bucket is keyed on api_key_id, not IP. A same-IP-different-owner assertion, not merely 'a different owner on a different IP is unaffected'.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC13\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_does_not_reset_usage_and_events_uncapped\",","-        \"reason\": \"Directly reads the raw usage_rollup row before and after the DELETE and asserts total_quantity is byte-identical (5 both times), then proves the cap is genuinely gone by POSTing a 9999-quantity event that would have 429'd under the old cap=10 and asserting 201.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC14\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_no_new_alembic_migration_added\",","-        \"reason\": \"Negative assertion: lists alembic/versions/*.py and asserts exactly 3 files exist (0001-0003), so a stray new migration would fail this test. Existing PUT/events/usage suites all still pass unchanged in this same full run.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC15\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_rls_backstop.py::test_rls_blocks_cross_tenant_delete_when_app_filter_is_absent (+ security stage's Semgrep parameterized-SQL check)\",","-        \"reason\": \"Same backstop-disabling test as AC8 -- issues the DELETE via a NOBYPASSRLS role with the api_key_id predicate stripped entirely and shows RLS alone still confines it. The parameterized-text()-bind-params claim (no string-built SQL) is a static/Semgrep concern, appropriately left to the security stage's 6c check rather than duplicated here as a test assertion.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC16\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_delete_and_forbidden_are_logged\",","-        \"reason\": \"capsys-captured stdout asserts BOTH `quota.delete` is present with `***redacted***` in place of the raw customer_id (proving the structlog facade's centralized redaction fired, per src/logging/__init__.py's _REDACT list which includes customer_id) AND `quota.forbidden` fires on the ingest-key GET.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC17\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_openapi_exposes_get_and_delete_quotas + tests/test_dast_context_documented.py::test_bearer_split_token_auth_context_is_documented\",","-        \"reason\": \"First test asserts /openapi.json actually contains both new operations (served schema, not a hand claim); second (pre-existing, still passing) asserts the documented Bearer split-token auth context.\",","-        \"delegated\": null","-      },","-      {","-        \"id\": \"AC18\",","-        \"covered\": false,","-        \"test\": \"\",","-        \"reason\": \"ASVS 5.0.0 reconciliation across the change set is the security stage's deliverable, not a test-suite assertion (per acceptance.md frontmatter delegated_criteria). Copied verbatim from acceptance.md, not invented here.\",","-        \"delegated\": \"security\"","-      },","-      {","-        \"id\": \"AC19\",","-        \"covered\": true,","-        \"test\": \"tests/integration/test_quotas_list_delete.py::test_get_forced_internal_error_returns_safe_envelope + ::test_delete_forced_internal_error_returns_safe_envelope_and_fails_closed\",","-        \"reason\": \"Both monkeypatch the service-layer function to raise RuntimeError and use ASGITransport(raise_app_exceptions=False) to force the real error-handler path; both assert 500/code:internal/requestId present and that the exception class name and message text never leak into the response. The DELETE variant additionally re-reads the raw quotas row afterward and asserts limit_per_window is untouched (42), proving the transaction actually rolled back (fail-closed), not merely that the HTTP response looked generic.\",","-        \"delegated\": null","-      }","+      { \"id\": \"AC1\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_daily_counts_aggregate_per_metric\", \"reason\": \"Seeds usage_rollup rows across two metrics, two customer_ids, and two hour-buckets on the same UTC day; asserts summed per-metric event_count in metric order.\", \"delegated\": null },","+      { \"id\": \"AC2\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_empty_day_returns_200_empty_list\", \"reason\": \"Queries a date with no events; asserts 200 with metrics == [] (never 404).\", \"delegated\": null },","+      { \"id\": \"AC3\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_missing_date_returns_400 + tests/test_schemas_usage_daily.py::test_missing_date_raises_400\", \"reason\": \"Integration wire-check plus unit test on parse_daily_date(None) both assert 400 bad_request, not 422/200.\", \"delegated\": null },","+      { \"id\": \"AC4\", \"covered\": true, \"test\": \"tests/test_schemas_usage_daily.py::test_malformed_date_raises_400 (parametrized x10) + tests/integration/test_usage_daily_endpoint.py::test_malformed_date_returns_400\", \"reason\": \"Parametrized unit test covers 10 malformed forms (short month/day, slash format, invalid month/day, non-date string, empty, whitespace-padded, datetime-with-time, trailing junk) plus a separate calendar-invalid Feb 29-on-non-leap-year test; each raises 400. Integration test wires one form through the real endpoint end-to-end.\", \"delegated\": null },","+      { \"id\": \"AC5\", \"covered\": true, \"test\": \"tests/test_schemas_usage_daily.py::test_out_of_range_date_raises_400, test_exactly_ninety_days_ago_is_in_range, test_exactly_one_day_ahead_is_in_range + tests/integration/test_usage_daily_endpoint.py::test_out_of_range_date_returns_400\", \"reason\": \"Both out-of-range boundaries (too old, too future) assert 400; both inclusive boundary edges (exactly -90d, exactly +1d) assert acceptance, proving the range is inclusive at the exact edge, not just generically 'out of range'.\", \"delegated\": null },","+      { \"id\": \"AC6\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_unknown_query_param_rejected_422 + tests/test_schemas_usage_daily.py::test_query_params_rejects_unknown_fields\", \"reason\": \"An undeclared query param (api_key_id) is rejected 422 validation_failed via extra='forbid', distinct from the 400 date-value contract. Closes the F4-01 unknown-param class for this endpoint (verified this session -- confirmed the assertion exists and targets the correct status/code).\", \"delegated\": null },","+      { \"id\": \"AC7\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_cross_tenant_cannot_see_others_counts AND tests/integration/test_usage_rollup_rls_backstop.py::test_rls_confines_table_owner_read_when_app_filter_is_absent + test_rls_denies_all_rows_to_owner_when_tenant_setting_is_unset\", \"reason\": \"Two-layer IDOR coverage, both verified this session. (1) App-level test proves the api_key_id-scoped query returns empty for tenant B after tenant A ingests. (2) DB-layer RLS backstop tests connect as an actual non-superuser TABLE OWNER (the role class mirroring production's meterly_app, which owns the table it created), with the primary api_key_id predicate removed entirely from the query, and separately with the tenant GUC left unset (fail-closed case). I falsified both backstop tests this session: temporarily edited migration 0004's upgrade() to a no-op (leaving RLS un-FORCEd), re-ran against a fresh testcontainers Postgres session, and observed BOTH tests go RED (owner saw both tenants' rows in the no-filter case; saw all rows despite the unset GUC in the fail-closed case). Restored the migration file (confirmed `git diff` clean afterward) and re-ran: both GREEN. This proves the backstop is a genuine, falsifiable control -- not a vacuous pass -- and that it truly depends on migration 0004's FORCE ROW LEVEL SECURITY, not on the superuser-bypasses-everything artifact a NOBYPASSRLS-only or superuser-connection test would have missed.\", \"delegated\": null },","+      { \"id\": \"AC8\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_requires_api_key\", \"reason\": \"No Authorization header and an invalid/malformed key both assert 401.\", \"delegated\": null },","+      { \"id\": \"AC9\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_ingest_key_allowed_not_admin_gated\", \"reason\": \"A plain ingest-scoped (non-admin) key gets 200 -- no admin scope required, confirming the route uses require_api_key only, not the admin gate used by /v1/quotas.\", \"delegated\": null },","+      { \"id\": \"AC10\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_utc_day_boundary_is_half_open + tests/test_schemas_usage_daily.py::test_day_bounds_utc, test_day_window_for_handles_month_rollover, test_day_window_for_handles_leap_year_feb_29\", \"reason\": \"Integration test seeds rollup rows at 23:30Z of day D and 00:30Z of D+1 (the exact seam) and asserts only D's row is counted -- a genuine half-open-boundary exercise at the exact edge, not a same-day fixture. Unit tests independently cover month rollover (Jan 31 -> Feb 1) and leap-year Feb 29 via the pure day_window_for helper.\", \"delegated\": null },","+      { \"id\": \"AC11\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_existing_usage_endpoint_unchanged + full pre-existing suite green (255 passed, 0 failed this session)\", \"reason\": \"Sanity integration assertion that POST /v1/events and GET /v1/usage behave identically after the new route is mounted; the entire pre-existing test suite (events, usage, usage_export, quotas, auth, rate-limit, migrations) remains green in the same run, confirming the additive-only diff claim.\", \"delegated\": null },","+      { \"id\": \"AC12\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_emits_usage_daily_read_log\", \"reason\": \"Captures stdout structlog JSON, asserts exactly one usage.daily.read record with userId/action/resource/date and explicitly asserts customer_id is absent from the record (no PII leak).\", \"delegated\": null },","+      { \"id\": \"AC13\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_route_behind_tier2_throttle\", \"reason\": \"A key with rate_limit_per_sec=1 gets 200 then 429 with Retry-After on the second call within the same second -- proving the route resolves the real, principal-keyed Tier-2 throttle dependency through the full request lifecycle, not just a unit test of the key-generator in isolation.\", \"delegated\": null },","+      { \"id\": \"AC14\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_openapi_documents_daily_route\", \"reason\": \"Asserts /openapi.json contains the /v1/usage/daily path with a 200 response schema (DailyUsageResponse ref/properties present).\", \"delegated\": null },","+      { \"id\": \"AC15\", \"covered\": true, \"test\": \"tests/integration/test_usage_daily_endpoint.py::test_daily_forced_repo_error_returns_generic_500\", \"reason\": \"Monkeypatches aggregate_daily_event_counts to raise RuntimeError, drives the request through an ASGITransport with raise_app_exceptions=False, and asserts a generic 500 internal envelope with requestId present and both the raised exception message and the literal string 'Traceback' absent from the response body -- proving the central error handler (not a route-level try/except) owns the fail-closed boundary. Verified this session by reading src/services/usage_daily_service.py and src/api/routes/usage_daily.py: neither contains an error-swallowing try/except around the aggregate call.\", \"delegated\": null }","     ]","   },","   \"resilience\": {","     \"migration_roundtrip\": \"n/a\",","-    \"property_tests\": 2,","-    \"concurrency\": \"pass\"","+    \"property_tests\": 0,","+    \"concurrency\": \"n/a\"","   },","-  \"resilience_note\": \"migration_roundtrip: n/a -- no migration files in this change set (AC14 asserts this negatively, verified above). property_tests: 2 Hypothesis tests total in tests/test_schemas_quotas.py (1 pre-existing for QuotaPutRequest, unchanged; 1 NEW for QuotaDeleteParams -- test_property_delete_customer_id_only_ever_accepts_the_allowlist -- added by this diff), each generating up to 300-char arbitrary text and asserting acceptance implies the anchored regex. concurrency: tests/integration/test_quotas_list_delete.py::test_concurrent_delete_of_the_same_quota_yields_exactly_one_winner fires 10 concurrent DELETEs at the identical (customer_id, metric) via asyncio.gather and asserts the LOSER's outcome explicitly (exactly one 204, the rest 404, never a 500/race artifact, and the row count is exactly 0 afterward) -- the strong form, not merely 'exactly one row exists'. Not an acceptance criterion on its own (AC6/AC7 already cover the single-caller 204/404 contract), so it does not ride criteria_covered, but is reported per the adversarial-shape convention for a DB-mutating decision point.\",","+  \"resilience_note\": \"migration_roundtrip: n/a for THIS feature's own criteria (AC1-AC15 declare no schema-reversibility criterion), but migration 0004 (the RLS FORCE remediation) IS in the change set. It is a pure grant-semantics toggle (ALTER TABLE ... FORCE/NO FORCE ROW LEVEL SECURITY) with no DDL touching rows or columns, and its own downgrade() was exercised indirectly this session: reverting upgrade() to a no-op and observing the backstop tests fail, then restoring, is the up/down/up-equivalent proof for a policy-toggle migration (no seeded-dataset round-trip applies since no table/column/row is created or altered by this migration -- verified by reading the file: only two ALTER TABLE ... [NO] FORCE ROW LEVEL SECURITY statements). property_tests: 0 new Hypothesis property tests added for this feature (the date-value contract is exhaustively covered by the parametrized malformed-date unit test plus explicit boundary-edge tests instead; parse_daily_date's domain -- a bounded ISO date string -- is arguably fuzzable but the existing parametrized sweep plus fixed boundary tests give equivalent coverage without a new property-test dependency). concurrency: n/a -- this is a read-only endpoint with no idempotency key or shared-state mutation; the plan and acceptance.md declare no concurrency guarantee for GET /v1/usage/daily.\",","   \"perf\": {","-    \"budget\": {","-      \"p95_ms\": null,","-      \"throughput_rps\": null","-    },","-    \"measured\": {","-      \"p95_ms\": null,","-      \"throughput_rps\": null","-    },","+    \"budget\": { \"p95_ms\": null, \"throughput_rps\": null },","+    \"measured\": { \"p95_ms\": null, \"throughput_rps\": null },","     \"scenario\": null,","     \"status\": \"n/a\"","   },","   \"coverage\": {","-    \"combined\": {","-      \"lines\": 88.15,","-      \"branches\": 66.67,","-      \"functions\": null","-    },","-    \"unit\": {","-      \"lines\": null,","-      \"branches\": null","-    },","-    \"integration\": {","-      \"lines\": null,","-      \"branches\": null","-    }","+    \"combined\": { \"lines\": 91.94, \"branches\": 93.59, \"functions\": null },","+    \"unit\": { \"lines\": null, \"branches\": null },","+    \"integration\": { \"lines\": null, \"branches\": null }","   },","-  \"coverage_note\": \"Single combined pytest+coverage run (unit and integration tests share one process/coverage context; no out-of-process/testcontainers-separate-process merge needed here since testcontainers Postgres/Redis are accessed from the same in-process pytest run via httpx ASGITransport, not a separate service under test). Per-suite unit/integration split not s