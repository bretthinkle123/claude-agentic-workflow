{"parentUuid":"f6562271-9112-4802-9cd5-97fcd87397d7","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEVFvqnXD45czHavLr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GyFFPB5vapNRXEj7t6tuSZ","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1265,"cache_read_input_tokens":46859,"cache_creation":{"ephemeral_5m_input_tokens":1265,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcvwEUNbS239wQtVJJLVR","attributionAgent":"implementation","type":"assistant","uuid":"05547c99-8119-47ef-8099-08266434901d","timestamp":"2026-07-11T20:54:46.214Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"05547c99-8119-47ef-8099-08266434901d","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GyFFPB5vapNRXEj7t6tuSZ","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage`.\n2\t\n3\t`window` must be a timezone-aware ISO-8601 timestamp within `[now-90d, now+1h]`;\n4\ta naive datetime (no offset) is rejected rather than silently assumed-UTC, since\n5\tguessing wrong would silently misattribute a bucket.\n6\t\"\"\"\n7\t\n8\tfrom datetime import datetime, timedelta, timezone\n9\tfrom decimal import Decimal\n10\t\n11\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, field_validator\n12\t\n13\tfrom src.api.schemas.events import CustomerId, Metric\n14\t\n15\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n16\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n17\t\n18\t\n19\tclass UsageQueryParams(BaseModel):\n20\t    \"\"\"The three required query parameters of `GET /v1/usage`, validated as a\n21\t    single boundary schema rather than three ad-hoc query-param checks.\"\"\"\n22\t\n23\t    model_config = ConfigDict(extra=\"forbid\")\n24\t\n25\t    customer_id: CustomerId\n26\t    metric: Metric\n27\t    window: AwareDatetime\n28\t\n29\t    @field_validator(\"window\")\n30\t    @classmethod\n31\t    def _window_within_supported_range(cls, value: datetime) -> datetime:\n32\t        \"\"\"Reject a `window` timestamp outside the supported query range.\n33\t\n34\t        Pydantic's `AwareDatetime` already rejects naive datetimes; this\n35\t        validator adds the `[now-90d, now+1h]` bound so a caller can't probe\n36\t        arbitrarily far into the past (unbounded query cost) or the future\n37\t        (nothing to aggregate yet).\n38\t        \"\"\"\n39\t        now = datetime.now(timezone.utc)\n40\t        earliest = now - _MAX_WINDOW_LOOKBACK\n41\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n42\t        if not (earliest <= value <= latest):\n43\t            raise ValueError(\n44\t                f\"window must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n45\t            )\n46\t        return value\n47\t\n48\t\n49\tclass UsageResponse(BaseModel):\n50\t    \"\"\"The minimal response field set for a usage query (ASVS 15.3.1).\"\"\"\n51\t\n52\t    model_config = ConfigDict(extra=\"forbid\")\n53\t\n54\t    customer_id: str\n55\t    metric: str\n56\t    window_start: str\n57\t    total_quantity: Decimal\n58\t    event_count: int\n59\t"}]},"uuid":"0036f999-aa14-4086-b528-4a79710e4f06","timestamp":"2026-07-11T20:54:46.259Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage.py","content":"\"\"\"Validation contract for `GET /v1/usage`.\n\n`window` must be a timezone-aware ISO-8601 timestamp within `[now-90d, now+1h]`;\na naive datetime (no offset) is rejected rather than silently assumed-UTC, since\nguessing wrong would silently misattribute a bucket.\n\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\nfrom decimal import Decimal\n\nfrom pydantic import AwareDatetime, BaseModel, ConfigDict, field_validator\n\nfrom src.api.schemas.events import CustomerId, Metric\n\n_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n\n\nclass UsageQueryParams(BaseModel):\n    \"\"\"The three required query parameters of `GET /v1/usage`, validated as a\n    single boundary schema rather than three ad-hoc query-param checks.\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    customer_id: CustomerId\n    metric: Metric\n    window: AwareDatetime\n\n    @field_validator(\"window\")\n    @classmethod\n    def _window_within_supported_range(cls, value: datetime) -> datetime:\n        \"\"\"Reject a `window` timestamp outside the supported query range.\n\n        Pydantic's `AwareDatetime` already rejects naive datetimes; this\n        validator adds the `[now-90d, now+1h]` bound so a caller can't probe\n        arbitrarily far into the past (unbounded query cost) or the future\n        (nothing to aggregate yet).\n        \"\"\"\n        now = datetime.now(timezone.utc)\n        earliest = now - _MAX_WINDOW_LOOKBACK\n        latest = now + _MAX_WINDOW_LOOKAHEAD\n        if not (earliest <= value <= latest):\n            raise ValueError(\n                f\"window must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n            )\n        return value\n\n\nclass UsageResponse(BaseModel):\n    \"\"\"The minimal response field set for a usage query (ASVS 15.3.1).\"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\")\n\n    customer_id: str\n    metric: str\n    window_start: str\n    total_quantity: Decimal\n    event_count: int\n","numLines":59,"startLine":1,"totalLines":59}},"sourceToolAssistantUUID":"05547c99-8119-47ef-8099-08266434901d","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"0036f999-aa14-4086-b528-4a79710e4f06","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEVFvqnXD45czHavLr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01GLbG4ALtmaVFwfMypr1gpz","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1265,"cache_read_input_tokens":46859,"cache_creation":{"ephemeral_5m_input_tokens":1265,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcvwEUNbS239wQtVJJLVR","attributionAgent":"implementation","type":"assistant","uuid":"f56e0442-66be-4d10-816c-f7ab0cb0d77d","timestamp":"2026-07-11T20:54:47.047Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"f56e0442-66be-4d10-816c-f7ab0cb0d77d","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GLbG4ALtmaVFwfMypr1gpz","type":"tool_result","content":"1\t\"\"\"Validation contract for `GET /v1/usage/export`.\n2\t\n3\tReuses the exact `customer_id`/`metric` anchored allowlists\n4\t`src/api/schemas/events.py` already enforces for the SQL sink these filters\n5\tshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\n6\tapplied here as an optional `[from, to]` range rather than a single\n7\tpoint-in-time window.\n8\t\"\"\"\n9\t\n10\tfrom datetime import datetime, timedelta, timezone\n11\t\n12\tfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n13\t\n14\tfrom src.api.schemas.events import CustomerId, Metric\n15\t\n16\t_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n17\t_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n18\t\n19\t\n20\tclass UsageExportQueryParams(BaseModel):\n21\t    \"\"\"Optional filters for `GET /v1/usage/export`.\n22\t\n23\t    Every field is optional; omitting all of them exports the caller's full\n24\t    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n25\t    unknown query parameter — the same mass-assignment posture the write\n26\t    schemas use, applied to a read (a client-supplied `api_key_id` is\n27\t    rejected rather than silently ignored).\n28\t    \"\"\"\n29\t\n30\t    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n31\t\n32\t    customer_id: CustomerId | None = None\n33\t    metric: Metric | None = None\n34\t    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n35\t    to: AwareDatetime | None = None\n36\t\n37\t    @model_validator(mode=\"after\")\n38\t    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n39\t        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n40\t        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n41\t        so a caller can't probe arbitrarily far into the past (unbounded\n42\t        query cost) or the future.\"\"\"\n43\t        now = datetime.now(timezone.utc)\n44\t        earliest = now - _MAX_WINDOW_LOOKBACK\n45\t        latest = now + _MAX_WINDOW_LOOKAHEAD\n46\t\n47\t        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n48\t            if value is not None and not (earliest <= value <= latest):\n49\t                raise ValueError(\n50\t                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n51\t                )\n52\t\n53\t        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n54\t            raise ValueError(\"from must be <= to\")\n55\t\n56\t        return self\n57\t"}]},"uuid":"0fe1a6b9-fb95-4f82-97f9-4c15360a1128","timestamp":"2026-07-11T20:54:47.087Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/schemas/usage_export.py","content":"\"\"\"Validation contract for `GET /v1/usage/export`.\n\nReuses the exact `customer_id`/`metric` anchored allowlists\n`src/api/schemas/events.py` already enforces for the SQL sink these filters\nshare, and the same `[now-90d, now+1h]` window-bound idiom `usage.py` uses —\napplied here as an optional `[from, to]` range rather than a single\npoint-in-time window.\n\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\n\nfrom pydantic import AwareDatetime, BaseModel, ConfigDict, Field, model_validator\n\nfrom src.api.schemas.events import CustomerId, Metric\n\n_MAX_WINDOW_LOOKBACK = timedelta(days=90)\n_MAX_WINDOW_LOOKAHEAD = timedelta(hours=1)\n\n\nclass UsageExportQueryParams(BaseModel):\n    \"\"\"Optional filters for `GET /v1/usage/export`.\n\n    Every field is optional; omitting all of them exports the caller's full\n    row set (subject to the 100,000-row cap). `extra='forbid'` rejects an\n    unknown query parameter — the same mass-assignment posture the write\n    schemas use, applied to a read (a client-supplied `api_key_id` is\n    rejected rather than silently ignored).\n    \"\"\"\n\n    model_config = ConfigDict(extra=\"forbid\", populate_by_name=True)\n\n    customer_id: CustomerId | None = None\n    metric: Metric | None = None\n    from_: AwareDatetime | None = Field(default=None, alias=\"from\")\n    to: AwareDatetime | None = None\n\n    @model_validator(mode=\"after\")\n    def _validate_window_bounds(self) -> \"UsageExportQueryParams\":\n        \"\"\"Enforce `from <= to` and both within `[now-90d, now+1h]` —\n        mirrors `UsageQueryParams`'s single-window bound, applied to a range\n        so a caller can't probe arbitrarily far into the past (unbounded\n        query cost) or the future.\"\"\"\n        now = datetime.now(timezone.utc)\n        earliest = now - _MAX_WINDOW_LOOKBACK\n        latest = now + _MAX_WINDOW_LOOKAHEAD\n\n        for field_name, value in ((\"from\", self.from_), (\"to\", self.to)):\n            if value is not None and not (earliest <= value <= latest):\n                raise ValueError(\n                    f\"{field_name} must be within [{earliest.isoformat()}, {latest.isoformat()}]\"\n                )\n\n        if self.from_ is not None and self.to is not None and self.from_ > self.to:\n            raise ValueError(\"from must be <= to\")\n\n        return self\n","numLines":57,"startLine":1,"totalLines":57}},"sourceToolAssistantUUID":"f56e0442-66be-4d10-816c-f7ab0cb0d77d","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"0fe1a6b9-fb95-4f82-97f9-4c15360a1128","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEVFvqnXD45czHavLr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Q8xq7tHkTgowrvpGuPfVZC","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/usage.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1265,"cache_read_input_tokens":46859,"cache_creation":{"ephemeral_5m_input_tokens":1265,"ephemeral_1h_input_tokens":0},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcvwEUNbS239wQtVJJLVR","attributionAgent":"implementation","type":"assistant","uuid":"fca1da08-6da9-4964-9693-f174e97687aa","timestamp":"2026-07-11T20:54:47.433Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"fca1da08-6da9-4964-9693-f174e97687aa","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Q8xq7tHkTgowrvpGuPfVZC","type":"tool_result","content":"1\t\"\"\"`GET /v1/usage` — the aggregated usage counter for a customer/metric/window.\"\"\"\n2\t\n3\tfrom typing import Annotated\n4\t\n5\tfrom fastapi import APIRouter, Depends, Query, Request\n6\t\n7\tfrom src.api.schemas.usage import UsageQueryParams, UsageResponse\n8\tfrom src.auth import require_api_key\n9\tfrom src.auth.api_key import AuthenticatedPrincipal\n10\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n11\tfrom src.services.usage_service import get_usage\n12\t\n13\trouter = APIRouter(tags=[\"usage\"])\n14\t\n15\t\n16\tasync def _require_authenticated_and_throttled(\n17\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n18\t) -> AuthenticatedPrincipal:\n19\t    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (mirrors\n20\t    `src/api/routes/events.py` — kept as a sibling, not a shared import, so\n21\t    each route's dependency chain stays independently readable).\"\"\"\n22\t    await enforce_tier2_rate_limit(request, principal)\n23\t    return principal\n24\t\n25\t\n26\t@router.get(\"/v1/usage\", response_model=UsageResponse)\n27\tasync def get_usage_endpoint(\n28\t    query: Annotated[UsageQueryParams, Query()],\n29\t    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n30\t) -> UsageResponse:\n31\t    \"\"\"Return the aggregated `{total_quantity, event_count}` for the caller's\n32\t    own `(customer_id, metric, window)` bucket. A bucket with no data returns\n33\t    zeros with 200, never 404.\"\"\"\n34\t    return await get_usage(principal, query)\n35\t"}]},"uuid":"ca159473-4e4b-4d2f-8cdc-9d125262d9de","timestamp":"2026-07-11T20:54:47.469Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/usage.py","content":"\"\"\"`GET /v1/usage` — the aggregated usage counter for a customer/metric/window.\"\"\"\n\nfrom typing import Annotated\n\nfrom fastapi import APIRouter, Depends, Query, Request\n\nfrom src.api.schemas.usage import UsageQueryParams, UsageResponse\nfrom src.auth import require_api_key\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.auth.rate_limit import enforce_tier2_rate_limit\nfrom src.services.usage_service import get_usage\n\nrouter = APIRouter(tags=[\"usage\"])\n\n\nasync def _require_authenticated_and_throttled(\n    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n) -> AuthenticatedPrincipal:\n    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (mirrors\n    `src/api/routes/events.py` — kept as a sibling, not a shared import, so\n    each route's dependency chain stays independently readable).\"\"\"\n    await enforce_tier2_rate_limit(request, principal)\n    return principal\n\n\n@router.get(\"/v1/usage\", response_model=UsageResponse)\nasync def get_usage_endpoint(\n    query: Annotated[UsageQueryParams, Query()],\n    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n) -> UsageResponse:\n    \"\"\"Return the aggregated `{total_quantity, event_count}` for the caller's\n    own `(customer_id, metric, window)` bucket. A bucket with no data returns\n    zeros with 200, never 404.\"\"\"\n    return await get_usage(principal, query)\n","numLines":35,"startLine":1,"totalLines":35}},"sourceToolAssistantUUID":"fca1da08-6da9-4964-9693-f174e97687aa","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"ca159473-4e4b-4d2f-8cdc-9d125262d9de","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEVFvqnXD45czHavLr","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Y8fP8C8vJpsD9UfBcudi2q","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1265,"cache_read_input_tokens":46859,"output_tokens":460,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":1265},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":460,"cache_read_input_tokens":46859,"cache_creation_input_tokens":1265,"cache_creation":{"ephemeral_5m_input_tokens":1265,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcvwEUNbS239wQtVJJLVR","attributionAgent":"implementation","type":"assistant","uuid":"a275e06e-1225-456e-ad59-458fb41c05de","timestamp":"2026-07-11T20:54:47.743Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"a275e06e-1225-456e-ad59-458fb41c05de","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Y8fP8C8vJpsD9UfBcudi2q","type":"tool_result","content":"1\t\"\"\"`GET /v1/usage/export` — streams the authenticated caller's own\n2\t`usage_rollup` rows as an RFC 4180 CSV.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; this route wires\n6\tauth -> Tier-2 throttle -> schema validation -> a two-phase pre-flight-cap +\n7\tstream service call, mirroring `src/api/routes/usage.py`'s composition. Kept\n8\tin its own module (not added to `usage.py`) so `GET /v1/usage`'s code path is\n9\tliterally untouched by this change — the brief's no-behavior-change\n10\tconstraint is then trivially auditable in the diff.\n11\t\"\"\"\n12\t\n13\tfrom datetime import datetime, timezone\n14\tfrom typing import Annotated\n15\t\n16\tfrom fastapi import APIRouter, Depends, Query, Request\n17\tfrom fastapi.responses import StreamingResponse\n18\t\n19\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n20\tfrom src.auth import require_api_key\n21\tfrom src.auth.api_key import AuthenticatedPrincipal\n22\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n23\tfrom src.services.usage_export_service import prepare_export, stream_export_csv\n24\t\n25\trouter = APIRouter(tags=[\"usage\"])\n26\t\n27\t# Explicit OpenAPI response metadata: a StreamingResponse has no `response_model`\n28\t# for FastAPI to introspect, so the served schema would otherwise omit the real\n29\t# response shape — this is what a DAST scanner (and AC19) reads.\n30\t_EXPORT_RESPONSES: dict = {\n31\t    200: {\n32\t        \"description\": \"The caller's usage_rollup rows as RFC 4180 CSV (header row always first).\",\n33\t        \"content\": {\"text/csv\": {\"schema\": {\"type\": \"string\", \"format\": \"binary\"}}},\n34\t    },\n35\t    422: {\n36\t        \"description\": \"Validation failure, or the filtered result exceeds the 100,000-row export cap.\",\n37\t        \"content\": {\n38\t            \"application/json\": {\n39\t                \"example\": {\n40\t                    \"error\": {\n41\t                        \"code\": \"validation_failed\",\n42\t                        \"message\": \"result exceeds 100000 rows; narrow with customer_id, metric, from, and/or to\",\n43\t                        \"requestId\": \"…\",\n44\t                    }\n45\t                }\n46\t            }\n47\t        },\n48\t    },\n49\t}\n50\t\n51\t\n52\tasync def _require_authenticated_and_throttled(\n53\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n54\t) -> AuthenticatedPrincipal:\n55\t    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (kept as\n56\t    a sibling, not a shared import, per the existing per-route convention —\n57\t    each route's dependency chain stays independently readable).\"\"\"\n58\t    await enforce_tier2_rate_limit(request, principal)\n59\t    return principal\n60\t\n61\t\n62\tdef _export_filename(now: datetime) -> str:\n63\t    \"\"\"Build the `Content-Disposition` filename: a UTC timestamp only — no\n64\t    tenant identifier, so the filename itself never leaks `api_key_id` or any\n65\t    caller identity (ASVS 14.3.2).\"\"\"\n66\t    return f\"usage-export-{now:%Y%m%dT%H%M%SZ}.csv\"\n67\t\n68\t\n69\t@router.get(\"/v1/usage/export\", responses=_EXPORT_RESPONSES)\n70\tasync def get_usage_export(\n71\t    params: Annotated[UsageExportQueryParams, Query()],\n72\t    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n73\t) -> StreamingResponse:\n74\t    \"\"\"Stream the caller's own `usage_rollup` rows as CSV, optionally\n75\t    narrowed by `customer_id`/`metric`/`from`/`to`.\n76\t\n77\t    Two-phase: `prepare_export` runs the pre-flight row-cap check (a clean\n78\t    422 over 100,000 rows, or a fail-closed generic 500 on an unexpected\n79\t    error — AC22) before any response byte; only then is the\n80\t    `StreamingResponse` constructed. Starlette pulls `stream_export_csv`\n81\t    after this handler returns, so the generator opens its own DB\n82\t    transaction rather than reusing one already closed by the time it runs.\n83\t    \"\"\"\n84\t    await prepare_export(principal, params)\n85\t\n86\t    filename = _export_filename(datetime.now(timezone.utc))\n87\t    return StreamingResponse(\n88\t        stream_export_csv(principal, params),\n89\t        media_type=\"text/csv; charset=utf-8\",\n90\t        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},\n91\t    )\n92\t"}]},"uuid":"5d75d24d-2864-40ea-9daa-3e5cab4174a3","timestamp":"2026-07-11T20:54:47.795Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/api/routes/usage_export.py","content":"\"\"\"`GET /v1/usage/export` — streams the authenticated caller's own\n`usage_rollup` rows as an RFC 4180 CSV.\n\nEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\ninherited from the middleware stack; this route wires\nauth -> Tier-2 throttle -> schema validation -> a two-phase pre-flight-cap +\nstream service call, mirroring `src/api/routes/usage.py`'s composition. Kept\nin its own module (not added to `usage.py`) so `GET /v1/usage`'s code path is\nliterally untouched by this change — the brief's no-behavior-change\nconstraint is then trivially auditable in the diff.\n\"\"\"\n\nfrom datetime import datetime, timezone\nfrom typing import Annotated\n\nfrom fastapi import APIRouter, Depends, Query, Request\nfrom fastapi.responses import StreamingResponse\n\nfrom src.api.schemas.usage_export import UsageExportQueryParams\nfrom src.auth import require_api_key\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.auth.rate_limit import enforce_tier2_rate_limit\nfrom src.services.usage_export_service import prepare_export, stream_export_csv\n\nrouter = APIRouter(tags=[\"usage\"])\n\n# Explicit OpenAPI response metadata: a StreamingResponse has no `response_model`\n# for FastAPI to introspect, so the served schema would otherwise omit the real\n# response shape — this is what a DAST scanner (and AC19) reads.\n_EXPORT_RESPONSES: dict = {\n    200: {\n        \"description\": \"The caller's usage_rollup rows as RFC 4180 CSV (header row always first).\",\n        \"content\": {\"text/csv\": {\"schema\": {\"type\": \"string\", \"format\": \"binary\"}}},\n    },\n    422: {\n        \"description\": \"Validation failure, or the filtered result exceeds the 100,000-row export cap.\",\n        \"content\": {\n            \"application/json\": {\n                \"example\": {\n                    \"error\": {\n                        \"code\": \"validation_failed\",\n                        \"message\": \"result exceeds 100000 rows; narrow with customer_id, metric, from, and/or to\",\n                        \"requestId\": \"…\",\n                    }\n                }\n            }\n        },\n    },\n}\n\n\nasync def _require_authenticated_and_throttled(\n    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n) -> AuthenticatedPrincipal:\n    \"\"\"Compose auth then the Tier-2 per-key throttle, in that order (kept as\n    a sibling, not a shared import, per the existing per-route convention —\n    each route's dependency chain stays independently readable).\"\"\"\n    await enforce_tier2_rate_limit(request, principal)\n    return principal\n\n\ndef _export_filename(now: datetime) -> str:\n    \"\"\"Build the `Content-Disposition` filename: a UTC timestamp only — no\n    tenant identifier, so the filename itself never leaks `api_key_id` or any\n    caller identity (ASVS 14.3.2).\"\"\"\n    return f\"usage-export-{now:%Y%m%dT%H%M%SZ}.csv\"\n\n\n@router.get(\"/v1/usage/export\", responses=_EXPORT_RESPONSES)\nasync def get_usage_export(\n    params: Annotated[UsageExportQueryParams, Query()],\n    principal: AuthenticatedPrincipal = Depends(_require_authenticated_and_throttled),\n) -> StreamingResponse:\n    \"\"\"Stream the caller's own `usage_rollup` rows as CSV, optionally\n    narrowed by `customer_id`/`metric`/`from`/`to`.\n\n    Two-phase: `prepare_export` runs the pre-flight row-cap check (a clean\n    422 over 100,000 rows, or a fail-closed generic 500 on an unexpected\n    error — AC22) before any response byte; only then is the\n    `StreamingResponse` constructed. Starlette pulls `stream_export_csv`\n    after this handler returns, so the generator opens its own DB\n    transaction rather than reusing one already closed by the time it runs.\n    \"\"\"\n    await prepare_export(principal, params)\n\n    filename = _export_filename(datetime.now(timezone.utc))\n    return StreamingResponse(\n        stream_export_csv(principal, params),\n        media_type=\"text/csv; charset=utf-8\",\n        headers={\"Content-Disposition\": f'attachment; filename=\"{filename}\"'},\n    )\n","numLines":92,"startLine":1,"totalLines":92}},"sourceToolAssistantUUID":"a275e06e-1225-456e-ad59-458fb41c05de","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"5d75d24d-2864-40ea-9daa-3e5cab4174a3","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEuHJKmFVyFr3ipyry","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TJLPyERtTVLikep4fMyUXc","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4813,"cache_read_input_tokens":48124,"cache_creation":{"ephemeral_5m_input_tokens":4813,"ephemeral_1h_input_tokens":0},"output_tokens":37,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcvwEsacAa7oCqsSaj9jL","attributionAgent":"implementation","type":"assistant","uuid":"4ef0f516-eb75-4804-bec5-bbd6fe71cc43","timestamp":"2026-07-11T20:54:50.616Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"4ef0f516-eb75-4804-bec5-bbd6fe71cc43","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TJLPyERtTVLikep4fMyUXc","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage` — the scoped rollup read + hour flooring.\n2\t\n3\tA missing bucket is a valid, common answer (zero usage), not an error — see\n4\t`get_usage`'s docstring for why this must never become a 404.\n5\t\"\"\"\n6\t\n7\tfrom decimal import Decimal\n8\t\n9\tfrom src.api.schemas.usage import UsageQueryParams, UsageResponse\n10\tfrom src.auth.api_key import AuthenticatedPrincipal\n11\tfrom src.db.session import scoped_transaction\n12\tfrom src.logging import get_logger\n13\tfrom src.repositories.usage_repo import find_usage_rollup\n14\tfrom src.services.time_windows import floor_to_hour_utc\n15\t\n16\tlogger = get_logger(service=\"meterly\")\n17\t\n18\t\n19\tasync def get_usage(\n20\t    principal: AuthenticatedPrincipal, query: UsageQueryParams\n21\t) -> UsageResponse:\n22\t    \"\"\"Return the aggregated usage counter for `(customer_id, metric, window)`.\n23\t\n24\t    A bucket with no recorded events returns zeros with a 200, never a 404 —\n25\t    returning 404 would leak whether *any* tenant has data for that bucket,\n26\t    and \"no usage yet\" is a legitimate steady state for a new customer.\n27\t    \"\"\"\n28\t    window_start = floor_to_hour_utc(query.window)\n29\t\n30\t    async with scoped_transaction(principal.api_key_id) as session:\n31\t        rollup = await find_usage_rollup(\n32\t            session,\n33\t            api_key_id=principal.api_key_id,\n34\t            customer_id=query.customer_id,\n35\t            metric=query.metric,\n36\t            window_start=window_start,\n37\t        )\n38\t\n39\t    logger.info(\n40\t        \"usage.read\",\n41\t        userId=principal.api_key_id,\n42\t        action=\"read\",\n43\t        found=rollup is not None,\n44\t    )\n45\t\n46\t    total_quantity = rollup.total_quantity if rollup is not None else Decimal(\"0\")\n47\t    event_count = rollup.event_count if rollup is not None else 0\n48\t\n49\t    return UsageResponse(\n50\t        customer_id=query.customer_id,\n51\t        metric=query.metric,\n52\t        window_start=window_start.isoformat(),\n53\t        total_quantity=Decimal(total_quantity),\n54\t        event_count=event_count,\n55\t    )\n56\t"}]},"uuid":"90f4db01-457c-478a-992d-b94037fff4b5","timestamp":"2026-07-11T20:54:50.662Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_service.py","content":"\"\"\"Service for `GET /v1/usage` — the scoped rollup read + hour flooring.\n\nA missing bucket is a valid, common answer (zero usage), not an error — see\n`get_usage`'s docstring for why this must never become a 404.\n\"\"\"\n\nfrom decimal import Decimal\n\nfrom src.api.schemas.usage import UsageQueryParams, UsageResponse\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.db.session import scoped_transaction\nfrom src.logging import get_logger\nfrom src.repositories.usage_repo import find_usage_rollup\nfrom src.services.time_windows import floor_to_hour_utc\n\nlogger = get_logger(service=\"meterly\")\n\n\nasync def get_usage(\n    principal: AuthenticatedPrincipal, query: UsageQueryParams\n) -> UsageResponse:\n    \"\"\"Return the aggregated usage counter for `(customer_id, metric, window)`.\n\n    A bucket with no recorded events returns zeros with a 200, never a 404 —\n    returning 404 would leak whether *any* tenant has data for that bucket,\n    and \"no usage yet\" is a legitimate steady state for a new customer.\n    \"\"\"\n    window_start = floor_to_hour_utc(query.window)\n\n    async with scoped_transaction(principal.api_key_id) as session:\n        rollup = await find_usage_rollup(\n            session,\n            api_key_id=principal.api_key_id,\n            customer_id=query.customer_id,\n            metric=query.metric,\n            window_start=window_start,\n        )\n\n    logger.info(\n        \"usage.read\",\n        userId=principal.api_key_id,\n        action=\"read\",\n        found=rollup is not None,\n    )\n\n    total_quantity = rollup.total_quantity if rollup is not None else Decimal(\"0\")\n    event_count = rollup.event_count if rollup is not None else 0\n\n    return UsageResponse(\n        customer_id=query.customer_id,\n        metric=query.metric,\n        window_start=window_start.isoformat(),\n        total_quantity=Decimal(total_quantity),\n        event_count=event_count,\n    )\n","numLines":56,"startLine":1,"totalLines":56}},"sourceToolAssistantUUID":"4ef0f516-eb75-4804-bec5-bbd6fe71cc43","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"90f4db01-457c-478a-992d-b94037fff4b5","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEuHJKmFVyFr3ipyry","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01V1r82yV5N3yJAsdhSpMtcm","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_export_service.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4813,"cache_read_input_tokens":48124,"cache_creation":{"ephemeral_5m_input_tokens":4813,"ephemeral_1h_input_tokens":0},"output_tokens":37,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcvwEsacAa7oCqsSaj9jL","attributionAgent":"implementation","type":"assistant","uuid":"08bf3e12-f184-4371-b494-3f789ce5ff64","timestamp":"2026-07-11T20:54:51.244Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"08bf3e12-f184-4371-b494-3f789ce5ff64","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01V1r82yV5N3yJAsdhSpMtcm","type":"tool_result","content":"1\t\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\n2\tconstant-memory CSV streaming generator.\n3\t\n4\tTwo-phase by design: `prepare_export` runs to completion (and can still\n5\tcleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n6\t*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\n7\tis the response body, pulled by Starlette only after the handler returns, so\n8\tit opens its own transaction rather than reusing one the handler already closed.\n9\t\"\"\"\n10\t\n11\timport csv\n12\timport io\n13\tfrom collections.abc import AsyncIterator\n14\t\n15\tfrom fastapi import HTTPException, status\n16\t\n17\tfrom src.api.csv_export import (\n18\t    EXPORT_HEADER,\n19\t    escape_csv_text_cell,\n20\t    format_total_quantity,\n21\t    format_window_start,\n22\t)\n23\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n24\tfrom src.auth.api_key import AuthenticatedPrincipal\n25\tfrom src.db.session import scoped_transaction\n26\tfrom src.logging import get_logger\n27\tfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n28\t\n29\tlogger = get_logger(service=\"meterly\")\n30\t\n31\tMAX_EXPORT_ROWS = 100_000\n32\tEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n33\t\n34\t# How many encoded data rows to accumulate in the buffer before handing one\n35\t# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n36\t# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n37\t# every streamed chunk through its own anyio memory-object-stream — ran once\n38\t# per row (100,000× at the cap), which dominated the export's wall-clock time\n39\t# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n40\t# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n41\t# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n42\t_ROWS_PER_CHUNK = 1000\n43\t\n44\t\n45\tasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n46\t    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n47\t    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n48\t\n49\t    This must run and fully resolve *before* the route returns a\n50\t    `StreamingResponse` — once that response object exists the status line\n51\t    is already 200 and bytes may already be on the wire, so a 422 can no\n52\t    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n53\t    (a DB connection drop, a query error) is deliberately left to propagate\n54\t    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n55\t    handler): fail-closed generic `500 internal`, the pre-flight transaction\n56\t    rolled back, and no `StreamingResponse` ever constructed (AC22).\n57\t    \"\"\"\n58\t    async with scoped_transaction(principal.api_key_id) as session:\n59\t        row_count = await count_usage_rollups(\n60\t            session,\n61\t            api_key_id=principal.api_key_id,\n62\t            customer_id=params.customer_id,\n63\t            metric=params.metric,\n64\t            window_from=params.from_,\n65\t            window_to=params.to,\n66\t        )\n67\t\n68\t    if row_count > MAX_EXPORT_ROWS:\n69\t        logger.warning(\n70\t            \"usage.export.rejected\",\n71\t            userId=principal.api_key_id,\n72\t            action=\"deny\",\n73\t            reason=\"row_cap_exceeded\",\n74\t        )\n75\t        raise HTTPException(\n76\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n77\t            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n78\t        )\n79\t\n80\t\n81\tdef _drain(buffer: io.StringIO) -> bytes:\n82\t    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n83\t    place — this is what keeps the generator at constant memory: it never\n84\t    holds more than one row's encoded text at a time.\"\"\"\n85\t    data = buffer.getvalue().encode(\"utf-8\")\n86\t    buffer.seek(0)\n87\t    buffer.truncate(0)\n88\t    return data\n89\t\n90\t\n91\tasync def stream_export_csv(\n92\t    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n93\t) -> AsyncIterator[bytes]:\n94\t    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n95\t    CSV-encoded row per streamed `usage_rollup` record.\n96\t\n97\t    Yielding the header before touching the database means an empty result\n98\t    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n99\t    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n100\t    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n101\t    setting and the server-side cursor both stay valid for the whole stream.\n102\t    \"\"\"\n103\t    row_count = 0\n104\t    capped = False\n105\t    completed = False\n106\t\n107\t    buffer = io.StringIO()\n108\t    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n109\t\n110\t    try:\n111\t        # Header first, always, as its own chunk — so an empty result is a\n112\t        # 200 header-only CSV (AC12) and the first bytes are observable before\n113\t        # the data rows stream (AC9), independent of the data-row batching below.\n114\t        writer.writerow(EXPORT_HEADER)\n115\t        yield _drain(buffer)\n116\t\n117\t        async with scoped_transaction(principal.api_key_id) as session:\n118\t            async for record in stream_usage_rollups(\n119\t                session,\n120\t                api_key_id=principal.api_key_id,\n121\t                customer_id=params.customer_id,\n122\t                metric=params.metric,\n123\t                window_from=params.from_,\n124\t                window_to=params.to,\n125\t                limit=MAX_EXPORT_ROWS,\n126\t            ):\n127\t                writer.writerow(\n128\t                    [\n129\t                        escape_csv_text_cell(record.customer_id),\n130\t                        escape_csv_text_cell(record.metric),\n131\t                        format_window_start(record.window_start),\n132\t                        format_total_quantity(record.total_quantity),\n133\t                    ]\n134\t                )\n135\t                row_count += 1\n136\t                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n137\t                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n138\t                # cap this yields ~100 chunks, never one buffered blob.\n139\t                if row_count % _ROWS_PER_CHUNK == 0:\n140\t                    yield _drain(buffer)\n141\t\n142\t        # Flush the trailing partial batch. For an empty result nothing is\n143\t        # buffered here (the header already went out above), so no stray chunk.\n144\t        if buffer.tell():\n145\t            yield _drain(buffer)\n146\t\n147\t        capped = row_count >= MAX_EXPORT_ROWS\n148\t        completed = True\n149\t    finally:\n150\t        # In `finally` so a client disconnect or a mid-stream DB error still\n151\t        # records what was actually sent (`completed=False` in that case) —\n152\t        # exactly one usage.export event per request either way (AC17).\n153\t        logger.info(\n154\t            \"usage.export\",\n155\t            userId=principal.api_key_id,\n156\t            action=\"read\",\n157\t            resource=\"usage_rollup\",\n158\t            rowCount=row_count,\n159\t            capped=capped,\n160\t            completed=completed,\n161\t            filtered_by_customer=params.customer_id is not None,\n162\t            filtered_by_metric=params.metric is not None,\n163\t            bounded_from=params.from_ is not None,\n164\t            bounded_to=params.to is not None,\n165\t        )\n166\t"}]},"uuid":"58ab1a1b-ef1a-4a08-b728-2cbfd28226e8","timestamp":"2026-07-11T20:54:51.280Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/services/usage_export_service.py","content":"\"\"\"Service for `GET /v1/usage/export` — the pre-flight row-cap check and the\nconstant-memory CSV streaming generator.\n\nTwo-phase by design: `prepare_export` runs to completion (and can still\ncleanly 422, or fail closed to a generic 500 on an unexpected error — AC22)\n*before* the route ever constructs a `StreamingResponse`; `stream_export_csv`\nis the response body, pulled by Starlette only after the handler returns, so\nit opens its own transaction rather than reusing one the handler already closed.\n\"\"\"\n\nimport csv\nimport io\nfrom collections.abc import AsyncIterator\n\nfrom fastapi import HTTPException, status\n\nfrom src.api.csv_export import (\n    EXPORT_HEADER,\n    escape_csv_text_cell,\n    format_total_quantity,\n    format_window_start,\n)\nfrom src.api.schemas.usage_export import UsageExportQueryParams\nfrom src.auth.api_key import AuthenticatedPrincipal\nfrom src.db.session import scoped_transaction\nfrom src.logging import get_logger\nfrom src.repositories.usage_repo import count_usage_rollups, stream_usage_rollups\n\nlogger = get_logger(service=\"meterly\")\n\nMAX_EXPORT_ROWS = 100_000\nEXPORT_COLUMNS = (\"customer_id\", \"metric\", \"window_start\", \"total_quantity\")\n\n# How many encoded data rows to accumulate in the buffer before handing one\n# chunk to the ASGI stack. Emitting a chunk *per row* meant the full stack —\n# four nested Starlette `BaseHTTPMiddleware` layers, each of which re-pumps\n# every streamed chunk through its own anyio memory-object-stream — ran once\n# per row (100,000× at the cap), which dominated the export's wall-clock time\n# (p95 ~10-25s), not the DB read or the CSV encoding. Batching ~1,000 rows per\n# chunk cuts that per-chunk fan-out ~1,000× while staying constant-memory: the\n# buffer holds at most one batch of encoded rows (~tens of KB) before it drains.\n_ROWS_PER_CHUNK = 1000\n\n\nasync def prepare_export(principal: AuthenticatedPrincipal, params: UsageExportQueryParams) -> None:\n    \"\"\"Pre-flight cap check: raise a 422 before any response byte if the\n    caller's filtered result exceeds `MAX_EXPORT_ROWS`.\n\n    This must run and fully resolve *before* the route returns a\n    `StreamingResponse` — once that response object exists the status line\n    is already 200 and bytes may already be on the wire, so a 422 can no\n    longer be sent. Any *other* (non-cap) exception from the `COUNT` query\n    (a DB connection drop, a query error) is deliberately left to propagate\n    uncaught to the error-envelope boundary (`src/api/errors.py`'s catch-all\n    handler): fail-closed generic `500 internal`, the pre-flight transaction\n    rolled back, and no `StreamingResponse` ever constructed (AC22).\n    \"\"\"\n    async with scoped_transaction(principal.api_key_id) as session:\n        row_count = await count_usage_rollups(\n            session,\n            api_key_id=principal.api_key_id,\n            customer_id=params.customer_id,\n            metric=params.metric,\n            window_from=params.from_,\n            window_to=params.to,\n        )\n\n    if row_count > MAX_EXPORT_ROWS:\n        logger.warning(\n            \"usage.export.rejected\",\n            userId=principal.api_key_id,\n            action=\"deny\",\n            reason=\"row_cap_exceeded\",\n        )\n        raise HTTPException(\n            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n            detail=f\"result exceeds {MAX_EXPORT_ROWS} rows; narrow with customer_id, metric, from, and/or to\",\n        )\n\n\ndef _drain(buffer: io.StringIO) -> bytes:\n    \"\"\"Read `buffer`'s current contents as UTF-8 bytes, then reset it in\n    place — this is what keeps the generator at constant memory: it never\n    holds more than one row's encoded text at a time.\"\"\"\n    data = buffer.getvalue().encode(\"utf-8\")\n    buffer.seek(0)\n    buffer.truncate(0)\n    return data\n\n\nasync def stream_export_csv(\n    principal: AuthenticatedPrincipal, params: UsageExportQueryParams\n) -> AsyncIterator[bytes]:\n    \"\"\"The `StreamingResponse` body: the header row first, always, then one\n    CSV-encoded row per streamed `usage_rollup` record.\n\n    Yielding the header before touching the database means an empty result\n    is still a 200 header-only CSV, never a 404 (AC12, mirrors the existing\n    zeros-not-404 contract on `GET /v1/usage`). Opens its own tenant-scoped\n    transaction so the `SET LOCAL app.current_api_key_id` RLS-backstop\n    setting and the server-side cursor both stay valid for the whole stream.\n    \"\"\"\n    row_count = 0\n    capped = False\n    completed = False\n\n    buffer = io.StringIO()\n    writer = csv.writer(buffer, lineterminator=\"\\r\\n\", quoting=csv.QUOTE_MINIMAL)\n\n    try:\n        # Header first, always, as its own chunk — so an empty result is a\n        # 200 header-only CSV (AC12) and the first bytes are observable before\n        # the data rows stream (AC9), independent of the data-row batching below.\n        writer.writerow(EXPORT_HEADER)\n        yield _drain(buffer)\n\n        async with scoped_transaction(principal.api_key_id) as session:\n            async for record in stream_usage_rollups(\n                session,\n                api_key_id=principal.api_key_id,\n                customer_id=params.customer_id,\n                metric=params.metric,\n                window_from=params.from_,\n                window_to=params.to,\n                limit=MAX_EXPORT_ROWS,\n            ):\n                writer.writerow(\n                    [\n                        escape_csv_text_cell(record.customer_id),\n                        escape_csv_text_cell(record.metric),\n                        format_window_start(record.window_start),\n                        format_total_quantity(record.total_quantity),\n                    ]\n                )\n                row_count += 1\n                # Hand a chunk to the ASGI stack once per _ROWS_PER_CHUNK rows,\n                # not once per row (see _ROWS_PER_CHUNK). Still streaming: at the\n                # cap this yields ~100 chunks, never one buffered blob.\n                if row_count % _ROWS_PER_CHUNK == 0:\n                    yield _drain(buffer)\n\n        # Flush the trailing partial batch. For an empty result nothing is\n        # buffered here (the header already went out above), so no stray chunk.\n        if buffer.tell():\n            yield _drain(buffer)\n\n        capped = row_count >= MAX_EXPORT_ROWS\n        completed = True\n    finally:\n        # In `finally` so a client disconnect or a mid-stream DB error still\n        # records what was actually sent (`completed=False` in that case) —\n        # exactly one usage.export event per request either way (AC17).\n        logger.info(\n            \"usage.export\",\n            userId=principal.api_key_id,\n            action=\"read\",\n            resource=\"usage_rollup\",\n            rowCount=row_count,\n            capped=capped,\n            completed=completed,\n            filtered_by_customer=params.customer_id is not None,\n            filtered_by_metric=params.metric is not None,\n            bounded_from=params.from_ is not None,\n            bounded_to=params.to is not None,\n        )\n","numLines":166,"startLine":1,"totalLines":166}},"sourceToolAssistantUUID":"08bf3e12-f184-4371-b494-3f789ce5ff64","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"58ab1a1b-ef1a-4a08-b728-2cbfd28226e8","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwEuHJKmFVyFr3ipyry","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01WihHGbD1DHVTEtFVFhhSY6","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/repositories/usage_repo.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":4813,"cache_read_input_tokens":48124,"output_tokens":287,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":4813},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":287,"cache_read_input_tokens":48124,"cache_creation_input_tokens":4813,"cache_creation":{"ephemeral_5m_input_tokens":4813,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcvwEsacAa7oCqsSaj9jL","attributionAgent":"implementation","type":"assistant","uuid":"ec777f3e-c809-48a0-956b-217aef2f47d7","timestamp":"2026-07-11T20:54:51.585Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"ec777f3e-c809-48a0-956b-217aef2f47d7","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WihHGbD1DHVTEtFVFhhSY6","type":"tool_result","content":"1\t\"\"\"Repository for reading `usage_rollup` — the O(1) aggregate lookup behind\n2\t`GET /v1/usage`, and the count/stream queries behind `GET /v1/usage/export`.\n3\t\n4\tReads the pre-aggregated counter rather than summing `events` live, which is\n5\twhat keeps the GET p95 budget bounded as ingest volume grows (see the plan's\n6\t\"why reading the rollup\" writeup).\n7\t\"\"\"\n8\t\n9\tfrom collections.abc import AsyncIterator\n10\tfrom dataclasses import dataclass\n11\tfrom datetime import datetime\n12\tfrom decimal import Decimal\n13\t\n14\tfrom sqlalchemy import text\n15\tfrom sqlalchemy.ext.asyncio import AsyncSession\n16\t\n17\t\n18\t@dataclass(frozen=True)\n19\tclass UsageRollupRecord:\n20\t    \"\"\"The aggregate counter for one `(api_key_id, customer_id, metric, window_start)` bucket.\"\"\"\n21\t\n22\t    total_quantity: Decimal\n23\t    event_count: int\n24\t\n25\t\n26\tasync def find_usage_rollup(\n27\t    session: AsyncSession,\n28\t    *,\n29\t    api_key_id: int,\n30\t    customer_id: str,\n31\t    metric: str,\n32\t    window_start: datetime,\n33\t) -> UsageRollupRecord | None:\n34\t    \"\"\"Fetch the usage counter for a bucket, scoped by the authenticated\n35\t    `api_key_id` first — an authenticated key can never read another\n36\t    tenant's totals (IDOR/BOLA mitigation, AC17). None means no events have\n37\t    landed in this bucket yet (the caller returns zeros, not 404).\"\"\"\n38\t    result = await session.execute(\n39\t        text(\n40\t            \"\"\"\n41\t            SELECT total_quantity, event_count\n42\t            FROM usage_rollup\n43\t            WHERE api_key_id = :api_key_id\n44\t              AND customer_id = :customer_id\n45\t              AND metric = :metric\n46\t              AND window_start = :window_start\n47\t            \"\"\"\n48\t        ),\n49\t        {\n50\t            \"api_key_id\": api_key_id,\n51\t            \"customer_id\": customer_id,\n52\t            \"metric\": metric,\n53\t            \"window_start\": window_start,\n54\t        },\n55\t    )\n56\t    row = result.mappings().first()\n57\t    if row is None:\n58\t        return None\n59\t    return UsageRollupRecord(total_quantity=row[\"total_quantity\"], event_count=row[\"event_count\"])\n60\t\n61\t\n62\t@dataclass(frozen=True)\n63\tclass UsageRollupExportRecord:\n64\t    \"\"\"The four columns `GET /v1/usage/export` emits — deliberately excludes\n65\t    `event_count`, `updated_at`, and `api_key_id` (ASVS 15.3.1 minimal-\n66\t    projection rule; the caller's identity is never echoed back).\"\"\"\n67\t\n68\t    customer_id: str\n69\t    metric: str\n70\t    window_start: datetime\n71\t    total_quantity: Decimal\n72\t\n73\t\n74\tdef _export_filter_clause_and_params(\n75\t    *,\n76\t    api_key_id: int,\n77\t    customer_id: str | None,\n78\t    metric: str | None,\n79\t    window_from: datetime | None,\n80\t    window_to: datetime | None,\n81\t) -> tuple[str, dict]:\n82\t    \"\"\"Build the shared WHERE clause + bound-parameter dict for the export\n83\t    count and stream queries, so the two statements can never drift apart.\n84\t\n85\t    Every fragment is a fixed literal chosen only by which filters are\n86\t    *present*; the filter *values* always travel as bound parameters, never\n87\t    concatenated into the SQL string.\n88\t    \"\"\"\n89\t    clauses = [\"api_key_id = :api_key_id\"]\n90\t    params: dict = {\"api_key_id\": api_key_id}\n91\t    if customer_id is not None:\n92\t        clauses.append(\"customer_id = :customer_id\")\n93\t        params[\"customer_id\"] = customer_id\n94\t    if metric is not None:\n95\t        clauses.append(\"metric = :metric\")\n96\t        params[\"metric\"] = metric\n97\t    if window_from is not None:\n98\t        clauses.append(\"window_start >= :window_from\")\n99\t        params[\"window_from\"] = window_from\n100\t    if window_to is not None:\n101\t        clauses.append(\"window_start <= :window_to\")\n102\t        params[\"window_to\"] = window_to\n103\t    return \" AND \".join(clauses), params\n104\t\n105\t\n106\tasync def count_usage_rollups(\n107\t    session: AsyncSession,\n108\t    *,\n109\t    api_key_id: int,\n110\t    customer_id: str | None = None,\n111\t    metric: str | None = None,\n112\t    window_from: datetime | None = None,\n113\t    window_to: datetime | None = None,\n114\t) -> int:\n115\t    \"\"\"Count the caller's rollup rows matching the optional filters.\n116\t\n117\t    Backs the export's pre-flight row-cap check (AC8) — an index-prefix scan\n118\t    on `api_key_id`, scoped first (row-level-security invariant), cheap even\n119\t    without a covering index on the export's ORDER BY (see the plan's\n120\t    \"Ordering vs. index\" tradeoff writeup).\n121\t    \"\"\"\n122\t    where_clause, params = _export_filter_clause_and_params(\n123\t        api_key_id=api_key_id,\n124\t        customer_id=customer_id,\n125\t        metric=metric,\n126\t        window_from=window_from,\n127\t        window_to=window_to,\n128\t    )\n129\t    # Safe: `where_clause` is composed only of fixed literal fragments chosen by\n130\t    # _export_filter_clause_and_params (which filters are *present*); every filter\n131\t    # *value* travels in `params` as a bound parameter, never interpolated into the\n132\t    # SQL string. No caller-controlled input reaches this text(). Not a SQLi sink.\n133\t    count_sql = text(f\"SELECT count(*) FROM usage_rollup WHERE {where_clause}\")  # nosemgrep: python.sqlalchemy.security.audit.avoid-sqlalchemy-text.avoid-sqlalchemy-text\n134\t    result = await session.execute(count_sql, params)\n135\t    return result.scalar_one()\n136\t\n137\t\n138\t# Rows fetched per server-side-cursor round-trip in `stream_usage_rollups`.\n139\t# Bounds the client-side buffer (at most one batch is held, regardless of the\n140\t# total result size — the constant-memory streaming invariant is preserved) and\n141\t# trades a handful of extra rows of memory for far fewer cursor round-trips when\n142\t# draining a large export.\n143\t_STREAM_FETCH_BATCH = 5000\n144\t\n145\t\n146\tasync def stream_usage_rollups(\n147\t    session: AsyncSession,\n148\t    *,\n149\t    api_key_id: int,\n150\t    customer_id: str | None = None,\n151\t    metric: str | None = None,\n152\t    window_from: datetime | None = None,\n153\t    window_to: datetime | None = None,\n154\t    limit: int,\n155\t) -> AsyncIterator[UsageRollupExportRecord]:\n156\t    \"\"\"Stream the caller's rollup rows matching the optional filters via a\n157\t    server-side cursor, in deterministic order (AC9, AC13).\n158\t\n159\t    The `ORDER BY` clause is a fixed literal built from server-side column\n160\t    names, never derived from client input, so the sort key is not a\n161\t    tampering sink. `session.stream(...)` fetches from PostgreSQL via a\n162\t    server-side cursor rather than buffering the whole result client-side —\n163\t    the property the constant-memory streaming design depends on.\n164\t\n165\t    `yield_per` tunes *how many* rows that server-side cursor fetches per\n166\t    round-trip (it does not abandon the cursor): the default single-row/small\n167\t    partition fetch cost ~1s to drain 100,000 rows, versus ~0.6s at\n168\t    `_STREAM_FETCH_BATCH`, while keeping memory bounded — at most one batch of\n169\t    rows is buffered client-side, independent of the total result size.\n170\t    \"\"\"\n171\t    where_clause, params = _export_filter_clause_and_params(\n172\t        api_key_id=api_key_id,\n173\t        customer_id=customer_id,\n174\t        metric=metric,\n175\t        window_from=window_from,\n176\t        window_to=window_to,\n177\t    )\n178\t    params[\"limit\"] = limit\n179\t    # Safe: same invariant as count_usage_rollups — `where_clause` is fixed\n180\t    # literal fragments only, the ORDER BY is a server-side constant, and every\n181\t    # filter value (plus :limit) is a bound parameter in `params`. No caller\n182\t    # input is interpolated into the SQL string. Not a SQLi sink.\n183\t    stream_sql = text(  # nosemgrep: python.sqlalchemy.security.audit.avoid-sqlalchemy-text.avoid-sqlalchemy-text\n184\t        f\"\"\"\n185\t        SELECT customer_id, metric, window_start, total_quantity\n186\t        FROM usage_rollup\n187\t        WHERE {where_clause}\n188\t        ORDER BY window_start, customer_id, metric ASC\n189\t        LIMIT :limit\n190\t        \"\"\"\n191\t    ).execution_options(yield_per=_STREAM_FETCH_BATCH)\n192\t    result = await session.stream(stream_sql, params)\n193\t    async for row in result.mappings():\n194\t        yield UsageRollupExportRecord(\n195\t            customer_id=row[\"customer_id\"],\n196\t            metric=row[\"metric\"],\n197\t            window_start=row[\"window_start\"],\n198\t            total_quantity=row[\"total_quantity\"],\n199\t        )\n200\t"}]},"uuid":"fdc07244-071d-4073-aa0d-ac38116b3dc3","timestamp":"2026-07-11T20:54:51.620Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/src/repositories/usage_repo.py","content":"\"\"\"Repository for reading `usage_rollup` — the O(1) aggregate lookup behind\n`GET /v1/usage`, and the count/stream queries behind `GET /v1/usage/export`.\n\nReads the pre-aggregated counter rather than summing `events` live, which is\nwhat keeps the GET p95 budget bounded as ingest volume grows (see the plan's\n\"why reading the rollup\" writeup).\n\"\"\"\n\nfrom collections.abc import AsyncIterator\nfrom dataclasses import dataclass\nfrom datetime import datetime\nfrom decimal import Decimal\n\nfrom sqlalchemy import text\nfrom sqlalchemy.ext.asyncio import AsyncSession\n\n\n@dataclass(frozen=True)\nclass UsageRollupRecord:\n    \"\"\"The aggregate counter for one `(api_key_id, customer_id, metric, window_start)` bucket.\"\"\"\n\n    total_quantity: Decimal\n    event_count: int\n\n\nasync def find_usage_rollup(\n    session: AsyncSession,\n    *,\n    api_key_id: int,\n    customer_id: str,\n    metric: str,\n    window_start: datetime,\n) -> UsageRollupRecord | None:\n    \"\"\"Fetch the usage counter for a bucket, scoped by the authenticated\n    `api_key_id` first — an authenticated key can never read another\n    tenant's totals (IDOR/BOLA mitigation, AC17). None means no events have\n    landed in this bucket yet (the caller returns zeros, not 404).\"\"\"\n    result = await session.execute(\n        text(\n            \"\"\"\n            SELECT total_quantity, event_count\n            FROM usage_rollup\n            WHERE api_key_id = :api_key_id\n              AND customer_id = :customer_id\n              AND metric = :metric\n              AND window_start = :window_start\n            \"\"\"\n        ),\n        {\n            \"api_key_id\": api_key_id,\n            \"customer_id\": customer_id,\n            \"metric\": metric,\n            \"window_start\": window_start,\n        },\n    )\n    row = result.mappings().first()\n    if row is None:\n        return None\n    return UsageRollupRecord(total_quantity=row[\"total_quantity\"], event_count=row[\"event_count\"])\n\n\n@dataclass(frozen=True)\nclass UsageRollupExportRecord:\n    \"\"\"The four columns `GET /v1/usage/export` emits — deliberately excludes\n    `event_count`, `updated_at`, and `api_key_id` (ASVS 15.3.1 minimal-\n    projection rule; the caller's identity is never echoed back).\"\"\"\n\n    customer_id: str\n    metric: str\n    window_start: datetime\n    total_quantity: Decimal\n\n\ndef _export_filter_clause_and_params(\n    *,\n    api_key_id: int,\n    customer_id: str | None,\n    metric: str | None,\n    window_from: datetime | None,\n    window_to: datetime | None,\n) -> tuple[str, dict]:\n    \"\"\"Build the shared WHERE clause + bound-parameter dict for the export\n    count and stream queries, so the two statements can never drift apart.\n\n    Every fragment is a fixed literal chosen only by which filters are\n    *present*; the filter *values* always travel as bound parameters, never\n    concatenated into the SQL string.\n    \"\"\"\n    clauses = [\"api_key_id = :api_key_id\"]\n    params: dict = {\"api_key_id\": api_key_id}\n    if customer_id is not None:\n        clauses.append(\"customer_id = :customer_id\")\n        params[\"customer_id\"] = customer_id\n    if metric is not None:\n        clauses.append(\"metric = :metric\")\n        params[\"metric\"] = metric\n    if window_from is not None:\n        clauses.append(\"window_start >= :window_from\")\n        params[\"window_from\"] = window_from\n    if window_to is not None:\n        clauses.append(\"window_start <= :window_to\")\n        params[\"window_to\"] = window_to\n    return \" AND \".join(clauses), params\n\n\nasync def count_usage_rollups(\n    session: AsyncSession,\n    *,\n    api_key_id: int,\n    customer_id: str | None = None,\n    metric: str | None = None,\n    window_from: datetime | None = None,\n    window_to: datetime | None = None,\n) -> int:\n    \"\"\"Count the caller's rollup rows matching the optional filters.\n\n    Backs the export's pre-flight row-cap check (AC8) — an index-prefix scan\n    on `api_key_id`, scoped first (row-level-security invariant), cheap even\n    without a covering index on the export's ORDER BY (see the plan's\n    \"Ordering vs. index\" tradeoff writeup).\n    \"\"\"\n    where_clause, params = _export_filter_clause_and_params(\n        api_key_id=api_key_id,\n        customer_id=customer_id,\n        metric=metric,\n        window_from=window_from,\n        window_to=window_to,\n    )\n    # Safe: `where_clause` is composed only of fixed literal fragments chosen by\n    # _export_filter_clause_and_params (which filters are *present*); every filter\n    # *value* travels in `params` as a bound parameter, never interpolated into the\n    # SQL string. No caller-controlled input reaches this text(). Not a SQLi sink.\n    count_sql = text(f\"SELECT count(*) FROM usage_rollup WHERE {where_clause}\")  # nosemgrep: python.sqlalchemy.security.audit.avoid-sqlalchemy-text.avoid-sqlalchemy-text\n    result = await session.execute(count_sql, params)\n    return result.scalar_one()\n\n\n# Rows fetched per server-side-cursor round-trip in `stream_usage_rollups`.\n# Bounds the client-side buffer (at most one batch is held, regardless of the\n# total result size — the constant-memory streaming invariant is preserved) and\n# trades a handful of extra rows of memory for far fewer cursor round-trips when\n# draining a large export.\n_STREAM_FETCH_BATCH = 5000\n\n\nasync def stream_usage_rollups(\n    session: AsyncSession,\n    *,\n    api_key_id: int,\n    customer_id: str | None = None,\n    metric: str | None = None,\n    window_from: datetime | None = None,\n    window_to: datetime | None = None,\n    limit: int,\n) -> AsyncIterator[UsageRollupExportRecord]:\n    \"\"\"Stream the caller's rollup rows matching the optional filters via a\n    server-side cursor, in deterministic order (AC9, AC13).\n\n    The `ORDER BY` clause is a fixed literal built from server-side column\n    names, never derived from client input, so the sort key is not a\n    tampering sink. `session.stream(...)` fetches from PostgreSQL via a\n    server-side cursor rather than buffering the whole result client-side —\n    the property the constant-memory streaming design depends on.\n\n    `yield_per` tunes *how many* rows that server-side cursor fetches per\n    round-trip (it does not abandon the cursor): the default single-row/small\n    partition fetch cost ~1s to drain 100,000 rows, versus ~0.6s at\n    `_STREAM_FETCH_BATCH`, while keeping memory bounded — at most one batch of\n    rows is buffered client-side, independent of the total result size.\n    \"\"\"\n    where_clause, params = _export_filter_clause_and_params(\n        api_key_id=api_key_id,\n        customer_id=customer_id,\n        metric=metric,\n        window_from=window_from,\n        window_to=window_to,\n    )\n    params[\"limit\"] = limit\n    # Safe: same invariant as count_usage_rollups — `where_clause` is fixed\n    # literal fragments only, the ORDER BY is a server-side constant, and every\n    # filter value (plus :limit) is a bound parameter in `params`. No caller\n    # input is interpolated into the SQL string. Not a SQLi sink.\n    stream_sql = text(  # nosemgrep: python.sqlalchemy.security.audit.avoid-sqlalchemy-text.avoid-sqlalchemy-text\n        f\"\"\"\n        SELECT customer_id, metric, window_start, total_quantity\n        FROM usage_rollup\n        WHERE {where_clause}\n        ORDER BY window_start, customer_id, metric ASC\n        LIMIT :limit\n        \"\"\"\n    ).execution_options(yield_per=_STREAM_FETCH_BATCH)\n    result = await session.stream(stream_sql, params)\n    async for row in result.mappings():\n        yield UsageRollupExportRecord(\n            customer_id=row[\"customer_id\"],\n            metric=row[\"metric\"],\n            window_start=row[\"window_start\"],\n            total_quantity=row[\"total_quantity\"],\n        )\n","numLines":200,"startLine":1,"totalLines":200}},"sourceToolAssistantUUID":"ec777f3e-c809-48a0-956b-217aef2f47d7","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
