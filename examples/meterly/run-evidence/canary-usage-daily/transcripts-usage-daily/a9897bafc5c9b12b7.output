re.isoformat()))\n45\t\n46\t\n47\t@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\n48\tdef test_rejects_injection_in_customer_id(customer_id):\n49\t    \"\"\"Injection payloads in customer_id are rejected at the boundary.\"\"\"\n50\t    with pytest.raises(ValidationError):\n51\t        UsageQueryParams(**_valid_query(customer_id=customer_id))\n52\t\n53\t\n54\tdef test_rejects_unknown_fields():\n55\t    \"\"\"`extra='forbid'` rejects an unexpected query parameter.\"\"\"\n56\t    with pytest.raises(ValidationError):\n57\t        UsageQueryParams(**_valid_query(api_key_id=999))\n58\t"}]},"uuid":"00ecebea-8626-4ab0-a1b9-b559e01ab295","timestamp":"2026-07-11T20:55:05.745Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/test_schemas_usage.py","content":"\"\"\"Validation-contract tests for `UsageQueryParams` (AC15).\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom src.api.schemas.usage import UsageQueryParams\n\n\ndef _valid_query(**overrides) -> dict:\n    payload = {\n        \"customer_id\": \"cust_123\",\n        \"metric\": \"api_calls\",\n        \"window\": datetime.now(timezone.utc).isoformat(),\n    }\n    payload.update(overrides)\n    return payload\n\n\ndef test_accepts_a_well_formed_query():\n    \"\"\"A valid, timezone-aware window within range parses successfully.\"\"\"\n    query = UsageQueryParams(**_valid_query())\n    assert query.customer_id == \"cust_123\"\n\n\ndef test_rejects_naive_datetime():\n    \"\"\"A naive (no-offset) datetime is rejected rather than silently assumed UTC.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageQueryParams(**_valid_query(window=\"2026-01-01T00:00:00\"))\n\n\ndef test_rejects_window_too_far_in_the_past():\n    \"\"\"A window older than 90 days is rejected (unbounded query-cost guard).\"\"\"\n    too_old = datetime.now(timezone.utc) - timedelta(days=91)\n    with pytest.raises(ValidationError):\n        UsageQueryParams(**_valid_query(window=too_old.isoformat()))\n\n\ndef test_rejects_window_too_far_in_the_future():\n    \"\"\"A window more than 1 hour ahead is rejected.\"\"\"\n    too_future = datetime.now(timezone.utc) + timedelta(hours=2)\n    with pytest.raises(ValidationError):\n        UsageQueryParams(**_valid_query(window=too_future.isoformat()))\n\n\n@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\ndef test_rejects_injection_in_customer_id(customer_id):\n    \"\"\"Injection payloads in customer_id are rejected at the boundary.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageQueryParams(**_valid_query(customer_id=customer_id))\n\n\ndef test_rejects_unknown_fields():\n    \"\"\"`extra='forbid'` rejects an unexpected query parameter.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageQueryParams(**_valid_query(api_key_id=999))\n","numLines":58,"startLine":1,"totalLines":58}},"sourceToolAssistantUUID":"112348e6-e38e-46a7-8e4d-a390a42d22d1","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"00ecebea-8626-4ab0-a1b9-b559e01ab295","isSidechain":true,"agentId":"a9897bafc5c9b12b7","message":{"model":"claude-sonnet-5","id":"msg_011CcvwFspWz9T3WLXizMoZV","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011UsNB5nsVa7NPWgwwJTzFz","name":"Read","input":{"file_path":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/test_schemas_usage_export.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":11501,"cache_read_input_tokens":66898,"output_tokens":458,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":11501},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":458,"cache_read_input_tokens":66898,"cache_creation_input_tokens":11501,"cache_creation":{"ephemeral_5m_input_tokens":11501,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcvwFrcbD9aMgubR1oxxn","attributionAgent":"implementation","type":"assistant","uuid":"dcc3541b-52c2-45f1-b2d9-325cb4d34098","timestamp":"2026-07-11T20:55:06.155Z","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
{"parentUuid":"dcc3541b-52c2-45f1-b2d9-325cb4d34098","isSidechain":true,"promptId":"31d62281-78eb-4b7d-bb8c-b1ec8a71c6f0","agentId":"a9897bafc5c9b12b7","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011UsNB5nsVa7NPWgwwJTzFz","type":"tool_result","content":"1\t\"\"\"Validation-contract tests for `UsageExportQueryParams` (AC2, AC3, AC4).\"\"\"\n2\t\n3\tfrom datetime import datetime, timedelta, timezone\n4\t\n5\timport pytest\n6\tfrom pydantic import ValidationError\n7\t\n8\tfrom src.api.schemas.usage_export import UsageExportQueryParams\n9\t\n10\t\n11\tdef test_all_filters_omitted_is_valid():\n12\t    \"\"\"AC2: every filter is optional — an empty query parses successfully.\"\"\"\n13\t    query = UsageExportQueryParams()\n14\t    assert query.customer_id is None\n15\t    assert query.metric is None\n16\t    assert query.from_ is None\n17\t    assert query.to is None\n18\t\n19\t\n20\tdef test_accepts_well_formed_filters():\n21\t    \"\"\"AC2: customer_id/metric/from/to all parse when supplied together.\"\"\"\n22\t    now = datetime.now(timezone.utc)\n23\t    query = UsageExportQueryParams(\n24\t        customer_id=\"cust_123\",\n25\t        metric=\"api_calls\",\n26\t        **{\"from\": (now - timedelta(days=1)).isoformat()},\n27\t        to=now.isoformat(),\n28\t    )\n29\t    assert query.customer_id == \"cust_123\"\n30\t    assert query.metric == \"api_calls\"\n31\t    assert query.from_ is not None\n32\t    assert query.to is not None\n33\t\n34\t\n35\tdef test_from_alias_binds_to_from__field():\n36\t    \"\"\"AC3: the query param name `from` (a Python keyword) binds to `from_`.\"\"\"\n37\t    now = datetime.now(timezone.utc)\n38\t    query = UsageExportQueryParams(**{\"from\": now.isoformat()})\n39\t    assert query.from_ == now\n40\t\n41\t\n42\tdef test_rejects_naive_from_datetime():\n43\t    \"\"\"AC3: a naive (no-offset) `from` is rejected rather than silently assumed UTC.\"\"\"\n44\t    with pytest.raises(ValidationError):\n45\t        UsageExportQueryParams(**{\"from\": \"2026-01-01T00:00:00\"})\n46\t\n47\t\n48\tdef test_rejects_naive_to_datetime():\n49\t    \"\"\"AC3: a naive (no-offset) `to` is rejected.\"\"\"\n50\t    with pytest.raises(ValidationError):\n51\t        UsageExportQueryParams(to=\"2026-01-01T00:00:00\")\n52\t\n53\t\n54\tdef test_rejects_from_after_to():\n55\t    \"\"\"AC3: from > to is an invalid (inverted) range.\"\"\"\n56\t    now = datetime.now(timezone.utc)\n57\t    with pytest.raises(ValidationError):\n58\t        UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": (now - timedelta(days=1)).isoformat()})\n59\t\n60\t\n61\tdef test_accepts_from_equal_to_to():\n62\t    \"\"\"AC3: from == to is a valid (zero-width) range.\"\"\"\n63\t    now = datetime.now(timezone.utc)\n64\t    query = UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": now.isoformat()})\n65\t    assert query.from_ == query.to\n66\t\n67\t\n68\tdef test_rejects_from_too_far_in_the_past():\n69\t    \"\"\"AC3: from older than 90 days is rejected (unbounded query-cost guard).\"\"\"\n70\t    too_old = datetime.now(timezone.utc) - timedelta(days=91)\n71\t    with pytest.raises(ValidationError):\n72\t        UsageExportQueryParams(**{\"from\": too_old.isoformat()})\n73\t\n74\t\n75\tdef test_rejects_to_too_far_in_the_future():\n76\t    \"\"\"AC3: to more than 1 hour ahead is rejected.\"\"\"\n77\t    too_future = datetime.now(timezone.utc) + timedelta(hours=2)\n78\t    with pytest.raises(ValidationError):\n79\t        UsageExportQueryParams(to=too_future.isoformat())\n80\t\n81\t\n82\t@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\n83\tdef test_rejects_injection_in_customer_id(customer_id):\n84\t    \"\"\"AC4: injection payloads in customer_id are rejected at the boundary.\"\"\"\n85\t    with pytest.raises(ValidationError):\n86\t        UsageExportQueryParams(customer_id=customer_id)\n87\t\n88\t\n89\tdef test_rejects_unknown_fields():\n90\t    \"\"\"AC4: `extra='forbid'` rejects an unexpected query parameter (e.g. a\n91\t    client-supplied `api_key_id` probe).\"\"\"\n92\t    with pytest.raises(ValidationError):\n93\t        UsageExportQueryParams(api_key_id=999)\n94\t"}]},"uuid":"892a27d8-9746-418b-bcb8-de910687e75b","timestamp":"2026-07-11T20:55:06.228Z","toolUseResult":{"type":"text","file":{"filePath":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test/tests/test_schemas_usage_export.py","content":"\"\"\"Validation-contract tests for `UsageExportQueryParams` (AC2, AC3, AC4).\"\"\"\n\nfrom datetime import datetime, timedelta, timezone\n\nimport pytest\nfrom pydantic import ValidationError\n\nfrom src.api.schemas.usage_export import UsageExportQueryParams\n\n\ndef test_all_filters_omitted_is_valid():\n    \"\"\"AC2: every filter is optional — an empty query parses successfully.\"\"\"\n    query = UsageExportQueryParams()\n    assert query.customer_id is None\n    assert query.metric is None\n    assert query.from_ is None\n    assert query.to is None\n\n\ndef test_accepts_well_formed_filters():\n    \"\"\"AC2: customer_id/metric/from/to all parse when supplied together.\"\"\"\n    now = datetime.now(timezone.utc)\n    query = UsageExportQueryParams(\n        customer_id=\"cust_123\",\n        metric=\"api_calls\",\n        **{\"from\": (now - timedelta(days=1)).isoformat()},\n        to=now.isoformat(),\n    )\n    assert query.customer_id == \"cust_123\"\n    assert query.metric == \"api_calls\"\n    assert query.from_ is not None\n    assert query.to is not None\n\n\ndef test_from_alias_binds_to_from__field():\n    \"\"\"AC3: the query param name `from` (a Python keyword) binds to `from_`.\"\"\"\n    now = datetime.now(timezone.utc)\n    query = UsageExportQueryParams(**{\"from\": now.isoformat()})\n    assert query.from_ == now\n\n\ndef test_rejects_naive_from_datetime():\n    \"\"\"AC3: a naive (no-offset) `from` is rejected rather than silently assumed UTC.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(**{\"from\": \"2026-01-01T00:00:00\"})\n\n\ndef test_rejects_naive_to_datetime():\n    \"\"\"AC3: a naive (no-offset) `to` is rejected.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(to=\"2026-01-01T00:00:00\")\n\n\ndef test_rejects_from_after_to():\n    \"\"\"AC3: from > to is an invalid (inverted) range.\"\"\"\n    now = datetime.now(timezone.utc)\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": (now - timedelta(days=1)).isoformat()})\n\n\ndef test_accepts_from_equal_to_to():\n    \"\"\"AC3: from == to is a valid (zero-width) range.\"\"\"\n    now = datetime.now(timezone.utc)\n    query = UsageExportQueryParams(**{\"from\": now.isoformat(), \"to\": now.isoformat()})\n    assert query.from_ == query.to\n\n\ndef test_rejects_from_too_far_in_the_past():\n    \"\"\"AC3: from older than 90 days is rejected (unbounded query-cost guard).\"\"\"\n    too_old = datetime.now(timezone.utc) - timedelta(days=91)\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(**{\"from\": too_old.isoformat()})\n\n\ndef test_rejects_to_too_far_in_the_future():\n    \"\"\"AC3: to more than 1 hour ahead is rejected.\"\"\"\n    too_future = datetime.now(timezone.utc) + timedelta(hours=2)\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(to=too_future.isoformat())\n\n\n@pytest.mark.parametrize(\"customer_id\", [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\"])\ndef test_rejects_injection_in_customer_id(customer_id):\n    \"\"\"AC4: injection payloads in customer_id are rejected at the boundary.\"\"\"\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(customer_id=customer_id)\n\n\ndef test_rejects_unknown_fields():\n    \"\"\"AC4: `extra='forbid'` rejects an unexpected query parameter (e.g. a\n    client-supplied `api_key_id` probe).\"\"\"\n    with pytest.raises(ValidationError):\n        UsageExportQueryParams(api_key_id=999)\n","numLines":94,"startLine":1,"totalLines":94}},"sourceToolAssistantUUID":"dcc3541b-52c2-45f1-b2d9-325cb4d34098","userType":"external","entrypoint":"cli","cwd":"/mnt/c/Users/brett/OneDrive/Documents/GitHub/meterly-pipeline-test","sessionId":"8b12bd3f-3c00-43c5-ad29-92ed49e714d3","version":"2.1.207","gitBranch":"feature/usage-daily"}
