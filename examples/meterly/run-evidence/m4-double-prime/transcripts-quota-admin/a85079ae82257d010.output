{"parentUuid":"7be44f9d-83e9-495e-be79-88be5f3c567f","isSidechain":true,"promptId":"8cb584c6-6387-4c83-b506-fb1ef5a9a08f","agentId":"a85079ae82257d010","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NPrrCncVEm7xyjxgd8MLtW","type":"tool_result","content":"1\t\"\"\"Repository for reading `usage_rollup` — the O(1) aggregate lookup behind\n2\t`GET /v1/usage`, and the count/stream queries behind `GET /v1/usage/export`.\n3\t\n4\tReads the pre-aggregated counter rather than summing `events` live, which is\n5\twhat keeps the GET p95 budget bounded as ingest volume grows (see the plan's\n6\t\"why reading the rollup\" writeup).\n7\t\"\"\"\n8\t\n9\tfrom collections.abc import AsyncIterator\n10\tfrom dataclasses import dataclass\n11\tfrom datetime import datetime\n12\tfrom decimal import Decimal\n13\t\n14\tfrom sqlalchemy import text\n15\tfrom sqlalchemy.ext.asyncio import AsyncSession\n16\t\n17\t\n18\t@dataclass(frozen=True)\n19\tclass UsageRollupRecord:\n20\t    \"\"\"The aggregate counter for one `(api_key_id, customer_id, metric, window_start)` bucket.\"\"\"\n21\t\n22\t    total_quantity: Decimal\n23\t    event_count: int\n24\t\n25\t\n26\tasync def find_usage_rollup(\n27\t    session: AsyncSession,\n28\t    *,\n29\t    api_key_id: int,\n30\t    customer_id: str,\n31\t    metric: str,\n32\t    window_start: datetime,\n33\t) -> UsageRollupRecord | None:\n34\t    \"\"\"Fetch the usage counter for a bucket, scoped by the authenticated\n35\t    `api_key_id` first — an authenticated key can never read another\n36\t    tenant's totals (IDOR/BOLA mitigation, AC17). None means no events have\n37\t    landed in this bucket yet (the caller returns zeros, not 404).\"\"\"\n38\t    result = await session.execute(\n39\t        text(\n40\t            \"\"\"\n41\t            SELECT total_quantity, event_count\n42\t            FROM usage_rollup\n43\t            WHERE api_key_id = :api_key_id\n44\t              AND customer_id = :customer_id\n45\t              AND metric = :metric\n46\t              AND window_start = :window_start\n47\t            \"\"\"\n48\t        ),\n49\t        {\n50\t            \"api_key_id\": api_key_id,\n51\t            \"customer_id\": customer_id,\n52\t            \"metric\": metric,\n53\t            \"window_start\": window_start,\n54\t        },\n55\t    )\n56\t    row = result.mappings().first()\n57\t    if row is None:\n58\t        return None\n59\t    return UsageRollupRecord(total_quantity=row[\"total_quantity\"], event_count=row[\"event_count\"])\n60\t\n61\t\n62\t@dataclass(frozen=True)\n63\tclass UsageRollupExportRecord:\n64\t    \"\"\"The four columns `GET /v1/usage/export` emits — deliberately excludes\n65\t    `event_count`, `updated_at`, and `api_key_id` (ASVS 15.3.1 minimal-\n66\t    projection rule; the caller's identity is never echoed back).\"\"\"\n67\t\n68\t    customer_id: str\n69\t    metric: str\n70\t    window_start: datetime\n71\t    total_quantity: Decimal\n72\t\n73\t\n74\tdef _export_filter_clause_and_params(\n75\t    *,\n76\t    api_key_id: int,\n77\t    customer_id: str | None,\n78\t    metric: str | None,\n79\t    window_from: datetime | None,\n80\t    window_to: datetime | None,\n81\t) -> tuple[str, dict]:\n82\t    \"\"\"Build the shared WHERE clause + bound-parameter dict for the export\n83\t    count and stream queries, so the two statements can never drift apart.\n84\t\n85\t    Every fragment is a fixed literal chosen only by which filters are\n86\t    *present*; the filter *values* always travel as bound parameters, never\n87\t    concatenated into the SQL string.\n88\t    \"\"\"\n89\t    clauses = [\"api_key_id = :api_key_id\"]\n90\t    params: dict = {\"api_key_id\": api_key_id}\n91\t    if customer_id is not None:\n92\t        clauses.append(\"customer_id = :customer_id\")\n93\t        params[\"customer_id\"] = customer_id\n94\t    if metric is not None:\n95\t        clauses.append(\"metric = :metric\")\n96\t        params[\"metric\"] = metric\n97\t    if window_from is not None:\n98\t        clauses.append(\"window_start >= :window_from\")\n99\t        params[\"window_from\"] = window_from\n100\t    if window_to is not None:\n101\t        clauses.append(\"window_start <= :window_to\")\n102\t        params[\"window_to\"] = window_to\n103\t    return \" AND \".join(clauses), params\n104\t\n105\t\n106\tasync def count_usage_rollups(\n107\t    session: AsyncSession,\n108\t    *,\n109\t    api_key_id: int,\n110\t    customer_id: str | None = None,\n111\t    metric: str | None = None,\n112\t    window_from: datetime | None = None,\n113\t    window_to: datetime | None = None,\n114\t) -> int:\n115\t    \"\"\"Count the caller's rollup rows matching the optional filters.\n116\t\n117\t    Backs the export's pre-flight row-cap check (AC8) — an index-prefix scan\n118\t    on `api_key_id`, scoped first (row-level-security invariant), cheap even\n119\t    without a covering index on the export's ORDER BY (see the plan's\n120\t    \"Ordering vs. index\" tradeoff writeup).\n121\t    \"\"\"\n122\t    where_clause, params = _export_filter_clause_and_params(\n123\t        api_key_id=api_key_id,\n124\t        customer_id=customer_id,\n125\t        metric=metric,\n126\t        window_from=window_from,\n127\t        window_to=window_to,\n128\t    )\n129\t    result = await session.execute(text(f\"SELECT count(*) FROM usage_rollup WHERE {where_clause}\"), params)\n130\t    return result.scalar_one()\n131\t\n132\t\n133\t# Rows fetched per server-side-cursor round-trip in `stream_usage_rollups`.\n134\t# Bounds the client-side buffer (at most one batch is held, regardless of the\n135\t# total result size — the constant-memory streaming invariant is preserved) and\n136\t# trades a handful of extra rows of memory for far fewer cursor round-trips when\n137\t# draining a large export.\n138\t_STREAM_FETCH_BATCH = 5000\n139\t\n140\t\n141\tasync def stream_usage_rollups(\n142\t    session: AsyncSession,\n143\t    *,\n144\t    api_key_id: int,\n145\t    customer_id: str | None = None,\n146\t    metric: str | None = None,\n147\t    window_from: datetime | None = None,\n148\t    window_to: datetime | None = None,\n149\t    limit: int,\n150\t) -> AsyncIterator[UsageRollupExportRecord]:\n151\t    \"\"\"Stream the caller's rollup rows matching the optional filters via a\n152\t    server-side cursor, in deterministic order (AC9, AC13).\n153\t\n154\t    The `ORDER BY` clause is a fixed literal built from server-side column\n155\t    names, never derived from client input, so the sort key is not a\n156\t    tampering sink. `session.stream(...)` fetches from PostgreSQL via a\n157\t    server-side cursor rather than buffering the whole result client-side —\n158\t    the property the constant-memory streaming design depends on.\n159\t\n160\t    `yield_per` tunes *how many* rows that server-side cursor fetches per\n161\t    round-trip (it does not abandon the cursor): the default single-row/small\n162\t    partition fetch cost ~1s to drain 100,000 rows, versus ~0.6s at\n163\t    `_STREAM_FETCH_BATCH`, while keeping memory bounded — at most one batch of\n164\t    rows is buffered client-side, independent of the total result size.\n165\t    \"\"\"\n166\t    where_clause, params = _export_filter_clause_and_params(\n167\t        api_key_id=api_key_id,\n168\t        customer_id=customer_id,\n169\t        metric=metric,\n170\t        window_from=window_from,\n171\t        window_to=window_to,\n172\t    )\n173\t    params[\"limit\"] = limit\n174\t    result = await session.stream(\n175\t        text(\n176\t            f\"\"\"\n177\t            SELECT customer_id, metric, window_start, total_quantity\n178\t            FROM usage_rollup\n179\t            WHERE {where_clause}\n180\t            ORDER BY window_start, customer_id, metric ASC\n181\t            LIMIT :limit\n182\t            \"\"\"\n183\t        ).execution_options(yield_per=_STREAM_FETCH_BATCH),\n184\t        params,\n185\t    )\n186\t    async for row in result.mappings():\n187\t        yield UsageRollupExportRecord(\n188\t            customer_id=row[\"customer_id\"],\n189\t            metric=row[\"metric\"],\n190\t            window_start=row[\"window_start\"],\n191\t            total_quantity=row[\"total_quantity\"],\n192\t        )\n193\t"}]},"uuid":"c12b2abf-1038-47b2-a0e2-fc600ed472d5","timestamp":"2026-07-10T04:26:27.922Z","sourceToolAssistantUUID":"7be44f9d-83e9-495e-be79-88be5f3c567f","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"ci-fix/required-checks-green"}
