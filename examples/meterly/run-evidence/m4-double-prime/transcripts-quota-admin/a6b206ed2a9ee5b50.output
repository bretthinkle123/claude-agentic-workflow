{"parentUuid":"0df618ee-271d-47d2-82cf-cdb3b01d1b6f","isSidechain":true,"agentId":"a6b206ed2a9ee5b50","message":{"model":"claude-sonnet-5","id":"msg_011CcsfNdugAsShWfyBnoghk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Myzug8XSqG22TJugWHXmL3","name":"Read","input":{"file_path":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\test_schemas_quotas.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6248,"cache_read_input_tokens":45822,"cache_creation":{"ephemeral_5m_input_tokens":6248,"ephemeral_1h_input_tokens":0},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsfNcpwfEtACpuJCoUxS","attributionAgent":"testing","type":"assistant","uuid":"b234678c-5270-40ff-acef-dd594640246d","timestamp":"2026-07-10T03:25:00.258Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"b234678c-5270-40ff-acef-dd594640246d","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"a6b206ed2a9ee5b50","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Myzug8XSqG22TJugWHXmL3","type":"tool_result","content":"1\t\"\"\"Validation-contract tests for `QuotaPutRequest` (AC5, AC18) and\n2\t`QuotaDeleteParams` (AC9).\"\"\"\n3\t\n4\timport pytest\n5\tfrom hypothesis import given\n6\tfrom hypothesis import strategies as st\n7\tfrom pydantic import ValidationError\n8\t\n9\tfrom src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest\n10\t\n11\t\n12\tdef _valid_payload(**overrides) -> dict:\n13\t    payload = {\n14\t        \"customer_id\": \"cust_123\",\n15\t        \"metric\": \"api_calls\",\n16\t        \"limit_per_window\": 1000,\n17\t    }\n18\t    payload.update(overrides)\n19\t    return payload\n20\t\n21\t\n22\tdef test_accepts_a_well_formed_payload():\n23\t    \"\"\"A valid payload parses with the exact fields supplied.\"\"\"\n24\t    quota = QuotaPutRequest(**_valid_payload())\n25\t    assert quota.customer_id == \"cust_123\"\n26\t    assert quota.metric == \"api_calls\"\n27\t    assert quota.limit_per_window == 1000\n28\t\n29\t\n30\tdef test_rejects_unknown_fields_mass_assignment():\n31\t    \"\"\"`extra='forbid'` rejects a client-supplied `api_key_id`/`scope`\n32\t    (ASVS 15.3.3) — the server alone sets the tenant and never accepts a\n33\t    caller-supplied scope elevation.\"\"\"\n34\t    with pytest.raises(ValidationError):\n35\t        QuotaPutRequest(**_valid_payload(api_key_id=999))\n36\t    with pytest.raises(ValidationError):\n37\t        QuotaPutRequest(**_valid_payload(scope=\"admin\"))\n38\t\n39\t\n40\t@pytest.mark.parametrize(\"limit_per_window\", [0, -1, -1000])\n41\tdef test_rejects_non_positive_limit(limit_per_window):\n42\t    \"\"\"A cap must be >= 1 — zero/negative is rejected (no kill-switch this slice).\"\"\"\n43\t    with pytest.raises(ValidationError):\n44\t        QuotaPutRequest(**_valid_payload(limit_per_window=limit_per_window))\n45\t\n46\t\n47\t@pytest.mark.parametrize(\"limit_per_window\", [\"not-a-number\", 1.5, None])\n48\tdef test_rejects_non_integer_limit(limit_per_window):\n49\t    \"\"\"A non-integer limit is rejected.\"\"\"\n50\t    with pytest.raises(ValidationError):\n51\t        QuotaPutRequest(**_valid_payload(limit_per_window=limit_per_window))\n52\t\n53\t\n54\tdef test_rejects_absurdly_large_limit():\n55\t    \"\"\"A limit beyond the BIGINT-safe upper bound is rejected (overflow guard).\"\"\"\n56\t    with pytest.raises(ValidationError):\n57\t        QuotaPutRequest(**_valid_payload(limit_per_window=10**16))\n58\t\n59\t\n60\tdef test_accepts_the_upper_bound_limit():\n61\t    \"\"\"The declared upper bound itself (1e15) is accepted.\"\"\"\n62\t    quota = QuotaPutRequest(**_valid_payload(limit_per_window=10**15))\n63\t    assert quota.limit_per_window == 10**15\n64\t\n65\t\n66\t@pytest.mark.parametrize(\n67\t    \"customer_id\",\n68\t    [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\", \"a\" * 129, \"\"],\n69\t)\n70\tdef test_rejects_injection_and_oversized_customer_id(customer_id):\n71\t    \"\"\"SQLi/path-traversal/CRLF/oversized customer_id is rejected at the boundary (AC18).\"\"\"\n72\t    with pytest.raises(ValidationError):\n73\t        QuotaPutRequest(**_valid_payload(customer_id=customer_id))\n74\t\n75\t\n76\t@pytest.mark.parametrize(\"metric\", [\"' OR 1=1--\", \"a\" * 65, \"\"])\n77\tdef test_rejects_invalid_metric(metric):\n78\t    \"\"\"Injection/oversized metric is rejected at the boundary (AC18).\"\"\"\n79\t    with pytest.raises(ValidationError):\n80\t        QuotaPutRequest(**_valid_payload(metric=metric))\n81\t\n82\t\n83\t@given(customer_id=st.text(min_size=1, max_size=300))\n84\tdef test_property_customer_id_only_ever_accepts_the_allowlist(customer_id):\n85\t    \"\"\"Hypothesis: any customer_id that parses successfully matches the anchored allowlist.\"\"\"\n86\t    import re\n87\t\n88\t    try:\n89\t        quota = QuotaPutRequest(**_valid_payload(customer_id=customer_id))\n90\t    except ValidationError:\n91\t        return\n92\t    assert re.fullmatch(r\"[A-Za-z0-9_.:-]{1,128}\", quota.customer_id)\n93\t\n94\t\n95\tdef _valid_delete_params(**overrides) -> dict:\n96\t    params = {\"customer_id\": \"cust_123\", \"metric\": \"api_calls\"}\n97\t    params.update(overrides)\n98\t    return params\n99\t\n100\t\n101\tdef test_delete_params_accepts_well_formed_identifiers():\n102\t    \"\"\"AC9: a valid (customer_id, metric) pair parses with the exact values supplied.\"\"\"\n103\t    params = QuotaDeleteParams(**_valid_delete_params())\n104\t    assert params.customer_id == \"cust_123\"\n105\t    assert params.metric == \"api_calls\"\n106\t\n107\t\n108\tdef test_delete_params_rejects_missing_fields():\n109\t    \"\"\"AC9: both customer_id and metric are required.\"\"\"\n110\t    with pytest.raises(ValidationError):\n111\t        QuotaDeleteParams(customer_id=\"cust_123\")\n112\t    with pytest.raises(ValidationError):\n113\t        QuotaDeleteParams(metric=\"api_calls\")\n114\t\n115\t\n116\tdef test_delete_params_rejects_unknown_fields_mass_assignment():\n117\t    \"\"\"AC9: `extra='forbid'` rejects a client-supplied `api_key_id` — the\n118\t    server alone resolves the tenant from the authenticated principal\n119\t    (ASVS 15.3.3).\"\"\"\n120\t    with pytest.raises(ValidationError):\n121\t        QuotaDeleteParams(**_valid_delete_params(api_key_id=999))\n122\t\n123\t\n124\t@pytest.mark.parametrize(\n125\t    \"customer_id\",\n126\t    [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\", \"a\" * 129, \"\"],\n127\t)\n128\tdef test_delete_params_rejects_injection_and_oversized_customer_id(customer_id):\n129\t    \"\"\"AC9: SQLi/path-traversal/CRLF/oversized customer_id is rejected at the\n130\t    schema boundary and never reaches the DELETE SQL sink.\"\"\"\n131\t    with pytest.raises(ValidationError):\n132\t        QuotaDeleteParams(**_valid_delete_params(customer_id=customer_id))\n133\t\n134\t\n135\t@pytest.mark.parametrize(\"metric\", [\"' OR 1=1--\", \"a\" * 65, \"\"])\n136\tdef test_delete_params_rejects_invalid_metric(metric):\n137\t    \"\"\"AC9: injection/oversized metric is rejected at the schema boundary.\"\"\"\n138\t    with pytest.raises(ValidationError):\n139\t        QuotaDeleteParams(**_valid_delete_params(metric=metric))\n140\t\n141\t\n142\t@given(customer_id=st.text(min_size=1, max_size=300))\n143\tdef test_property_delete_customer_id_only_ever_accepts_the_allowlist(customer_id):\n144\t    \"\"\"Hypothesis: any customer_id accepted by QuotaDeleteParams matches the anchored allowlist.\"\"\"\n145\t    import re\n146\t\n147\t    try:\n148\t        params = QuotaDeleteParams(**_valid_delete_params(customer_id=customer_id))\n149\t    except ValidationError:\n150\t        return\n151\t    assert re.fullmatch(r\"[A-Za-z0-9_.:-]{1,128}\", params.customer_id)\n152\t"}]},"uuid":"fda2bc7c-0faf-43d9-95c2-68c926a3ada2","timestamp":"2026-07-10T03:25:00.290Z","sourceToolAssistantUUID":"b234678c-5270-40ff-acef-dd594640246d","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"fda2bc7c-0faf-43d9-95c2-68c926a3ada2","isSidechain":true,"agentId":"a6b206ed2a9ee5b50","message":{"model":"claude-sonnet-5","id":"msg_011CcsfNdugAsShWfyBnoghk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013EbbyTbJca4cYnJTegqJsA","name":"Bash","input":{"command":"cd \"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\" && git diff HEAD -- src/api/routes/quotas.py src/api/schemas/quotas.py src/repositories/quotas_repo.py src/services/quota_service.py src/api/middleware.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":6248,"cache_read_input_tokens":45822,"output_tokens":319,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":6248},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":319,"cache_read_input_tokens":45822,"cache_creation_input_tokens":6248,"cache_creation":{"ephemeral_5m_input_tokens":6248,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcsfNcpwfEtACpuJCoUxS","attributionAgent":"testing","type":"assistant","uuid":"c7e3dc39-6639-482f-a616-164760c19827","timestamp":"2026-07-10T03:25:01.033Z","userType":"external","entrypoint":"claude-vscode","cwd":"c:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"c7e3dc39-6639-482f-a616-164760c19827","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"a6b206ed2a9ee5b50","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013EbbyTbJca4cYnJTegqJsA","type":"tool_result","content":"diff --git a/src/api/middleware.py b/src/api/middleware.py\nindex f21399c..7b6f60b 100644\n--- a/src/api/middleware.py\n+++ b/src/api/middleware.py\n@@ -160,6 +160,6 @@ def configure_cors(app: FastAPI, settings: Settings) -> None:\n         CORSMiddleware,\n         allow_origins=list(settings.cors_allowed_origins),\n         allow_credentials=False,\n-        allow_methods=[\"GET\", \"POST\", \"PUT\"],\n+        allow_methods=[\"GET\", \"POST\", \"PUT\", \"DELETE\"],\n         allow_headers=[\"Authorization\", \"Content-Type\", \"Idempotency-Key\"],\n     )\ndiff --git a/src/api/routes/quotas.py b/src/api/routes/quotas.py\nindex 2443d41..b31d62b 100644\n--- a/src/api/routes/quotas.py\n+++ b/src/api/routes/quotas.py\n@@ -1,21 +1,30 @@\n-\"\"\"`PUT /v1/quotas` — admin-scoped create-or-replace of a per-customer,\n-per-metric usage cap.\n+\"\"\"`/v1/quotas` — admin-scoped create-or-replace (`PUT`), list (`GET`), and\n+remove (`DELETE`) of a per-customer, per-metric usage cap.\n \n Edge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n-inherited from the middleware stack; this route wires\n+inherited from the middleware stack; every route on this router wires\n auth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\n mirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\n-pattern (kept per-route, not shared, per the existing convention).\n+pattern (kept per-route, not shared, per the existing convention). All three\n+verbs depend on the same `_require_admin_and_throttled` chain — GET/DELETE\n+reuse it verbatim rather than introducing a new scope or auth path.\n \"\"\"\n \n-from fastapi import APIRouter, Depends, HTTPException, Request, Response, status\n+from typing import Annotated\n \n-from src.api.schemas.quotas import QuotaPutRequest, QuotaResponse\n+from fastapi import APIRouter, Depends, HTTPException, Query, Request, Response, status\n+\n+from src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\n from src.auth import require_api_key\n from src.auth.api_key import AuthenticatedPrincipal\n from src.auth.rate_limit import enforce_tier2_rate_limit\n from src.logging import get_logger\n-from src.services.quota_service import to_response, upsert_tenant_quota\n+from src.services.quota_service import (\n+    delete_tenant_quota,\n+    list_tenant_quotas,\n+    to_response,\n+    upsert_tenant_quota,\n+)\n \n router = APIRouter(tags=[\"quotas\"])\n logger = get_logger(service=\"meterly\")\n@@ -54,3 +63,25 @@ async def put_quota(\n     outcome = await upsert_tenant_quota(principal, payload)\n     response.status_code = outcome.http_status\n     return to_response(outcome)\n+\n+\n+@router.get(\"/v1/quotas\", response_model=list[QuotaResponse])\n+async def list_quotas_endpoint(\n+    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n+) -> list[QuotaResponse]:\n+    \"\"\"Return the caller's own tenant's full, unpaginated quota list,\n+    deterministically ordered by `(customer_id, metric)`. An empty tenant\n+    gets `200 []`, never a 404.\"\"\"\n+    return await list_tenant_quotas(principal)\n+\n+\n+@router.delete(\"/v1/quotas\", status_code=status.HTTP_204_NO_CONTENT)\n+async def delete_quota_endpoint(\n+    params: Annotated[QuotaDeleteParams, Query()],\n+    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n+) -> Response:\n+    \"\"\"Remove the cap for `(customer_id, metric)` under the caller's own\n+    tenant — 204 on success, 404 if no such quota exists in this tenant\n+    (explicit, not silently idempotent).\"\"\"\n+    await delete_tenant_quota(principal, params)\n+    return Response(status_code=status.HTTP_204_NO_CONTENT)\ndiff --git a/src/api/schemas/quotas.py b/src/api/schemas/quotas.py\nindex d1270ff..3fcd099 100644\n--- a/src/api/schemas/quotas.py\n+++ b/src/api/schemas/quotas.py\n@@ -45,3 +45,19 @@ class QuotaResponse(BaseModel):\n     customer_id: str\n     metric: str\n     limit_per_window: int\n+\n+\n+class QuotaDeleteParams(BaseModel):\n+    \"\"\"The two required query parameters of `DELETE /v1/quotas`, reusing the\n+    exact same anchored `CustomerId`/`Metric` allowlists `QuotaPutRequest`\n+    validates against — same identifiers, same sinks, same rejection\n+    behavior (422). `extra='forbid'` rejects any unknown query param\n+    (including a client-supplied `api_key_id`), the mass-assignment defense\n+    that keeps the delete target's tenant resolved only from the\n+    authenticated principal (ASVS 15.3.3).\n+    \"\"\"\n+\n+    model_config = ConfigDict(extra=\"forbid\")\n+\n+    customer_id: CustomerId\n+    metric: Metric\ndiff --git a/src/repositories/quotas_repo.py b/src/repositories/quotas_repo.py\nindex 52e9394..9578be4 100644\n--- a/src/repositories/quotas_repo.py\n+++ b/src/repositories/quotas_repo.py\n@@ -36,6 +36,15 @@ class QuotaState:\n     current_total: Decimal\n \n \n+@dataclass(frozen=True)\n+class QuotaListItem:\n+    \"\"\"One row of `GET /v1/quotas`'s listing — the minimal, public quota shape.\"\"\"\n+\n+    customer_id: str\n+    metric: str\n+    limit_per_window: int\n+\n+\n async def upsert_quota(\n     session: AsyncSession,\n     *,\n@@ -147,3 +156,60 @@ async def read_tenant_quota_state_locked(\n     rollup_row = rollup_result.mappings().first()\n     current_total = rollup_row[\"total_quantity\"] if rollup_row is not None else Decimal(0)\n     return QuotaState(limit_per_window=lock_row[\"limit_per_window\"], current_total=Decimal(current_total))\n+\n+\n+async def list_quotas(session: AsyncSession, *, api_key_id: int) -> list[QuotaListItem]:\n+    \"\"\"Return every quota row for the caller's own tenant, ordered by\n+    `(customer_id, metric)` for a deterministic, repeatable listing.\n+\n+    The `ORDER BY` matches the leading columns of the table's primary key\n+    `(api_key_id, customer_id, metric)`, so the sort is index-friendly on top\n+    of the already-scoped index scan (plan §\"deterministic ORDER BY\").\n+    \"\"\"\n+    result = await session.execute(\n+        text(\n+            \"\"\"\n+            SELECT customer_id, metric, limit_per_window\n+            FROM quotas\n+            WHERE api_key_id = :api_key_id\n+            ORDER BY customer_id, metric\n+            \"\"\"\n+        ),\n+        {\"api_key_id\": api_key_id},\n+    )\n+    return [\n+        QuotaListItem(\n+            customer_id=row[\"customer_id\"],\n+            metric=row[\"metric\"],\n+            limit_per_window=row[\"limit_per_window\"],\n+        )\n+        for row in result.mappings().all()\n+    ]\n+\n+\n+async def delete_quota(\n+    session: AsyncSession, *, api_key_id: int, customer_id: str, metric: str\n+) -> bool:\n+    \"\"\"Remove the cap for `(api_key_id, customer_id, metric)`, returning\n+    whether a row actually matched and was removed.\n+\n+    `RETURNING customer_id` on a single-statement, parameterized `DELETE` is\n+    what lets the service distinguish \"removed\" from \"nothing there to\n+    remove\" without a separate existence check (avoiding a TOCTOU gap\n+    between check and delete). The explicit `api_key_id` filter is the\n+    primary tenant-confinement control; `quotas_tenant_isolation` FORCE RLS\n+    (migration `0003`) is the backstop — a cross-tenant call matches zero\n+    rows here, which the service maps to 404 (plan §\"Tenant confinement is\n+    structural, not a special case\").\n+    \"\"\"\n+    result = await session.execute(\n+        text(\n+            \"\"\"\n+            DELETE FROM quotas\n+            WHERE api_key_id = :api_key_id AND customer_id = :customer_id AND metric = :metric\n+            RETURNING customer_id\n+            \"\"\"\n+        ),\n+        {\"api_key_id\": api_key_id, \"customer_id\": customer_id, \"metric\": metric},\n+    )\n+    return result.mappings().first() is not None\ndiff --git a/src/services/quota_service.py b/src/services/quota_service.py\nindex eb3cc40..40da34c 100644\n--- a/src/services/quota_service.py\n+++ b/src/services/quota_service.py\n@@ -1,18 +1,22 @@\n-\"\"\"Service for `PUT /v1/quotas` — the admin-scoped upsert + 201/200 mapping.\n+\"\"\"Service for `/v1/quotas` — the admin-scoped upsert (`PUT`), list (`GET`),\n+and remove (`DELETE`) operations.\n \n-Orchestrates one transaction per request: the `xmax` upsert in\n-`src/repositories/quotas_repo.py` reports create-vs-replace in a single\n-round-trip, so this layer only maps that to the HTTP status and emits the\n-audit-trail log (`quota.upsert`, plan §\"Repudiation\").\n+Each entry point orchestrates one transaction per request: the `xmax` upsert\n+in `src/repositories/quotas_repo.py` reports create-vs-replace in a single\n+round-trip for `PUT`; `GET` opens a read-only scoped transaction for the\n+ordered listing; `DELETE` maps \"no row matched\" to a 404 rather than a\n+silent success (plan §\"DELETE — remove one cap, explicitly\").\n \"\"\"\n \n from dataclasses import dataclass\n \n-from src.api.schemas.quotas import QuotaPutRequest, QuotaResponse\n+from fastapi import HTTPException, status\n+\n+from src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\n from src.auth.api_key import AuthenticatedPrincipal\n from src.db.session import scoped_transaction\n from src.logging import get_logger\n-from src.repositories.quotas_repo import upsert_quota\n+from src.repositories.quotas_repo import delete_quota, list_quotas, upsert_quota\n \n logger = get_logger(service=\"meterly\")\n \n@@ -69,3 +73,50 @@ def to_response(outcome: QuotaUpsertOutcome) -> QuotaResponse:\n         metric=outcome.metric,\n         limit_per_window=outcome.limit_per_window,\n     )\n+\n+\n+async def list_tenant_quotas(principal: AuthenticatedPrincipal) -> list[QuotaResponse]:\n+    \"\"\"Return the caller's own tenant's full, deterministically ordered quota\n+    list — an empty tenant gets an empty list, never a 404 (plan §\"Empty set\n+    -> 200 [], never 404\"). Deliberately not logged as a business event (open\n+    question 1, resolved default): a plain read of the caller's own\n+    configuration, mirroring `GET /v1/usage`.\n+    \"\"\"\n+    async with scoped_transaction(principal.api_key_id) as session:\n+        rows = await list_quotas(session, api_key_id=principal.api_key_id)\n+\n+    return [\n+        QuotaResponse(customer_id=row.customer_id, metric=row.metric, limit_per_window=row.limit_per_window)\n+        for row in rows\n+    ]\n+\n+\n+async def delete_tenant_quota(\n+    principal: AuthenticatedPrincipal, params: QuotaDeleteParams\n+) -> None:\n+    \"\"\"Remove the cap for `(customer_id, metric)` under the caller's own\n+    tenant, raising 404 if no such quota exists (explicit, not silently\n+    idempotent — plan §\"Why 404-on-absent, not idempotent-204\").\n+\n+    A cross-tenant delete attempt matches zero rows (the `api_key_id` filter\n+    + FORCE RLS backstop), which is indistinguishable from a truly-absent\n+    quota — the intended BOLA-safe behavior (threat E2).\n+    \"\"\"\n+    async with scoped_transaction(principal.api_key_id) as session:\n+        removed = await delete_quota(\n+            session,\n+            api_key_id=principal.api_key_id,\n+            customer_id=params.customer_id,\n+            metric=params.metric,\n+        )\n+\n+    if not removed:\n+        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=\"quota not found\")\n+\n+    logger.info(\n+        \"quota.delete\",\n+        userId=principal.api_key_id,\n+        action=\"delete\",\n+        customer_id=params.customer_id,\n+        metric=params.metric,\n+    )","is_error":false}]},"uuid":"22c99f8c-a143-44a4-a3de-3685a9b98a12",