{"parentUuid":"94c124b5-49de-4fa7-b4ea-1a3ad922c6f4","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"a4faa30a4db9ebeeb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01TAwCR8Xoaxao6U3sCkRtZy","type":"tool_result","content":"src/api:\nREADME.md\n__init__.py\n__pycache__\ncsv_export.py\nerrors.py\nmiddleware.py\nroutes\nschemas\n\nsrc/api/routes:\n__init__.py\n__pycache__\nevents.py\nhealth.py\nquotas.py\nusage.py\nusage_export.py\n\nsrc/api/schemas:\n__init__.py\n__pycache__\nevents.py\nquotas.py\nusage.py\nusage_export.py\n\nsrc/auth:\nREADME.md\n__init__.py\n__pycache__\napi_key.py\nrate_limit.py\n\nsrc/db:\nREADME.md\n__init__.py\n__pycache__\nsession.py\n\nsrc/repositories:\nREADME.md\n__init__.py\n__pycache__\napi_keys_repo.py\nevents_repo.py\nquotas_repo.py\nusage_repo.py\n\nsrc/services:\nREADME.md\n__init__.py\n__pycache__\nevents_service.py\nquota_service.py\ntime_windows.py\nusage_export_service.py\nusage_service.py\ndiff --git a/tests/integration/test_quotas_rls_backstop.py b/tests/integration/test_quotas_rls_backstop.py\nindex 297093c..3f29b9f 100644\n--- a/tests/integration/test_quotas_rls_backstop.py\n+++ b/tests/integration/test_quotas_rls_backstop.py\n@@ -130,6 +130,73 @@ async def test_rls_blocks_cross_tenant_read_when_app_filter_is_absent(\n         await role_engine.dispose()\n \n \n+async def test_rls_blocks_cross_tenant_delete_when_app_filter_is_absent(\n+    postgres_url, nobypassrls_role, make_api_key\n+):\n+    \"\"\"AC8/AC15 backstop proof for the quota-admin feature's new `DELETE\n+    /v1/quotas` surface: with the explicit `api_key_id` filter entirely\n+    removed from the query (simulating the primary control being\n+    missing/buggy in `quotas_repo.delete_quota`), the RLS policy alone must\n+    still confine a `NOBYPASSRLS` session's DELETE to only its own tenant's\n+    row -- tenant B's row must survive an unfiltered DELETE issued under\n+    tenant A's session setting.\n+    \"\"\"\n+    _, tenant_a_id = await make_api_key(label=\"rls-delete-tenant-a\", scope=\"admin\")\n+    _, tenant_b_id = await make_api_key(label=\"rls-delete-tenant-b\", scope=\"admin\")\n+\n+    admin_engine = create_async_engine(postgres_url)\n+    async with admin_engine.begin() as connection:\n+        await connection.execute(\n+            text(\n+                \"INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window) \"\n+                \"VALUES (:id, 'rls_del_cust', 'api_calls', 1000)\"\n+            ),\n+            {\"id\": tenant_a_id},\n+        )\n+        await connection.execute(\n+            text(\n+                \"INSERT INTO quotas (api_key_id, customer_id, metric, limit_per_window) \"\n+                \"VALUES (:id, 'rls_del_cust', 'api_calls', 2000)\"\n+            ),\n+            {\"id\": tenant_b_id},\n+        )\n+    await admin_engine.dispose()\n+\n+    role_engine = create_async_engine(nobypassrls_role)\n+    try:\n+        async with role_engine.begin() as connection:\n+            await connection.execute(\n+                text(\"SELECT set_config('app.current_api_key_id', :id, true)\"),\n+                {\"id\": str(tenant_a_id)},\n+            )\n+            # No api_key_id predicate at all -- mirrors delete_quota's DELETE\n+            # statement with its primary WHERE clause stripped out.\n+            result = await connection.execute(\n+                text(\"DELETE FROM quotas WHERE customer_id = 'rls_del_cust' RETURNING api_key_id\")\n+            )\n+            deleted_ids = {row[0] for row in result.fetchall()}\n+        assert deleted_ids == {tenant_a_id}, (\n+            \"an unfiltered DELETE under tenant A's session setting must only \"\n+            f\"remove tenant A's own row; deleted api_key_ids={deleted_ids}\"\n+        )\n+\n+        admin_check_engine = create_async_engine(postgres_url)\n+        async with admin_check_engine.connect() as connection:\n+            survivor = (\n+                await connection.execute(\n+                    text(\n+                        \"SELECT limit_per_window FROM quotas \"\n+                        \"WHERE api_key_id = :id AND customer_id = 'rls_del_cust'\"\n+                    ),\n+                    {\"id\": tenant_b_id},\n+                )\n+            ).mappings().one()\n+        await admin_check_engine.dispose()\n+        assert survivor[\"limit_per_window\"] == 2000, \"tenant B's row must survive the cross-tenant DELETE\"\n+    finally:\n+        await role_engine.dispose()\n+\n+\n async def test_rls_denies_all_rows_when_tenant_setting_is_unset(\n     postgres_url, nobypassrls_role, make_api_key\n ):\ndiff --git a/tests/test_schemas_quotas.py b/tests/test_schemas_quotas.py\nindex a079863..a316414 100644\n--- a/tests/test_schemas_quotas.py\n+++ b/tests/test_schemas_quotas.py\n@@ -1,11 +1,12 @@\n-\"\"\"Validation-contract tests for `QuotaPutRequest` (AC5, AC18).\"\"\"\n+\"\"\"Validation-contract tests for `QuotaPutRequest` (AC5, AC18) and\n+`QuotaDeleteParams` (AC9).\"\"\"\n \n import pytest\n from hypothesis import given\n from hypothesis import strategies as st\n from pydantic import ValidationError\n \n-from src.api.schemas.quotas import QuotaPutRequest\n+from src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest\n \n \n def _valid_payload(**overrides) -> dict:\n@@ -89,3 +90,62 @@ def test_property_customer_id_only_ever_accepts_the_allowlist(customer_id):\n     except ValidationError:\n         return\n     assert re.fullmatch(r\"[A-Za-z0-9_.:-]{1,128}\", quota.customer_id)\n+\n+\n+def _valid_delete_params(**overrides) -> dict:\n+    params = {\"customer_id\": \"cust_123\", \"metric\": \"api_calls\"}\n+    params.update(overrides)\n+    return params\n+\n+\n+def test_delete_params_accepts_well_formed_identifiers():\n+    \"\"\"AC9: a valid (customer_id, metric) pair parses with the exact values supplied.\"\"\"\n+    params = QuotaDeleteParams(**_valid_delete_params())\n+    assert params.customer_id == \"cust_123\"\n+    assert params.metric == \"api_calls\"\n+\n+\n+def test_delete_params_rejects_missing_fields():\n+    \"\"\"AC9: both customer_id and metric are required.\"\"\"\n+    with pytest.raises(ValidationError):\n+        QuotaDeleteParams(customer_id=\"cust_123\")\n+    with pytest.raises(ValidationError):\n+        QuotaDeleteParams(metric=\"api_calls\")\n+\n+\n+def test_delete_params_rejects_unknown_fields_mass_assignment():\n+    \"\"\"AC9: `extra='forbid'` rejects a client-supplied `api_key_id` — the\n+    server alone resolves the tenant from the authenticated principal\n+    (ASVS 15.3.3).\"\"\"\n+    with pytest.raises(ValidationError):\n+        QuotaDeleteParams(**_valid_delete_params(api_key_id=999))\n+\n+\n+@pytest.mark.parametrize(\n+    \"customer_id\",\n+    [\"' OR 1=1--\", \"../../etc/passwd\", \"line1\\r\\nline2\", \"a\" * 129, \"\"],\n+)\n+def test_delete_params_rejects_injection_and_oversized_customer_id(customer_id):\n+    \"\"\"AC9: SQLi/path-traversal/CRLF/oversized customer_id is rejected at the\n+    schema boundary and never reaches the DELETE SQL sink.\"\"\"\n+    with pytest.raises(ValidationError):\n+        QuotaDeleteParams(**_valid_delete_params(customer_id=customer_id))\n+\n+\n+@pytest.mark.parametrize(\"metric\", [\"' OR 1=1--\", \"a\" * 65, \"\"])\n+def test_delete_params_rejects_invalid_metric(metric):\n+    \"\"\"AC9: injection/oversized metric is rejected at the schema boundary.\"\"\"\n+    with pytest.raises(ValidationError):\n+        QuotaDeleteParams(**_valid_delete_params(metric=metric))\n+\n+\n+@given(customer_id=st.text(min_size=1, max_size=300))\n+def test_property_delete_customer_id_only_ever_accepts_the_allowlist(customer_id):\n+    \"\"\"Hypothesis: any customer_id accepted by QuotaDeleteParams matches the anchored allowlist.\"\"\"\n+    import re\n+\n+    try:\n+        params = QuotaDeleteParams(**_valid_delete_params(customer_id=customer_id))\n+    except ValidationError:\n+        return\n+    assert re.fullmatch(r\"[A-Za-z0-9_.:-]{1,128}\", params.customer_id)","is_error":false}]},"uuid":"519836b6-792e-453f-b4fb-f61121e55bf7","timestamp":"2026-07-10T04:03:21.804Z","sourceToolAssistantUUID":"94c124b5-49de-4fa7-b4ea-1a3ad922c6f4","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"519836b6-792e-453f-b4fb-f61121e55bf7","isSidechain":true,"agentId":"a4faa30a4db9ebeeb","message":{"model":"claude-fable-5","id":"msg_011CcsiJXNGG6p9AnyrhTtf9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01LXw2YRk9Qn8oNCTU5Tighe","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3523,"cache_read_input_tokens":30146,"cache_creation":{"ephemeral_5m_input_tokens":3523,"ephemeral_1h_input_tokens":0},"output_tokens":43,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiJWH2mgkdZV3e5kRea","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"6b344126-84e2-4256-8959-f78ecac070e1","timestamp":"2026-07-10T04:03:31.698Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"6b344126-84e2-4256-8959-f78ecac070e1","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"a4faa30a4db9ebeeb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01LXw2YRk9Qn8oNCTU5Tighe","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"cd068ea8-a900-4433-bc09-81f09856093b","timestamp":"2026-07-10T04:03:31.731Z","sourceToolAssistantUUID":"6b344126-84e2-4256-8959-f78ecac070e1","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"cd068ea8-a900-4433-bc09-81f09856093b","isSidechain":true,"agentId":"a4faa30a4db9ebeeb","message":{"model":"claude-fable-5","id":"msg_011CcsiJXNGG6p9AnyrhTtf9","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01ARzJ6GGq6wC1wZsoqTWKSK","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_quotas_list_delete.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3523,"cache_read_input_tokens":30146,"output_tokens":187,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":3523},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":187,"cache_read_input_tokens":30146,"cache_creation_input_tokens":3523,"cache_creation":{"ephemeral_5m_input_tokens":3523,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcsiJWH2mgkdZV3e5kRea","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"291cb592-28b6-41b1-aa28-044107b1c3e4","timestamp":"2026-07-10T04:03:32.009Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"291cb592-28b6-41b1-aa28-044107b1c3e4","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"a4faa30a4db9ebeeb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01ARzJ6GGq6wC1wZsoqTWKSK","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/quotas` (list) and `DELETE /v1/quotas`\n2\tagainst a real Postgres + Redis (AC1-AC17, AC19; AC18 is delegated to the\n3\tsecurity stage's ASVS reconciliation).\n4\t\"\"\"\n5\t\n6\timport asyncio\n7\t\n8\tfrom httpx import ASGITransport, AsyncClient\n9\tfrom sqlalchemy import text\n10\t\n11\t\n12\tdef _put_payload(**overrides) -> dict:\n13\t    payload = {\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"limit_per_window\": 1000}\n14\t    payload.update(overrides)\n15\t    return payload\n16\t\n17\t\n18\tasync def _seed_quota(client, headers, **overrides) -> None:\n19\t    \"\"\"Create a quota via the existing PUT endpoint — reusing the already-proven\n20\t    write path rather than inserting rows directly keeps these tests focused on\n21\t    the new GET/DELETE behavior.\"\"\"\n22\t    response = await client.put(\"/v1/quotas\", json=_put_payload(**overrides), headers=headers)\n23\t    assert response.status_code in (200, 201)\n24\t\n25\t\n26\tasync def test_get_lists_tenant_quotas_ordered_minimal_fields(client, make_api_key):\n27\t    \"\"\"AC1: GET returns the full unpaginated list, ordered by (customer_id,\n28\t    metric), each row exactly {customer_id, metric, limit_per_window}.\"\"\"\n29\t    presented_key, _ = await make_api_key(scope=\"admin\")\n30\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n31\t\n32\t    # Seed out of order so the response ordering is actually proven, not\n33\t    # merely echoing insertion order.\n34\t    await _seed_quota(client, headers, customer_id=\"cust_b\", metric=\"api_calls\", limit_per_window=200)\n35\t    await _seed_quota(client, headers, customer_id=\"cust_a\", metric=\"storage_gb\", limit_per_window=50)\n36\t    await _seed_quota(client, headers, customer_id=\"cust_a\", metric=\"api_calls\", limit_per_window=100)\n37\t\n38\t    response = await client.get(\"/v1/quotas\", headers=headers)\n39\t\n40\t    assert response.status_code == 200\n41\t    body = response.json()\n42\t    assert body == [\n43\t        {\"customer_id\": \"cust_a\", \"metric\": \"api_calls\", \"limit_per_window\": 100},\n44\t        {\"customer_id\": \"cust_a\", \"metric\": \"storage_gb\", \"limit_per_window\": 50},\n45\t        {\"customer_id\": \"cust_b\", \"metric\": \"api_calls\", \"limit_per_window\": 200},\n46\t    ]\n47\t    for row in body:\n48\t        assert set(row.keys()) == {\"customer_id\", \"metric\", \"limit_per_window\"}\n49\t\n50\t\n51\tasync def test_get_is_tenant_isolated(client, make_api_key):\n52\t    \"\"\"AC2: tenant A's list contains only tenant A's rows, never tenant B's.\"\"\"\n53\t    key_a, _ = await make_api_key(label=\"tenant-a\", scope=\"admin\")\n54\t    key_b, _ = await make_api_key(label=\"tenant-b\", scope=\"admin\")\n55\t    headers_a = {\"Authorization\": f\"Bearer {key_a}\"}\n56\t    headers_b = {\"Authorization\": f\"Bearer {key_b}\"}\n57\t\n58\t    await _seed_quota(client, headers_a, customer_id=\"cust_a\", limit_per_window=100)\n59\t    await _seed_quota(client, headers_b, customer_id=\"cust_b\", limit_per_window=200)\n60\t\n61\t    response_a = await client.get(\"/v1/quotas\", headers=headers_a)\n62\t    assert response_a.status_code == 200\n63\t    body_a = response_a.json()\n64\t    assert len(body_a) == 1\n65\t    assert body_a[0][\"customer_id\"] == \"cust_a\"\n66\t\n67\t\n68\tasync def test_get_empty_returns_200_empty_list(client, make_api_key):\n69\t    \"\"\"AC3: no quotas -> 200 with an empty array, never 404.\"\"\"\n70\t    presented_key, _ = await make_api_key(scope=\"admin\")\n71\t\n72\t    response = await client.get(\n73\t        \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n74\t    )\n75\t\n76\t    assert response.status_code == 200\n77\t    assert response.json() == []\n78\t\n79\t\n80\tasync def test_get_ingest_key_forbidden(client, make_api_key):\n81\t    \"\"\"AC4: an ingest-scoped key gets 403 `forbidden` on GET — admin scope required.\"\"\"\n82\t    presented_key, _ = await make_api_key(scope=\"ingest\")\n83\t\n84\t    response = await client.get(\n85\t        \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n86\t    )\n87\t\n88\t    assert response.status_code == 403\n89\t    assert response.json()[\"error\"][\"code\"] == \"forbidden\"\n90\t\n91\t\n92\tasync def test_get_requires_auth(client):\n93\t    \"\"\"AC5: missing/malformed auth -> 401 on GET.\"\"\"\n94\t    response = await client.get(\"/v1/quotas\")\n95\t    assert response.status_code == 401\n96\t\n97\t    response = await client.get(\n98\t        \"/v1/quotas\", headers={\"Authorization\": \"Bearer not-a-real-token\"}\n99\t    )\n100\t    assert response.status_code == 401\n101\t\n102\t\n103\tasync def test_delete_existing_returns_204_and_removes_row(client, make_api_key, postgres_url):\n104\t    \"\"\"AC6: DELETE of an existing quota -> 204 empty body; the row is gone\n105\t    from a subsequent GET and from the table directly.\"\"\"\n106\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n107\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n108\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\")\n109\t\n110\t    response = await client.delete(\n111\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers\n112\t    )\n113\t\n114\t    assert response.status_code == 204\n115\t    assert response.content == b\"\"\n116\t\n117\t    listing = await client.get(\"/v1/quotas\", headers=headers)\n118\t    assert listing.json() == []\n119\t\n120\t    from sqlalchemy.ext.asyncio import create_async_engine\n121\t\n122\t    engine = create_async_engine(postgres_url)\n123\t    async with engine.connect() as connection:\n124\t        count = (\n125\t            await connection.execute(\n126\t                text(\"SELECT COUNT(*) FROM quotas WHERE api_key_id = :id\"), {\"id\": api_key_id}\n127\t            )\n128\t        ).scalar_one()\n129\t    await engine.dispose()\n130\t    assert count == 0\n131\t\n132\t\n133\tasync def test_delete_absent_returns_404_envelope(client, make_api_key):\n134\t    \"\"\"AC7: DELETE of a (customer_id, metric) with no quota -> 404 not_found,\n135\t    the standard error envelope (explicit, not silently idempotent).\"\"\"\n136\t    presented_key, _ = await make_api_key(scope=\"admin\")\n137\t\n138\t    response = await client.delete(\n139\t        \"/v1/quotas\",\n140\t        params={\"customer_id\": \"cust_missing\", \"metric\": \"api_calls\"},\n141\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n142\t    )\n143\t\n144\t    assert response.status_code == 404\n145\t    assert response.json()[\"error\"][\"code\"] == \"not_found\"\n146\t\n147\t\n148\tasync def test_delete_cannot_touch_other_tenant(client, make_api_key, postgres_url):\n149\t    \"\"\"AC8: tenant A deleting a (customer_id, metric) that exists only under\n150\t    tenant B -> 404 (invisible), and tenant B's row is still present.\"\"\"\n151\t    key_a, _ = await make_api_key(label=\"tenant-a\", scope=\"admin\")\n152\t    key_b, api_key_id_b = await make_api_key(label=\"tenant-b\", scope=\"admin\")\n153\t    headers_a = {\"Authorization\": f\"Bearer {key_a}\"}\n154\t    headers_b = {\"Authorization\": f\"Bearer {key_b}\"}\n155\t\n156\t    await _seed_quota(client, headers_b, customer_id=\"cust_shared\", metric=\"api_calls\", limit_per_window=500)\n157\t\n158\t    response = await client.delete(\n159\t        \"/v1/quotas\", params={\"customer_id\": \"cust_shared\", \"metric\": \"api_calls\"}, headers=headers_a\n160\t    )\n161\t    assert response.status_code == 404\n162\t\n163\t    from sqlalchemy.ext.asyncio import create_async_engine\n164\t\n165\t    engine = create_async_engine(postgres_url)\n166\t    async with engine.connect() as connection:\n167\t        row = (\n168\t            await connection.execute(\n169\t                text(\"SELECT limit_per_window FROM quotas WHERE api_key_id = :id\"),\n170\t                {\"id\": api_key_id_b},\n171\t            )\n172\t        ).mappings().one()\n173\t    await engine.dispose()\n174\t    assert row[\"limit_per_window\"] == 500\n175\t\n176\t\n177\tasync def test_delete_validation_rejections(client, make_api_key):\n178\t    \"\"\"AC9: missing/invalid/injection/unknown-extra query params -> 422 validation_failed.\"\"\"\n179\t    presented_key, _ = await make_api_key(scope=\"admin\")\n180\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n181\t\n182\t    missing_metric = await client.delete(\n183\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\"}, headers=headers\n184\t    )\n185\t    assert missing_metric.status_code == 422\n186\t    assert missing_metric.json()[\"error\"][\"code\"] == \"validation_failed\"\n187\t\n188\t    bad_customer_id = await client.delete(\n189\t        \"/v1/quotas\", params={\"customer_id\": \"bad id with spaces\", \"metric\": \"api_calls\"}, headers=headers\n190\t    )\n191\t    assert bad_customer_id.status_code == 422\n192\t\n193\t    injection = await client.delete(\n194\t        \"/v1/quotas\", params={\"customer_id\": \"' OR 1=1--\", \"metric\": \"api_calls\"}, headers=headers\n195\t    )\n196\t    assert injection.status_code == 422\n197\t\n198\t    extra_param = await client.delete(\n199\t        \"/v1/quotas\",\n200\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"api_key_id\": \"999\"},\n201\t        headers=headers,\n202\t    )\n203\t    assert extra_param.status_code == 422\n204\t\n205\t\n206\tasync def test_delete_ingest_key_forbidden(client, make_api_key):\n207\t    \"\"\"AC10: an ingest-scoped key gets 403 `forbidden` on DELETE.\"\"\"\n208\t    presented_key, _ = await make_api_key(scope=\"ingest\")\n209\t\n210\t    response = await client.delete(\n211\t        \"/v1/quotas\",\n212\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n213\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n214\t    )\n215\t\n216\t    assert response.status_code == 403\n217\t    assert response.json()[\"error\"][\"code\"] == \"forbidden\"\n218\t\n219\t\n220\tasync def test_delete_requires_auth(client):\n221\t    \"\"\"AC11: missing/malformed auth -> 401 on DELETE.\"\"\"\n222\t    response = await client.delete(\n223\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}\n224\t    )\n225\t    assert response.status_code == 401\n226\t\n227\t    response = await client.delete(\n228\t        \"/v1/quotas\",\n229\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n230\t        headers={\"Authorization\": \"Bearer not-a-real-token\"},\n231\t    )\n232\t    assert response.status_code == 401\n233\t\n234\t\n235\tasync def test_quota_admin_routes_rate_limited_per_principal(truncate_tables, make_api_key):\n236\t    \"\"\"AC12: both GET and DELETE /v1/quotas are Tier-2 per-api_key_id rate\n237\t    limited; two admin principals sharing one client IP get independent\n238\t    buckets (mirrors test_quotas_endpoint.py::test_put_rate_limited_per_principal).\"\"\"\n239\t    from src.main import app\n240\t\n241\t    key_a, _ = await make_api_key(label=\"a\", rate_limit_per_sec=1, scope=\"admin\")\n242\t    key_b, _ = await make_api_key(label=\"b\", rate_limit_per_sec=100, scope=\"admin\")\n243\t\n244\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 4000))\n245\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as test_client:\n246\t        first = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n247\t        second = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n248\t        assert first.status_code == 200\n249\t        assert second.status_code == 429\n250\t        assert \"Retry-After\" in second.headers\n251\t\n252\t        b_response = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n253\t        assert b_response.status_code == 200, \"principal B, same IP, must have its own untouched bucket\"\n254\t\n255\t        third = await test_client.delete(\n256\t            \"/v1/quotas\",\n257\t            params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n258\t            headers={\"Authorization\": f\"Bearer {key_b}\"},\n259\t        )\n260\t        # key_b's bucket has capacity left (100/sec); a 404 (no such quota) is\n261\t        # the expected outcome here, proving the request reached the handler\n262\t        # rather than being throttled.\n263\t        assert third.status_code == 404\n264\t\n265\t\n266\tasync def test_delete_does_not_reset_usage_and_events_uncapped(client, make_api_key, postgres_url):\n267\t    \"\"\"AC13: deleting a quota removes only the cap — `usage_rollup` for that\n268\t    (customer, metric) is unchanged, and a subsequent POST /v1/events for the\n269\t    now-uncapped pair is accepted 201 unlimited (same as never-capped).\"\"\"\n270\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n271\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n272\t\n273\t    # Cap it low, then record usage that approaches (but does not exceed) the cap.\n274\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\", limit_per_window=10)\n275\t    event_response = await client.post(\n276\t        \"/v1/events\",\n277\t        json={\n278\t            \"customer_id\": \"cust_1\",\n279\t            \"metric\": \"api_calls\",\n280\t            \"quantity\": \"5\",\n281\t            \"idempotency_key\": \"pre-delete-event\",\n282\t        },\n283\t        headers=headers,\n284\t    )\n285\t    assert event_response.status_code == 201\n286\t\n287\t    from sqlalchemy.ext.asyncio import create_async_engine\n288\t\n289\t    engine = create_async_engine(postgres_url)\n290\t    async with engine.connect() as connection:\n291\t        rollup_before = (\n292\t            await connection.execute(\n293\t                text(\n294\t                    \"SELECT total_quantity FROM usage_rollup WHERE api_key_id = :id \"\n295\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n296\t                ),\n297\t                {\"id\": api_key_id},\n298\t            )\n299\t        ).scalar_one()\n300\t    await engine.dispose()\n301\t    assert rollup_before == 5\n302\t\n303\t    delete_response = await client.delete(\n304\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers\n305\t    )\n306\t    assert delete_response.status_code == 204\n307\t\n308\t    engine = create_async_engine(postgres_url)\n309\t    async with engine.connect() as connection:\n310\t        rollup_after = (\n311\t            await connection.execute(\n312\t                text(\n313\t                    \"SELECT total_quantity FROM usage_rollup WHERE api_key_id = :id \"\n314\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n315\t                ),\n316\t                {\"id\": api_key_id},\n317\t            )\n318\t        ).scalar_one()\n319\t    await engine.dispose()\n320\t    assert rollup_after == 5, \"DELETE must never touch usage_rollup\"\n321\t\n322\t    # A large event that would have exceeded the old cap (10) is now accepted\n323\t    # unlimited, since the cap no longer exists.\n324\t    uncapped_response = await client.post(\n325\t        \"/v1/events\",\n326\t        json={\n327\t            \"customer_id\": \"cust_1\",\n328\t            \"metric\": \"api_calls\",\n329\t            \"quantity\": \"9999\",\n330\t            \"idempotency_key\": \"post-delete-event\",\n331\t        },\n332\t        headers=headers,\n333\t    )\n334\t    assert uncapped_response.status_code == 201\n335\t\n336\t\n337\tasync def test_delete_and_forbidden_are_logged(client, make_api_key, capsys):\n338\t    \"\"\"AC16: a successful DELETE logs `quota.delete` INFO (customer_id\n339\t    redacted); a scope-denied GET or DELETE logs the existing `quota.forbidden` WARNING.\"\"\"\n340\t    admin_key, _ = await make_api_key(scope=\"admin\")\n341\t    ingest_key, _ = await make_api_key(label=\"ingest-only\", scope=\"ingest\")\n342\t    headers = {\"Authorization\": f\"Bearer {admin_key}\"}\n343\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\")\n344\t\n345\t    await client.delete(\"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers)\n346\t    await client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n347\t\n348\t    captured = capsys.readouterr()\n349\t    assert \"quota.delete\" in captured.out\n350\t    assert \"***redacted***\" in captured.out\n351\t    assert \"quota.forbidden\" in captured.out\n352\t\n353\t\n354\tasync def test_openapi_exposes_get_and_delete_quotas(client):\n355\t    \"\"\"AC17 (DAST-readiness): the served /openapi.json includes both GET and\n356\t    DELETE /v1/quotas, matching the implemented routes/schemas.\"\"\"\n357\t    response = await client.get(\"/openapi.json\")\n358\t    assert response.status_code == 200\n359\t    schema = response.json()\n360\t    assert \"/v1/quotas\" in schema[\"paths\"]\n361\t    assert \"get\" in schema[\"paths\"][\"/v1/quotas\"]\n362\t    assert \"delete\" in schema[\"paths\"][\"/v1/quotas\"]\n363\t\n364\t\n365\tasync def test_get_forced_internal_error_returns_safe_envelope(\n366\t    truncate_tables, make_api_key, monkeypatch\n367\t):\n368\t    \"\"\"AC19: a forced internal error during the GET list read returns the\n369\t    generic 500 envelope, with no stack trace / SQL fragment / exception\n370\t    type / internal path leaked.\"\"\"\n371\t    presented_key, _ = await make_api_key(scope=\"admin\")\n372\t\n373\t    from src.services import quota_service\n374\t\n375\t    async def _boom(*args, **kwargs):\n376\t        raise RuntimeError(\"simulated read failure\")\n377\t\n378\t    monkeypatch.setattr(quota_service, \"list_quotas\", _boom)\n379\t\n380\t    from src.main import app\n381\t\n382\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n383\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as raw_client:\n384\t        response = await raw_client.get(\n385\t            \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n386\t        )\n387\t\n388\t    assert response.status_code == 500\n389\t    body = response.json()\n390\t    assert body[\"error\"][\"code\"] == \"internal\"\n391\t    assert \"requestId\" in body[\"error\"]\n392\t    message = body[\"error\"][\"message\"].lower()\n393\t    assert \"runtimeerror\" not in message\n394\t    assert \"simulated read failure\" not in message\n395\t    assert \"traceback\" not in message\n396\t\n397\t\n398\tasync def test_delete_forced_internal_error_returns_safe_envelope_and_fails_closed(\n399\t    client, make_api_key, postgres_url, monkeypatch\n400\t):\n401\t    \"\"\"AC19: a forced internal error during DELETE returns the generic 500\n402\t    envelope and fails closed — the transaction rolls back, so the target\n403\t    quota row survives (mirrors test_events_endpoint.py's forced-error test).\"\"\"\n404\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n405\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n406\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\", limit_per_window=42)\n407\t\n408\t    from src.services import quota_service\n409\t\n410\t    async def _boom(*args, **kwargs):\n411\t        raise RuntimeError(\"simulated delete failure\")\n412\t\n413\t    monkeypatch.setattr(quota_service, \"delete_quota\", _boom)\n414\t\n415\t    from src.main import app\n416\t\n417\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n418\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as raw_client:\n419\t        response = await raw_client.delete(\n420\t            \"/v1/quotas\",\n421\t            params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n422\t            headers=headers,\n423\t        )\n424\t\n425\t    assert response.status_code == 500\n426\t    body = response.json()\n427\t    assert body[\"error\"][\"code\"] == \"internal\"\n428\t    assert \"requestId\" in body[\"error\"]\n429\t    message = body[\"error\"][\"message\"].lower()\n430\t    assert \"runtimeerror\" not in message\n431\t    assert \"simulated delete failure\" not in message\n432\t    assert \"traceback\" not in message\n433\t\n434\t    from sqlalchemy.ext.asyncio import create_async_engine\n435\t\n436\t    engine = create_async_engine(postgres_url)\n437\t    async with engine.connect() as connection:\n438\t        row = (\n439\t            await connection.execute(\n440\t                text(\n441\t                    \"SELECT limit_per_window FROM quotas WHERE api_key_id = :id \"\n442\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n443\t                ),\n444\t                {\"id\": api_key_id},\n445\t            )\n446\t        ).mappings().one()\n447\t    await engine.dispose()\n448\t    assert row[\"limit_per_window\"] == 42, \"a failed DELETE must leave the target row intact (fail-closed)\"\n449\t\n450\t\n451\tasync def test_concurrent_delete_of_the_same_quota_yields_exactly_one_winner(\n452\t    client, make_api_key, postgres_url\n453\t):\n454\t    \"\"\"AC6/AC7 under contention: N concurrent DELETE requests for the exact\n455\t    same (customer_id, metric) must yield exactly one 204 (the winner) and\n456\t    the rest 404 (the loser's explicit outcome) -- never two 204s (a double\n457\t    side effect) and never a 500/race artifact. Proves the decision point\n458\t    (delete_quota's single parameterized DELETE ... RETURNING) is actually\n459\t    atomic under real concurrent access, not merely correct in the\n460\t    single-caller tests above.\"\"\"\n461\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n462\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n463\t    await _seed_quota(client, headers, customer_id=\"cust_race\", metric=\"api_calls\", limit_per_window=100)\n464\t\n465\t    concurrent_requests = 10\n466\t\n467\t    async def _delete():\n468\t        return await client.delete(\n469\t            \"/v1/quotas\", params={\"customer_id\": \"cust_race\", \"metric\": \"api_calls\"}, headers=headers\n470\t        )\n471\t\n472\t    responses = await asyncio.gather(*(_delete() for _ in range(concurrent_requests)))\n473\t    statuses = [response.status_code for response in responses]\n474\t\n475\t    winners = [status for status in statuses if status == 204]\n476\t    losers = [status for status in statuses if status == 404]\n477\t\n478\t    assert len(winners) == 1, f\"expected exactly one 204 winner, got statuses: {statuses}\"\n479\t    assert len(losers) == concurrent_requests - 1, f\"expected the rest to be 404 losers, got statuses: {statuses}\"\n480\t    assert set(statuses) <= {204, 404}, f\"no request should error under contention, got statuses: {statuses}\"\n481\t\n482\t    from sqlalchemy.ext.asyncio import create_async_engine\n483\t\n484\t    engine = create_async_engine(postgres_url)\n485\t    async with engine.connect() as connection:\n486\t        count = (\n487\t            await connection.execute(\n488\t                text(\n489\t                    \"SELECT COUNT(*) FROM quotas WHERE api_key_id = :id \"\n490\t                    \"AND customer_id = 'cust_race' AND metric = 'api_calls'\"\n491\t                ),\n492\t                {\"id\": api_key_id},\n493\t            )\n494\t        ).scalar_one()\n495\t    await engine.dispose()\n496\t    assert count == 0, \"the row must be gone exactly once, not left behind or double-removed\"\n497\t\n498\t\n499\tasync def test_no_new_alembic_migration_added(postgres_url):\n500\t    \"\"\"AC14: this feature operates on the existing `quotas` table — no new\n501\t    file under alembic/versions/ beyond the existing revisions 0001-0003.\"\"\"\n502\t    from pathlib import Path\n503\t\n504\t    versions_dir = Path(__file__).resolve().parents[2] / \"alembic\" / \"versions\"\n505\t    revision_files = sorted(p.name for p in versions_dir.glob(\"*.py\") if not p.name.startswith(\"__\"))\n506\t    assert len(revision_files) == 3, f\"expected exactly 3 migration files, found: {revision_files}\"\n507\t"}]},"uuid":"5c5a19c4-dba4-4003-ac9e-82268a19c707","timestamp":"2026-07-10T04:03:32.038Z","sourceToolAssistantUUID":"291cb592-28b6-41b1-aa28-044107b1c3e4","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
