{"parentUuid":"9f3fdb45-4c1c-4238-a397-806ec9340c3c","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiHKsBrjFmD7Xm8cFSJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01AUHatnwaKposcXKdECJFb8","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\routes\\quotas.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18164,"cache_read_input_tokens":26379,"cache_creation":{"ephemeral_5m_input_tokens":18164,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiHJruyCkNiZEvmXGZF","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"0050ef68-42eb-46c2-a120-788a8a748734","timestamp":"2026-07-10T04:03:15.731Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"0050ef68-42eb-46c2-a120-788a8a748734","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"ac1c3361cb16ecefb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AUHatnwaKposcXKdECJFb8","type":"tool_result","content":"1\t\"\"\"`/v1/quotas` — admin-scoped create-or-replace (`PUT`), list (`GET`), and\n2\tremove (`DELETE`) of a per-customer, per-metric usage cap.\n3\t\n4\tEdge behavior (security headers, CORS, body-size guard, Tier-1 throttle) is\n5\tinherited from the middleware stack; every route on this router wires\n6\tauth -> Tier-2 throttle -> admin-scope check -> schema validation -> service,\n7\tmirroring the `events`/`usage` routes' sibling `_require_authenticated_and_throttled`\n8\tpattern (kept per-route, not shared, per the existing convention). All three\n9\tverbs depend on the same `_require_admin_and_throttled` chain — GET/DELETE\n10\treuse it verbatim rather than introducing a new scope or auth path.\n11\t\"\"\"\n12\t\n13\tfrom typing import Annotated\n14\t\n15\tfrom fastapi import APIRouter, Depends, HTTPException, Query, Request, Response, status\n16\t\n17\tfrom src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\n18\tfrom src.auth import require_api_key\n19\tfrom src.auth.api_key import AuthenticatedPrincipal\n20\tfrom src.auth.rate_limit import enforce_tier2_rate_limit\n21\tfrom src.logging import get_logger\n22\tfrom src.services.quota_service import (\n23\t    delete_tenant_quota,\n24\t    list_tenant_quotas,\n25\t    to_response,\n26\t    upsert_tenant_quota,\n27\t)\n28\t\n29\trouter = APIRouter(tags=[\"quotas\"])\n30\tlogger = get_logger(service=\"meterly\")\n31\t\n32\t_ADMIN_SCOPE = \"admin\"\n33\t\n34\t\n35\tasync def _require_admin_and_throttled(\n36\t    request: Request, principal: AuthenticatedPrincipal = Depends(require_api_key)\n37\t) -> AuthenticatedPrincipal:\n38\t    \"\"\"Compose auth, then the Tier-2 per-key throttle, then the admin-scope\n39\t    gate, in that order — mirrors `src/api/routes/events.py`'s dependency\n40\t    chain, extended with the function-level authorization check this route\n41\t    alone requires (ASVS 8.2.1).\n42\t    \"\"\"\n43\t    await enforce_tier2_rate_limit(request, principal)\n44\t    if principal.scope != _ADMIN_SCOPE:\n45\t        logger.warning(\n46\t            \"quota.forbidden\",\n47\t            userId=principal.api_key_id,\n48\t            action=\"deny\",\n49\t            reason=\"insufficient_scope\",\n50\t        )\n51\t        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail=\"admin scope required\")\n52\t    return principal\n53\t\n54\t\n55\t@router.put(\"/v1/quotas\", response_model=QuotaResponse)\n56\tasync def put_quota(\n57\t    payload: QuotaPutRequest,\n58\t    response: Response,\n59\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n60\t) -> QuotaResponse:\n61\t    \"\"\"Create or replace the cap for `(customer_id, metric)` under the\n62\t    caller's own tenant — 201 on create, 200 on replace.\"\"\"\n63\t    outcome = await upsert_tenant_quota(principal, payload)\n64\t    response.status_code = outcome.http_status\n65\t    return to_response(outcome)\n66\t\n67\t\n68\t@router.get(\"/v1/quotas\", response_model=list[QuotaResponse])\n69\tasync def list_quotas_endpoint(\n70\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n71\t) -> list[QuotaResponse]:\n72\t    \"\"\"Return the caller's own tenant's full, unpaginated quota list,\n73\t    deterministically ordered by `(customer_id, metric)`. An empty tenant\n74\t    gets `200 []`, never a 404.\"\"\"\n75\t    return await list_tenant_quotas(principal)\n76\t\n77\t\n78\t@router.delete(\"/v1/quotas\", status_code=status.HTTP_204_NO_CONTENT)\n79\tasync def delete_quota_endpoint(\n80\t    params: Annotated[QuotaDeleteParams, Query()],\n81\t    principal: AuthenticatedPrincipal = Depends(_require_admin_and_throttled),\n82\t) -> Response:\n83\t    \"\"\"Remove the cap for `(customer_id, metric)` under the caller's own\n84\t    tenant — 204 on success, 404 if no such quota exists in this tenant\n85\t    (explicit, not silently idempotent).\"\"\"\n86\t    await delete_tenant_quota(principal, params)\n87\t    return Response(status_code=status.HTTP_204_NO_CONTENT)\n88\t"}]},"uuid":"cb001962-5120-452d-b75c-c18827193a56","timestamp":"2026-07-10T04:03:15.761Z","sourceToolAssistantUUID":"0050ef68-42eb-46c2-a120-788a8a748734","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"cb001962-5120-452d-b75c-c18827193a56","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiHKsBrjFmD7Xm8cFSJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01Gx31pBXW2KFEeEe3oevB8j","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\schemas\\quotas.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18164,"cache_read_input_tokens":26379,"cache_creation":{"ephemeral_5m_input_tokens":18164,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiHJruyCkNiZEvmXGZF","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"d27c6309-2278-4cca-921d-27cb785c82b0","timestamp":"2026-07-10T04:03:16.663Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"d27c6309-2278-4cca-921d-27cb785c82b0","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"ac1c3361cb16ecefb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gx31pBXW2KFEeEe3oevB8j","type":"tool_result","content":"1\t\"\"\"Validation contract for `PUT /v1/quotas`.\n2\t\n3\t`customer_id`/`metric` reuse the exact anchored allowlists `src/api/schemas/events.py`\n4\talready validates against (the same identifiers, same sinks) — kept as separate\n5\t`constr` instances here rather than a cross-module import so this schema stays a\n6\tself-contained boundary contract (plan's validation-contract table). `api_key_id`\n7\tand `scope` are deliberately absent: the server sets `api_key_id` from the\n8\tauthenticated principal and never accepts a client-supplied `scope`, which is\n9\tthe mass-assignment defense against writing another tenant's cap or\n10\tself-elevating privilege (ASVS 15.3.3, threat T3/E2 in the plan's STRIDE model).\n11\t\"\"\"\n12\t\n13\tfrom pydantic import BaseModel, ConfigDict, conint, constr\n14\t\n15\tCustomerId = constr(pattern=r\"^[A-Za-z0-9_.:-]{1,128}$\")\n16\tMetric = constr(pattern=r\"^[A-Za-z0-9_.:-]{1,64}$\")\n17\t# BIGINT-safe upper bound: guards against an absurd/overflowing value reaching\n18\t# the BIGINT column or the R+Q>L comparison (plan's DoS row on limit_per_window).\n19\tLimitPerWindow = conint(ge=1, le=10**15)\n20\t\n21\t\n22\tclass QuotaPutRequest(BaseModel):\n23\t    \"\"\"The client-supplied body of `PUT /v1/quotas`.\n24\t\n25\t    `extra='forbid'` rejects any unknown field outright, including a\n26\t    client-supplied `api_key_id` or `scope` — the create-or-replace identity\n27\t    is exactly `(customer_id, metric)`, resolved against the authenticated\n28\t    principal's own `api_key_id` by the service layer, never the request body.\n29\t    \"\"\"\n30\t\n31\t    model_config = ConfigDict(extra=\"forbid\")\n32\t\n33\t    customer_id: CustomerId\n34\t    metric: Metric\n35\t    limit_per_window: LimitPerWindow\n36\t\n37\t\n38\tclass QuotaResponse(BaseModel):\n39\t    \"\"\"The minimal response field set for a quota (ASVS 15.3.1) — echoes only\n40\t    what the caller supplied, never the full `quotas` row (`api_key_id`,\n41\t    `created_at`, `updated_at` stay internal).\"\"\"\n42\t\n43\t    model_config = ConfigDict(extra=\"forbid\")\n44\t\n45\t    customer_id: str\n46\t    metric: str\n47\t    limit_per_window: int\n48\t\n49\t\n50\tclass QuotaDeleteParams(BaseModel):\n51\t    \"\"\"The two required query parameters of `DELETE /v1/quotas`, reusing the\n52\t    exact same anchored `CustomerId`/`Metric` allowlists `QuotaPutRequest`\n53\t    validates against — same identifiers, same sinks, same rejection\n54\t    behavior (422). `extra='forbid'` rejects any unknown query param\n55\t    (including a client-supplied `api_key_id`), the mass-assignment defense\n56\t    that keeps the delete target's tenant resolved only from the\n57\t    authenticated principal (ASVS 15.3.3).\n58\t    \"\"\"\n59\t\n60\t    model_config = ConfigDict(extra=\"forbid\")\n61\t\n62\t    customer_id: CustomerId\n63\t    metric: Metric\n64\t"}]},"uuid":"61b0ede9-86c8-4c87-b38b-3742b308b0fc","timestamp":"2026-07-10T04:03:16.695Z","sourceToolAssistantUUID":"d27c6309-2278-4cca-921d-27cb785c82b0","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"61b0ede9-86c8-4c87-b38b-3742b308b0fc","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiHKsBrjFmD7Xm8cFSJ","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01SBatoB1KpJUBPwoKVnGK4x","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\services\\quota_service.py"},"caller":{"type":"direct"}}],"stop_reason":"tool_use","stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":18164,"cache_read_input_tokens":26379,"output_tokens":385,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":0,"ephemeral_5m_input_tokens":18164},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":385,"cache_read_input_tokens":26379,"cache_creation_input_tokens":18164,"cache_creation":{"ephemeral_5m_input_tokens":18164,"ephemeral_1h_input_tokens":0},"type":"message"}],"speed":"standard"},"diagnostics":null},"requestId":"req_011CcsiHJruyCkNiZEvmXGZF","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"21cd939b-02ab-4795-a9c2-30083e2fa5da","timestamp":"2026-07-10T04:03:17.133Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"21cd939b-02ab-4795-a9c2-30083e2fa5da","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"ac1c3361cb16ecefb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SBatoB1KpJUBPwoKVnGK4x","type":"tool_result","content":"1\t\"\"\"Service for `/v1/quotas` — the admin-scoped upsert (`PUT`), list (`GET`),\n2\tand remove (`DELETE`) operations.\n3\t\n4\tEach entry point orchestrates one transaction per request: the `xmax` upsert\n5\tin `src/repositories/quotas_repo.py` reports create-vs-replace in a single\n6\tround-trip for `PUT`; `GET` opens a read-only scoped transaction for the\n7\tordered listing; `DELETE` maps \"no row matched\" to a 404 rather than a\n8\tsilent success (plan §\"DELETE — remove one cap, explicitly\").\n9\t\"\"\"\n10\t\n11\tfrom dataclasses import dataclass\n12\t\n13\tfrom fastapi import HTTPException, status\n14\t\n15\tfrom src.api.schemas.quotas import QuotaDeleteParams, QuotaPutRequest, QuotaResponse\n16\tfrom src.auth.api_key import AuthenticatedPrincipal\n17\tfrom src.db.session import scoped_transaction\n18\tfrom src.logging import get_logger\n19\tfrom src.repositories.quotas_repo import delete_quota, list_quotas, upsert_quota\n20\t\n21\tlogger = get_logger(service=\"meterly\")\n22\t\n23\t\n24\t@dataclass(frozen=True)\n25\tclass QuotaUpsertOutcome:\n26\t    \"\"\"The result of processing a `PUT /v1/quotas` request: the stored quota\n27\t    and the HTTP status the route should return (201 create, 200 replace).\"\"\"\n28\t\n29\t    customer_id: str\n30\t    metric: str\n31\t    limit_per_window: int\n32\t    http_status: int\n33\t\n34\t\n35\tasync def upsert_tenant_quota(\n36\t    principal: AuthenticatedPrincipal, payload: QuotaPutRequest\n37\t) -> QuotaUpsertOutcome:\n38\t    \"\"\"Create-or-replace the cap for `(customer_id, metric)` under the\n39\t    authenticated principal's own `api_key_id` — the server, never the\n40\t    client, sets `api_key_id`, which is the mass-assignment protection\n41\t    (ASVS 15.3.3) against writing another tenant's cap.\n42\t    \"\"\"\n43\t    async with scoped_transaction(principal.api_key_id) as session:\n44\t        record = await upsert_quota(\n45\t            session,\n46\t            api_key_id=principal.api_key_id,\n47\t            customer_id=payload.customer_id,\n48\t            metric=payload.metric,\n49\t            limit_per_window=payload.limit_per_window,\n50\t        )\n51\t\n52\t    action = \"create\" if record.inserted else \"replace\"\n53\t    logger.info(\n54\t        \"quota.upsert\",\n55\t        userId=principal.api_key_id,\n56\t        action=action,\n57\t        customer_id=record.customer_id,\n58\t        metric=record.metric,\n59\t        limit_per_window=record.limit_per_window,\n60\t    )\n61\t    return QuotaUpsertOutcome(\n62\t        customer_id=record.customer_id,\n63\t        metric=record.metric,\n64\t        limit_per_window=record.limit_per_window,\n65\t        http_status=201 if record.inserted else 200,\n66\t    )\n67\t\n68\t\n69\tdef to_response(outcome: QuotaUpsertOutcome) -> QuotaResponse:\n70\t    \"\"\"Map the service outcome to the minimal public response shape (ASVS 15.3.1).\"\"\"\n71\t    return QuotaResponse(\n72\t        customer_id=outcome.customer_id,\n73\t        metric=outcome.metric,\n74\t        limit_per_window=outcome.limit_per_window,\n75\t    )\n76\t\n77\t\n78\tasync def list_tenant_quotas(principal: AuthenticatedPrincipal) -> list[QuotaResponse]:\n79\t    \"\"\"Return the caller's own tenant's full, deterministically ordered quota\n80\t    list — an empty tenant gets an empty list, never a 404 (plan §\"Empty set\n81\t    -> 200 [], never 404\"). Deliberately not logged as a business event (open\n82\t    question 1, resolved default): a plain read of the caller's own\n83\t    configuration, mirroring `GET /v1/usage`.\n84\t    \"\"\"\n85\t    async with scoped_transaction(principal.api_key_id) as session:\n86\t        rows = await list_quotas(session, api_key_id=principal.api_key_id)\n87\t\n88\t    return [\n89\t        QuotaResponse(customer_id=row.customer_id, metric=row.metric, limit_per_window=row.limit_per_window)\n90\t        for row in rows\n91\t    ]\n92\t\n93\t\n94\tasync def delete_tenant_quota(\n95\t    principal: AuthenticatedPrincipal, params: QuotaDeleteParams\n96\t) -> None:\n97\t    \"\"\"Remove the cap for `(customer_id, metric)` under the caller's own\n98\t    tenant, raising 404 if no such quota exists (explicit, not silently\n99\t    idempotent — plan §\"Why 404-on-absent, not idempotent-204\").\n100\t\n101\t    A cross-tenant delete attempt matches zero rows (the `api_key_id` filter\n102\t    + FORCE RLS backstop), which is indistinguishable from a truly-absent\n103\t    quota — the intended BOLA-safe behavior (threat E2).\n104\t    \"\"\"\n105\t    async with scoped_transaction(principal.api_key_id) as session:\n106\t        removed = await delete_quota(\n107\t            session,\n108\t            api_key_id=principal.api_key_id,\n109\t            customer_id=params.customer_id,\n110\t            metric=params.metric,\n111\t        )\n112\t\n113\t    if not removed:\n114\t        raise HTTPException(status_code=status.HTTP_404_NOT_FOUND, detail=\"quota not found\")\n115\t\n116\t    logger.info(\n117\t        \"quota.delete\",\n118\t        userId=principal.api_key_id,\n119\t        action=\"delete\",\n120\t        customer_id=params.customer_id,\n121\t        metric=params.metric,\n122\t    )\n123\t"}]},"uuid":"d6a3f575-1ce4-4e56-a02f-88e9d89dfad6","timestamp":"2026-07-10T04:03:17.169Z","sourceToolAssistantUUID":"21cd939b-02ab-4795-a9c2-30083e2fa5da","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"d6a3f575-1ce4-4e56-a02f-88e9d89dfad6","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiJBi5bGdFJ9d93CSNh","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5303,"cache_read_input_tokens":44543,"cache_creation":{"ephemeral_5m_input_tokens":5303,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiJAgZQsmjXcBu9MmvD","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"df5732f4-da5c-410c-a829-98e11ed0f26b","timestamp":"2026-07-10T04:03:36.922Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"df5732f4-da5c-410c-a829-98e11ed0f26b","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiJBi5bGdFJ9d93CSNh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FJQaZjsrU5WSdVpbEZJMJ9","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\tests\\integration\\test_quotas_list_delete.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5303,"cache_read_input_tokens":44543,"cache_creation":{"ephemeral_5m_input_tokens":5303,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiJAgZQsmjXcBu9MmvD","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"93cc6fb9-10ed-435b-a476-3c08e290d23c","timestamp":"2026-07-10T04:03:42.092Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"93cc6fb9-10ed-435b-a476-3c08e290d23c","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"ac1c3361cb16ecefb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FJQaZjsrU5WSdVpbEZJMJ9","type":"tool_result","content":"1\t\"\"\"Integration tests for `GET /v1/quotas` (list) and `DELETE /v1/quotas`\n2\tagainst a real Postgres + Redis (AC1-AC17, AC19; AC18 is delegated to the\n3\tsecurity stage's ASVS reconciliation).\n4\t\"\"\"\n5\t\n6\timport asyncio\n7\t\n8\tfrom httpx import ASGITransport, AsyncClient\n9\tfrom sqlalchemy import text\n10\t\n11\t\n12\tdef _put_payload(**overrides) -> dict:\n13\t    payload = {\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"limit_per_window\": 1000}\n14\t    payload.update(overrides)\n15\t    return payload\n16\t\n17\t\n18\tasync def _seed_quota(client, headers, **overrides) -> None:\n19\t    \"\"\"Create a quota via the existing PUT endpoint — reusing the already-proven\n20\t    write path rather than inserting rows directly keeps these tests focused on\n21\t    the new GET/DELETE behavior.\"\"\"\n22\t    response = await client.put(\"/v1/quotas\", json=_put_payload(**overrides), headers=headers)\n23\t    assert response.status_code in (200, 201)\n24\t\n25\t\n26\tasync def test_get_lists_tenant_quotas_ordered_minimal_fields(client, make_api_key):\n27\t    \"\"\"AC1: GET returns the full unpaginated list, ordered by (customer_id,\n28\t    metric), each row exactly {customer_id, metric, limit_per_window}.\"\"\"\n29\t    presented_key, _ = await make_api_key(scope=\"admin\")\n30\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n31\t\n32\t    # Seed out of order so the response ordering is actually proven, not\n33\t    # merely echoing insertion order.\n34\t    await _seed_quota(client, headers, customer_id=\"cust_b\", metric=\"api_calls\", limit_per_window=200)\n35\t    await _seed_quota(client, headers, customer_id=\"cust_a\", metric=\"storage_gb\", limit_per_window=50)\n36\t    await _seed_quota(client, headers, customer_id=\"cust_a\", metric=\"api_calls\", limit_per_window=100)\n37\t\n38\t    response = await client.get(\"/v1/quotas\", headers=headers)\n39\t\n40\t    assert response.status_code == 200\n41\t    body = response.json()\n42\t    assert body == [\n43\t        {\"customer_id\": \"cust_a\", \"metric\": \"api_calls\", \"limit_per_window\": 100},\n44\t        {\"customer_id\": \"cust_a\", \"metric\": \"storage_gb\", \"limit_per_window\": 50},\n45\t        {\"customer_id\": \"cust_b\", \"metric\": \"api_calls\", \"limit_per_window\": 200},\n46\t    ]\n47\t    for row in body:\n48\t        assert set(row.keys()) == {\"customer_id\", \"metric\", \"limit_per_window\"}\n49\t\n50\t\n51\tasync def test_get_is_tenant_isolated(client, make_api_key):\n52\t    \"\"\"AC2: tenant A's list contains only tenant A's rows, never tenant B's.\"\"\"\n53\t    key_a, _ = await make_api_key(label=\"tenant-a\", scope=\"admin\")\n54\t    key_b, _ = await make_api_key(label=\"tenant-b\", scope=\"admin\")\n55\t    headers_a = {\"Authorization\": f\"Bearer {key_a}\"}\n56\t    headers_b = {\"Authorization\": f\"Bearer {key_b}\"}\n57\t\n58\t    await _seed_quota(client, headers_a, customer_id=\"cust_a\", limit_per_window=100)\n59\t    await _seed_quota(client, headers_b, customer_id=\"cust_b\", limit_per_window=200)\n60\t\n61\t    response_a = await client.get(\"/v1/quotas\", headers=headers_a)\n62\t    assert response_a.status_code == 200\n63\t    body_a = response_a.json()\n64\t    assert len(body_a) == 1\n65\t    assert body_a[0][\"customer_id\"] == \"cust_a\"\n66\t\n67\t\n68\tasync def test_get_empty_returns_200_empty_list(client, make_api_key):\n69\t    \"\"\"AC3: no quotas -> 200 with an empty array, never 404.\"\"\"\n70\t    presented_key, _ = await make_api_key(scope=\"admin\")\n71\t\n72\t    response = await client.get(\n73\t        \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n74\t    )\n75\t\n76\t    assert response.status_code == 200\n77\t    assert response.json() == []\n78\t\n79\t\n80\tasync def test_get_ingest_key_forbidden(client, make_api_key):\n81\t    \"\"\"AC4: an ingest-scoped key gets 403 `forbidden` on GET — admin scope required.\"\"\"\n82\t    presented_key, _ = await make_api_key(scope=\"ingest\")\n83\t\n84\t    response = await client.get(\n85\t        \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n86\t    )\n87\t\n88\t    assert response.status_code == 403\n89\t    assert response.json()[\"error\"][\"code\"] == \"forbidden\"\n90\t\n91\t\n92\tasync def test_get_requires_auth(client):\n93\t    \"\"\"AC5: missing/malformed auth -> 401 on GET.\"\"\"\n94\t    response = await client.get(\"/v1/quotas\")\n95\t    assert response.status_code == 401\n96\t\n97\t    response = await client.get(\n98\t        \"/v1/quotas\", headers={\"Authorization\": \"Bearer not-a-real-token\"}\n99\t    )\n100\t    assert response.status_code == 401\n101\t\n102\t\n103\tasync def test_delete_existing_returns_204_and_removes_row(client, make_api_key, postgres_url):\n104\t    \"\"\"AC6: DELETE of an existing quota -> 204 empty body; the row is gone\n105\t    from a subsequent GET and from the table directly.\"\"\"\n106\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n107\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n108\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\")\n109\t\n110\t    response = await client.delete(\n111\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers\n112\t    )\n113\t\n114\t    assert response.status_code == 204\n115\t    assert response.content == b\"\"\n116\t\n117\t    listing = await client.get(\"/v1/quotas\", headers=headers)\n118\t    assert listing.json() == []\n119\t\n120\t    from sqlalchemy.ext.asyncio import create_async_engine\n121\t\n122\t    engine = create_async_engine(postgres_url)\n123\t    async with engine.connect() as connection:\n124\t        count = (\n125\t            await connection.execute(\n126\t                text(\"SELECT COUNT(*) FROM quotas WHERE api_key_id = :id\"), {\"id\": api_key_id}\n127\t            )\n128\t        ).scalar_one()\n129\t    await engine.dispose()\n130\t    assert count == 0\n131\t\n132\t\n133\tasync def test_delete_absent_returns_404_envelope(client, make_api_key):\n134\t    \"\"\"AC7: DELETE of a (customer_id, metric) with no quota -> 404 not_found,\n135\t    the standard error envelope (explicit, not silently idempotent).\"\"\"\n136\t    presented_key, _ = await make_api_key(scope=\"admin\")\n137\t\n138\t    response = await client.delete(\n139\t        \"/v1/quotas\",\n140\t        params={\"customer_id\": \"cust_missing\", \"metric\": \"api_calls\"},\n141\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n142\t    )\n143\t\n144\t    assert response.status_code == 404\n145\t    assert response.json()[\"error\"][\"code\"] == \"not_found\"\n146\t\n147\t\n148\tasync def test_delete_cannot_touch_other_tenant(client, make_api_key, postgres_url):\n149\t    \"\"\"AC8: tenant A deleting a (customer_id, metric) that exists only under\n150\t    tenant B -> 404 (invisible), and tenant B's row is still present.\"\"\"\n151\t    key_a, _ = await make_api_key(label=\"tenant-a\", scope=\"admin\")\n152\t    key_b, api_key_id_b = await make_api_key(label=\"tenant-b\", scope=\"admin\")\n153\t    headers_a = {\"Authorization\": f\"Bearer {key_a}\"}\n154\t    headers_b = {\"Authorization\": f\"Bearer {key_b}\"}\n155\t\n156\t    await _seed_quota(client, headers_b, customer_id=\"cust_shared\", metric=\"api_calls\", limit_per_window=500)\n157\t\n158\t    response = await client.delete(\n159\t        \"/v1/quotas\", params={\"customer_id\": \"cust_shared\", \"metric\": \"api_calls\"}, headers=headers_a\n160\t    )\n161\t    assert response.status_code == 404\n162\t\n163\t    from sqlalchemy.ext.asyncio import create_async_engine\n164\t\n165\t    engine = create_async_engine(postgres_url)\n166\t    async with engine.connect() as connection:\n167\t        row = (\n168\t            await connection.execute(\n169\t                text(\"SELECT limit_per_window FROM quotas WHERE api_key_id = :id\"),\n170\t                {\"id\": api_key_id_b},\n171\t            )\n172\t        ).mappings().one()\n173\t    await engine.dispose()\n174\t    assert row[\"limit_per_window\"] == 500\n175\t\n176\t\n177\tasync def test_delete_validation_rejections(client, make_api_key):\n178\t    \"\"\"AC9: missing/invalid/injection/unknown-extra query params -> 422 validation_failed.\"\"\"\n179\t    presented_key, _ = await make_api_key(scope=\"admin\")\n180\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n181\t\n182\t    missing_metric = await client.delete(\n183\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\"}, headers=headers\n184\t    )\n185\t    assert missing_metric.status_code == 422\n186\t    assert missing_metric.json()[\"error\"][\"code\"] == \"validation_failed\"\n187\t\n188\t    bad_customer_id = await client.delete(\n189\t        \"/v1/quotas\", params={\"customer_id\": \"bad id with spaces\", \"metric\": \"api_calls\"}, headers=headers\n190\t    )\n191\t    assert bad_customer_id.status_code == 422\n192\t\n193\t    injection = await client.delete(\n194\t        \"/v1/quotas\", params={\"customer_id\": \"' OR 1=1--\", \"metric\": \"api_calls\"}, headers=headers\n195\t    )\n196\t    assert injection.status_code == 422\n197\t\n198\t    extra_param = await client.delete(\n199\t        \"/v1/quotas\",\n200\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\", \"api_key_id\": \"999\"},\n201\t        headers=headers,\n202\t    )\n203\t    assert extra_param.status_code == 422\n204\t\n205\t\n206\tasync def test_delete_ingest_key_forbidden(client, make_api_key):\n207\t    \"\"\"AC10: an ingest-scoped key gets 403 `forbidden` on DELETE.\"\"\"\n208\t    presented_key, _ = await make_api_key(scope=\"ingest\")\n209\t\n210\t    response = await client.delete(\n211\t        \"/v1/quotas\",\n212\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n213\t        headers={\"Authorization\": f\"Bearer {presented_key}\"},\n214\t    )\n215\t\n216\t    assert response.status_code == 403\n217\t    assert response.json()[\"error\"][\"code\"] == \"forbidden\"\n218\t\n219\t\n220\tasync def test_delete_requires_auth(client):\n221\t    \"\"\"AC11: missing/malformed auth -> 401 on DELETE.\"\"\"\n222\t    response = await client.delete(\n223\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}\n224\t    )\n225\t    assert response.status_code == 401\n226\t\n227\t    response = await client.delete(\n228\t        \"/v1/quotas\",\n229\t        params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n230\t        headers={\"Authorization\": \"Bearer not-a-real-token\"},\n231\t    )\n232\t    assert response.status_code == 401\n233\t\n234\t\n235\tasync def test_quota_admin_routes_rate_limited_per_principal(truncate_tables, make_api_key):\n236\t    \"\"\"AC12: both GET and DELETE /v1/quotas are Tier-2 per-api_key_id rate\n237\t    limited; two admin principals sharing one client IP get independent\n238\t    buckets (mirrors test_quotas_endpoint.py::test_put_rate_limited_per_principal).\"\"\"\n239\t    from src.main import app\n240\t\n241\t    key_a, _ = await make_api_key(label=\"a\", rate_limit_per_sec=1, scope=\"admin\")\n242\t    key_b, _ = await make_api_key(label=\"b\", rate_limit_per_sec=100, scope=\"admin\")\n243\t\n244\t    same_ip_transport = ASGITransport(app=app, client=(\"10.0.0.9\", 4000))\n245\t    async with AsyncClient(transport=same_ip_transport, base_url=\"http://test\") as test_client:\n246\t        first = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n247\t        second = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_a}\"})\n248\t        assert first.status_code == 200\n249\t        assert second.status_code == 429\n250\t        assert \"Retry-After\" in second.headers\n251\t\n252\t        b_response = await test_client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {key_b}\"})\n253\t        assert b_response.status_code == 200, \"principal B, same IP, must have its own untouched bucket\"\n254\t\n255\t        third = await test_client.delete(\n256\t            \"/v1/quotas\",\n257\t            params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n258\t            headers={\"Authorization\": f\"Bearer {key_b}\"},\n259\t        )\n260\t        # key_b's bucket has capacity left (100/sec); a 404 (no such quota) is\n261\t        # the expected outcome here, proving the request reached the handler\n262\t        # rather than being throttled.\n263\t        assert third.status_code == 404\n264\t\n265\t\n266\tasync def test_delete_does_not_reset_usage_and_events_uncapped(client, make_api_key, postgres_url):\n267\t    \"\"\"AC13: deleting a quota removes only the cap — `usage_rollup` for that\n268\t    (customer, metric) is unchanged, and a subsequent POST /v1/events for the\n269\t    now-uncapped pair is accepted 201 unlimited (same as never-capped).\"\"\"\n270\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n271\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n272\t\n273\t    # Cap it low, then record usage that approaches (but does not exceed) the cap.\n274\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\", limit_per_window=10)\n275\t    event_response = await client.post(\n276\t        \"/v1/events\",\n277\t        json={\n278\t            \"customer_id\": \"cust_1\",\n279\t            \"metric\": \"api_calls\",\n280\t            \"quantity\": \"5\",\n281\t            \"idempotency_key\": \"pre-delete-event\",\n282\t        },\n283\t        headers=headers,\n284\t    )\n285\t    assert event_response.status_code == 201\n286\t\n287\t    from sqlalchemy.ext.asyncio import create_async_engine\n288\t\n289\t    engine = create_async_engine(postgres_url)\n290\t    async with engine.connect() as connection:\n291\t        rollup_before = (\n292\t            await connection.execute(\n293\t                text(\n294\t                    \"SELECT total_quantity FROM usage_rollup WHERE api_key_id = :id \"\n295\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n296\t                ),\n297\t                {\"id\": api_key_id},\n298\t            )\n299\t        ).scalar_one()\n300\t    await engine.dispose()\n301\t    assert rollup_before == 5\n302\t\n303\t    delete_response = await client.delete(\n304\t        \"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers\n305\t    )\n306\t    assert delete_response.status_code == 204\n307\t\n308\t    engine = create_async_engine(postgres_url)\n309\t    async with engine.connect() as connection:\n310\t        rollup_after = (\n311\t            await connection.execute(\n312\t                text(\n313\t                    \"SELECT total_quantity FROM usage_rollup WHERE api_key_id = :id \"\n314\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n315\t                ),\n316\t                {\"id\": api_key_id},\n317\t            )\n318\t        ).scalar_one()\n319\t    await engine.dispose()\n320\t    assert rollup_after == 5, \"DELETE must never touch usage_rollup\"\n321\t\n322\t    # A large event that would have exceeded the old cap (10) is now accepted\n323\t    # unlimited, since the cap no longer exists.\n324\t    uncapped_response = await client.post(\n325\t        \"/v1/events\",\n326\t        json={\n327\t            \"customer_id\": \"cust_1\",\n328\t            \"metric\": \"api_calls\",\n329\t            \"quantity\": \"9999\",\n330\t            \"idempotency_key\": \"post-delete-event\",\n331\t        },\n332\t        headers=headers,\n333\t    )\n334\t    assert uncapped_response.status_code == 201\n335\t\n336\t\n337\tasync def test_delete_and_forbidden_are_logged(client, make_api_key, capsys):\n338\t    \"\"\"AC16: a successful DELETE logs `quota.delete` INFO (customer_id\n339\t    redacted); a scope-denied GET or DELETE logs the existing `quota.forbidden` WARNING.\"\"\"\n340\t    admin_key, _ = await make_api_key(scope=\"admin\")\n341\t    ingest_key, _ = await make_api_key(label=\"ingest-only\", scope=\"ingest\")\n342\t    headers = {\"Authorization\": f\"Bearer {admin_key}\"}\n343\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\")\n344\t\n345\t    await client.delete(\"/v1/quotas\", params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"}, headers=headers)\n346\t    await client.get(\"/v1/quotas\", headers={\"Authorization\": f\"Bearer {ingest_key}\"})\n347\t\n348\t    captured = capsys.readouterr()\n349\t    assert \"quota.delete\" in captured.out\n350\t    assert \"***redacted***\" in captured.out\n351\t    assert \"quota.forbidden\" in captured.out\n352\t\n353\t\n354\tasync def test_openapi_exposes_get_and_delete_quotas(client):\n355\t    \"\"\"AC17 (DAST-readiness): the served /openapi.json includes both GET and\n356\t    DELETE /v1/quotas, matching the implemented routes/schemas.\"\"\"\n357\t    response = await client.get(\"/openapi.json\")\n358\t    assert response.status_code == 200\n359\t    schema = response.json()\n360\t    assert \"/v1/quotas\" in schema[\"paths\"]\n361\t    assert \"get\" in schema[\"paths\"][\"/v1/quotas\"]\n362\t    assert \"delete\" in schema[\"paths\"][\"/v1/quotas\"]\n363\t\n364\t\n365\tasync def test_get_forced_internal_error_returns_safe_envelope(\n366\t    truncate_tables, make_api_key, monkeypatch\n367\t):\n368\t    \"\"\"AC19: a forced internal error during the GET list read returns the\n369\t    generic 500 envelope, with no stack trace / SQL fragment / exception\n370\t    type / internal path leaked.\"\"\"\n371\t    presented_key, _ = await make_api_key(scope=\"admin\")\n372\t\n373\t    from src.services import quota_service\n374\t\n375\t    async def _boom(*args, **kwargs):\n376\t        raise RuntimeError(\"simulated read failure\")\n377\t\n378\t    monkeypatch.setattr(quota_service, \"list_quotas\", _boom)\n379\t\n380\t    from src.main import app\n381\t\n382\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n383\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as raw_client:\n384\t        response = await raw_client.get(\n385\t            \"/v1/quotas\", headers={\"Authorization\": f\"Bearer {presented_key}\"}\n386\t        )\n387\t\n388\t    assert response.status_code == 500\n389\t    body = response.json()\n390\t    assert body[\"error\"][\"code\"] == \"internal\"\n391\t    assert \"requestId\" in body[\"error\"]\n392\t    message = body[\"error\"][\"message\"].lower()\n393\t    assert \"runtimeerror\" not in message\n394\t    assert \"simulated read failure\" not in message\n395\t    assert \"traceback\" not in message\n396\t\n397\t\n398\tasync def test_delete_forced_internal_error_returns_safe_envelope_and_fails_closed(\n399\t    client, make_api_key, postgres_url, monkeypatch\n400\t):\n401\t    \"\"\"AC19: a forced internal error during DELETE returns the generic 500\n402\t    envelope and fails closed — the transaction rolls back, so the target\n403\t    quota row survives (mirrors test_events_endpoint.py's forced-error test).\"\"\"\n404\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n405\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n406\t    await _seed_quota(client, headers, customer_id=\"cust_1\", metric=\"api_calls\", limit_per_window=42)\n407\t\n408\t    from src.services import quota_service\n409\t\n410\t    async def _boom(*args, **kwargs):\n411\t        raise RuntimeError(\"simulated delete failure\")\n412\t\n413\t    monkeypatch.setattr(quota_service, \"delete_quota\", _boom)\n414\t\n415\t    from src.main import app\n416\t\n417\t    transport = ASGITransport(app=app, raise_app_exceptions=False)\n418\t    async with AsyncClient(transport=transport, base_url=\"http://test\") as raw_client:\n419\t        response = await raw_client.delete(\n420\t            \"/v1/quotas\",\n421\t            params={\"customer_id\": \"cust_1\", \"metric\": \"api_calls\"},\n422\t            headers=headers,\n423\t        )\n424\t\n425\t    assert response.status_code == 500\n426\t    body = response.json()\n427\t    assert body[\"error\"][\"code\"] == \"internal\"\n428\t    assert \"requestId\" in body[\"error\"]\n429\t    message = body[\"error\"][\"message\"].lower()\n430\t    assert \"runtimeerror\" not in message\n431\t    assert \"simulated delete failure\" not in message\n432\t    assert \"traceback\" not in message\n433\t\n434\t    from sqlalchemy.ext.asyncio import create_async_engine\n435\t\n436\t    engine = create_async_engine(postgres_url)\n437\t    async with engine.connect() as connection:\n438\t        row = (\n439\t            await connection.execute(\n440\t                text(\n441\t                    \"SELECT limit_per_window FROM quotas WHERE api_key_id = :id \"\n442\t                    \"AND customer_id = 'cust_1' AND metric = 'api_calls'\"\n443\t                ),\n444\t                {\"id\": api_key_id},\n445\t            )\n446\t        ).mappings().one()\n447\t    await engine.dispose()\n448\t    assert row[\"limit_per_window\"] == 42, \"a failed DELETE must leave the target row intact (fail-closed)\"\n449\t\n450\t\n451\tasync def test_concurrent_delete_of_the_same_quota_yields_exactly_one_winner(\n452\t    client, make_api_key, postgres_url\n453\t):\n454\t    \"\"\"AC6/AC7 under contention: N concurrent DELETE requests for the exact\n455\t    same (customer_id, metric) must yield exactly one 204 (the winner) and\n456\t    the rest 404 (the loser's explicit outcome) -- never two 204s (a double\n457\t    side effect) and never a 500/race artifact. Proves the decision point\n458\t    (delete_quota's single parameterized DELETE ... RETURNING) is actually\n459\t    atomic under real concurrent access, not merely correct in the\n460\t    single-caller tests above.\"\"\"\n461\t    presented_key, api_key_id = await make_api_key(scope=\"admin\")\n462\t    headers = {\"Authorization\": f\"Bearer {presented_key}\"}\n463\t    await _seed_quota(client, headers, customer_id=\"cust_race\", metric=\"api_calls\", limit_per_window=100)\n464\t\n465\t    concurrent_requests = 10\n466\t\n467\t    async def _delete():\n468\t        return await client.delete(\n469\t            \"/v1/quotas\", params={\"customer_id\": \"cust_race\", \"metric\": \"api_calls\"}, headers=headers\n470\t        )\n471\t\n472\t    responses = await asyncio.gather(*(_delete() for _ in range(concurrent_requests)))\n473\t    statuses = [response.status_code for response in responses]\n474\t\n475\t    winners = [status for status in statuses if status == 204]\n476\t    losers = [status for status in statuses if status == 404]\n477\t\n478\t    assert len(winners) == 1, f\"expected exactly one 204 winner, got statuses: {statuses}\"\n479\t    assert len(losers) == concurrent_requests - 1, f\"expected the rest to be 404 losers, got statuses: {statuses}\"\n480\t    assert set(statuses) <= {204, 404}, f\"no request should error under contention, got statuses: {statuses}\"\n481\t\n482\t    from sqlalchemy.ext.asyncio import create_async_engine\n483\t\n484\t    engine = create_async_engine(postgres_url)\n485\t    async with engine.connect() as connection:\n486\t        count = (\n487\t            await connection.execute(\n488\t                text(\n489\t                    \"SELECT COUNT(*) FROM quotas WHERE api_key_id = :id \"\n490\t                    \"AND customer_id = 'cust_race' AND metric = 'api_calls'\"\n491\t                ),\n492\t                {\"id\": api_key_id},\n493\t            )\n494\t        ).scalar_one()\n495\t    await engine.dispose()\n496\t    assert count == 0, \"the row must be gone exactly once, not left behind or double-removed\"\n497\t\n498\t\n499\tasync def test_no_new_alembic_migration_added(postgres_url):\n500\t    \"\"\"AC14: this feature operates on the existing `quotas` table — no new\n501\t    file under alembic/versions/ beyond the existing revisions 0001-0003.\"\"\"\n502\t    from pathlib import Path\n503\t\n504\t    versions_dir = Path(__file__).resolve().parents[2] / \"alembic\" / \"versions\"\n505\t    revision_files = sorted(p.name for p in versions_dir.glob(\"*.py\") if not p.name.startswith(\"__\"))\n506\t    assert len(revision_files) == 3, f\"expected exactly 3 migration files, found: {revision_files}\"\n507\t"}]},"uuid":"7643c9bd-71aa-4698-a3e9-5d08ee0a26ea","timestamp":"2026-07-10T04:03:42.111Z","sourceToolAssistantUUID":"93cc6fb9-10ed-435b-a476-3c08e290d23c","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"7643c9bd-71aa-4698-a3e9-5d08ee0a26ea","isSidechain":true,"agentId":"ac1c3361cb16ecefb","message":{"model":"claude-fable-5","id":"msg_011CcsiJBi5bGdFJ9d93CSNh","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01KUpnsz3KvWL8Uoe6BBSdUP","name":"Read","input":{"file_path":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test\\src\\api\\errors.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":5303,"cache_read_input_tokens":44543,"cache_creation":{"ephemeral_5m_input_tokens":5303,"ephemeral_1h_input_tokens":0},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null},"requestId":"req_011CcsiJAgZQsmjXcBu9MmvD","attributionAgent":"general-purpose","attributionSkill":"code-review","type":"assistant","uuid":"2eca7178-0b00-4675-bd26-9bd794690837","timestamp":"2026-07-10T04:03:42.290Z","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
{"parentUuid":"2eca7178-0b00-4675-bd26-9bd794690837","isSidechain":true,"promptId":"b6d534eb-f80d-405a-a05d-4c7eb6280654","agentId":"ac1c3361cb16ecefb","type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KUpnsz3KvWL8Uoe6BBSdUP","type":"tool_result","content":"1\t\"\"\"The error-envelope facade — every exception a handler raises terminates\n2\there, at one centralized boundary, as the single response shape:\n3\t`{\"error\": {\"code\", \"message\", \"requestId\"}}`.\n4\t\n5\tNever leaks a stack trace, exception type, SQL, or internal path to the\n6\tclient (ASVS 16.5.1/16.5.3) — the detail is logged server-side and the client\n7\tgets a generic, stable `code` plus the `requestId` that ties a user report\n8\tback to the server log line.\n9\t\"\"\"\n10\t\n11\tfrom fastapi import FastAPI, HTTPException, Request, status\n12\tfrom fastapi.exceptions import RequestValidationError\n13\tfrom fastapi.responses import JSONResponse\n14\tfrom starlette.exceptions import HTTPException as StarletteHTTPException\n15\t\n16\tfrom src.logging import get_logger\n17\t\n18\tlogger = get_logger(service=\"meterly\")\n19\t\n20\t_STATUS_TO_CODE = {\n21\t    status.HTTP_400_BAD_REQUEST: \"bad_request\",\n22\t    status.HTTP_401_UNAUTHORIZED: \"unauthorized\",\n23\t    status.HTTP_403_FORBIDDEN: \"forbidden\",\n24\t    status.HTTP_404_NOT_FOUND: \"not_found\",\n25\t    status.HTTP_409_CONFLICT: \"conflict\",\n26\t    status.HTTP_413_REQUEST_ENTITY_TOO_LARGE: \"payload_too_large\",\n27\t    status.HTTP_422_UNPROCESSABLE_ENTITY: \"validation_failed\",\n28\t    status.HTTP_429_TOO_MANY_REQUESTS: \"rate_limited\",\n29\t}\n30\t\n31\t\n32\tdef _request_id(request: Request) -> str:\n33\t    \"\"\"Read the correlation id the logging middleware assigned to this request.\"\"\"\n34\t    return getattr(request.state, \"request_id\", \"unknown\")\n35\t\n36\t\n37\tdef _envelope(code: str, message: str, request_id: str) -> dict:\n38\t    \"\"\"Build the one response shape every error returns.\"\"\"\n39\t    return {\"error\": {\"code\": code, \"message\": message, \"requestId\": request_id}}\n40\t\n41\t\n42\tclass AppError(HTTPException):\n43\t    \"\"\"An `HTTPException` carrying an explicit `app_code`, for the cases where\n44\t    `_STATUS_TO_CODE`'s status->code map can't express the distinction —\n45\t    `429` already maps to `rate_limited` (the Tier-2 throttle), but a quota\n46\t    rejection needs its own, distinct `quota_exceeded` code on the same\n47\t    status. `handle_http_exception` prefers `app_code` over the status map\n48\t    when present, so this is the minimal single-boundary extension rather\n49\t    than reshaping the map itself.\n50\t    \"\"\"\n51\t\n52\t    def __init__(self, status_code: int, *, app_code: str, detail: str, headers: dict | None = None) -> None:\n53\t        super().__init__(status_code=status_code, detail=detail, headers=headers)\n54\t        self.app_code = app_code\n55\t\n56\t\n57\tdef register_error_handlers(app: FastAPI) -> None:\n58\t    \"\"\"Register the centralized exception handlers on `app`.\n59\t\n60\t    Called once from `src/main.py` at app construction — no route ever builds\n61\t    its own error response; it raises and lets this boundary map it.\n62\t    \"\"\"\n63\t\n64\t    @app.exception_handler(RequestValidationError)\n65\t    async def handle_validation_error(request: Request, exc: RequestValidationError) -> JSONResponse:\n66\t        \"\"\"Map Pydantic/FastAPI validation failures to 422 with a safe message.\"\"\"\n67\t        request_id = _request_id(request)\n68\t        logger.warning(\n69\t            \"validation.failed\",\n70\t            requestId=request_id,\n71\t            endpoint=request.url.path,\n72\t            errorCount=len(exc.errors()),\n73\t        )\n74\t        return JSONResponse(\n75\t            status_code=status.HTTP_422_UNPROCESSABLE_ENTITY,\n76\t            content=_envelope(\"validation_failed\", \"the request failed validation\", request_id),\n77\t        )\n78\t\n79\t    @app.exception_handler(StarletteHTTPException)\n80\t    async def handle_http_exception(request: Request, exc: StarletteHTTPException) -> JSONResponse:\n81\t        \"\"\"Map a raised `HTTPException` (auth, rate-limit, not-found, ...) to the envelope.\n82\t\n83\t        Prefers an explicit `app_code` (set by `AppError`) over the status->code\n84\t        map — this is what lets two different exceptions share one HTTP status\n85\t        (`429 rate_limited` vs. `429 quota_exceeded`) with distinct client-facing codes.\n86\t        \"\"\"\n87\t        request_id = _request_id(request)\n88\t        code = getattr(exc, \"app_code\", None) or _STATUS_TO_CODE.get(exc.status_code, \"error\")\n89\t        message = exc.detail if isinstance(exc.detail, str) else \"request failed\"\n90\t        return JSONResponse(\n91\t            status_code=exc.status_code,\n92\t            content=_envelope(code, message, request_id),\n93\t            headers=getattr(exc, \"headers\", None) or {},\n94\t        )\n95\t\n96\t    @app.exception_handler(Exception)\n97\t    async def handle_unexpected_error(request: Request, exc: Exception) -> JSONResponse:\n98\t        \"\"\"Catch-all: log the full detail server-side, return a generic 500 to the client.\n99\t\n100\t        This is the fail-closed boundary — an unhandled exception mid-write\n101\t        never leaks stack/SQL/secret detail, and because the events + rollup\n102\t        write happens in one transaction (`src/services/events_service.py`),\n103\t        an exception here means that transaction was rolled back, not\n104\t        partially applied.\n105\t        \"\"\"\n106\t        request_id = _request_id(request)\n107\t        logger.error(\n108\t            \"request.unhandled_error\",\n109\t            requestId=request_id,\n110\t            endpoint=request.url.path,\n111\t            **{\"error.type\": type(exc).__name__, \"error.message\": str(exc)},\n112\t            exc_info=True,\n113\t        )\n114\t        return JSONResponse(\n115\t            status_code=status.HTTP_500_INTERNAL_SERVER_ERROR,\n116\t            content=_envelope(\"internal\", \"an internal error occurred\", request_id),\n117\t        )\n118\t\n119\t\n120\t__all__ = [\"register_error_handlers\", \"HTTPException\", \"AppError\"]\n121\t"}]},"uuid":"c4325aaa-c7cd-4580-bb48-488537dec6ed","timestamp":"2026-07-10T04:03:42.312Z","sourceToolAssistantUUID":"2eca7178-0b00-4675-bd26-9bd794690837","userType":"external","entrypoint":"claude-vscode","cwd":"C:\\Users\\brett\\OneDrive\\Documents\\GitHub\\meterly-pipeline-test","sessionId":"cb1e5971-0f87-4706-9a1d-09f830df9e6f","version":"2.1.205","gitBranch":"feature/quota-admin"}
