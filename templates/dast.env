# dast.env — DAST Layer 1 (OWASP ZAP passive baseline against the running app). Copy to
# .pipeline/dast.env on a project with an HTTP surface that wants the post-GREEN advisory DAST
# stage; delete/omit it and the stage is a no-op. Sourced by dast-capture.sh (kept LOCAL/untracked
# like smoke.env — a git-tracked copy is refused). Requires Docker (already assumed for Semgrep/Trivy).

# Where the app answers (loopback is rewritten to host.docker.internal for the ZAP container).
# U-14 — SERVED-UI TARGETS: set this to the actual served PAGE route, not the bare host. ZAP's
# spider SEEDS here; if the seed 404s (e.g. host root while the page is at /dashboard), the scan
# traverses nothing and the "within budget" verdict is meaningless. dast-capture probes this URL's
# status directly and flags target_reached:false in dast-review.json (advisory) when it is not a
# live page. Point it at the real entry route (e.g. http://localhost:8000/dashboard).
DAST_TARGET_URL="http://localhost:8000"

# How to boot the app for the scan. Leave empty if it is already running (e.g. a shared dev server).
# Often the same command as smoke.env's SMOKE_START_CMD.
DAST_START_CMD="python -m uvicorn src.main:app --host 0.0.0.0 --port 8000"

# Polled until it answers before scanning (preferred over a fixed wait). Optional.
DAST_HEALTH_URL="http://localhost:8000/health"

# Fallback wait (seconds) when no health URL is given. Optional.
DAST_STARTUP_WAIT="5"
