# ui.env — FE Layer 4 (visual-regression design-review + a11y). Copy to .pipeline/ui.env on a
# UI project that wants the design-review stage; delete/omit it and the stage is a no-op.
# Sourced by ui-capture.sh. Requires (once): npm i -D playwright pixelmatch pngjs @axe-core/playwright
# && npx playwright install chromium.

# How to serve the built UI for capture (leave empty if it is already running).
UI_START_CMD="npm run preview"

# Where the served UI answers.
UI_BASE_URL="http://localhost:4173"

# The screens to capture: space-separated name:/route pairs. The name must match the baseline PNG.
UI_SCREENS="home:/ login:/login"

# Baseline PNGs to diff against, named <name>.png. Point this at the design render (design-fidelity)
# or an approved golden set (regression). For a Claude Design HTML export, render it once to PNGs;
# for a Figma export, drop the exported frames here.
UI_BASELINE_DIR="design/baseline"
