# dast.env — DAST Layer 1 (OWASP ZAP passive baseline against the running app).
# Local/untracked like smoke.env (.pipeline/ is gitignored; a git-tracked copy is refused).
# Enables the post-GREEN advisory DAST stage so run 3's newly-served dashboard HTML surface
# gets a runtime passive scan (headers/cookies/info-leaks). Requires Docker (already up).

# Where the app answers (loopback is rewritten to host.docker.internal for the ZAP container).
DAST_TARGET_URL="http://localhost:8000"

# Boot command — venv-explicit (bare `python` on this host is system 3.10 without deps) and
# bound to 0.0.0.0 so the ZAP container can reach it via host.docker.internal.
DAST_START_CMD=".venv/Scripts/python.exe -m uvicorn src.main:app --host 0.0.0.0 --port 8000"

# Polled until it answers before scanning.
DAST_HEALTH_URL="http://localhost:8000/health"

# Fallback wait (seconds) if the health poll is unavailable.
DAST_STARTUP_WAIT="5"
